<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_CommitteeVoting" targetNamespace="http://sla.governance/bpmn/committee-voting" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:process id="Process_CommitteeVoting" name="Committee Governance Voting" isExecutable="true">
    <bpmn:startEvent id="CV_Start" name="Voting&#10;Requested">
      <bpmn:outgoing>Flow_Start_DetermineRules</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:businessRuleTask id="Task_DetermineVotingRules" name="Determine&#10;Voting Rules">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="OB_DMN_CommitteeVotingRules" resultVariable="votingConfig" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_DetermineRules</bpmn:incoming>
      <bpmn:outgoing>Flow_DetermineRules_ResolveAuthority</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:serviceTask id="Task_ResolveAuthority" name="Resolve&#10;Committee Authority">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="resolve-committee-authority" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_DetermineRules_ResolveAuthority</bpmn:incoming>
      <bpmn:outgoing>Flow_ResolveAuthority_AssembleBrief</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_AssembleBrief" name="Assemble&#10;Committee Brief">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="assemble-committee-brief" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ResolveAuthority_AssembleBrief</bpmn:incoming>
      <bpmn:outgoing>Flow_AssembleBrief_ReviewBrief</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_ReviewBrief" name="Review&#10;Brief">
      <bpmn:extensionElements>
        <zeebe:formDefinition formId="cv-review-brief" />
        <zeebe:assignmentDefinition candidateGroups="governance-lane" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_AssembleBrief_ReviewBrief</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewBrief_DistributeMerge</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_DistributeMerge">
      <bpmn:incoming>Flow_ReviewBrief_DistributeMerge</bpmn:incoming>
      <bpmn:incoming>Flow_MaxIterations_No</bpmn:incoming>
      <bpmn:outgoing>Flow_DistributeMerge_Distribute</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_DistributeBrief" name="Distribute&#10;Brief">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="distribute-committee-brief" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_DistributeMerge_Distribute</bpmn:incoming>
      <bpmn:outgoing>Flow_Distribute_QAEnabled</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_QAEnabled" name="Q&amp;A&#10;Enabled?" default="Flow_QA_No">
      <bpmn:incoming>Flow_Distribute_QAEnabled</bpmn:incoming>
      <bpmn:outgoing>Flow_QA_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_QA_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:subProcess id="SP_QAPhase" name="Q&amp;A Phase">
      <bpmn:incoming>Flow_QA_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_QAPhase_QAMerge</bpmn:outgoing>
      <bpmn:startEvent id="SPQA_Start">
        <bpmn:outgoing>Flow_SPQA_Start_Submit</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:userTask id="Task_SubmitQuestion" name="Submit&#10;Question">
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="cv-submit-question" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SPQA_Start_Submit</bpmn:incoming>
        <bpmn:incoming>Flow_SPQA_MoreYes</bpmn:incoming>
        <bpmn:outgoing>Flow_SPQA_Submit_Answer</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:userTask id="Task_AnswerQuestion" name="Answer&#10;Question">
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="cv-answer-question" />
          <zeebe:assignmentDefinition candidateGroups="governance-lane" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SPQA_Submit_Answer</bpmn:incoming>
        <bpmn:outgoing>Flow_SPQA_Answer_More</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:exclusiveGateway id="GW_MoreQuestions" name="More&#10;Questions?" default="Flow_SPQA_MoreNo">
        <bpmn:incoming>Flow_SPQA_Answer_More</bpmn:incoming>
        <bpmn:outgoing>Flow_SPQA_MoreYes</bpmn:outgoing>
        <bpmn:outgoing>Flow_SPQA_MoreNo</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:endEvent id="SPQA_End">
        <bpmn:incoming>Flow_SPQA_MoreNo</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_SPQA_Start_Submit" sourceRef="SPQA_Start" targetRef="Task_SubmitQuestion" />
      <bpmn:sequenceFlow id="Flow_SPQA_Submit_Answer" sourceRef="Task_SubmitQuestion" targetRef="Task_AnswerQuestion" />
      <bpmn:sequenceFlow id="Flow_SPQA_Answer_More" sourceRef="Task_AnswerQuestion" targetRef="GW_MoreQuestions" />
      <bpmn:sequenceFlow id="Flow_SPQA_MoreYes" name="Yes" sourceRef="GW_MoreQuestions" targetRef="Task_SubmitQuestion">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=moreQuestions = true</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_SPQA_MoreNo" name="No" sourceRef="GW_MoreQuestions" targetRef="SPQA_End" />
    </bpmn:subProcess>
    <bpmn:boundaryEvent id="Timer_QAPeriod" name="Q&amp;A&#10;Period" cancelActivity="true" attachedToRef="SP_QAPhase">
      <bpmn:outgoing>Flow_QATimer_QAMerge</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_QAPeriod">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">=votingConfig.qaPeriodDuration</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="GW_QAMerge">
      <bpmn:incoming>Flow_QAPhase_QAMerge</bpmn:incoming>
      <bpmn:incoming>Flow_QATimer_QAMerge</bpmn:incoming>
      <bpmn:incoming>Flow_QA_No</bpmn:incoming>
      <bpmn:outgoing>Flow_QAMerge_VotingPhase</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:subProcess id="SP_VotingPhase" name="Voting Phase">
      <bpmn:incoming>Flow_QAMerge_VotingPhase</bpmn:incoming>
      <bpmn:outgoing>Flow_VotingPhase_TallyVotes</bpmn:outgoing>
      <bpmn:startEvent id="SPV_Start">
        <bpmn:outgoing>Flow_SPV_Start_CastVote</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:userTask id="Task_CastVote" name="Cast&#10;Vote">
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="cv-cast-vote" />
          <zeebe:assignmentDefinition assignee="=committeeMember.email" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SPV_Start_CastVote</bpmn:incoming>
        <bpmn:outgoing>Flow_SPV_CastVote_End</bpmn:outgoing>
        <bpmn:multiInstanceLoopCharacteristics>
          <bpmn:extensionElements>
            <zeebe:loopCharacteristics inputCollection="=lockedRoster" inputElement="committeeMember" outputCollection="votes" outputElement="=memberVote" />
          </bpmn:extensionElements>
          <bpmn:completionCondition xsi:type="bpmn:tFormalExpression">=earlyTermination</bpmn:completionCondition>
        </bpmn:multiInstanceLoopCharacteristics>
      </bpmn:userTask>
      <bpmn:endEvent id="SPV_End">
        <bpmn:incoming>Flow_SPV_CastVote_End</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_SPV_Start_CastVote" sourceRef="SPV_Start" targetRef="Task_CastVote" />
      <bpmn:sequenceFlow id="Flow_SPV_CastVote_End" sourceRef="Task_CastVote" targetRef="SPV_End" />
    </bpmn:subProcess>
    <bpmn:boundaryEvent id="Timer_Reminder" name="Voting&#10;Reminder" cancelActivity="false" attachedToRef="SP_VotingPhase">
      <bpmn:outgoing>Flow_Reminder_SendReminder</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Reminder">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">=votingConfig.reminderDuration</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Timer_Escalation" name="Voting&#10;Escalation" cancelActivity="false" attachedToRef="SP_VotingPhase">
      <bpmn:outgoing>Flow_Escalation_SendEscalation</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Escalation">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">=votingConfig.escalationDuration</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Timer_Deadline" name="Voting&#10;Deadline" cancelActivity="true" attachedToRef="SP_VotingPhase">
      <bpmn:outgoing>Flow_Deadline_ApplyDefault</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Deadline">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">=votingConfig.deadlineDuration</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="Task_SendReminder" name="Send&#10;Reminder">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-voting-reminder" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Reminder_SendReminder</bpmn:incoming>
      <bpmn:outgoing>Flow_SendReminder_EndReminder</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_ReminderSent" name="Reminder&#10;Sent">
      <bpmn:incoming>Flow_SendReminder_EndReminder</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_SendEscalation" name="Send&#10;Escalation">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-voting-escalation" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Escalation_SendEscalation</bpmn:incoming>
      <bpmn:outgoing>Flow_SendEscalation_EndEscalation</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_EscalationSent" name="Escalation&#10;Sent">
      <bpmn:incoming>Flow_SendEscalation_EndEscalation</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_ApplyDefaultRule" name="Apply Default&#10;Voting Rule">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="apply-default-voting-rule" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Deadline_ApplyDefault</bpmn:incoming>
      <bpmn:outgoing>Flow_ApplyDefault_TallyMerge</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_TallyMerge">
      <bpmn:incoming>Flow_VotingPhase_TallyVotes</bpmn:incoming>
      <bpmn:incoming>Flow_ApplyDefault_TallyMerge</bpmn:incoming>
      <bpmn:outgoing>Flow_TallyMerge_Tally</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_TallyVotes" name="Tally&#10;Votes">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="tally-committee-votes" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_TallyMerge_Tally</bpmn:incoming>
      <bpmn:outgoing>Flow_Tally_ConditionsConflict</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_ConditionsConflict" name="Conditions&#10;Conflict?" default="Flow_Conditions_No">
      <bpmn:incoming>Flow_Tally_ConditionsConflict</bpmn:incoming>
      <bpmn:outgoing>Flow_Conditions_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Conditions_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ReconcileConditions" name="Reconcile&#10;Conditions">
      <bpmn:extensionElements>
        <zeebe:formDefinition formId="cv-reconcile-conditions" />
        <zeebe:assignmentDefinition candidateGroups="governance-lane" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Conditions_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Reconcile_ConditionsMerge</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_ConditionsMerge">
      <bpmn:incoming>Flow_Reconcile_ConditionsMerge</bpmn:incoming>
      <bpmn:incoming>Flow_Conditions_No</bpmn:incoming>
      <bpmn:outgoing>Flow_ConditionsMerge_Outcome</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_VotingOutcome" name="Outcome?" default="Flow_Outcome_Remediation">
      <bpmn:incoming>Flow_ConditionsMerge_Outcome</bpmn:incoming>
      <bpmn:outgoing>Flow_Outcome_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_Outcome_Conditional</bpmn:outgoing>
      <bpmn:outgoing>Flow_Outcome_Rejected</bpmn:outgoing>
      <bpmn:outgoing>Flow_Outcome_Remediation</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_Approved" name="Committee&#10;Approved">
      <bpmn:incoming>Flow_Outcome_Approved</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_ApprovedConditional" name="Approved&#10;with Conditions">
      <bpmn:incoming>Flow_Outcome_Conditional</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Rejected" name="Committee&#10;Rejected">
      <bpmn:incoming>Flow_Outcome_Rejected</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Task_ReviseBrief" name="Revise&#10;Brief">
      <bpmn:extensionElements>
        <zeebe:formDefinition formId="cv-remediation-revise" />
        <zeebe:assignmentDefinition candidateGroups="governance-lane" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Outcome_Remediation</bpmn:incoming>
      <bpmn:outgoing>Flow_Revise_MaxIterations</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_MaxIterations" name="Max&#10;Loops?" default="Flow_MaxIterations_No">
      <bpmn:incoming>Flow_Revise_MaxIterations</bpmn:incoming>
      <bpmn:outgoing>Flow_MaxIterations_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_MaxIterations_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_AutoEscalate" name="Auto&#10;Escalate">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="auto-escalate-governance" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_MaxIterations_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_AutoEscalate_EndEscalated</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_Escalated" name="Auto&#10;Escalated">
      <bpmn:incoming>Flow_AutoEscalate_EndEscalated</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_DetermineRules" sourceRef="CV_Start" targetRef="Task_DetermineVotingRules" />
    <bpmn:sequenceFlow id="Flow_DetermineRules_ResolveAuthority" sourceRef="Task_DetermineVotingRules" targetRef="Task_ResolveAuthority" />
    <bpmn:sequenceFlow id="Flow_ResolveAuthority_AssembleBrief" sourceRef="Task_ResolveAuthority" targetRef="Task_AssembleBrief" />
    <bpmn:sequenceFlow id="Flow_AssembleBrief_ReviewBrief" sourceRef="Task_AssembleBrief" targetRef="Task_ReviewBrief" />
    <bpmn:sequenceFlow id="Flow_ReviewBrief_DistributeMerge" sourceRef="Task_ReviewBrief" targetRef="GW_DistributeMerge" />
    <bpmn:sequenceFlow id="Flow_DistributeMerge_Distribute" sourceRef="GW_DistributeMerge" targetRef="Task_DistributeBrief" />
    <bpmn:sequenceFlow id="Flow_Distribute_QAEnabled" sourceRef="Task_DistributeBrief" targetRef="GW_QAEnabled" />
    <bpmn:sequenceFlow id="Flow_QA_Yes" name="Yes" sourceRef="GW_QAEnabled" targetRef="SP_QAPhase">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=votingConfig.qaEnabled = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_QA_No" name="No" sourceRef="GW_QAEnabled" targetRef="GW_QAMerge" />
    <bpmn:sequenceFlow id="Flow_QAPhase_QAMerge" sourceRef="SP_QAPhase" targetRef="GW_QAMerge" />
    <bpmn:sequenceFlow id="Flow_QATimer_QAMerge" sourceRef="Timer_QAPeriod" targetRef="GW_QAMerge" />
    <bpmn:sequenceFlow id="Flow_QAMerge_VotingPhase" sourceRef="GW_QAMerge" targetRef="SP_VotingPhase" />
    <bpmn:sequenceFlow id="Flow_Reminder_SendReminder" sourceRef="Timer_Reminder" targetRef="Task_SendReminder" />
    <bpmn:sequenceFlow id="Flow_SendReminder_EndReminder" sourceRef="Task_SendReminder" targetRef="End_ReminderSent" />
    <bpmn:sequenceFlow id="Flow_Escalation_SendEscalation" sourceRef="Timer_Escalation" targetRef="Task_SendEscalation" />
    <bpmn:sequenceFlow id="Flow_SendEscalation_EndEscalation" sourceRef="Task_SendEscalation" targetRef="End_EscalationSent" />
    <bpmn:sequenceFlow id="Flow_Deadline_ApplyDefault" sourceRef="Timer_Deadline" targetRef="Task_ApplyDefaultRule" />
    <bpmn:sequenceFlow id="Flow_ApplyDefault_TallyMerge" sourceRef="Task_ApplyDefaultRule" targetRef="GW_TallyMerge" />
    <bpmn:sequenceFlow id="Flow_VotingPhase_TallyVotes" sourceRef="SP_VotingPhase" targetRef="GW_TallyMerge" />
    <bpmn:sequenceFlow id="Flow_TallyMerge_Tally" sourceRef="GW_TallyMerge" targetRef="Task_TallyVotes" />
    <bpmn:sequenceFlow id="Flow_Tally_ConditionsConflict" sourceRef="Task_TallyVotes" targetRef="GW_ConditionsConflict" />
    <bpmn:sequenceFlow id="Flow_Conditions_Yes" name="Yes" sourceRef="GW_ConditionsConflict" targetRef="Task_ReconcileConditions">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=conditionalCount > 1 and hasConflictingConditions = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Conditions_No" name="No" sourceRef="GW_ConditionsConflict" targetRef="GW_ConditionsMerge" />
    <bpmn:sequenceFlow id="Flow_Reconcile_ConditionsMerge" sourceRef="Task_ReconcileConditions" targetRef="GW_ConditionsMerge" />
    <bpmn:sequenceFlow id="Flow_ConditionsMerge_Outcome" sourceRef="GW_ConditionsMerge" targetRef="GW_VotingOutcome" />
    <bpmn:sequenceFlow id="Flow_Outcome_Approved" name="Approved" sourceRef="GW_VotingOutcome" targetRef="End_Approved">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=committeeDecision = "Approved"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Outcome_Conditional" name="Approved&#10;w/ Conditions" sourceRef="GW_VotingOutcome" targetRef="End_ApprovedConditional">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=committeeDecision = "ApprovedConditional"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Outcome_Rejected" name="Rejected" sourceRef="GW_VotingOutcome" targetRef="End_Rejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=committeeDecision = "Rejected"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Outcome_Remediation" name="Remediation" sourceRef="GW_VotingOutcome" targetRef="Task_ReviseBrief" />
    <bpmn:sequenceFlow id="Flow_Revise_MaxIterations" sourceRef="Task_ReviseBrief" targetRef="GW_MaxIterations" />
    <bpmn:sequenceFlow id="Flow_MaxIterations_Yes" name="Yes" sourceRef="GW_MaxIterations" targetRef="Task_AutoEscalate">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=remediationLoopCount >= votingConfig.maxRemediationLoops</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_MaxIterations_No" name="No" sourceRef="GW_MaxIterations" targetRef="GW_DistributeMerge" />
    <bpmn:sequenceFlow id="Flow_AutoEscalate_EndEscalated" sourceRef="Task_AutoEscalate" targetRef="End_Escalated" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Main">
    <bpmndi:BPMNPlane id="BPMNPlane_Main" bpmnElement="Process_CommitteeVoting">
      <bpmndi:BPMNShape id="CV_Start_di" bpmnElement="CV_Start">
        <dc:Bounds x="180" y="282" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="172" y="325" width="52" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DetermineVotingRules_di" bpmnElement="Task_DetermineVotingRules">
        <dc:Bounds x="270" y="260" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ResolveAuthority_di" bpmnElement="Task_ResolveAuthority">
        <dc:Bounds x="430" y="260" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AssembleBrief_di" bpmnElement="Task_AssembleBrief">
        <dc:Bounds x="590" y="260" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReviewBrief_di" bpmnElement="Task_ReviewBrief">
        <dc:Bounds x="750" y="260" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_DistributeMerge_di" bpmnElement="GW_DistributeMerge" isMarkerVisible="true">
        <dc:Bounds x="905" y="275" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DistributeBrief_di" bpmnElement="Task_DistributeBrief">
        <dc:Bounds x="1010" y="260" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_QAEnabled_di" bpmnElement="GW_QAEnabled" isMarkerVisible="true">
        <dc:Bounds x="1165" y="275" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1163" y="332" width="54" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SP_QAPhase_di" bpmnElement="SP_QAPhase" isExpanded="true">
        <dc:Bounds x="1270" y="160" width="530" height="180" />
