{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "Form_MockAwaitSignedContract",
  "components": [
    {
      "id": "Field_001",
      "type": "text",
      "text": "## Await Signed Contract\\n\\nThis is a mock task replacing the receive task. In production, this would wait for the vendor to return the signed contract. For testing, complete this form to simulate contract receipt."
    },
    {
      "id": "Field_002",
      "type": "textfield",
      "key": "contractReference",
      "label": "Contract Reference Number",
      "validate": {
        "required": true
      }
    },
    {
      "id": "Field_003",
      "type": "radio",
      "key": "contractSigned",
      "label": "Contract Signed?",
      "values": [
        {
          "label": "Yes",
          "value": "yes"
        },
        {
          "label": "No",
          "value": "no"
        }
      ],
      "validate": {
        "required": true
      }
    }
  ],
  "type": "default"
}
