{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "Form_VendorDeploySupport",
  "components": [
    {
      "type": "group",
      "label": "Deployment Execution",
      "id": "Field_001",
      "components": [
        {
          "type": "textfield",
          "key": "deploymentDate",
          "label": "Deployment date",
          "validate": {
            "required": true
          },
          "id": "Field_002"
        },
        {
          "type": "textfield",
          "key": "deploymentDuration",
          "label": "Deployment duration",
          "id": "Field_003"
        },
        {
          "type": "select",
          "key": "vendorDeploymentMethod",
          "label": "Deployment method",
          "values": [
            {
              "label": "Blue-Green",
              "value": "blue-green"
            },
            {
              "label": "Rolling",
              "value": "rolling"
            },
            {
              "label": "Big Bang",
              "value": "big-bang"
            }
          ],
          "validate": {
            "required": true
          },
          "id": "Field_004"
        },
        {
          "type": "textarea",
          "key": "environmentsDeployedTo",
          "label": "Environments deployed to",
          "validate": {
            "required": true
          },
          "id": "Field_005"
        }
      ]
    },
    {
      "type": "group",
      "label": "Verification",
      "id": "Field_006",
      "components": [
        {
          "type": "checkbox",
          "key": "deploymentRunbookFollowed",
          "label": "Deployment runbook followed",
          "validate": {
            "required": true
          },
          "id": "Field_007"
        },
        {
          "type": "checkbox",
          "key": "vendorSmokeTestsPassed",
          "label": "Smoke tests passed",
          "validate": {
            "required": true
          },
          "id": "Field_008"
        },
        {
          "type": "checkbox",
          "key": "rollbackTested",
          "label": "Rollback tested",
          "validate": {
            "required": true
          },
          "id": "Field_009"
        },
        {
          "type": "checkbox",
          "key": "configurationBaselineCaptured",
          "label": "Configuration baseline captured",
          "validate": {
            "required": true
          },
          "id": "Field_010"
        },
        {
          "type": "radio",
          "key": "dataMigrationValidated",
          "label": "Data migration validated",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            },
            {
              "label": "N/A",
              "value": "na"
            }
          ],
          "id": "Field_011"
        }
      ]
    },
    {
      "type": "group",
      "label": "Stabilization",
      "id": "Field_012",
      "components": [
        {
          "type": "textfield",
          "key": "onCallSupportContact",
          "label": "On-call support contact",
          "validate": {
            "required": true
          },
          "id": "Field_013"
        },
        {
          "type": "textfield",
          "key": "onCallSupportSchedule",
          "label": "On-call support schedule",
          "validate": {
            "required": true
          },
          "id": "Field_014"
        },
        {
          "type": "textarea",
          "key": "issuesEncountered",
          "label": "Issues encountered",
          "id": "Field_015"
        },
        {
          "type": "checkbox",
          "key": "postDeploymentMonitoringConfirmed",
          "label": "Post-deployment monitoring confirmed",
          "validate": {
            "required": true
          },
          "id": "Field_016"
        }
      ]
    }
  ],
  "type": "default"
}
