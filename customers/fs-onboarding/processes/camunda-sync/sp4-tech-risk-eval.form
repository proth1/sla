              "label": "Low",
              "value": "low"
            },
            {
              "label": "Medium",
              "value": "medium"
            },
            {
              "label": "High",
              "value": "high"
            }
          ],
          "id": "Field_012"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_013"
    },
    {
      "type": "group",
