          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Low",
              "value": "low"
            },
            {
              "label": "Medium",
              "value": "medium"
            },
            {
              "label": "High",
              "value": "high"
            }
          ],
          "id": "Field_009"
        },
        {
          "type": "select",
          "key": "dataLossRisk",
          "label": "Data Loss Risk",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Low",
              "value": "low"
            },
            {
              "label": "Medium",
              "value": "medium"
            },
            {
              "label": "High",
              "value": "high"
            }
          ],
          "id": "Field_010"
        },
        {
          "type": "select",
          "key": "recoveryCapability",
