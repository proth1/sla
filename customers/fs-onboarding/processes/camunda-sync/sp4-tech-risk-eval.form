        {
          "type": "radio",
          "key": "techRiskApproved",
          "label": "Technology Risk Approved?",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
