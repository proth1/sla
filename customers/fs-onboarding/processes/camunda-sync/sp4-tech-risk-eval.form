          "key": "technologyMaturity",
          "label": "Technology Maturity",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Emerging",
              "value": "emerging"
            },
            {
              "label": "Established",
              "value": "established"
            },
            {
              "label": "Mature",
              "value": "mature"
            },
            {
              "label": "Legacy",
              "value": "legacy"
            }
          ],
          "id": "Field_003"
        },
        {
          "type": "select",
          "key": "vendorLockInRisk",
          "label": "Vendor Lock-in Risk",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Low",
              "value": "low"
            },
            {
              "label": "Medium",
              "value": "medium"
            },
            {
              "label": "High",
              "value": "high"
            }
          ],
          "id": "Field_004"
        },
        {
          "type": "select",
          "key": "integrationRisk",
          "label": "Integration Risk",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Low",
              "value": "low"
            },
            {
              "label": "Medium",
              "value": "medium"
            },
            {
              "label": "High",
              "value": "high"
            }
          ],
          "id": "Field_005"
        },
        {
          "type": "select",
          "key": "scalabilityRisk",
          "label": "Scalability Risk",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Low",
              "value": "low"
            },
            {
              "label": "Medium",
              "value": "medium"
            },
            {
              "label": "High",
              "value": "high"
            }
          ],
          "id": "Field_006"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_007"
    },
    {
      "type": "group",
