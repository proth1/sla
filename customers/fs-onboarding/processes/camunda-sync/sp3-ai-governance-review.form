    {
      "type": "separator",
      "id": "Field_038"
    },
    {
      "type": "group",
      "label": "AI Governance Decision",
      "id": "Field_039",
      "components": [
        {
          "type": "select",
          "key": "aiRiskClassification",
          "label": "AI Risk Classification",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Acceptable",
              "value": "acceptable"
            },
            {
              "label": "Conditional",
              "value": "conditional"
            },
            {
              "label": "Unacceptable",
              "value": "unacceptable"
            }
          ],
          "id": "Field_040"
        },
        {
          "type": "textarea",
          "key": "aiGovernanceNotes",
          "label": "AI Governance Notes",
          "validate": {
            "required": true
          },
          "id": "Field_041"
        },
        {
          "type": "select",
          "key": "aiApproval",
          "label": "AI Approval",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Approved",
              "value": "approved"
            },
            {
              "label": "Conditional",
              "value": "conditional"
            },
            {
              "label": "Rejected",
              "value": "rejected"
