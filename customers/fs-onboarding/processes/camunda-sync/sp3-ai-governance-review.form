              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_035"
        },
        {
          "type": "radio",
          "key": "potentialHarmsIdentified",
          "label": "Potential Harms Identified",
          "validate": {
