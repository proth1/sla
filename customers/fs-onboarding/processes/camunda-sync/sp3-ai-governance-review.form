{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "Form_AIGovernanceReview",
  "components": [
    {
      "type": "text",
      "text": "## Consolidated AI Governance Assessment",
      "id": "Field_001"
    },
    {
      "type": "text",
      "text": "AI/ML risk classification and governance review per EU AI Act and SR 11-7 requirements.",
      "id": "Field_002"
    },
    {
      "type": "separator",
      "id": "Field_003"
    },
    {
      "type": "group",
      "label": "AI Model Overview",
      "id": "Field_810",
      "components": [
        {
          "type": "textfield",
          "key": "aiModelType",
          "label": "AI Model Type",
          "validate": {
            "required": true
          },
          "id": "Field_811"
        },
        {
          "type": "select",
          "key": "aiRiskClassificationEuAiAct",
          "label": "AI Risk Classification (EU AI Act)",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Unacceptable",
              "value": "unacceptable"
            },
            {
              "label": "High",
              "value": "high"
            },
            {
              "label": "Limited",
              "value": "limited"
            },
            {
              "label": "Minimal",
              "value": "minimal"
            }
          ],
          "id": "Field_812"
        },
        {
          "type": "textarea",
          "key": "modelValidationPlan",
          "label": "Model Validation Plan",
          "description": "Describe the planned approach for model validation and testing.",
          "id": "Field_813"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_814"
    },
    {
      "type": "group",
      "label": "AI System Classification",
      "id": "Field_004",
      "components": [
        {
          "type": "select",
          "key": "aiSystemType",
          "label": "AI System Type",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "ML Model",
              "value": "ml-model"
            },
            {
              "label": "LLM",
              "value": "llm"
            },
            {
              "label": "Rule-Based",
              "value": "rule-based"
            },
            {
              "label": "Hybrid",
              "value": "hybrid"
            },
            {
              "label": "Other",
              "value": "other"
            }
          ],
          "id": "Field_005"
        },
        {
          "type": "select",
          "key": "euAiActRiskCategory",
          "label": "EU AI Act Risk Category",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Unacceptable",
              "value": "unacceptable"
            },
            {
              "label": "High",
              "value": "high"
            },
            {
              "label": "Limited",
              "value": "limited"
            },
            {
              "label": "Minimal",
              "value": "minimal"
            }
          ],
          "id": "Field_006"
        },
        {
          "type": "select",
          "key": "sr117ModelTier",
          "label": "SR 11-7 Model Tier",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Tier 1 - Critical",
              "value": "tier1-critical"
            },
            {
              "label": "Tier 2 - Significant",
              "value": "tier2-significant"
            },
            {
              "label": "Tier 3 - Limited",
              "value": "tier3-limited"
            }
          ],
          "id": "Field_007"
        },
        {
          "type": "textarea",
          "key": "modelNamesAndVersions",
          "label": "Model Names and Versions",
          "validate": {
            "required": true
          },
          "id": "Field_008"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_009"
    },
    {
      "type": "group",
      "label": "Data & Training",
      "id": "Field_010",
      "components": [
        {
          "type": "textarea",
          "key": "trainingDataSources",
          "label": "Training Data Sources",
          "validate": {
            "required": true
          },
          "id": "Field_011"
        },
        {
          "type": "select",
          "key": "trainingDataClassification",
          "label": "Training Data Classification",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Public",
              "value": "public"
            },
            {
              "label": "Internal",
              "value": "internal"
            },
            {
              "label": "Confidential",
              "value": "confidential"
            },
            {
              "label": "Restricted",
              "value": "restricted"
            }
          ],
          "id": "Field_012"
        },
        {
          "type": "radio",
          "key": "customerDataUsedForTraining",
          "label": "Customer Data Used for Training",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_013"
        },
        {
          "type": "radio",
          "key": "optOutMechanismAvailable",
          "label": "Opt-Out Mechanism Available",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            },
            {
              "label": "N/A",
              "value": "na"
            }
          ],
          "id": "Field_014"
        },
        {
          "type": "textarea",
          "key": "dataDiversityMeasures",
          "label": "Data Diversity Measures",
          "id": "Field_015"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_016"
    },
    {
      "type": "group",
      "label": "Model Risk",
      "id": "Field_017",
      "components": [
        {
          "type": "radio",
          "key": "biasTestingPerformed",
          "label": "Bias Testing Performed",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_018"
        },
        {
          "type": "textarea",
          "key": "biasTestingResults",
          "label": "Bias Testing Results",
          "id": "Field_019"
        },
        {
          "type": "radio",
          "key": "explainabilityToolsAvailable",
          "label": "Explainability Tools Available",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_020"
        },
        {
          "type": "radio",
          "key": "modelDriftMonitoring",
          "label": "Model Drift Monitoring",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_021"
        },
        {
          "type": "radio",
          "key": "adversarialTestingPerformed",
          "label": "Adversarial Testing Performed",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_022"
        },
        {
          "type": "radio",
          "key": "promptInjectionControls",
          "label": "Prompt Injection Controls",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            },
            {
              "label": "N/A",
              "value": "na"
            }
          ],
          "id": "Field_023"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_024"
    },
    {
      "type": "group",
      "label": "Governance",
      "id": "Field_025",
      "components": [
        {
          "type": "radio",
          "key": "aiGovernanceDocumentation",
          "label": "AI Governance Documentation",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            },
            {
              "label": "Partial",
              "value": "partial"
            }
          ],
          "id": "Field_026"
        },
        {
          "type": "radio",
          "key": "designatedAiRiskOwner",
          "label": "Designated AI Risk Owner",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_027"
        },
        {
          "type": "radio",
          "key": "humanInTheLoopOversight",
          "label": "Human-in-the-Loop Oversight",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_028"
        },
        {
          "type": "radio",
          "key": "modelVersioningAuditTrails",
          "label": "Model Versioning and Audit Trails",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_029"
        },
        {
          "type": "radio",
          "key": "ethicalReviewMechanism",
          "label": "Ethical Review Mechanism",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_030"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_031"
    },
    {
      "type": "group",
      "label": "Performance Monitoring",
      "id": "Field_032",
      "components": [
        {
          "type": "radio",
          "key": "performanceMetricsTracked",
