{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "pdlc-integration",
  "components": [
    {
      "type": "text",
      "text": "## Integration and Deployment Readiness",
      "id": "Field_001"
    },
    {
      "type": "group",
      "label": "Integration Testing",
      "id": "Field_002",
      "components": [
        {
          "type": "textarea",
          "key": "integrationEnvironmentsTested",
          "label": "Integration Environments Tested",
          "validate": {
            "required": true
          },
          "id": "Field_003"
        },
        {
          "type": "radio",
          "key": "apiIntegrationVerified",
          "label": "API Integration Verified?",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_004"
        },
        {
          "type": "radio",
          "key": "dataFlowValidation",
          "label": "Data Flow Validation?",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_005"
        },
        {
          "type": "textarea",
          "key": "endToEndTestResults",
          "label": "End-to-End Test Results",
          "validate": {
            "required": true
          },
          "id": "Field_006"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_007"
    },
    {
      "type": "group",
      "label": "Deployment Readiness",
      "id": "Field_008",
      "components": [
        {
          "type": "radio",
          "key": "deploymentRunbookPrepared",
          "label": "Deployment Runbook Prepared?",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_009"
        },
        {
          "type": "radio",
          "key": "rollbackPlanDocumented",
          "label": "Rollback Plan Documented?",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_010"
        },
        {
          "type": "radio",
          "key": "configurationManagement",
          "label": "Configuration Management?",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_011"
        },
        {
          "type": "radio",
          "key": "monitoringConfigured",
          "label": "Monitoring Configured?",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_012"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_013"
    },
    {
      "type": "group",
      "label": "Release Decision",
      "id": "Field_014",
      "components": [
        {
          "type": "select",
          "key": "releaseReadiness",
          "label": "Release Readiness",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Ready",
              "value": "ready"
            },
            {
              "label": "Needs Work",
              "value": "needs-work"
            },
            {
              "label": "Blocked",
              "value": "blocked"
            }
          ],
          "id": "Field_015"
        },
        {
          "type": "textarea",
          "key": "releaseNotes",
          "label": "Release Notes",
          "validate": {
            "required": true
          },
          "id": "Field_016"
        },
        {
          "type": "radio",
          "key": "integrationComplete",
          "label": "Integration Complete?",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_017"
        }
      ]
    }
  ],
  "type": "default"
}
