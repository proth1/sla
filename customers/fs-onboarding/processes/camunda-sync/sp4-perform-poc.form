{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "Form_PerformPoC",
  "components": [
    {
      "type": "text",
      "text": "## Proof of Concept Execution",
      "id": "Field_001"
    },
    {
      "type": "group",
      "label": "PoC Design",
      "id": "Field_002",
      "components": [
        {
          "type": "textarea",
          "key": "pocObjectives",
          "label": "PoC Objectives",
          "validate": {
            "required": true
          },
          "id": "Field_003"
        },
        {
          "type": "textarea",
          "key": "pocScope",
          "label": "PoC Scope",
          "validate": {
            "required": true
          },
          "id": "Field_004"
        },
        {
          "type": "textarea",
          "key": "pocSuccessCriteria",
          "label": "Success Criteria",
          "validate": {
            "required": true
          },
          "id": "Field_005"
        },
        {
          "type": "textfield",
          "key": "pocDuration",
          "label": "PoC Duration",
          "validate": {
            "required": true
          },
          "id": "Field_006"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_007"
    },
    {
      "type": "group",
      "label": "PoC Execution",
      "id": "Field_008",
      "components": [
        {
          "type": "textarea",
          "key": "technicalEnvironment",
          "label": "Technical Environment",
          "id": "Field_009"
        },
        {
          "type": "textarea",
          "key": "testScenariosExecuted",
          "label": "Test Scenarios Executed",
          "validate": {
            "required": true
          },
          "id": "Field_010"
        },
        {
          "type": "textarea",
          "key": "integrationTestResults",
          "label": "Integration Test Results",
          "id": "Field_011"
        },
        {
          "type": "textarea",
          "key": "performanceTestResults",
          "label": "Performance Test Results",
          "id": "Field_012"
        },
        {
          "type": "textarea",
          "key": "securityTestResults",
          "label": "Security Test Results",
          "id": "Field_013"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_014"
    },
    {
      "type": "group",
      "label": "PoC Results",
      "id": "Field_015",
      "components": [
        {
          "type": "select",
          "key": "pocOutcome",
          "label": "PoC Outcome",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Success",
              "value": "success"
            },
            {
              "label": "Partial",
              "value": "partial"
            },
            {
              "label": "Failure",
              "value": "failure"
            }
          ],
          "id": "Field_016"
        },
        {
          "type": "textarea",
          "key": "pocKeyFindings",
          "label": "Key Findings",
          "validate": {
            "required": true
          },
          "id": "Field_017"
        },
        {
          "type": "textarea",
          "key": "pocRisksIdentified",
          "label": "Risks Identified",
          "id": "Field_018"
        },
        {
          "type": "select",
          "key": "pocRecommendation",
          "label": "Recommendation",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Proceed",
              "value": "proceed"
            },
            {
              "label": "Proceed with Conditions",
              "value": "proceed-with-conditions"
            },
            {
              "label": "Do Not Proceed",
              "value": "do-not-proceed"
            }
          ],
          "id": "Field_019"
        },
        {
          "type": "textarea",
          "key": "pocRecommendationRationale",
          "label": "Recommendation Rationale",
          "validate": {
            "required": true
          },
          "id": "Field_020"
        }
      ]
    }
  ],
  "type": "default"
}
