{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "sp1-review-existing",
  "components": [
    {
      "type": "text",
      "text": "## Review Existing Software Portfolio\nSearch the existing software catalog for reuse opportunities before initiating a new procurement or build.",
      "id": "Field_001"
    },
    {
      "type": "textarea",
      "key": "requestDescription",
      "label": "Request Description",
      "validate": {
        "required": true
      },
      "id": "Field_002"
    },
    {
      "type": "textfield",
      "key": "businessUnit",
      "label": "Business Unit",
      "validate": {
        "required": true
      },
      "id": "Field_003"
    },
    {
      "type": "separator",
      "id": "Field_004"
    },
    {
      "type": "text",
      "text": "## Catalog Search Results",
      "id": "Field_005"
    },
    {
      "type": "textarea",
      "key": "catalogSearchResults",
      "label": "Search Results from Software Catalog",
      "description": "Paste or summarize results from the enterprise software catalog search.",
      "id": "Field_006"
    },
    {
      "type": "radio",
      "key": "existingSolutionFound",
      "label": "Existing Solution Found?",
      "validate": {
        "required": true
      },
      "values": [
        {
          "label": "Yes",
          "value": "yes"
        },
        {
          "label": "No",
          "value": "no"
        }
      ],
      "id": "Field_007"
    },
    {
      "type": "separator",
      "id": "Field_008"
    },
    {
      "type": "group",
      "label": "Existing Solution Details",
      "components": [
        {
          "type": "textfield",
          "key": "existingSolutionName",
          "label": "Existing Solution Name",
          "id": "Field_009"
        },
        {
          "type": "textfield",
          "key": "existingSolutionVersion",
          "label": "Version",
          "id": "Field_010"
        },
        {
          "type": "textfield",
          "key": "existingLicenseStatus",
          "label": "License Status",
          "id": "Field_011"
        },
        {
          "type": "number",
          "key": "existingUtilizationRate",
          "label": "Current Utilization Rate (%)",
          "id": "Field_012"
        }
      ],
      "id": "Field_013"
    },
    {
      "type": "separator",
      "id": "Field_014"
    },
    {
      "type": "text",
      "text": "## Gap Analysis",
      "id": "Field_015"
    },
    {
      "type": "textarea",
      "key": "gapAnalysis",
      "label": "Gap Analysis",
      "description": "What does the existing solution cover vs. what is missing?",
      "id": "Field_016"
    },
    {
      "type": "radio",
      "key": "existingSolutionSufficient",
      "label": "Is the existing solution sufficient?",
      "validate": {
        "required": true
      },
      "values": [
        {
          "label": "Sufficient \u2014 can be leveraged as-is or with minor configuration",
          "value": "sufficient"
        },
        {
          "label": "Insufficient \u2014 new procurement or build required",
          "value": "insufficient"
        }
      ],
      "id": "Field_017"
    },
    {
      "type": "number",
      "key": "estimatedCostAvoidance",
      "label": "Estimated Cost Avoidance if Leveraged ($)",
      "id": "Field_018"
    }
  ],
  "type": "default"
}
