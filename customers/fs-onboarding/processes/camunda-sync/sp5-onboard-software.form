{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "sp5-onboard-software",
  "components": [
    {
      "type": "group",
      "label": "Provisioning",
      "id": "Field_001",
      "components": [
        {
          "type": "number",
          "key": "usersProvisionedCount",
          "label": "Users provisioned count",
          "validate": {
            "required": true
          },
          "id": "Field_002"
        },
        {
          "type": "textarea",
          "key": "accessLevelsConfigured",
          "label": "Access levels configured",
          "validate": {
            "required": true
          },
          "id": "Field_003"
        },
        {
          "type": "checkbox",
          "key": "mfaEnabled",
          "label": "MFA enabled",
          "validate": {
            "required": true
          },
          "id": "Field_004"
        },
        {
          "type": "checkbox",
          "key": "rbacConfigured",
          "label": "RBAC configured",
          "validate": {
            "required": true
          },
          "id": "Field_005"
        }
      ]
    },
    {
      "type": "group",
      "label": "Deployment",
      "id": "Field_006",
      "components": [
        {
          "type": "textfield",
          "key": "goLiveDate",
          "label": "Go-live date",
          "validate": {
            "required": true
          },
          "id": "Field_007"
        },
        {
          "type": "select",
          "key": "deploymentMethod",
          "label": "Deployment method",
          "values": [
            {
              "label": "Blue-Green",
              "value": "blue-green"
            },
            {
              "label": "Rolling",
              "value": "rolling"
            },
            {
              "label": "Big Bang",
              "value": "big-bang"
            },
            {
              "label": "Canary",
              "value": "canary"
            }
          ],
          "validate": {
            "required": true
          },
          "id": "Field_008"
        },
        {
          "type": "radio",
          "key": "productionEnvironmentConfirmed",
          "label": "Production environment confirmed",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "validate": {
            "required": true
          },
          "id": "Field_009"
        },
        {
          "type": "radio",
          "key": "smokeTestsPassed",
          "label": "Smoke tests passed",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "validate": {
            "required": true
          },
          "id": "Field_010"
        }
      ]
    },
    {
      "type": "group",
      "label": "Monitoring Setup",
      "id": "Field_011",
      "components": [
        {
          "type": "number",
          "key": "monitoringKRIsEstablished",
          "label": "Monitoring KRIs established",
          "id": "Field_012"
        },
        {
          "type": "checkbox",
          "key": "cmdbEntryCreated",
          "label": "CMDB entry created",
          "validate": {
            "required": true
          },
          "id": "Field_013"
        },
        {
          "type": "checkbox",
          "key": "operationalRunbookCompleted",
          "label": "Operational runbook completed",
          "validate": {
            "required": true
          },
          "id": "Field_014"
        },
        {
          "type": "checkbox",
          "key": "backupConfigurationVerified",
          "label": "Backup configuration verified",
          "validate": {
            "required": true
          },
          "id": "Field_015"
        },
        {
          "type": "textfield",
          "key": "supportTeamAssigned",
          "label": "Support team assigned",
          "validate": {
            "required": true
          },
          "id": "Field_016"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_017"
    },
    {
      "type": "radio",
      "key": "onboardingComplete",
      "label": "Onboarding complete",
      "values": [
        {
          "label": "Yes",
          "value": "yes"
        },
        {
          "label": "No",
          "value": "no"
        }
      ],
      "validate": {
        "required": true
      },
      "id": "Field_018"
    }
  ],
  "type": "default"
}
