<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="OB-DMN6-SecurityAssessmentRouting-definitions"
             name="OB-DMN-6: Security Assessment Routing (Onboarding)"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="OB_DMN_SecurityAssessmentRouting"
            name="Security Assessment Routing (Onboarding)"
            camunda:historyTimeToLive="180">
    <decisionTable id="OB_DMN_SecurityAssessmentRouting-table" hitPolicy="FIRST">

      <!--
        OB-DMN-6: Security Assessment Routing (Onboarding Variant)
        Phase: 3 (Evaluation and Due Diligence)
        Hit Policy: FIRST (most restrictive assessment level wins)
        Inputs: riskTier, dataClassification, hasAIComponent, deploymentModel
        Outputs: assessmentLevel (Baseline/Elevated/Major), requiresPenTest (boolean)
      -->

      <input id="ob6-input-riskTier" label="Risk Tier">
        <inputExpression id="ob6-inputExpr-riskTier" typeRef="string">
          <text>riskTier</text>
        </inputExpression>
        <inputValues id="ob6-inputVals-riskTier">
          <text>"High","Medium","Low"</text>
        </inputValues>
      </input>

      <input id="ob6-input-dataClassification" label="Data Classification">
        <inputExpression id="ob6-inputExpr-dataClassification" typeRef="string">
          <text>dataClassification</text>
        </inputExpression>
        <inputValues id="ob6-inputVals-dataClassification">
          <text>"Public","Internal","Confidential","Restricted"</text>
        </inputValues>
      </input>

      <input id="ob6-input-hasAIComponent" label="Has AI Component">
        <inputExpression id="ob6-inputExpr-hasAIComponent" typeRef="boolean">
          <text>hasAIComponent</text>
        </inputExpression>
      </input>

      <input id="ob6-input-deploymentModel" label="Deployment Model">
        <inputExpression id="ob6-inputExpr-deploymentModel" typeRef="string">
          <text>deploymentModel</text>
        </inputExpression>
        <inputValues id="ob6-inputVals-deploymentModel">
          <text>"Cloud","On-Premise","Hybrid"</text>
        </inputValues>
      </input>

      <output id="ob6-output-assessmentLevel"
              label="Assessment Level"
              name="assessmentLevel"
              typeRef="string" />

      <output id="ob6-output-requiresPenTest"
              label="Requires Pen Test"
              name="requiresPenTest"
              typeRef="boolean" />

      <!-- Major: High risk tier — always requires full assessment -->
      <rule id="ob6-rule-1">
        <description>Major: High risk tier — full security assessment and pen test required</description>
        <inputEntry id="ob6-ie-1-1"><text>"High"</text></inputEntry>
        <inputEntry id="ob6-ie-1-2"><text>-</text></inputEntry>
        <inputEntry id="ob6-ie-1-3"><text>-</text></inputEntry>
        <inputEntry id="ob6-ie-1-4"><text>-</text></inputEntry>
        <outputEntry id="ob6-oe-1-1"><text>"Major"</text></outputEntry>
        <outputEntry id="ob6-oe-1-2"><text>true</text></outputEntry>
      </rule>

      <!-- Major: Restricted data classification — highest data sensitivity -->
      <rule id="ob6-rule-2">
        <description>Major: Restricted data classification — maximum security controls required</description>
        <inputEntry id="ob6-ie-2-1"><text>-</text></inputEntry>
        <inputEntry id="ob6-ie-2-2"><text>"Restricted"</text></inputEntry>
        <inputEntry id="ob6-ie-2-3"><text>-</text></inputEntry>
        <inputEntry id="ob6-ie-2-4"><text>-</text></inputEntry>
        <outputEntry id="ob6-oe-2-1"><text>"Major"</text></outputEntry>
        <outputEntry id="ob6-oe-2-2"><text>true</text></outputEntry>
      </rule>

      <!-- Major: AI component present — AI governance requires full assessment -->
      <rule id="ob6-rule-3">
        <description>Major: AI component detected — AI governance and model risk assessment required</description>
        <inputEntry id="ob6-ie-3-1"><text>-</text></inputEntry>
        <inputEntry id="ob6-ie-3-2"><text>-</text></inputEntry>
        <inputEntry id="ob6-ie-3-3"><text>true</text></inputEntry>
        <inputEntry id="ob6-ie-3-4"><text>-</text></inputEntry>
        <outputEntry id="ob6-oe-3-1"><text>"Major"</text></outputEntry>
        <outputEntry id="ob6-oe-3-2"><text>true</text></outputEntry>
      </rule>

      <!-- Elevated: Confidential data classification -->
      <rule id="ob6-rule-4">
        <description>Elevated: Confidential data — enhanced security review but no mandatory pen test</description>
        <inputEntry id="ob6-ie-4-1"><text>-</text></inputEntry>
        <inputEntry id="ob6-ie-4-2"><text>"Confidential"</text></inputEntry>
        <inputEntry id="ob6-ie-4-3"><text>-</text></inputEntry>
        <inputEntry id="ob6-ie-4-4"><text>-</text></inputEntry>
        <outputEntry id="ob6-oe-4-1"><text>"Elevated"</text></outputEntry>
        <outputEntry id="ob6-oe-4-2"><text>false</text></outputEntry>
      </rule>

      <!-- Elevated: Cloud deployment model -->
      <rule id="ob6-rule-5">
        <description>Elevated: Cloud deployment — additional cloud security controls review</description>
        <inputEntry id="ob6-ie-5-1"><text>-</text></inputEntry>
        <inputEntry id="ob6-ie-5-2"><text>-</text></inputEntry>
        <inputEntry id="ob6-ie-5-3"><text>-</text></inputEntry>
        <inputEntry id="ob6-ie-5-4"><text>"Cloud"</text></inputEntry>
        <outputEntry id="ob6-oe-5-1"><text>"Elevated"</text></outputEntry>
        <outputEntry id="ob6-oe-5-2"><text>false</text></outputEntry>
      </rule>

      <!-- Baseline: Default — all other combinations -->
      <rule id="ob6-rule-6">
        <description>Baseline: Default — standard security assessment for low-risk, non-sensitive combinations</description>
        <inputEntry id="ob6-ie-6-1"><text>-</text></inputEntry>
        <inputEntry id="ob6-ie-6-2"><text>-</text></inputEntry>
        <inputEntry id="ob6-ie-6-3"><text>-</text></inputEntry>
        <inputEntry id="ob6-ie-6-4"><text>-</text></inputEntry>
        <outputEntry id="ob6-oe-6-1"><text>"Baseline"</text></outputEntry>
        <outputEntry id="ob6-oe-6-2"><text>false</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="OB-DMN6-diagram">
      <dmndi:DMNShape id="OB-DMN6-shape" dmnElementRef="OB_DMN_SecurityAssessmentRouting">
        <dc:Bounds x="100" y="100" width="380" height="80" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
