{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "Form_VendorComplianceReview",
  "components": [
    {
      "type": "group",
      "label": "Regulatory Certifications",
      "id": "Field_001",
      "components": [
        {
          "type": "textarea",
          "key": "certificationsHeldWithExpiry",
          "label": "Certifications held with expiry dates",
          "validate": {
            "required": true
          },
          "id": "Field_002"
        },
        {
          "type": "radio",
          "key": "auditRightsConfirmation",
          "label": "Audit rights confirmation",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "validate": {
            "required": true
          },
          "id": "Field_003"
        },
        {
          "type": "textarea",
          "key": "regulatoryExaminationHistory",
          "label": "Regulatory examination history",
          "id": "Field_004"
        },
        {
          "type": "radio",
          "key": "enforcementActionsPast5Years",
          "label": "Enforcement actions in past 5 years",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "validate": {
            "required": true
          },
          "id": "Field_005"
        }
      ]
    },
    {
      "type": "group",
      "label": "Data Protection",
      "id": "Field_006",
      "components": [
        {
          "type": "select",
          "key": "dpaExecutionStatus",
          "label": "DPA execution status",
          "values": [
            {
              "label": "Executed",
              "value": "executed"
            },
            {
              "label": "Draft",
              "value": "draft"
            },
            {
              "label": "Pending",
              "value": "pending"
            }
          ],
          "validate": {
            "required": true
          },
          "id": "Field_007"
        },
        {
          "type": "number",
          "key": "subProcessorCount",
          "label": "Sub-processor count",
          "validate": {
            "required": true
          },
          "id": "Field_008"
        },
        {
          "type": "textarea",
          "key": "subProcessorJurisdictions",
          "label": "Sub-processor jurisdictions",
          "validate": {
            "required": true
          },
          "id": "Field_009"
        },
        {
          "type": "textarea",
          "key": "dataResidencyCountries",
          "label": "Data residency countries",
          "validate": {
            "required": true
          },
          "id": "Field_010"
        },
        {
          "type": "textfield",
          "key": "dataBreachNotificationTimeline",
          "label": "Data breach notification timeline",
          "validate": {
            "required": true
          },
          "id": "Field_011"
        }
      ]
    },
    {
      "type": "group",
      "label": "Privacy",
      "id": "Field_012",
      "components": [
        {
          "type": "textfield",
          "key": "privacyOfficerContact",
          "label": "Privacy officer contact",
          "validate": {
            "required": true
          },
          "id": "Field_013"
        },
        {
          "type": "textarea",
          "key": "dataRetentionPolicy",
          "label": "Data retention policy",
          "validate": {
            "required": true
          },
          "id": "Field_014"
        },
        {
          "type": "radio",
          "key": "dataDeletionOnTermination",
          "label": "Data deletion on termination",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "validate": {
            "required": true
          },
          "id": "Field_015"
        },
        {
          "type": "radio",
          "key": "dpiaSupportAvailable",
          "label": "DPIA support available",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_016"
        }
      ]
    }
  ],
  "type": "default"
}
