{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "vendor-tech-demo",
  "components": [
    {
      "type": "group",
      "label": "Demo Execution",
      "id": "Field_001",
      "components": [
        {
          "type": "number",
          "key": "demoScriptCompletionPercentage",
          "label": "Demo script completion percentage",
          "validate": {
            "required": true
          },
          "id": "Field_002"
        },
        {
          "type": "textarea",
          "key": "functionalityDemonstrated",
          "label": "Functionality demonstrated",
          "validate": {
            "required": true
          },
          "id": "Field_003"
        },
        {
          "type": "textarea",
          "key": "securityControlsDemonstrated",
          "label": "Security controls demonstrated",
          "id": "Field_004"
        },
        {
          "type": "radio",
          "key": "failoverRecoveryDemonstrated",
          "label": "Failover/recovery demonstrated",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_005"
        },
        {
          "type": "radio",
          "key": "integrationCompatibilityConfirmed",
          "label": "Integration compatibility confirmed",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_006"
        }
      ]
    },
    {
      "type": "group",
      "label": "Demo Scoring",
      "id": "Field_007",
      "components": [
        {
          "type": "number",
          "key": "functionalityScore",
          "label": "Functionality score (0-100)",
          "id": "Field_008"
        },
        {
          "type": "number",
          "key": "securityScore",
          "label": "Security score (0-100)",
          "id": "Field_009"
        },
        {
          "type": "number",
          "key": "performanceScore",
          "label": "Performance score (0-100)",
          "id": "Field_010"
        },
        {
          "type": "number",
          "key": "usabilityScore",
          "label": "Usability score (0-100)",
          "id": "Field_011"
        },
        {
          "type": "number",
          "key": "integrationScore",
          "label": "Integration score (0-100)",
          "id": "Field_012"
        }
      ]
    },
    {
      "type": "group",
      "label": "Demo Outcome",
      "id": "Field_013",
      "components": [
        {
          "type": "textarea",
          "key": "identifiedGapsOrLimitations",
          "label": "Identified gaps or limitations",
          "id": "Field_014"
        },
        {
          "type": "select",
          "key": "estimatedCustomizationEffort",
          "label": "Estimated customization effort",
          "values": [
            {
              "label": "None",
              "value": "none"
            },
            {
              "label": "Minor",
              "value": "minor"
            },
            {
              "label": "Moderate",
              "value": "moderate"
            },
            {
              "label": "Significant",
              "value": "significant"
            }
          ],
          "id": "Field_015"
        },
        {
          "type": "textarea",
          "key": "demoNotes",
          "label": "Demo notes",
          "id": "Field_016"
        }
      ]
    }
  ],
  "type": "default"
}
