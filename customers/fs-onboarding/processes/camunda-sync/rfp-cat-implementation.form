    },
    {
      "type": "separator",
      "id": "Field_Cat6_Sep1"
    },
    {
      "id": "Field_C6_1",
      "label": "C6.1: Typical implementation timeline",
      "type": "textfield",
      "key": "c6_1"
    },
    {
      "id": "Field_C6_2",
      "label": "C6.2: Implementation methodology",
      "type": "textarea",
      "key": "c6_2"
    },
    {
      "id": "Field_C6_3",
      "label": "C6.3: Training options",
      "type": "checklist",
      "key": "c6_3",
      "values": [
        {
          "label": "On-site",
          "value": "on-site"
        },
        {
          "label": "Virtual",
          "value": "virtual"
        },
        {
          "label": "Self-paced",
          "value": "self-paced"
        },
        {
