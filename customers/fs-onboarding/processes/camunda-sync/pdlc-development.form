{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "pdlc-development",
  "components": [
    {
      "type": "text",
      "text": "## Development and Build Tracking",
      "id": "Field_001"
    },
    {
      "type": "group",
      "label": "Development Status",
      "id": "Field_002",
      "components": [
        {
          "type": "number",
          "key": "sprintNumber",
          "label": "Sprint Number",
          "validate": {
            "required": true
          },
          "id": "Field_003"
        },
        {
          "type": "textarea",
          "key": "featuresCompleted",
          "label": "Features Completed",
          "validate": {
            "required": true
          },
          "id": "Field_004"
        },
        {
          "type": "select",
          "key": "codeReviewStatus",
          "label": "Code Review Status",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "All Reviewed",
              "value": "all-reviewed"
            },
            {
              "label": "Partial",
              "value": "partial"
            },
            {
              "label": "Pending",
              "value": "pending"
            }
          ],
          "id": "Field_005"
        },
        {
          "type": "textarea",
          "key": "staticAnalysisResults",
          "label": "Static Analysis Results",
          "id": "Field_006"
        },
        {
          "type": "textfield",
          "key": "unitTestCoverage",
          "label": "Unit Test Coverage (e.g., 85%)",
          "validate": {
            "required": true
          },
          "id": "Field_007"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_008"
    },
    {
      "type": "group",
      "label": "Security in Development",
      "id": "Field_009",
      "components": [
        {
          "type": "radio",
          "key": "sastScanCompleted",
          "label": "SAST Scan Completed?",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_010"
        },
        {
          "type": "textarea",
          "key": "sastFindings",
          "label": "SAST Findings",
          "id": "Field_011"
        },
        {
          "type": "radio",
          "key": "secretsScanningCompleted",
          "label": "Secrets Scanning Completed?",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_012"
        },
        {
          "type": "radio",
          "key": "dependencyVulnerabilityScan",
          "label": "Dependency Vulnerability Scan?",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_013"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_014"
    },
    {
      "type": "radio",
      "key": "developmentComplete",
      "label": "Development Complete?",
      "validate": {
        "required": true
      },
      "values": [
        {
          "label": "Yes",
          "value": "yes"
        },
        {
          "label": "No",
          "value": "no"
        }
      ],
      "id": "Field_015"
    }
  ],
  "type": "default"
}
