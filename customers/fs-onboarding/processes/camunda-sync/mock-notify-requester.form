{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "mock-notify-requester",
  "components": [
    {
      "id": "Field_001",
      "type": "text",
      "text": "## Notify Requester\\n\\nThis is a mock task replacing the service task. In production, this would send an automated notification. For testing, review and confirm the notification."
    },
    {
      "id": "Field_002",
      "type": "textarea",
      "key": "notificationMessage",
      "label": "Notification Message",
      "validate": {
        "required": true
      }
    },
    {
      "id": "Field_003",
      "type": "radio",
      "key": "notificationSent",
      "label": "Notification Confirmed?",
      "values": [
        {
          "label": "Yes",
          "value": "yes"
        },
        {
          "label": "No",
          "value": "no"
        }
      ],
      "validate": {
        "required": true
      }
    }
  ],
  "type": "default"
}
