{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "sp1-triage-and-route",
  "components": [
    {
      "type": "text",
      "text": "## Triage & Route\nClassify the request, review upstream screening results, and make a triage decision.",
      "id": "Field_TR01"
    },
    {
      "type": "separator",
      "id": "Field_TR02"
    },
    {
      "type": "group",
      "label": "Request Summary",
      "components": [
        {
          "type": "textarea",
          "key": "businessProblem",
          "label": "Business Problem",
          "disabled": true,
          "id": "Field_TR03"
        },
        {
          "type": "textfield",
          "key": "urgencyLevel",
          "label": "Urgency Level",
          "disabled": true,
          "id": "Field_TR04"
        },
        {
          "type": "textfield",
          "key": "pathwayPreference",
          "label": "Pathway Preference",
          "disabled": true,
          "id": "Field_TR05"
        },
        {
          "type": "textfield",
          "key": "criticality",
          "label": "Business Criticality",
          "disabled": true,
          "id": "Field_TR06"
        },
        {
          "type": "textfield",
          "key": "estimatedBudget",
          "label": "Estimated Budget",
          "disabled": true,
          "id": "Field_TR07"
        },
        {
          "type": "textfield",
          "key": "hasAI",
          "label": "AI Involvement",
          "disabled": true,
          "id": "Field_TR08"
        },
        {
          "type": "textfield",
          "key": "dealKillerResult",
          "label": "Deal Killer Pre-Screen Result",
          "disabled": true,
          "description": "Automated deal killer check result (read-only).",
          "id": "Field_TR09"
        }
      ],
      "id": "Field_TR10"
    },
    {
      "type": "separator",
      "id": "Field_TR11"
    },
    {
      "type": "group",
      "label": "Classification",
      "components": [
        {
          "type": "radio",
          "key": "requestType",
          "label": "Request Type",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Defined Need \u2014 clear business requirement identified",
              "value": "defined-need"
            },
            {
              "label": "Forced Update \u2014 mandatory upgrade or regulatory requirement",
              "value": "forced-update"
            },
            {
              "label": "Speculative \u2014 exploratory or innovation-driven",
              "value": "speculative"
            }
          ],
          "id": "Field_TR12"
        },
        {
          "type": "textarea",
          "key": "classificationRationale",
          "label": "Classification Rationale",
          "validate": {
            "required": true
          },
          "description": "Explain the reasoning behind the selected request type classification.",
          "id": "Field_TR13"
        }
      ],
      "id": "Field_TR14"
    },
    {
      "type": "separator",
      "id": "Field_TR15"
    },
    {
      "type": "group",
      "label": "Triage Assessment",
      "components": [
        {
          "type": "select",
          "key": "riskTier",
          "label": "Risk Tier",
          "validate": {
            "required": true
          },
          "values": [
            { "label": "Low", "value": "Low" },
            { "label": "Medium", "value": "Medium" },
            { "label": "High", "value": "High" },
            { "label": "Critical", "value": "Critical" }
          ],
          "id": "Field_TR28"
        },
        {
          "type": "select",
          "key": "dataClassification",
          "label": "Data Classification",
          "values": [
            { "label": "Public", "value": "Public" },
            { "label": "Internal", "value": "Internal" },
            { "label": "Confidential", "value": "Confidential" },
            { "label": "Restricted", "value": "Restricted" }
          ],
          "id": "Field_TR29"
        },
        {
          "type": "number",
          "key": "strategicAlignment",
          "label": "Strategic Alignment Rating (1-5)",
          "validate": {
            "required": true,
            "min": 1,
            "max": 5
          },
          "id": "Field_TR16"
        },
        {
          "type": "textarea",
          "key": "duplicateDetectionResults",
          "label": "Duplicate Detection Results",
          "description": "Note any existing requests or solutions that overlap with this request.",
          "id": "Field_TR17"
        },
        {
          "type": "textarea",
          "key": "concentrationRiskAssessment",
          "label": "Concentration Risk Assessment",
          "description": "Assess vendor concentration risk if this is a Buy pathway.",
          "id": "Field_TR18"
        },
        {
          "type": "select",
          "key": "resourceAvailability",
          "label": "Resource Availability",
          "values": [
            {
              "label": "Available \u2014 resources can be allocated",
              "value": "available"
            },
            {
              "label": "Constrained \u2014 limited resources, may delay",
              "value": "constrained"
            },
            {
              "label": "Unavailable \u2014 no resources until next quarter",
              "value": "unavailable"
            }
          ],
          "id": "Field_TR19"
        },
        {
          "type": "textarea",
          "key": "preliminaryRiskIndicators",
          "label": "Preliminary Risk Indicators",
          "description": "Note any early risk signals (regulatory, technical, financial).",
          "id": "Field_TR20"
        }
      ],
      "id": "Field_TR21"
    },
    {
      "type": "separator",
      "id": "Field_TR22"
    },
    {
      "type": "group",
      "label": "Triage Decision",
      "components": [
        {
          "type": "select",
          "key": "triageDecision",
          "label": "Triage Decision",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Approve \u2014 proceed to planning",
              "value": "approve"
            },
            {
              "label": "Reject \u2014 does not meet criteria",
              "value": "reject"
            },
            {
              "label": "Return for Information \u2014 additional details needed",
              "value": "return-for-info"
            }
          ],
          "id": "Field_TR23"
        },
        {
          "type": "textarea",
          "key": "triageRationale",
          "label": "Decision Rationale",
          "validate": {
            "required": true
          },
          "id": "Field_TR24"
        },
        {
          "type": "select",
          "key": "assignedPriority",
          "label": "Assigned Priority",
          "values": [
            {
              "label": "Critical",
              "value": "critical"
            },
            {
              "label": "High",
              "value": "high"
            },
            {
              "label": "Standard",
              "value": "standard"
            },
            {
              "label": "Low",
              "value": "low"
            }
          ],
          "id": "Field_TR25"
        },
        {
          "type": "textfield",
          "key": "assignedAnalyst",
          "label": "Assigned Analyst",
          "id": "Field_TR26"
        }
      ],
      "id": "Field_TR27"
    }
  ],
  "type": "default"
}