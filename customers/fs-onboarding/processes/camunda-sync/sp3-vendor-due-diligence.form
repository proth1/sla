{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "sp3-vendor-due-diligence",
  "components": [
    {
      "type": "text",
      "text": "## Vendor Due Diligence",
      "id": "Field_001"
    },
    {
      "type": "text",
      "text": "Deep vendor due diligence covering financial stability, sanctions screening, and sub-contractor assessment.",
      "id": "Field_002"
    },
    {
      "type": "separator",
      "id": "Field_003"
    },
    {
      "type": "group",
      "label": "Vendor Profile",
      "id": "Field_004",
      "components": [
        {
          "type": "textfield",
          "key": "legalEntityName",
          "label": "Legal Entity Name",
          "validate": {
            "required": true
          },
          "id": "Field_005"
        },
        {
          "type": "textfield",
          "key": "taxIdDuns",
          "label": "Tax ID / DUNS",
          "id": "Field_006"
        },
        {
          "type": "textfield",
          "key": "jurisdictionOfIncorporation",
          "label": "Jurisdiction of Incorporation",
          "validate": {
            "required": true
          },
          "id": "Field_007"
        },
        {
          "type": "textarea",
          "key": "ownershipStructure",
          "label": "Ownership Structure",
          "id": "Field_008"
        },
        {
          "type": "number",
          "key": "yearsInOperation",
          "label": "Years in Operation",
          "id": "Field_009"
        },
        {
          "type": "select",
          "key": "annualRevenueRange",
          "label": "Annual Revenue Range",
          "values": [
            {
              "label": "Under $1M",
              "value": "under1M"
            },
            {
              "label": "$1M - $10M",
              "value": "1M-10M"
            },
            {
              "label": "$10M - $100M",
              "value": "10M-100M"
            },
            {
              "label": "$100M - $1B",
              "value": "100M-1B"
            },
            {
              "label": "Over $1B",
              "value": "over1B"
            }
          ],
          "id": "Field_010"
        },
        {
          "type": "number",
          "key": "numberOfEmployees",
          "label": "Number of Employees",
          "id": "Field_011"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_012"
    },
    {
      "type": "group",
      "label": "Financial Stability",
      "id": "Field_013",
      "components": [
        {
          "type": "textfield",
          "key": "creditRating",
          "label": "Credit Rating",
          "id": "Field_014"
        },
        {
          "type": "radio",
          "key": "auditedFinancialsAvailable",
          "label": "Audited Financials Available",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_015"
        },
        {
          "type": "select",
          "key": "financialStabilityAssessment",
          "label": "Financial Stability Assessment",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Strong",
              "value": "strong"
            },
            {
              "label": "Adequate",
              "value": "adequate"
            },
            {
              "label": "Concerns",
              "value": "concerns"
            },
            {
              "label": "Unacceptable",
              "value": "unacceptable"
            }
          ],
          "id": "Field_016"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_017"
    },
    {
      "type": "group",
      "label": "Sanctions & Compliance",
      "id": "Field_018",
      "components": [
        {
          "type": "select",
          "key": "sanctionsScreeningResult",
          "label": "Sanctions Screening Result",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Clear",
              "value": "clear"
            },
            {
              "label": "Match Found",
              "value": "match-found"
            },
            {
              "label": "Pending",
              "value": "pending"
            }
          ],
          "id": "Field_019"
        },
        {
          "type": "radio",
          "key": "conflictOfInterestDeclaration",
          "label": "Conflict of Interest Declaration",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Confirmed",
              "value": "confirmed"
            },
            {
              "label": "Not Confirmed",
              "value": "not-confirmed"
            }
          ],
          "id": "Field_020"
        },
        {
          "type": "textarea",
          "key": "regulatoryEnforcementHistory",
          "label": "Regulatory Enforcement History",
          "id": "Field_021"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_022"
    },
    {
      "type": "group",
      "label": "Sub-contractors",
      "id": "Field_023",
      "components": [
        {
          "type": "radio",
          "key": "subContractorsInvolved",
          "label": "Sub-contractors Involved",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_024"
        },
        {
          "type": "textarea",
          "key": "subContractorList",
          "label": "Sub-contractor List",
          "id": "Field_025"
        },
        {
          "type": "textarea",
          "key": "fourthPartyRiskAssessment",
          "label": "Fourth-Party Risk Assessment",
          "id": "Field_026"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_027"
    },
    {
      "type": "group",
      "label": "Due Diligence Decision",
      "id": "Field_028",
      "components": [
        {
          "type": "select",
          "key": "dueDiligenceResult",
          "label": "Due Diligence Result",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Satisfactory",
              "value": "satisfactory"
            },
            {
              "label": "Conditional",
              "value": "conditional"
            },
            {
              "label": "Unsatisfactory",
              "value": "unsatisfactory"
            }
          ],
          "id": "Field_029"
        },
        {
          "type": "textarea",
          "key": "dueDiligenceNotes",
          "label": "Due Diligence Notes",
          "validate": {
            "required": true
          },
          "id": "Field_030"
        }
      ]
    }
  ],
  "type": "default"
}
