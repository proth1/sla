    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_1xhs1a0" sourceRef="Start_SoftwareNeed" targetRef="SP_RequestTriage" />
    <bpmn:sequenceFlow id="Flow_v5_2" sourceRef="SP_RequestTriage" targetRef="GW_TriageDecision" />
    <bpmn:sequenceFlow id="Flow_v5_4" name="No" sourceRef="GW_TriageDecision" targetRef="End_Rejected" />
    <bpmn:sequenceFlow id="Flow_v5_7" name="Build" sourceRef="GW_BuyVsBuild" targetRef="Event_1whn5yx" />
    <bpmn:sequenceFlow id="Flow_v5_12" name="Yes" sourceRef="GW_EvalApproved" targetRef="SP_ContractBuild">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_v5_5" sourceRef="SP_PlanningRouting" targetRef="GW_BuyVsBuild" />
    <bpmn:sequenceFlow id="Flow_v5_10" name="Yes" sourceRef="GW_VendorSelected" targetRef="Activity_0e5d208">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_v5_11" name="No" sourceRef="GW_EvalApproved" targetRef="End_EvalRejected" />
    <bpmn:sequenceFlow id="Flow_v5_9" name="No" sourceRef="GW_VendorSelected" targetRef="End_VendorNotSelected" />
    <bpmn:sequenceFlow id="Flow_v5_8" sourceRef="SP_EvalDD" targetRef="GW_VendorSelected" />
    <bpmn:sequenceFlow id="Flow_v5_6" name="Buy" sourceRef="GW_BuyVsBuild" targetRef="SP_EvalDD">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:startEvent id="Start_SoftwareNeed" name="Software Need Identified">
      <bpmn:outgoing>Flow_1xhs1a0</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:subProcess id="SP_PlanningRouting" name="Review, Refine and Prioritize">
      <bpmn:incoming>Flow_1iblw95</bpmn:incoming>
      <bpmn:outgoing>Flow_v5_5</bpmn:outgoing>
      <bpmn:startEvent id="SP2_Start">
        <bpmn:outgoing>Flow_SP2_1</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:userTask id="Task_PrelimAnalysis" name="Preliminary&#10;Analysis">
        <bpmn:documentation>Conduct preliminary analysis of the approved request to assess scope, complexity, estimated effort, and determine whether backlog prioritization is needed. Analyze business requirements against available solutions, estimate total cost of ownership, and identify key risk factors. This analysis feeds the pathway routing decision (Buy vs. Build) and determines whether the request needs further assessment through backlog prioritization.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp2-preliminary-analysis" />
          <zeebe:assignmentDefinition candidateGroups="governance-lane" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Prioritization, Funding, Privacy" />
            <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 30: Pre-engagement planning — document the preliminary assessment of the vendor/software relationship complexity, data sensitivity, and operational criticality to inform the depth of subsequent due diligence. (2) NIST CSF 2.0 ID.RA (Risk Assessment): Conduct initial risk identification including data classification, integration complexity, and business continuity impact to feed into the risk tier classification downstream. (3) GDPR Article 35: If personal data processing is involved, confirm whether a full DPIA is required based on the data types, volume, and processing purposes identified. EVIDENCE COLLECTION: (a) Preliminary analysis report with scope assessment, complexity rating, and effort estimate. (b) Total cost of ownership (TCO) preliminary estimate (3-year and 5-year projections). (c) Risk factor identification matrix (data sensitivity, integration complexity, vendor dependency, regulatory exposure). (d) Build vs. buy preliminary recommendation with supporting rationale. (e) Backlog prioritization recommendation (if further assessment needed). DATA POINTS: Scope complexity rating (low/medium/high), estimated TCO range, risk factors identified (count and severity), data classification level, DPIA required (yes/no), build vs. buy preliminary leaning, backlog priority score, estimated timeline to deployment, number of integrations required, user population size." />
            <zeebe:property name="raci_r" value="Governance" />
            <zeebe:property name="raci_a" value="Governance" />
            <zeebe:property name="raci_c" value="Finance, Privacy" />
            <zeebe:property name="raci_i" value="Business" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP2_1</bpmn:incoming>
        <bpmn:outgoing>Flow_SP2_2</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:exclusiveGateway id="GW_NeedsAssessment" name="Needs further&#10;assessment?" default="Flow_SP2_No">
        <bpmn:incoming>Flow_SP2_2</bpmn:incoming>
        <bpmn:outgoing>Flow_SP2_Yes</bpmn:outgoing>
        <bpmn:outgoing>Flow_SP2_No</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:userTask id="Task_Backlog" name="Backlog&#10;Prioritization">
        <bpmn:documentation>Prioritize the request within the software onboarding backlog based on strategic value, urgency, resource availability, risk profile, and organizational capacity. Rank against competing requests using a weighted scoring model. Determine the scheduling window for when the request can proceed through the full evaluation process. Communicate priority and timeline expectations to the requesting business unit.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp2-backlog-prioritization" />
          <zeebe:assignmentDefinition candidateGroups="governance-lane" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Prioritization" />
            <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 25: Governance oversight — backlog prioritization must be transparent, documented, and follow a consistent methodology to ensure regulatory-critical requests (e.g., compliance remediation software) are not deprioritized without documented justification. (2) NIST CSF 2.0 GV.OC-04: Governance processes must ensure that risk-critical technology needs are addressed within acceptable timeframes. (3) SOX Section 404: Prioritization decisions affecting financial systems or controls must be documented with delegated authority sign-off. EVIDENCE COLLECTION: (a) Backlog prioritization scorecard with weighted criteria and scores. (b) Prioritized backlog list showing position relative to other requests. (c) Scheduling window assignment with estimated start and completion dates. (d) Communication to requesting business unit confirming priority and timeline. (e) Escalation documentation if the request was expedited due to regulatory or compliance urgency. DATA POINTS: Priority score (weighted composite), backlog position (rank), strategic value score, urgency rating, resource availability status, estimated scheduling window (start/end), competing requests assessed against, escalation flag (yes/no), stakeholder notification date." />
            <zeebe:property name="raci_r" value="Governance" />
            <zeebe:property name="raci_a" value="Governance" />
            <zeebe:property name="raci_c" value="Business" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP2_Yes</bpmn:incoming>
        <bpmn:outgoing>Flow_SP2_3</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:exclusiveGateway id="GW_MergeBacklog">
        <bpmn:incoming>Flow_SP2_No</bpmn:incoming>
        <bpmn:incoming>Flow_SP2_3</bpmn:incoming>
        <bpmn:outgoing>Flow_SP2_4</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:businessRuleTask id="Task_PathwayRouting" name="Pathway&#10;Routing">
        <bpmn:extensionElements>
          <zeebe:calledDecision decisionId="OB_DMN_PathwayRouting" resultVariable="selectedPathway" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Prioritization" />
            <zeebe:property name="raci_r" value="Governance" />
            <zeebe:property name="raci_a" value="Governance" />
            <zeebe:property name="raci_c" value="Business, Technical Assessment" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0nk2zjj</bpmn:incoming>
        <bpmn:outgoing>Flow_SP2_5</bpmn:outgoing>
      </bpmn:businessRuleTask>
      <bpmn:businessRuleTask id="Task_PrioritizationScoring" name="Prioritization&#10;Scoring">
        <bpmn:extensionElements>
          <zeebe:calledDecision decisionId="OB_DMN_PrioritizationScoring" resultVariable="priorityTier" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Prioritization" />
            <zeebe:property name="raci_r" value="Governance" />
            <zeebe:property name="raci_a" value="Governance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0pafab1</bpmn:incoming>
        <bpmn:outgoing>Flow_SP2_6</bpmn:outgoing>
      </bpmn:businessRuleTask>
      <bpmn:serviceTask id="SendTask_SP2Complete" name="SP2&#10;Notification">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="status-notification" />
          <zeebe:properties>
            <zeebe:property name="phase" value="SP2_Complete" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP2_5</bpmn:incoming>
        <bpmn:outgoing>Flow_SP2_Notify</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:sequenceFlow id="Flow_SP2_Notify" sourceRef="SendTask_SP2Complete" targetRef="SP2_End" />
      <bpmn:endEvent id="SP2_End">
        <bpmn:incoming>Flow_SP2_Notify</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_SP2_1" sourceRef="SP2_Start" targetRef="Task_PrelimAnalysis" />
      <bpmn:sequenceFlow id="Flow_SP2_2" sourceRef="Task_PrelimAnalysis" targetRef="GW_NeedsAssessment" />
      <bpmn:sequenceFlow id="Flow_SP2_Yes" name="Yes" sourceRef="GW_NeedsAssessment" targetRef="Task_Backlog">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=true</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_SP2_No" name="No" sourceRef="GW_NeedsAssessment" targetRef="GW_MergeBacklog" />
      <bpmn:sequenceFlow id="Flow_SP2_3" sourceRef="Task_Backlog" targetRef="GW_MergeBacklog" />
      <bpmn:sequenceFlow id="Flow_SP2_4" sourceRef="GW_MergeBacklog" targetRef="Activity_0r9imfk" />
      <bpmn:sequenceFlow id="Flow_SP2_6" sourceRef="Task_PrioritizationScoring" targetRef="Activity_1tnmqe5" />
      <bpmn:sequenceFlow id="Flow_SP2_5" sourceRef="Task_PathwayRouting" targetRef="SendTask_SP2Complete" />
      <bpmn:task id="Activity_0r9imfk" name="Buy vs Build">
        <bpmn:incoming>Flow_SP2_4</bpmn:incoming>
        <bpmn:outgoing>Flow_0pafab1</bpmn:outgoing>
      </bpmn:task>
      <bpmn:sequenceFlow id="Flow_0pafab1" sourceRef="Activity_0r9imfk" targetRef="Task_PrioritizationScoring" />
      <bpmn:task id="Activity_1tnmqe5" name="Prioritization Committee">
        <bpmn:incoming>Flow_SP2_6</bpmn:incoming>
        <bpmn:outgoing>Flow_0nk2zjj</bpmn:outgoing>
      </bpmn:task>
      <bpmn:sequenceFlow id="Flow_0nk2zjj" sourceRef="Activity_1tnmqe5" targetRef="Task_PathwayRouting" />
      <bpmn:task id="Activity_0dk0nar" name="Identify Required Domain SMEs" />
      <bpmn:textAnnotation id="TextAnnotation_05ffzwo">
        <bpmn:text>Forced Update</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1qj2zph" associationDirection="None" sourceRef="SP2_Start" targetRef="TextAnnotation_05ffzwo" />
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_1iblw95" sourceRef="GW_TriageDecision" targetRef="SP_PlanningRouting" />
    <bpmn:sequenceFlow id="Flow_v5_14" sourceRef="SP_UATGoLive" targetRef="GW_FinalDecision" />
    <bpmn:sequenceFlow id="Flow_v5_15" name="Yes" sourceRef="GW_FinalDecision" targetRef="End_SoftwareOnboarded">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_v5_16" name="No" sourceRef="GW_FinalDecision" targetRef="End_FinalRejected" />
    <bpmn:sequenceFlow id="Flow_v5_13" sourceRef="SP_ContractBuild" targetRef="SP_UATGoLive" />
    <bpmn:endEvent id="End_VendorNotSelected" name="Vendor&#10;Not Selected">
      <bpmn:incoming>Flow_v5_9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_VendorSelected" name="Vendor&#10;Selected?" default="Flow_v5_9">
      <bpmn:incoming>Flow_v5_8</bpmn:incoming>
      <bpmn:outgoing>Flow_v5_9</bpmn:outgoing>
      <bpmn:outgoing>Flow_v5_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_BuyVsBuild" name="Buy vs Build ?" default="Flow_v5_7">
      <bpmn:incoming>Flow_v5_5</bpmn:incoming>
      <bpmn:outgoing>Flow_v5_6</bpmn:outgoing>
      <bpmn:outgoing>Flow_v5_7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:subProcess id="SP_EvalDD" name="Vendor&#10;Evaluation">
      <bpmn:incoming>Flow_v5_6</bpmn:incoming>
      <bpmn:outgoing>Flow_v5_8</bpmn:outgoing>
      <bpmn:startEvent id="SP3_Start">
        <bpmn:outgoing>Flow_SP3_1</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="Task_DARTFormation" name="DART Team&#10;Formation">
        <bpmn:documentation>Automatically form a cross-functional Due diligence, Assessment, Review, and Testing (DART) team based on the request characteristics, risk tier, and data classification. The DART team composition is determined by the request type and includes representatives from Technical Architecture, Security, Compliance, Finance, and Procurement as needed.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="dart-formation" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Governance" />
            <zeebe:property name="raci_r" value="Automation" />
            <zeebe:property name="raci_a" value="Governance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1pt1t6r</bpmn:incoming>
        <bpmn:outgoing>Flow_SP3_DART</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:sequenceFlow id="Flow_SP3_DART" sourceRef="Task_DARTFormation" targetRef="GW_ParallelSplit" />
      <bpmn:inclusiveGateway id="GW_ParallelSplit">
        <bpmn:incoming>Flow_SP3_DART</bpmn:incoming>
        <bpmn:outgoing>Flow_SP3_P1</bpmn:outgoing>
        <bpmn:outgoing>Flow_SP3_P2</bpmn:outgoing>
        <bpmn:outgoing>Flow_SP3_P4</bpmn:outgoing>
        <bpmn:outgoing>Flow_SP3_P5</bpmn:outgoing>
        <bpmn:outgoing>Flow_0vzcnuh</bpmn:outgoing>
        <bpmn:outgoing>Flow_SP3_P6</bpmn:outgoing>
        <bpmn:outgoing>Flow_1p8m38v</bpmn:outgoing>
        <bpmn:outgoing>Flow_103u6cl</bpmn:outgoing>
        <bpmn:outgoing>Flow_0tgi2ai</bpmn:outgoing>
      </bpmn:inclusiveGateway>
      <bpmn:userTask id="Task_TechArchReview" name="Technical&#10;Architecture Review">
        <bpmn:documentation>Evaluate the proposed solution's technical architecture for scalability, reliability, maintainability, integration compatibility, and alignment with enterprise architecture standards. Assess API design, data flow architecture, infrastructure requirements, technology stack maturity, and technical debt risk. Verify the solution can integrate with existing enterprise systems without introducing architectural anti-patterns.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp3-tech-arch-review" />
          <zeebe:assignmentDefinition candidateGroups="technical-assessment" />
          <zeebe:properties>
            <zeebe:property name="topics" value="EA, Cyber" />
            <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) NIST CSF 2.0 PR.PS (Platform Security): Evaluate platform hardening, secure configuration baselines, and change management controls in the proposed architecture. (2) DORA Article 9: ICT system resilience — assess high availability design, failover mechanisms, disaster recovery architecture, and recovery time/point objectives. (3) OCC 2023-17 Section 50: Technology risk assessment — evaluate whether the vendor&#39;s architecture introduces systemic risk through single points of failure, deprecated technologies, or unsupported platforms. EVIDENCE COLLECTION: (a) Architecture review assessment report with findings and recommendations. (b) Integration compatibility matrix against enterprise systems. (c) Scalability assessment with projected capacity requirements. (d) Technology stack maturity evaluation (vendor support lifecycle, community health). (e) Architecture diagram review with annotated risk areas. DATA POINTS: Architecture pattern (microservices/monolith/hybrid), API standards compliance, integration points count, scalability ceiling estimate, technology stack age and support status, single points of failure identified, DR architecture rating, enterprise standards compliance score." />
            <zeebe:property name="raci_r" value="Technical Assessment" />
            <zeebe:property name="raci_a" value="Technical Assessment" />
            <zeebe:property name="raci_c" value="Governance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP3_P1</bpmn:incoming>
        <bpmn:outgoing>Flow_0ocj7ql</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:sequenceFlow id="Flow_SP3_P1" sourceRef="GW_ParallelSplit" targetRef="Task_TechArchReview" />
      <bpmn:userTask id="Task_SecurityAssessment" name="Security&#10;Assessment">
        <bpmn:documentation>Conduct a comprehensive security assessment of the proposed solution covering vulnerability posture, threat modeling, access control design, encryption standards, network security, application security, and incident response readiness. For Buy pathway, evaluate vendor security controls; for Build pathway, evaluate the security architecture of the proposed design. Identify security risks and required mitigations before proceeding.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp3-security-assessment" />
          <zeebe:assignmentDefinition candidateGroups="technical-assessment" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Cyber" />
            <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Sections 50-55: Information security assessment — evaluate access controls, data encryption (at rest and in transit), vulnerability management, patch management cadence, and security monitoring capabilities. (2) NIST CSF 2.0: PR.AA (Access Control), PR.DS (Data Security), DE.CM (Continuous Monitoring), DE.AE (Adverse Event Analysis) — structured assessment across all NIST security domains. (3) ISO 27001 Annex A: Map assessment findings to relevant Annex A controls — A.8 Asset Management, A.9 Access Control, A.10 Cryptography, A.12 Operations Security, A.14 System Acquisition. (4) DORA Articles 9-11: ICT security requirements — assess digital operational resilience, ICT-related incident management, and testing capabilities. EVIDENCE COLLECTION: (a) Security assessment report with risk-rated findings (critical/high/medium/low). (b) Threat model document identifying attack vectors and mitigations. (c) Vulnerability scan results or vendor-provided scan summary. (d) Encryption standards verification (algorithms, key lengths, key management). (e) Access control architecture review (RBAC/ABAC design, MFA, privileged access). (f) Security risk register entries for identified risks with mitigations and owners. DATA POINTS: Total findings by severity, open critical/high findings count, encryption standard compliance, MFA coverage, vulnerability scan score, penetration test date (if available), security certifications verified, mean time to patch for critical vulnerabilities, security monitoring coverage percentage." />
            <zeebe:property name="raci_r" value="Technical Assessment" />
            <zeebe:property name="raci_a" value="Technical Assessment" />
            <zeebe:property name="raci_c" value="Compliance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP3_P2</bpmn:incoming>
        <bpmn:outgoing>Flow_SP3_P2J</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:userTask id="Task_RiskCompliance" name="Legal Review">
        <bpmn:documentation>Evaluate legal risks and contract terms. Assess IP ownership, liability and indemnification provisions, DPA adequacy, licensing terms, and regulatory compliance of contractual obligations. Review data processing agreements for GDPR Article 28 compliance. Covers sourcing legal and contract review committee functions.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp3-legal-review" />
          <zeebe:assignmentDefinition candidateGroups="contracting-lane" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Legal, Contracting" />
            <zeebe:property name="raci_r" value="Contracting" />
            <zeebe:property name="raci_a" value="Contracting" />
            <zeebe:property name="raci_c" value="Governance, Compliance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0vzcnuh</bpmn:incoming>
        <bpmn:outgoing>Flow_16tnf77</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:userTask id="Task_FinancialAnalysis" name="Financial&#10;Analysis">
        <bpmn:documentation>Perform comprehensive financial analysis including total cost of ownership (TCO), return on investment (ROI), net present value (NPV), and payback period calculations. Evaluate licensing models, implementation costs, ongoing maintenance fees, infrastructure costs, training expenses, and exit costs. Compare against budget authorization and organizational spending thresholds. For Buy pathway, analyze vendor pricing competitiveness; for Build pathway, estimate development and maintenance costs.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp3-financial-analysis" />
          <zeebe:assignmentDefinition candidateGroups="finance-lane" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Funding, Sourcing" />
            <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) SOX Sections 302, 404: Financial analysis must follow the organization&#39;s capital expenditure and operating expenditure classification rules. All cost estimates must be verifiable and align with the delegated authority matrix. Cost projections affecting financial statements require controller sign-off. (2) OCC 2023-17 Section 40: Contract cost reasonableness — financial analysis must demonstrate the proposed pricing is reasonable relative to market benchmarks and the services provided. Exit cost analysis required to avoid vendor lock-in. (3) NIST CSF 2.0 GV.OC-03: Financial resource allocation must be aligned with the organization&#39;s cybersecurity and risk management strategy — ensure adequate budget for security controls. EVIDENCE COLLECTION: (a) TCO analysis (3-year and 5-year projections) with itemized cost categories. (b) ROI calculation with assumptions documented. (c) NPV and payback period analysis. (d) Budget authorization verification against delegated authority matrix. (e) Market pricing benchmark comparison (for Buy pathway). (f) Build vs. Buy cost comparison (if both pathways were evaluated). (g) Exit cost analysis including data migration, transition, and decommissioning costs. DATA POINTS: Total 3-year TCO, total 5-year TCO, annual recurring cost, one-time implementation cost, ROI percentage, payback period (months), NPV at organizational discount rate, licensing model type, exit cost estimate, budget variance (over/under authorized amount), cost per user, cost per transaction (if applicable)." />
            <zeebe:property name="raci_r" value="Finance" />
            <zeebe:property name="raci_a" value="Finance" />
            <zeebe:property name="raci_c" value="Governance, Procurement" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP3_P4</bpmn:incoming>
        <bpmn:outgoing>Flow_SP3_P4J</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:userTask id="Task_AssessVendorLandscape" name="Assess Vendor&#10;Landscape">
        <bpmn:documentation>Conduct a comprehensive assessment of the vendor landscape for the Buy pathway. Identify potential vendors through market research, analyst reports, peer benchmarking, and the organization's approved vendor registry. Evaluate vendor capabilities against requirements, assess market positioning, and develop a shortlist of qualified vendors to invite for formal proposal. Consider concentration risk with existing vendor portfolio.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp3-assess-vendor-landscape" />
          <zeebe:assignmentDefinition candidateGroups="procurement-lane" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Sourcing, TPRM" />
            <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 35: Vendor selection process — the landscape assessment must demonstrate a fair, documented evaluation of multiple vendors to avoid sole-source engagements without justification. Concentration risk analysis required against existing vendor portfolio. (2) NIST CSF 2.0 GV.SC-04: Supply chain risk assessment — evaluate vendor market stability, financial health, and geographic concentration. (3) DORA Article 28: ICT third-party concentration risk — assess whether shortlisted vendors would create or exacerbate concentration of critical ICT services with a single provider or within a single jurisdiction. EVIDENCE COLLECTION: (a) Market research report identifying candidate vendors (minimum 3 for competitive evaluation unless sole-source justified). (b) Vendor capability comparison matrix against requirements. (c) Concentration risk analysis against existing vendor portfolio. (d) Shortlist recommendation with selection rationale. (e) Sole-source justification document (if fewer than 3 candidates). (f) Analyst report references (Gartner, Forrester, etc. if used). DATA POINTS: Number of vendors identified, number shortlisted, selection criteria and weights, concentration risk assessment result, vendor market positions (leader/challenger/niche), geographic distribution of candidates, existing relationships with any candidates, estimated competitive savings opportunity." />
            <zeebe:property name="raci_r" value="Procurement" />
            <zeebe:property name="raci_a" value="Procurement" />
            <zeebe:property name="raci_c" value="Governance" />
            <zeebe:property name="raci_i" value="Oversight" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP3_P5</bpmn:incoming>
        <bpmn:outgoing>Flow_SP3_P5J</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:inclusiveGateway id="GW_ParallelJoin">
        <bpmn:incoming>Flow_SP3_P2J_Merged</bpmn:incoming>
        <bpmn:incoming>Flow_SP3_P4J</bpmn:incoming>
        <bpmn:incoming>Flow_SP3_P5J</bpmn:incoming>
        <bpmn:incoming>Flow_16tnf77</bpmn:incoming>
        <bpmn:incoming>Flow_SP3_P6J</bpmn:incoming>
        <bpmn:incoming>Flow_1qwbs9m</bpmn:incoming>
        <bpmn:incoming>Flow_1ihc8jh</bpmn:incoming>
        <bpmn:incoming>Flow_0ocj7ql</bpmn:incoming>
        <bpmn:incoming>Flow_1xapt70</bpmn:incoming>
        <bpmn:outgoing>Flow_1hkxuti</bpmn:outgoing>
      </bpmn:inclusiveGateway>
      <bpmn:userTask id="Task_AIGovernanceReview" name="AI Governance&#10;Review">
        <bpmn:documentation>Evaluate AI/ML components within the proposed software for model risk, bias, explainability, and regulatory compliance. Applicable when the software incorporates AI/ML models, automated decision-making, or generative AI capabilities. Assess against SR 11-7 (model risk management), EU AI Act risk classification, and the organization's AI governance framework.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp3-ai-governance-review" />
          <zeebe:assignmentDefinition candidateGroups="ai-review" />
          <zeebe:properties>
            <zeebe:property name="topics" value="AI Governance" />
            <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) SR 11-7: Model risk management — if the software uses AI/ML models for decision-making, each model must be inventoried, validated, and subject to ongoing monitoring. (2) EU AI Act: AI system risk classification — determine if the AI system is high-risk (Annex III), limited-risk, or minimal-risk. (3) NIST AI RMF: MAP, MEASURE, MANAGE functions — assess AI risks including bias, fairness, transparency, explainability, privacy, and security. (4) OCC 2023-17: Third-party AI — evaluate the vendor AI governance practices and model documentation. EVIDENCE COLLECTION: (a) AI component inventory. (b) EU AI Act risk classification. (c) SR 11-7 model risk assessment. (d) Bias and fairness assessment. (e) Explainability evaluation. (f) AI-specific data protection assessment. (g) Human oversight design documentation. DATA POINTS: AI components count, EU AI Act risk tier, model types, training data sources, bias metrics, explainability method, human override capability, model validation status, monitoring plan." />
            <zeebe:property name="raci_r" value="AI Review" />
            <zeebe:property name="raci_a" value="AI Review" />
            <zeebe:property name="raci_c" value="Technical Assessment, Compliance" />
            <zeebe:property name="raci_i" value="Governance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP3_P6</bpmn:incoming>
        <bpmn:outgoing>Flow_SP3_P6J</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:serviceTask id="SendTask_SP3Complete" name="SP3&#10;Notification">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="status-notification" />
          <zeebe:properties>
            <zeebe:property name="phase" value="SP3_Complete" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1hkxuti</bpmn:incoming>
        <bpmn:outgoing>Flow_SP3_Notify</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:sequenceFlow id="Flow_SP3_Notify" sourceRef="SendTask_SP3Complete" targetRef="SP3_End" />
      <bpmn:endEvent id="SP3_End">
        <bpmn:incoming>Flow_SP3_Notify</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_SP3_1" sourceRef="SP3_Start" targetRef="Gateway_0q8jc1p" />
      <bpmn:sequenceFlow id="Flow_SP3_P2" sourceRef="GW_ParallelSplit" targetRef="Task_SecurityAssessmentRouting">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=securityRequired = true</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:businessRuleTask id="Task_SecurityAssessmentRouting" name="Security Assessment&#10;Routing">
        <bpmn:extensionElements>
          <zeebe:calledDecision decisionId="OB_DMN_SecurityAssessmentRouting" resultVariable="securityAssessmentLevel" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Cyber" />
            <zeebe:property name="raci_r" value="Automation" />
            <zeebe:property name="raci_a" value="Technical Assessment" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP3_P2</bpmn:incoming>
        <bpmn:outgoing>Flow_SP3_SAR1</bpmn:outgoing>
      </bpmn:businessRuleTask>
      <bpmn:exclusiveGateway id="GW_SecurityLevel" name="Security&#10;Level?">
        <bpmn:incoming>Flow_SP3_SAR1</bpmn:incoming>
        <bpmn:outgoing>Flow_SP3_SAR_Baseline</bpmn:outgoing>
        <bpmn:outgoing>Flow_SP3_SAR_Elevated</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:serviceTask id="Task_BaselineSecurityCheck" name="Baseline Security&#10;Check">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="baseline-security-check" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Cyber" />
            <zeebe:property name="raci_r" value="Automation" />
            <zeebe:property name="raci_a" value="Technical Assessment" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP3_SAR_Baseline</bpmn:incoming>
        <bpmn:outgoing>Flow_SP3_SAR_BaselineJoin</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:exclusiveGateway id="GW_MergeSecurityAssessment">
        <bpmn:incoming>Flow_SP3_SAR_BaselineJoin</bpmn:incoming>
        <bpmn:incoming>Flow_SP3_P2J</bpmn:incoming>
        <bpmn:outgoing>Flow_SP3_P2J_Merged</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:sequenceFlow id="Flow_SP3_SAR1" sourceRef="Task_SecurityAssessmentRouting" targetRef="GW_SecurityLevel" />
      <bpmn:sequenceFlow id="Flow_SP3_SAR_Baseline" name="Baseline" sourceRef="GW_SecurityLevel" targetRef="Task_BaselineSecurityCheck">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=securityAssessmentLevel = "Baseline"</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_SP3_SAR_Elevated" name="Elevated/Major" sourceRef="GW_SecurityLevel" targetRef="Task_SecurityAssessment">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=securityAssessmentLevel != "Baseline"</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_SP3_SAR_BaselineJoin" sourceRef="Task_BaselineSecurityCheck" targetRef="GW_MergeSecurityAssessment" />
      <bpmn:sequenceFlow id="Flow_SP3_P4" sourceRef="GW_ParallelSplit" targetRef="Task_FinancialAnalysis">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=financialRequired = true</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_SP3_P5" sourceRef="GW_ParallelSplit" targetRef="Task_AssessVendorLandscape">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=vendorLandscapeRequired = true</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_SP3_P2J" sourceRef="Task_SecurityAssessment" targetRef="GW_MergeSecurityAssessment" />
      <bpmn:sequenceFlow id="Flow_SP3_P2J_Merged" sourceRef="GW_MergeSecurityAssessment" targetRef="GW_ParallelJoin" />
      <bpmn:sequenceFlow id="Flow_SP3_P4J" sourceRef="Task_FinancialAnalysis" targetRef="GW_ParallelJoin" />
      <bpmn:sequenceFlow id="Flow_SP3_P5J" sourceRef="Task_AssessVendorLandscape" targetRef="GW_ParallelJoin" />
      <bpmn:sequenceFlow id="Flow_16tnf77" sourceRef="Task_RiskCompliance" targetRef="GW_ParallelJoin" />
      <bpmn:sequenceFlow id="Flow_0vzcnuh" sourceRef="GW_ParallelSplit" targetRef="Task_RiskCompliance">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=legalRequired = true</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_SP3_P6" sourceRef="GW_ParallelSplit" targetRef="Task_AIGovernanceReview">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=aiGovernanceRequired = true</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_SP3_P6J" sourceRef="Task_AIGovernanceReview" targetRef="GW_ParallelJoin" />
      <bpmn:exclusiveGateway id="Gateway_0q8jc1p" name="Is Vendor Sourcing Required ?">
        <bpmn:incoming>Flow_SP3_1</bpmn:incoming>
        <bpmn:outgoing>Flow_1ytvmuz</bpmn:outgoing>
        <bpmn:outgoing>Flow_1efkip5</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:sequenceFlow id="Flow_1ytvmuz" name="Yes" sourceRef="Gateway_0q8jc1p" targetRef="Activity_0tfteab" />
      <bpmn:sequenceFlow id="Flow_0iyjhfz" sourceRef="Activity_0tfteab" targetRef="Gateway_1clkme8" />
      <bpmn:exclusiveGateway id="Gateway_1clkme8">
        <bpmn:incoming>Flow_0iyjhfz</bpmn:incoming>
        <bpmn:incoming>Flow_1efkip5</bpmn:incoming>
        <bpmn:outgoing>Flow_1pt1t6r</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:sequenceFlow id="Flow_1pt1t6r" sourceRef="Gateway_1clkme8" targetRef="Task_DARTFormation" />
      <bpmn:sequenceFlow id="Flow_1efkip5" name="No" sourceRef="Gateway_0q8jc1p" targetRef="Gateway_1clkme8" />
      <bpmn:subProcess id="Activity_0tfteab" name="Vendor Sourcing">
        <bpmn:incoming>Flow_1ytvmuz</bpmn:incoming>
        <bpmn:outgoing>Flow_0iyjhfz</bpmn:outgoing>
        <bpmn:userTask id="Activity_1htxinq" name="Vendor Due&#10;Diligence">
          <bpmn:documentation>Conduct formal vendor due diligence on the preferred vendor(s). This is a deep-dive investigation covering financial stability, operational resilience, legal standing, regulatory compliance history, security posture, business continuity capabilities, and fourth-party (sub-contractor) risk. Due diligence depth is calibrated to the vendor's risk tier. This task triggers the message flow to the Vendor pool for engagement initiation.</bpmn:documentation>
          <bpmn:extensionElements>
            <zeebe:formDefinition formId="sp3-vendor-due-diligence" />
            <zeebe:assignmentDefinition candidateGroups="procurement-lane" />
            <zeebe:properties>
              <zeebe:property name="topics" value="Sourcing, TPRM, Compliance" />
              <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Sections 35-55: Comprehensive due diligence requirements — financial condition assessment, business experience evaluation, legal and regulatory compliance verification, information security program review, operational resilience assessment, incident management capability review, and business continuity/disaster recovery evaluation. Due diligence depth must be commensurate with the risk and complexity of the relationship. (2) NIST CSF 2.0 GV.SC-06: Due diligence on supply chain partners — validate vendor risk management practices, security controls, and ability to meet contractual obligations. (3) DORA Article 28: ICT third-party risk assessment — evaluate the vendor&#39;s ability to meet digital operational resilience requirements, including incident reporting, testing, and exit planning. (4) GDPR Article 28: Verify the vendor&#39;s ability to comply with data processor obligations, including technical and organizational measures, sub-processor management, and data subject rights support. EVIDENCE COLLECTION: (a) Due diligence report covering all OCC 2023-17 assessment dimensions. (b) Financial stability analysis (credit reports, audited financials, going-concern assessment). (c) Legal standing verification (litigation history, regulatory actions, sanctions screening). (d) Business continuity and disaster recovery plan review results. (e) Fourth-party (sub-contractor) risk assessment. (f) Regulatory compliance history check. (g) On-site or virtual assessment results (if conducted). DATA POINTS: Due diligence scope (dimensions assessed), risk tier confirmed, financial stability rating, litigation/regulatory action history, BCP/DR test results and dates, sub-contractor count and risk assessment, overall due diligence rating (pass/conditional/fail), conditions for proceeding (if any), due diligence completion date." />
              <zeebe:property name="raci_r" value="Procurement" />
              <zeebe:property name="raci_a" value="Governance" />
              <zeebe:property name="raci_c" value="Compliance" />
              <zeebe:property name="raci_i" value="Oversight" />
            </zeebe:properties>
          </bpmn:extensionElements>
          <bpmn:incoming>Flow_00w7oa8</bpmn:incoming>
          <bpmn:outgoing>Flow_12ui09a</bpmn:outgoing>
        </bpmn:userTask>
        <bpmn:receiveTask id="Activity_1n7gpyq" name="Await Vendor&#10;Response" messageRef="Message_VendorResponse">
          <bpmn:extensionElements>
            <zeebe:properties>
              <zeebe:property name="topics" value="Sourcing" />
              <zeebe:property name="raci_r" value="Procurement" />
              <zeebe:property name="raci_a" value="Procurement" />
            </zeebe:properties>
          </bpmn:extensionElements>
          <bpmn:incoming>Flow_12ui09a</bpmn:incoming>
          <bpmn:outgoing>Flow_0nt7i0q</bpmn:outgoing>
        </bpmn:receiveTask>
        <bpmn:endEvent id="Event_06h5sf7" name="Vendor Response&#10;SLA Breach">
          <bpmn:incoming>Flow_178mpsf</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:userTask id="Activity_0wxhc15" name="Evaluate Vendor&#10;Response">
          <bpmn:documentation>Consolidate and evaluate vendor proposal responses against the parallel evaluation results (Technical Architecture, Security, Risk and Compliance, Financial). Score vendor proposals using a weighted evaluation matrix. Identify the preferred vendor or top-ranked candidates. Document evaluation rationale, strengths, weaknesses, and conditions for selection. This is the decision point for vendor shortlisting before due diligence.</bpmn:documentation>
          <bpmn:extensionElements>
            <zeebe:formDefinition formId="sp3-evaluate-vendor-response" />
            <zeebe:assignmentDefinition candidateGroups="procurement-lane" />
            <zeebe:properties>
              <zeebe:property name="topics" value="Sourcing, TPRM" />
              <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 40: Vendor selection must be based on documented, objective criteria applied consistently across all evaluated vendors. The evaluation must demonstrate that risk factors were weighted appropriately and that the selection was not based solely on cost. (2) NIST CSF 2.0 GV.SC-05: Supply chain risk evaluation — consolidated risk assessment across all evaluation dimensions must inform the selection decision. (3) SOX Section 404: Evaluation scoring methodology and results must be documented and retained for audit purposes. Conflicts of interest must be declared by all evaluators. EVIDENCE COLLECTION: (a) Consolidated evaluation scorecard with weighted scores across all dimensions (technical, security, compliance, financial). (b) Evaluator conflict-of-interest declarations. (c) Vendor ranking report with selection rationale. (d) Strengths/weaknesses/conditions matrix for each evaluated vendor. (e) Selection recommendation memo to governance committee. DATA POINTS: Number of vendors evaluated, weighted scores per vendor per dimension, overall ranking, preferred vendor recommendation, key differentiators identified, conditions or caveats noted, evaluator panel composition, evaluation completion date." />
              <zeebe:property name="raci_r" value="Procurement" />
              <zeebe:property name="raci_a" value="Governance" />
              <zeebe:property name="raci_c" value="Technical Assessment" />
            </zeebe:properties>
          </bpmn:extensionElements>
          <bpmn:incoming>Flow_0nt7i0q</bpmn:incoming>
          <bpmn:outgoing>Flow_13ig77g</bpmn:outgoing>
        </bpmn:userTask>
        <bpmn:boundaryEvent id="Event_00pl334" name="5 Day&#10;SLA" cancelActivity="false" attachedToRef="Activity_1n7gpyq">
          <bpmn:outgoing>Flow_178mpsf</bpmn:outgoing>
          <bpmn:timerEventDefinition id="TimerEventDefinition_0nqxlhv">
            <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P5D</bpmn:timeDuration>
          </bpmn:timerEventDefinition>
        </bpmn:boundaryEvent>
        <bpmn:sequenceFlow id="Flow_12ui09a" sourceRef="Activity_1htxinq" targetRef="Activity_1n7gpyq" />
        <bpmn:sequenceFlow id="Flow_0nt7i0q" sourceRef="Activity_1n7gpyq" targetRef="Activity_0wxhc15" />
        <bpmn:sequenceFlow id="Flow_178mpsf" sourceRef="Event_00pl334" targetRef="Event_06h5sf7" />
        <bpmn:startEvent id="Event_106n0tc">
          <bpmn:outgoing>Flow_00w7oa8</bpmn:outgoing>
        </bpmn:startEvent>
        <bpmn:sequenceFlow id="Flow_00w7oa8" sourceRef="Event_106n0tc" targetRef="Activity_1htxinq" />
        <bpmn:endEvent id="Event_0zthk1s">
          <bpmn:incoming>Flow_13ig77g</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:sequenceFlow id="Flow_13ig77g" sourceRef="Activity_0wxhc15" targetRef="Event_0zthk1s" />
      </bpmn:subProcess>
      <bpmn:sequenceFlow id="Flow_1hkxuti" sourceRef="GW_ParallelJoin" targetRef="SendTask_SP3Complete" />
      <bpmn:userTask id="Activity_0kq8o8j" name="Risk Assessment">
        <bpmn:documentation>Evaluate third-party and operational risks associated with the proposed solution. Conduct risk tier classification, risk register analysis, concentration risk assessment, and risk appetite alignment. Covers TPRM committee and RAE committee functions. Assess vendor risk posture, regulatory examination readiness, and willingness to provide audit access.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp3-risk-assessment" />
          <zeebe:assignmentDefinition candidateGroups="governance-lane" />
          <zeebe:properties>
            <zeebe:property name="topics" value="TPRM, Risk" />
            <zeebe:property name="raci_r" value="Governance" />
            <zeebe:property name="raci_a" value="Governance" />
            <zeebe:property name="raci_c" value="Compliance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1p8m38v</bpmn:incoming>
        <bpmn:outgoing>Flow_1ihc8jh</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:userTask id="Activity_0ksoea5" name="Compliance Review">
        <bpmn:documentation>Evaluate regulatory and compliance risks associated with the proposed solution. Assess financial controls adequacy (SOX), operational resilience requirements (DORA), and regulatory framework alignment. Conduct compliance gap analysis and identify required remediation actions. Determine applicable regulatory frameworks based on data types, geographic scope, and industry requirements.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp3-compliance-review" />
          <zeebe:assignmentDefinition candidateGroups="compliance-lane" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Compliance" />
            <zeebe:property name="raci_r" value="Compliance" />
            <zeebe:property name="raci_a" value="Compliance" />
            <zeebe:property name="raci_c" value="Governance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_103u6cl</bpmn:incoming>
        <bpmn:outgoing>Flow_1qwbs9m</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:sequenceFlow id="Flow_1p8m38v" sourceRef="GW_ParallelSplit" targetRef="Activity_0kq8o8j">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=riskRequired = true</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_103u6cl" sourceRef="GW_ParallelSplit" targetRef="Activity_0ksoea5">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=complianceRequired = true</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_1qwbs9m" sourceRef="Activity_0ksoea5" targetRef="GW_ParallelJoin" />
      <bpmn:sequenceFlow id="Flow_1ihc8jh" sourceRef="Activity_0kq8o8j" targetRef="GW_ParallelJoin" />
      <bpmn:sequenceFlow id="Flow_0ocj7ql" sourceRef="Task_TechArchReview" targetRef="GW_ParallelJoin" />
      <bpmn:userTask id="Activity_0mr2gdy" name="Privacy Assessment">
        <bpmn:documentation>Evaluate data protection and privacy risks. Conduct DPIA for high-risk processing, assess cross-border data transfers and transfer mechanisms (SCCs, adequacy decisions), data classification, data subject rights support, GDPR/CCPA compliance, and privacy-by-design requirements. Separate from compliance review to ensure dedicated Privacy SME assessment.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp3-privacy-assessment" />
          <zeebe:assignmentDefinition candidateGroups="compliance-lane" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Privacy" />
            <zeebe:property name="raci_r" value="Compliance" />
            <zeebe:property name="raci_a" value="Compliance" />
            <zeebe:property name="raci_c" value="Governance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0tgi2ai</bpmn:incoming>
        <bpmn:outgoing>Flow_1xapt70</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:sequenceFlow id="Flow_0tgi2ai" sourceRef="GW_ParallelSplit" targetRef="Activity_0mr2gdy">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=privacyRequired = true</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_1xapt70" sourceRef="Activity_0mr2gdy" targetRef="GW_ParallelJoin" />
    </bpmn:subProcess>
    <bpmn:endEvent id="Event_1whn5yx">
      <bpmn:incoming>Flow_v5_7</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_EvalApproved" name="Evaluation&#10;Approved?" default="Flow_v5_11">
      <bpmn:incoming>Flow_19gvzqq</bpmn:incoming>
      <bpmn:outgoing>Flow_v5_11</bpmn:outgoing>
      <bpmn:outgoing>Flow_v5_12</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_EvalRejected" name="Evaluation&#10;Failed">
      <bpmn:incoming>Flow_v5_11</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_FinalDecision" name="Approved?" default="Flow_v5_16">
      <bpmn:incoming>Flow_v5_14</bpmn:incoming>
      <bpmn:outgoing>Flow_v5_15</bpmn:outgoing>
      <bpmn:outgoing>Flow_v5_16</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_SoftwareOnboarded" name="Software&#10;Onboarded">
      <bpmn:incoming>Flow_v5_15</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_FinalRejected" name="Request&#10;Denied">
      <bpmn:incoming>Flow_v5_16</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:subProcess id="SP_UATGoLive" name="UAT&#10;and Go-Live">
      <bpmn:incoming>Flow_v5_13</bpmn:incoming>
      <bpmn:outgoing>Flow_v5_14</bpmn:outgoing>
      <bpmn:startEvent id="SP5_Start">
        <bpmn:outgoing>Flow_SP5_1</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:userTask id="Task_PerformUAT" name="Perform&#10;Pilot / UAT">
        <bpmn:documentation>Conduct User Acceptance Testing (UAT) or a controlled pilot with representative business users to validate the solution meets business requirements in a production-like environment. Execute predefined UAT test scenarios covering all critical business workflows. Collect user feedback on usability, performance, and completeness. Document defects, change requests, and acceptance decision. UAT sign-off is a prerequisite for final governance approval.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp5-perform-uat" />
          <zeebe:assignmentDefinition candidateGroups="business-lane" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Compliance" />
            <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 55: Business validation — the requesting business unit must confirm the solution meets the stated needs and operates as expected before governance approval. This creates accountability at the first line of defense. (2) SOX Section 404: For systems affecting financial controls, UAT must specifically validate control effectiveness — transaction accuracy, access controls, audit trail completeness, and segregation of duties. UAT evidence becomes part of the SOX compliance documentation. (3) GDPR Article 25: Validate privacy controls function as designed — data minimization, consent management, data subject rights (access, deletion, portability), and privacy notice accuracy. (4) NIST CSF 2.0 PR.AT: User training validation — confirm users can operate the system securely and understand their responsibilities. EVIDENCE COLLECTION: (a) UAT plan with test scenarios mapped to business requirements. (b) UAT execution results with pass/fail per scenario. (c) User feedback survey results. (d) Defect log with severity and resolution status. (e) UAT sign-off from business owner and key stakeholders. (f) Training completion records for UAT participants. (g) Change request log (if UAT identified needed modifications). DATA POINTS: UAT scenarios total, pass rate percentage, critical defects found, defects resolved before sign-off, defects deferred (with risk acceptance), user satisfaction score, pilot user count, pilot duration (days), business owner sign-off date, training completion rate." />
            <zeebe:property name="raci_r" value="Business" />
            <zeebe:property name="raci_a" value="Business" />
            <zeebe:property name="raci_c" value="Compliance" />
            <zeebe:property name="raci_i" value="Governance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP5_1</bpmn:incoming>
        <bpmn:outgoing>Flow_SP5_2</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:userTask id="Task_FinalApproval" name="Provide Final&#10;Approval">
        <bpmn:documentation>Third line of defense (Internal Audit/Oversight) provides final governance approval based on the complete evidence package — evaluation results, risk assessment, UAT sign-off, contract execution (for Buy), and compliance verification. This is the last governance gate before software onboarding. The oversight committee reviews the consolidated evidence and either approves, approves with conditions, or rejects the request. Approval authority is commensurate with the risk tier and contract value.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp5-final-approval" />
          <zeebe:assignmentDefinition candidateGroups="oversight-lane" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Compliance, TPRM" />
            <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 70: Board or senior management oversight — approval authority for third-party relationships must be commensurate with the risk and complexity. Critical and significant relationships require senior management or board-level approval. (2) NIST CSF 2.0 GV.OV (Oversight): Governance oversight must verify that all risk management activities have been completed satisfactorily. Third line of defense provides independent assurance. (3) SOX Section 302: Management certification — the approving authority certifies that all required due diligence, risk assessment, and compliance activities have been completed and the residual risk is within acceptable limits. (4) DORA Article 5: Management body responsibility — senior management must approve ICT third-party arrangements with appropriate oversight documentation. EVIDENCE COLLECTION: (a) Consolidated approval package including: evaluation results, risk assessment, UAT sign-off, contract summary, compliance verification. (b) Approval decision document with rationale and any conditions. (c) Delegated authority verification (approver has sufficient authority for this risk tier/contract value). (d) Conditions tracker (if approved with conditions — conditions, owners, deadlines). (e) Committee meeting minutes (if committee approval required). DATA POINTS: Approval decision (approve/conditional/reject), approver name and authority level, risk tier confirmed, conditions attached (count and descriptions), committee vote result (if applicable), approval date, conditions deadline dates, evidence package completeness score." />
            <zeebe:property name="raci_r" value="Oversight" />
            <zeebe:property name="raci_a" value="Oversight" />
            <zeebe:property name="raci_c" value="Governance, Compliance" />
            <zeebe:property name="raci_i" value="Business" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP5_2</bpmn:incoming>
        <bpmn:outgoing>Flow_SP5_3</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:userTask id="Task_OnboardSoftware" name="Onboard&#10;Software">
        <bpmn:documentation>Execute the technical onboarding of the approved software into the production environment. Provision user accounts, configure access controls, establish monitoring and alerting, update the CMDB and software asset register, deploy to production (for Buy pathway — activate licenses and configure; for Build pathway — promote from staging). Complete the go-live checklist including operational runbook, support handoff, and monitoring baseline establishment.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp5-onboard-software" />
          <zeebe:assignmentDefinition candidateGroups="automation-lane" />
          <zeebe:properties>
            <zeebe:property name="topics" value="TPRM, Cyber" />
            <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 80: Ongoing monitoring setup — establish the monitoring framework at onboarding including KRIs, performance metrics, SLA tracking, and escalation thresholds. Add the software/vendor to the third-party inventory with complete metadata. (2) NIST CSF 2.0 PR.AA: Identity and access management — provision user access following least-privilege principle, enforce MFA, configure RBAC per the approved access control design. Schedule periodic access reviews. (3) DORA Article 28: ICT register — add the solution to the organization&#39;s ICT asset register with all mandatory metadata (provider, services, criticality, dependencies). (4) ISO 27001 A.8: Asset management — register the software in the asset management system with owner, classification, and retention requirements. EVIDENCE COLLECTION: (a) Go-live checklist signed off by technical operations, security, and business owner. (b) User provisioning records with access levels documented. (c) CMDB/asset register update confirmation. (d) Monitoring and alerting configuration documentation. (e) Operational runbook and support handoff documentation. (f) Production deployment verification results. (g) Backup and recovery configuration confirmation. DATA POINTS: Go-live date, users provisioned (count), access levels configured, monitoring KRIs established (count), CMDB entry created, operational runbook completed, support team assigned, backup configuration verified, first monitoring baseline captured date." />
            <zeebe:property name="raci_r" value="Automation" />
            <zeebe:property name="raci_a" value="Automation" />
            <zeebe:property name="raci_c" value="Technical Assessment" />
            <zeebe:property name="raci_i" value="Governance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP5_MergeToOnboard</bpmn:incoming>
        <bpmn:outgoing>Flow_SP5_4</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:serviceTask id="Activity_0zf4l0g" name="Notify Requester">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="notify-requester" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Intake" />
            <zeebe:property name="raci_r" value="Automation" />
            <zeebe:property name="raci_a" value="Governance" />
            <zeebe:property name="raci_i" value="Business" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP5_4</bpmn:incoming>
        <bpmn:outgoing>Flow_SP5_5</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:userTask id="Task_AssignOwnership" name="Assign&#10;Ownership">
        <bpmn:documentation>Assign dual ownership for the onboarded software: a Business Owner responsible for functional requirements, usage, and business value; and a Vendor Owner (for Buy pathway) responsible for vendor relationship management, contract compliance, and service level monitoring.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp5-assign-ownership" />
          <zeebe:assignmentDefinition candidateGroups="governance-lane" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Governance" />
            <zeebe:property name="raci_r" value="Governance" />
            <zeebe:property name="raci_a" value="Governance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP5_5</bpmn:incoming>
        <bpmn:outgoing>Flow_SP5_OWN</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:sequenceFlow id="Flow_SP5_OWN" sourceRef="Task_AssignOwnership" targetRef="Task_CloseRequest" />
      <bpmn:userTask id="Task_CloseRequest" name="Close Request">
        <bpmn:documentation>Close the software onboarding request by archiving all decisions, evidence, and artifacts for audit trail and regulatory examination purposes. Confirm the transition to ongoing monitoring and vendor management (for Buy pathway) or operational support (for Build pathway). Update the portfolio and tracking systems. Conduct a brief lessons-learned retrospective to capture process improvement opportunities for future onboarding requests.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp5-close-request" />
          <zeebe:assignmentDefinition candidateGroups="governance-lane" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Intake" />
            <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 80: Transition to ongoing monitoring — confirm the monitoring cadence is established (references DMN_MonitoringCadenceAssignment), the vendor/software is in the third-party inventory, and the ongoing oversight responsibilities are assigned. (2) SEC 17a-4: Records retention — all onboarding artifacts must be archived in a compliant retention system. The complete audit trail from intake through deployment must be preserved, indexed, and retrievable for regulatory examination. Retention period per organizational policy (typically 7+ years). (3) NIST CSF 2.0 GV.SC-09: Lessons learned — document process improvement opportunities, track recurring issues, and feed improvements back into the onboarding process. (4) SOX Section 404: Confirm audit trail completeness — all decisions, approvals, and evidence must be traceable from request through go-live. EVIDENCE COLLECTION: (a) Request closure confirmation with summary of the complete onboarding journey. (b) Complete evidence archive index (all artifacts cataloged with retention dates). (c) Monitoring transition confirmation (cadence, KRIs, assigned reviewer). (d) Lessons-learned document from the onboarding process. (e) Portfolio and tracking system updates confirmed. (f) Stakeholder notification of successful onboarding completion. DATA POINTS: Total onboarding duration (days), total cost of onboarding process, pathway taken (Buy/Build), risk tier final, monitoring cadence assigned, next scheduled review date, lessons-learned recommendations count, evidence artifacts archived count, request closure date, stakeholders notified." />
            <zeebe:property name="raci_r" value="Governance" />
            <zeebe:property name="raci_a" value="Governance" />
            <zeebe:property name="raci_c" value="Business" />
            <zeebe:property name="raci_i" value="Oversight" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP5_OWN</bpmn:incoming>
        <bpmn:outgoing>Flow_SP5_6</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:endEvent id="SP5_End">
        <bpmn:incoming>Flow_SP5_6</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_SP5_1" sourceRef="SP5_Start" targetRef="Task_PerformUAT" />
      <bpmn:sequenceFlow id="Flow_SP5_2" sourceRef="Task_PerformUAT" targetRef="Task_FinalApproval" />
      <bpmn:userTask id="Task_ConditionVerification" name="Verify&#10;Conditions">
        <bpmn:documentation>For conditional approvals, verify that all conditions attached to the approval have been met before proceeding with software onboarding. Track condition status, evidence of completion, and verification sign-off.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp5-condition-verification" />
          <zeebe:assignmentDefinition candidateGroups="governance-lane" />
          <zeebe:properties>
            <zeebe:property name="raci_r" value="Governance" />
            <zeebe:property name="raci_a" value="Governance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP5_Conditional</bpmn:incoming>
        <bpmn:outgoing>Flow_SP5_CV</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:exclusiveGateway id="GW_ApprovalDecision" name="Approval&#10;Decision?">
        <bpmn:incoming>Flow_SP5_3</bpmn:incoming>
        <bpmn:outgoing>Flow_SP5_Approved</bpmn:outgoing>
        <bpmn:outgoing>Flow_SP5_Conditional</bpmn:outgoing>
        <bpmn:outgoing>Flow_SP5_Rejected</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:endEvent id="End_SP5_Rejected" name="Approval&#10;Rejected">
        <bpmn:incoming>Flow_SP5_Rejected</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:exclusiveGateway id="GW_MergeOnboard">
        <bpmn:incoming>Flow_SP5_Approved</bpmn:incoming>
        <bpmn:incoming>Flow_SP5_CV</bpmn:incoming>
        <bpmn:outgoing>Flow_SP5_MergeToOnboard</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:sequenceFlow id="Flow_SP5_3" sourceRef="Task_FinalApproval" targetRef="GW_ApprovalDecision" />
      <bpmn:sequenceFlow id="Flow_SP5_Approved" name="Approved" sourceRef="GW_ApprovalDecision" targetRef="GW_MergeOnboard">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=approvalDecision = "Approved"</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_SP5_Conditional" name="Conditions" sourceRef="GW_ApprovalDecision" targetRef="Task_ConditionVerification">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=approvalDecision = "Conditional"</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_SP5_Rejected" name="Rejected" sourceRef="GW_ApprovalDecision" targetRef="End_SP5_Rejected">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=approvalDecision = "Rejected"</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_SP5_CV" sourceRef="Task_ConditionVerification" targetRef="GW_MergeOnboard" />
      <bpmn:sequenceFlow id="Flow_SP5_MergeToOnboard" sourceRef="GW_MergeOnboard" targetRef="Task_OnboardSoftware" />
      <bpmn:sequenceFlow id="Flow_SP5_4" sourceRef="Task_OnboardSoftware" targetRef="Activity_0zf4l0g" />
      <bpmn:sequenceFlow id="Flow_SP5_5" sourceRef="Activity_0zf4l0g" targetRef="Task_AssignOwnership" />
      <bpmn:sequenceFlow id="Flow_SP5_6" sourceRef="Task_CloseRequest" targetRef="SP5_End" />
    </bpmn:subProcess>
    <bpmn:subProcess id="SP_ContractBuild" name="Contracting">
      <bpmn:incoming>Flow_v5_12</bpmn:incoming>
      <bpmn:outgoing>Flow_v5_13</bpmn:outgoing>
      <bpmn:startEvent id="SP4_Start">
        <bpmn:outgoing>Flow_SP4_1</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:exclusiveGateway id="GW_PathwayExec" name="Pathway ?" default="Flow_SP4_Buy">
        <bpmn:incoming>Flow_SP4_1</bpmn:incoming>
        <bpmn:outgoing>Flow_SP4_Buy</bpmn:outgoing>
        <bpmn:outgoing>Flow_SP4_Build</bpmn:outgoing>
        <bpmn:outgoing>Flow_SP4_Enable</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:userTask id="Task_RefineRequirements" name="Refine&#10;Requirements">
        <bpmn:documentation>Refine and finalize requirements based on insights from the parallel evaluations and vendor due diligence. Incorporate feedback from Technical Architecture, Security, Risk and Compliance, and Financial analysis streams. Update requirements to address identified gaps, risks, and conditions. Produce the final requirements specification that will guide the Proof of Concept and subsequent contracting or build activities.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp4-refine-requirements" />
          <zeebe:assignmentDefinition candidateGroups="business-lane" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Sourcing, Compliance, Privacy" />
            <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 40: Requirements refinement must incorporate all risk and compliance findings from the evaluation streams — security requirements, data protection requirements, audit rights, and regulatory compliance requirements must be explicitly captured in the final specification. (2) NIST CSF 2.0 PR (Protect): Refined requirements must include all identified security and privacy controls as mandatory requirements, not optional. (3) GDPR Article 25: Data protection by design — refined requirements must embed privacy requirements identified during the compliance evaluation. EVIDENCE COLLECTION: (a) Requirements change log documenting what was added, modified, or removed based on evaluation findings. (b) Traceability matrix linking evaluation findings to updated requirements. (c) Final requirements specification document (versioned and approved). (d) Sign-off from evaluation stream leads confirming their findings are reflected. DATA POINTS: Original requirements count, refined requirements count, requirements added from security stream, requirements added from compliance stream, requirements added from technical stream, critical requirements identified, requirements approval date, version number." />
            <zeebe:property name="raci_r" value="Business" />
            <zeebe:property name="raci_a" value="Governance" />
            <zeebe:property name="raci_c" value="Technical Assessment, Compliance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP4_Buy</bpmn:incoming>
        <bpmn:outgoing>Flow_SP4_2</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:userTask id="Task_PerformPoC" name="Perform Proof&#10;of Concep">
        <bpmn:documentation>Execute a structured Proof of Concept to validate the proposed solution against refined requirements in a controlled environment. Define PoC success criteria, test scenarios, evaluation metrics, and timeline. For Buy pathway, conduct a guided evaluation with the vendor's solution; for Build pathway, develop a prototype demonstrating key architectural decisions. Document results against predefined acceptance criteria.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp4-perform-poc" />
          <zeebe:assignmentDefinition candidateGroups="technical-assessment" />
          <zeebe:properties>
            <zeebe:property name="topics" value="EA, Cyber, Privacy" />
            <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 45: PoC environments must not use production data unless properly anonymized or pseudonymized. If vendor access is required, PoC-specific access controls and NDAs must be in place. (2) GDPR Article 5: Data minimization — PoC must use synthetic or anonymized data. If real data is necessary, a data protection assessment must be completed and documented. (3) NIST CSF 2.0 PR.DS: Data security controls must be applied to the PoC environment, including encryption, access controls, and audit logging. PoC environments must be decommissioned after evaluation. (4) DORA Article 9: ICT testing — PoC should validate resilience characteristics (failover, recovery) where feasible. EVIDENCE COLLECTION: (a) PoC plan with defined success criteria, test scenarios, and evaluation metrics. (b) PoC results report with pass/fail against each success criterion. (c) Performance test results (response times, throughput, resource utilization). (d) Integration test results with existing enterprise systems. (e) Data handling confirmation (synthetic data used or DPIA completed). (f) PoC environment decommission confirmation. DATA POINTS: PoC duration (days), success criteria count, criteria met/not met, performance benchmarks achieved, integration tests passed/failed, key findings and limitations discovered, go/no-go recommendation, evaluator sign-offs, PoC environment decommission date." />
            <zeebe:property name="raci_r" value="Technical Assessment" />
            <zeebe:property name="raci_a" value="Technical Assessment" />
            <zeebe:property name="raci_c" value="Business, Compliance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP4_2</bpmn:incoming>
        <bpmn:outgoing>Flow_SP4_3</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:userTask id="Task_TechRiskEval" name="Technology and&#10;Risk Evaluation">
        <bpmn:documentation>Conduct a consolidated technology and risk evaluation synthesizing results from all prior assessment activities — PoC findings, parallel evaluations, and due diligence results. Produce a final risk-rated assessment determining whether the solution meets the organization's risk appetite and technology standards. This is the final technical gate before the Evaluation Approved decision point.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp4-tech-risk-eval" />
          <zeebe:assignmentDefinition candidateGroups="technical-assessment" />
          <zeebe:properties>
            <zeebe:property name="topics" value="EA, Cyber, TPRM" />
            <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 55: Consolidated risk assessment — all evaluation dimensions must be synthesized into a single risk-rated view. Residual risks must be documented with accepted risk levels and compensating controls. (2) NIST CSF 2.0 ID.RA (Risk Assessment): Formal risk assessment following a structured methodology — identify threats, vulnerabilities, likelihood, and impact. Risk ratings must use the organization&#39;s standard risk taxonomy. (3) DORA Article 5: ICT risk management — the evaluation must assess the solution&#39;s impact on the organization&#39;s overall digital operational resilience posture. (4) SOX Section 404: If the solution affects financial controls, the risk evaluation must specifically address control effectiveness, segregation of duties, and audit trail adequacy. EVIDENCE COLLECTION: (a) Consolidated technology and risk evaluation report with overall risk rating. (b) Risk register entries for all identified residual risks with owners, mitigations, and accepted risk levels. (c) PoC results summary incorporated into the evaluation. (d) Compensating controls matrix for accepted risks. (e) Go/no-go recommendation with supporting rationale. (f) Evaluation committee sign-off. DATA POINTS: Overall risk rating (Critical/High/Medium/Low), residual risks count by severity, compensating controls count, PoC success rate, evaluation committee vote (approve/reject), conditions attached (if any), risk acceptance authority (who approved residual risks), evaluation completion date." />
            <zeebe:property name="raci_r" value="Technical Assessment" />
            <zeebe:property name="raci_a" value="Technical Assessment" />
            <zeebe:property name="raci_c" value="Governance, Compliance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP4_3</bpmn:incoming>
        <bpmn:outgoing>Flow_SP4_4</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:userTask id="Task_NegotiateContract" name="Negotiate&#10;Contract">
        <bpmn:documentation>Lead contract negotiation with the selected vendor, incorporating all requirements, risk mitigations, and compliance conditions identified during the evaluation process. Negotiate commercial terms, SLAs, data protection provisions, audit rights, termination clauses, liability caps, indemnification, intellectual property rights, and exit/transition assistance. Ensure all OCC 2023-17 required contractual provisions are included. This task triggers the message flow sending the contract draft to the Vendor pool.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp4-negotiate-contract" />
          <zeebe:assignmentDefinition candidateGroups="contracting-lane" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Commercial Counsel, Funding, TPRM" />
            <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Sections 60-70: Mandatory contractual provisions — audit rights (for institution and regulators), subcontracting restrictions, data ownership and return/destruction, business continuity requirements, default and termination provisions, indemnification, insurance requirements, dispute resolution, regulatory compliance representations. All provisions must be present or a documented exception approved by appropriate authority. (2) GDPR Article 28(3): DPA mandatory provisions — processing only on documented instructions, confidentiality obligations, security measures, sub-processor management, data subject rights assistance, breach notification (within 72 hours), deletion/return on termination, audit cooperation. (3) DORA Article 30: ICT contractual provisions — SLA definitions, availability targets, incident notification timelines, audit and access rights, exit strategy and transition assistance, sub-outsourcing governance. (4) SOX Sections 302, 404: Financial controls provisions — audit access, financial reporting cooperation, internal control representations. EVIDENCE COLLECTION: (a) Contract negotiation log documenting positions, counteroffers, and resolutions for each material term. (b) Legal review checklist cross-referenced against OCC 2023-17 Section 60 required provisions. (c) DPA checklist against GDPR Article 28(3) mandatory terms. (d) SLA schedule with measurable targets and remedies. (e) Risk mitigation conditions incorporated from evaluation findings. (f) Approved exceptions with authority sign-off (if any required provisions are modified or waived). DATA POINTS: Negotiation rounds count, material terms negotiated, SLA targets agreed, liability cap amount, indemnification scope, insurance minimums, termination notice period, data return/deletion timeline, audit rights frequency, contract value, contract term." />
            <zeebe:property name="raci_r" value="Contracting" />
            <zeebe:property name="raci_a" value="Contracting" />
            <zeebe:property name="raci_c" value="Finance, Governance" />
            <zeebe:property name="raci_i" value="Oversight" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP4_4</bpmn:incoming>
        <bpmn:outgoing>Flow_SP4_5</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:receiveTask id="Receive_SignedContract" name="Await Signed&#10;Contract" messageRef="Message_SignedContract">
        <bpmn:incoming>Flow_SP4_5</bpmn:incoming>
        <bpmn:outgoing>Flow_SP4_6</bpmn:outgoing>
      </bpmn:receiveTask>
      <bpmn:boundaryEvent id="Timer_ContractSLA" name="7 Day&#10;SLA" cancelActivity="false" attachedToRef="Receive_SignedContract">
        <bpmn:outgoing>Flow_SP4_SLA</bpmn:outgoing>
        <bpmn:timerEventDefinition id="TimerDef_ContractSLA">
          <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P7D</bpmn:timeDuration>
        </bpmn:timerEventDefinition>
      </bpmn:boundaryEvent>
      <bpmn:endEvent id="End_ContractSLABreach" name="Contract&#10;SLA Breach">
        <bpmn:incoming>Flow_SP4_SLA</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:userTask id="Task_FinalizeContract" name="Finalize&#10;Contract">
        <bpmn:documentation>Finalize the contract after receiving the vendor's signed counterpart and verifying all negotiated terms are reflected accurately. Confirm all schedules (MSA, SLA, DPA, SOW) are complete and internally consistent. Obtain internal approvals per the delegated authority matrix. Register the executed contract in the contract management system and initiate the vendor onboarding process. This task receives the signed contract message flow from the Vendor pool.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp4-finalize-contract" />
          <zeebe:assignmentDefinition candidateGroups="contracting-lane" />
          <zeebe:properties>
            <zeebe:property name="topics" value="Commercial Counsel, TPRM" />
            <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 60: Pre-execution verification — confirm all mandatory provisions are present in the final executed version. No material terms should differ from the negotiated and approved version. (2) SOX Section 302: Internal approval chain completed per delegated authority matrix — contract value determines required approval level (department head, VP, C-suite, board). (3) SEC 17a-4: Executed contract must be stored in a tamper-evident, compliant records retention system with appropriate retention period (7+ years for financial services). (4) GDPR Article 28: Confirm DPA is fully executed before any data processing commences. EVIDENCE COLLECTION: (a) Final executed contract comparison against negotiated terms (no unauthorized changes). (b) Internal approval chain documentation (all required approvals obtained). (c) Contract registration confirmation in contract management system with reference number. (d) Insurance certificate verification (current and meeting contractual minimums). (e) Contract summary memo for governance records. (f) Vendor onboarding trigger confirmation. DATA POINTS: Contract reference number, execution date, effective date, term length, total contract value, approval chain completed (names, dates, authorities), DPA execution confirmed, insurance verified, contract management system registration date, next review date." />
            <zeebe:property name="raci_r" value="Contracting" />
            <zeebe:property name="raci_a" value="Contracting" />
            <zeebe:property name="raci_c" value="Governance, Compliance" />
            <zeebe:property name="raci_i" value="Oversight" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP4_6</bpmn:incoming>
        <bpmn:outgoing>Flow_SP4_BuyMerge</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:userTask id="Task_DefineBuildReqs" name="Define Build&#10;Requirements">
        <bpmn:documentation>Define comprehensive build requirements for the Build pathway including functional specifications, non-functional requirements (performance, scalability, security, availability), architecture constraints, integration specifications, data model requirements, and acceptance criteria. Establish the product backlog, define MVP scope, and document technology stack decisions. Requirements must address security, compliance, and data protection from inception.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp4-define-build-reqs" />
          <zeebe:assignmentDefinition candidateGroups="business-lane" />
          <zeebe:properties>
            <zeebe:property name="topics" value="EA, Privacy, Cyber" />
            <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 40: If the build involves third-party components, libraries, or cloud services, each must be evaluated under the third-party risk management framework. Open-source components require license compliance and vulnerability assessment. (2) NIST CSF 2.0 PR.PS (Platform Security): Security requirements must be defined as part of the build specification — secure coding standards, authentication requirements, encryption standards, and logging requirements. (3) GDPR Article 25: Data protection by design and by default — privacy requirements must be embedded in the build specifications from the outset, not retrofitted. Data minimization, purpose limitation, and retention policies must be defined. (4) SOX Section 404: If the build touches financial data or controls, segregation of duties, access controls, and audit logging requirements must be specified. EVIDENCE COLLECTION: (a) Functional requirements specification document with acceptance criteria. (b) Non-functional requirements document (performance targets, scalability requirements, availability SLA). (c) Security requirements checklist (authentication, authorization, encryption, logging, vulnerability management). (d) Architecture decision records (ADRs) for key technology choices. (e) Data protection requirements including DPIA results if applicable. (f) Third-party component inventory (libraries, frameworks, cloud services) with license types. DATA POINTS: Total requirements count (functional + non-functional), security requirements count, data types processed, technology stack selected, estimated development effort (story points or person-days), MVP scope definition, target deployment date, third-party component count, open-source license types, DPIA required (yes/no)." />
            <zeebe:property name="raci_r" value="Business" />
            <zeebe:property name="raci_a" value="Business" />
            <zeebe:property name="raci_c" value="Technical Assessment, Privacy" />
            <zeebe:property name="raci_i" value="Governance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP4_Build</bpmn:incoming>
        <bpmn:outgoing>Flow_SP4_7</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:subProcess id="SP_PDLC" name="Product Development&#10;Life Cycle">
        <bpmn:incoming>Flow_SP4_7</bpmn:incoming>
        <bpmn:outgoing>Flow_SP4_BuildMerge</bpmn:outgoing>
        <bpmn:startEvent id="PDLC_Start" name="Start" />
        <bpmn:userTask id="PDLC_ArchReview" name="Architecture&#10;Review">
          <bpmn:documentation>Conduct formal architecture review of the build design before development begins. Validate the proposed architecture against enterprise standards, security requirements, scalability targets, and integration specifications. Review technology stack selections, data model design, API contracts, and infrastructure requirements. Produce an Architecture Decision Record (ADR) for each significant design choice.</bpmn:documentation>
          <bpmn:extensionElements>
            <zeebe:formDefinition formId="pdlc-arch-review" />
            <zeebe:assignmentDefinition candidateGroups="technical-assessment" />
            <zeebe:properties>
              <zeebe:property name="topics" value="EA" />
              <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) NIST CSF 2.0 PR.PS: Platform security review — validate secure architecture patterns, defense-in-depth design, and secure defaults. (2) GDPR Article 25: Data protection by design — verify privacy-preserving architecture (data minimization, purpose limitation enforced architecturally, encryption at rest and in transit). (3) SOX Section 404: If the build processes financial data, architecture must enforce segregation of duties, audit logging, and data integrity controls. (4) DORA Article 9: ICT resilience by design — verify high availability, failover, and recovery mechanisms are architecturally embedded. EVIDENCE COLLECTION: (a) Architecture review report with findings rated by severity. (b) Architecture Decision Records (ADRs) for key technology and design choices. (c) Security architecture review checklist. (d) Data flow diagram with encryption and access control annotations. (e) Enterprise standards compliance matrix. DATA POINTS: Architecture review findings count (by severity), ADRs produced, enterprise standards compliance percentage, security patterns implemented, data protection mechanisms confirmed, review board approval status." />
              <zeebe:property name="raci_r" value="Technical Assessment" />
              <zeebe:property name="raci_a" value="Technical Assessment" />
              <zeebe:property name="raci_c" value="Governance" />
            </zeebe:properties>
          </bpmn:extensionElements>
        </bpmn:userTask>
        <bpmn:userTask id="PDLC_Development" name="Development&#10;and Build">
          <bpmn:documentation>Execute the development and build phase following the approved architecture and refined requirements. Implement using secure coding standards, conduct peer code reviews, maintain automated CI/CD pipelines with quality gates, and track development progress against the product backlog. All third-party libraries and dependencies must be scanned for vulnerabilities and license compliance. Development must follow the organization's SDLC methodology.</bpmn:documentation>
          <bpmn:extensionElements>
            <zeebe:formDefinition formId="pdlc-development" />
            <zeebe:assignmentDefinition candidateGroups="technical-assessment" />
            <zeebe:properties>
              <zeebe:property name="topics" value="Cyber, EA" />
              <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) NIST CSF 2.0 PR.PS-01: Secure coding practices — OWASP Top 10 mitigation, input validation, output encoding, parameterized queries, secure authentication/authorization implementation. (2) OCC 2023-17 Section 50: If using open-source or third-party components, each must be assessed for security vulnerabilities (CVE scanning) and license compliance. Software composition analysis (SCA) required. (3) SOX Section 404: Change management controls — all code changes must go through peer review, approval, and be logged with audit trail. Segregation of duties between developer and approver. (4) GDPR Article 25: Privacy by design implementation — data minimization, pseudonymization, encryption, and access controls implemented per the architecture review. EVIDENCE COLLECTION: (a) Code review records (all PRs with reviewer approvals). (b) CI/CD pipeline execution logs with quality gate results. (c) Software composition analysis (SCA) report — third-party dependencies, vulnerabilities, licenses. (d) Static application security testing (SAST) results. (e) Code coverage metrics. (f) Development progress reports against backlog. DATA POINTS: Story points completed, code review approval rate, SAST findings by severity, SCA vulnerabilities found and remediated, code coverage percentage, CI/CD pipeline pass rate, third-party dependency count, open-source license types used, build artifacts versioned and stored." />
              <zeebe:property name="raci_r" value="Technical Assessment" />
              <zeebe:property name="raci_a" value="Technical Assessment" />
              <zeebe:property name="raci_c" value="Business" />
            </zeebe:properties>
          </bpmn:extensionElements>
          <bpmn:incoming>Flow_17ytyma</bpmn:incoming>
        </bpmn:userTask>
        <bpmn:userTask id="PDLC_Testing" name="Testing and&#10;Quality Assurance">
          <bpmn:documentation>Execute comprehensive testing and quality assurance activities including functional testing, integration testing, security testing (DAST, penetration testing), performance testing, accessibility testing, and regression testing. Validate all requirements are met per the acceptance criteria. Conduct dynamic application security testing (DAST) and, for high-risk applications, penetration testing. Test results determine whether the build proceeds to integration or loops back for remediation.</bpmn:documentation>
          <bpmn:extensionElements>
            <zeebe:formDefinition formId="pdlc-testing" />
            <zeebe:assignmentDefinition candidateGroups="technical-assessment" />
            <zeebe:properties>
              <zeebe:property name="topics" value="Cyber, Compliance" />
              <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) NIST CSF 2.0 DE.CM: Security testing — DAST scanning, penetration testing (for high-risk applications), and vulnerability assessment must be completed before production deployment. All findings must be remediated or accepted with documented risk acceptance. (2) DORA Article 24-27: Digital operational resilience testing — ICT systems must be tested for resilience, including threat-led penetration testing (TLPT) for critical systems. (3) SOX Section 404: Test evidence for systems affecting financial controls must be retained — functional test results demonstrating control effectiveness, access control testing, and data integrity validation. (4) ISO 27001 A.14.2: Security testing in development — verify secure development lifecycle testing requirements are met. EVIDENCE COLLECTION: (a) Test execution report with pass/fail rates across all test types. (b) DAST scan results with remediated findings. (c) Penetration test report (if applicable — required for high-risk applications). (d) Performance test results against defined SLA targets. (e) Accessibility audit results (WCAG 2.1 AA compliance). (f) Regression test suite results. (g) Test coverage metrics (requirements coverage, code coverage). DATA POINTS: Total test cases, pass rate percentage, DAST findings by severity, penetration test findings (if conducted), performance benchmarks met/missed, accessibility compliance score, regression test pass rate, test coverage percentage, defects found by severity, defects resolved vs. deferred." />
              <zeebe:property name="raci_r" value="Technical Assessment" />
              <zeebe:property name="raci_a" value="Technical Assessment" />
              <zeebe:property name="raci_c" value="Compliance" />
            </zeebe:properties>
          </bpmn:extensionElements>
        </bpmn:userTask>
        <bpmn:exclusiveGateway id="PDLC_GW_TestResult" name="Tests&#10;Passed?" default="Flow_PDLC_No" />
        <bpmn:userTask id="PDLC_Integration" name="Integration&#10;and Deployment">
          <bpmn:documentation>Execute integration testing with enterprise systems and deploy the build artifact to the target environment. Validate all integration points function correctly with production-like data. Follow the organization's change management process for deployment — change request, impact assessment, approval, implementation, and post-implementation review. Establish configuration baselines and verify rollback procedures before go-live.</bpmn:documentation>
          <bpmn:extensionElements>
            <zeebe:formDefinition formId="pdlc-integration" />
            <zeebe:assignmentDefinition candidateGroups="technical-assessment" />
            <zeebe:properties>
              <zeebe:property name="topics" value="EA, Compliance" />
              <zeebe:property name="comments" value="REGULATORY CONTROLS: (1) NIST CSF 2.0 PR.PS-04: Configuration management — establish and document configuration baselines for all deployed components. Enable configuration drift detection. (2) DORA Article 12: ICT change management — all deployment activities must follow formal change management with approval, testing, and rollback capability. Changes must be logged and auditable. (3) ISO 27001 A.12.1.2: Change management controls — formal change request with impact assessment, approval from change advisory board (for significant changes), implementation plan, and post-implementation verification. (4) SOX Section 404: Deployment of systems affecting financial controls requires segregation of duties between development and operations (developer cannot deploy to production). EVIDENCE COLLECTION: (a) Integration test results confirming all enterprise system connections function correctly. (b) Change management request with approvals. (c) Deployment plan and execution log. (d) Configuration baseline snapshot post-deployment. (e) Rollback plan tested and confirmed. (f) Post-implementation verification results. DATA POINTS: Integration points tested (count and pass/fail), change request number, deployment date and duration, deployment method, configuration items deployed, rollback test result, post-implementation verification status, environments deployed to, deployment approval chain." />
              <zeebe:property name="raci_r" value="Technical Assessment" />
              <zeebe:property name="raci_a" value="Technical Assessment" />
              <zeebe:property name="raci_c" value="Compliance" />
            </zeebe:properties>
          </bpmn:extensionElements>
        </bpmn:userTask>
        <bpmn:endEvent id="PDLC_End" name="PDLC&#10;Complete" />
        <bpmn:sequenceFlow id="Flow_PDLC1" sourceRef="PDLC_Start" targetRef="PDLC_ArchReview" />
        <bpmn:sequenceFlow id="Flow_PDLC2" sourceRef="PDLC_ArchReview" targetRef="Gateway_0q35ha8" />
        <bpmn:sequenceFlow id="Flow_PDLC3" sourceRef="PDLC_Development" targetRef="PDLC_Testing" />
        <bpmn:sequenceFlow id="Flow_PDLC4" sourceRef="PDLC_Testing" targetRef="PDLC_GW_TestResult" />
        <bpmn:sequenceFlow id="Flow_PDLC_Yes" name="Yes" sourceRef="PDLC_GW_TestResult" targetRef="PDLC_Integration">
          <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=testsPassed = true</bpmn:conditionExpression>
        </bpmn:sequenceFlow>
        <bpmn:sequenceFlow id="Flow_PDLC_No" name="No" sourceRef="PDLC_GW_TestResult" targetRef="Gateway_0q35ha8" />
        <bpmn:sequenceFlow id="Flow_PDLC5" sourceRef="PDLC_Integration" targetRef="PDLC_End" />
        <bpmn:exclusiveGateway id="Gateway_0q35ha8">
          <bpmn:incoming>Flow_PDLC2</bpmn:incoming>
          <bpmn:incoming>Flow_PDLC_No</bpmn:incoming>
          <bpmn:outgoing>Flow_17ytyma</bpmn:outgoing>
        </bpmn:exclusiveGateway>
        <bpmn:sequenceFlow id="Flow_17ytyma" sourceRef="Gateway_0q35ha8" targetRef="PDLC_Development" />
      </bpmn:subProcess>
      <bpmn:userTask id="Task_ComplianceReview" name="Compliance&#10;Review">
        <bpmn:documentation>Enable pathway compliance-only review. For vendor affinity / strategic partnership requests, conduct a focused compliance review covering regulatory requirements, data protection, and contractual standards without full competitive evaluation.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp4-compliance-review-enable" />
          <zeebe:assignmentDefinition candidateGroups="compliance-lane" />
          <zeebe:properties>
            <zeebe:property name="raci_r" value="Compliance" />
            <zeebe:property name="raci_a" value="Governance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP4_Enable</bpmn:incoming>
        <bpmn:outgoing>Flow_SP4_Enable2</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:userTask id="Task_EnableContractExec" name="Execute&#10;Contract">
        <bpmn:documentation>Enable pathway contract execution. For vendor affinity requests, execute the contract using pre-negotiated master agreement terms. No competitive negotiation required — focus on compliance verification and contract activation.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp4-contract-deviation" />
          <zeebe:assignmentDefinition candidateGroups="contracting-lane" />
          <zeebe:properties>
            <zeebe:property name="raci_r" value="Contracting" />
            <zeebe:property name="raci_a" value="Contracting" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP4_Enable2</bpmn:incoming>
        <bpmn:outgoing>Flow_SP4_EnableMerge</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:userTask id="Task_ContractDeviation" name="Contract&#10;Deviation Check">
        <bpmn:documentation>Review and document any deviations from standard contract terms. Track deviation type, risk acceptance, and approval authority for audit trail.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp4-contract-deviation" />
          <zeebe:assignmentDefinition candidateGroups="contracting-lane" />
          <zeebe:properties>
            <zeebe:property name="raci_r" value="Contracting" />
            <zeebe:property name="raci_a" value="Governance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP4_BuyMerge</bpmn:incoming>
        <bpmn:outgoing>Flow_SP4_DeviationToGW</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:exclusiveGateway id="GW_MergeExec">
        <bpmn:incoming>Flow_SP4_BuildMerge</bpmn:incoming>
        <bpmn:incoming>Flow_SP4_EnableMerge</bpmn:incoming>
        <bpmn:incoming>Flow_0rbqh0s</bpmn:incoming>
        <bpmn:outgoing>Flow_1fshpro</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:serviceTask id="SendTask_SP4Complete" name="SP4&#10;Notification">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="status-notification" />
          <zeebe:properties>
            <zeebe:property name="phase" value="SP4_Complete" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1fshpro</bpmn:incoming>
        <bpmn:outgoing>Flow_SP4_Notify</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:sequenceFlow id="Flow_SP4_Notify" sourceRef="SendTask_SP4Complete" targetRef="SP4_End" />
      <bpmn:endEvent id="SP4_End">
        <bpmn:incoming>Flow_SP4_Notify</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_SP4_1" sourceRef="SP4_Start" targetRef="GW_PathwayExec" />
      <bpmn:sequenceFlow id="Flow_SP4_Buy" name="Buy" sourceRef="GW_PathwayExec" targetRef="Task_RefineRequirements" />
      <bpmn:sequenceFlow id="Flow_SP4_Build" name="Build" sourceRef="GW_PathwayExec" targetRef="Task_DefineBuildReqs">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=true</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_SP4_2" sourceRef="Task_RefineRequirements" targetRef="Task_PerformPoC" />
      <bpmn:sequenceFlow id="Flow_SP4_3" sourceRef="Task_PerformPoC" targetRef="Task_TechRiskEval" />
      <bpmn:sequenceFlow id="Flow_SP4_4" sourceRef="Task_TechRiskEval" targetRef="Task_NegotiateContract" />
      <bpmn:sequenceFlow id="Flow_SP4_5" sourceRef="Task_NegotiateContract" targetRef="Receive_SignedContract" />
      <bpmn:sequenceFlow id="Flow_SP4_6" sourceRef="Receive_SignedContract" targetRef="Task_FinalizeContract" />
      <bpmn:sequenceFlow id="Flow_SP4_BuyMerge" sourceRef="Task_FinalizeContract" targetRef="Task_ContractDeviation" />
      <bpmn:userTask id="Task_CodingCorrection" name="Coding Matrix&#10;Correction">
        <bpmn:documentation>Finance coding matrix correction for proper GL account assignment, cost center allocation, and budget line mapping.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:formDefinition formId="sp4-coding-correction" />
          <zeebe:assignmentDefinition candidateGroups="business-lane" />
          <zeebe:properties>
            <zeebe:property name="raci_r" value="Business" />
            <zeebe:property name="raci_a" value="Governance" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_SP4_CodingNo</bpmn:incoming>
        <bpmn:outgoing>Flow_SP4_CodeToMerge</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:sequenceFlow id="Flow_SP4_DeviationToGW" sourceRef="Task_ContractDeviation" targetRef="GW_CodingCorrect" />
      <bpmn:exclusiveGateway id="GW_CodingCorrect" name="Coding Matrix&#10;Correct?">
        <bpmn:incoming>Flow_SP4_DeviationToGW</bpmn:incoming>
        <bpmn:outgoing>Flow_SP4_CodingYes</bpmn:outgoing>
        <bpmn:outgoing>Flow_SP4_CodingNo</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:sequenceFlow id="Flow_SP4_CodingYes" name="Yes" sourceRef="GW_CodingCorrect" targetRef="Gateway_0m1ca2l">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=codingMatrixCorrect = true</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_SP4_CodingNo" name="No" sourceRef="GW_CodingCorrect" targetRef="Task_CodingCorrection">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=codingMatrixCorrect = false</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_SP4_CodeToMerge" sourceRef="Task_CodingCorrection" targetRef="Gateway_0m1ca2l" />
      <bpmn:sequenceFlow id="Flow_SP4_Enable" name="Enable" sourceRef="GW_PathwayExec" targetRef="Task_ComplianceReview">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=selectedPathway = "Enable"</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_SP4_Enable2" sourceRef="Task_ComplianceReview" targetRef="Task_EnableContractExec" />
      <bpmn:sequenceFlow id="Flow_SP4_EnableMerge" sourceRef="Task_EnableContractExec" targetRef="GW_MergeExec" />
      <bpmn:sequenceFlow id="Flow_SP4_7" sourceRef="Task_DefineBuildReqs" targetRef="SP_PDLC" />
      <bpmn:sequenceFlow id="Flow_SP4_BuildMerge" sourceRef="SP_PDLC" targetRef="GW_MergeExec" />
      <bpmn:sequenceFlow id="Flow_SP4_SLA" sourceRef="Timer_ContractSLA" targetRef="End_ContractSLABreach" />
      <bpmn:sequenceFlow id="Flow_1fshpro" sourceRef="GW_MergeExec" targetRef="SendTask_SP4Complete" />
      <bpmn:exclusiveGateway id="Gateway_0m1ca2l">
        <bpmn:incoming>Flow_SP4_CodeToMerge</bpmn:incoming>
        <bpmn:incoming>Flow_SP4_CodingYes</bpmn:incoming>
        <bpmn:outgoing>Flow_0rbqh0s</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:sequenceFlow id="Flow_0rbqh0s" sourceRef="Gateway_0m1ca2l" targetRef="GW_MergeExec" />
    </bpmn:subProcess>
