<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_OB_Phase1Intake"
                  targetNamespace="http://sla.governance/bpmn/onboarding"
                  exporter="Camunda Modeler"
                  exporterVersion="5.25.0">

  <bpmn:collaboration id="Collaboration_OB_Phase1">
    <bpmn:participant id="Participant_EnterpriseGovernance" name="Enterprise Governance" processRef="Process_OB_Phase1_Intake" />
    <bpmn:participant id="Participant_VendorThirdParty" name="Vendor / Third Party" />
  </bpmn:collaboration>

  <bpmn:process id="Process_OB_Phase1_Intake" name="OB Phase 1: Initiation and Intake" isExecutable="false" camunda:historyTimeToLive="180">

    <bpmn:laneSet id="LaneSet_OB_Phase1">
      <bpmn:lane id="Lane_Business" name="Business">
        <bpmn:flowNodeRef>OB_StartEvent_IntakeRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Task_1_1_InitiativeRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_BoundaryEvent_PhaseSLA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_EndEvent_SLAEscalation</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Governance" name="Governance" />
      <bpmn:lane id="Lane_Contracting" name="Contracting" />
      <bpmn:lane id="Lane_TechnicalAssessment" name="Technical Assessment" />
      <bpmn:lane id="Lane_AIReview" name="AI Review" />
      <bpmn:lane id="Lane_Compliance" name="Compliance" />
      <bpmn:lane id="Lane_Oversight" name="Oversight" />
      <bpmn:lane id="Lane_Automation" name="Automation">
        <bpmn:flowNodeRef>OB_Task_1_2_AIPreScreening</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Task_1_3_PreliminaryCategorization</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Task_1_4_CapabilityReuseAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Task_1_5_KnowledgeHarvesting</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Task_1_6_RoutingAssignment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_EndEvent_Phase1Complete</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="OB_StartEvent_IntakeRequest" name="Onboarding&#10;Intake Request&#10;Received">
      <bpmn:outgoing>OB_Flow_Start_1_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="OB_MsgDef_IntakeRequest" />
    </bpmn:startEvent>

    <bpmn:userTask id="OB_Task_1_1_InitiativeRequest" name="1.1 Initiative&#10;Request Submission"
        camunda:candidateGroups="business-lane">
      <bpmn:incoming>OB_Flow_Start_1_1</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_1_1_1_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="OB_BoundaryEvent_PhaseSLA" name="1 Day&#10;Phase SLA"
        attachedToRef="OB_Task_1_1_InitiativeRequest" cancelActivity="false">
      <bpmn:outgoing>OB_Flow_SLA_Escalation</bpmn:outgoing>
      <bpmn:timerEventDefinition id="OB_TimerDef_PhaseSLA">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:endEvent id="OB_EndEvent_SLAEscalation" name="Phase SLA&#10;Escalation">
      <bpmn:incoming>OB_Flow_SLA_Escalation</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:serviceTask id="OB_Task_1_2_AIPreScreening" name="1.2 AI&#10;Pre-Screening"
        camunda:type="external" camunda:topic="ai-prescreening">
      <bpmn:incoming>OB_Flow_1_1_1_2</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_1_2_1_3</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="OB_Task_1_3_PreliminaryCategorization" name="1.3 Preliminary&#10;Categorization"
        camunda:type="external" camunda:topic="initiative-categorization">
      <bpmn:incoming>OB_Flow_1_2_1_3</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_1_3_1_4</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="OB_Task_1_4_CapabilityReuseAssessment" name="1.4 Capability&#10;Reuse Assessment"
        camunda:type="external" camunda:topic="capability-reuse-assessment">
      <bpmn:incoming>OB_Flow_1_3_1_4</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_1_4_1_5</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="OB_Task_1_5_KnowledgeHarvesting" name="1.5 Knowledge&#10;Harvesting"
        camunda:type="external" camunda:topic="knowledge-harvesting">
      <bpmn:incoming>OB_Flow_1_4_1_5</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_1_5_1_6</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:businessRuleTask id="OB_Task_1_6_RoutingAssignment" name="1.6 Routing&#10;Assignment"
        camunda:decisionRef="OB_DMN_PathwayRouting"
        camunda:decisionRefBinding="latest"
        camunda:resultVariable="selectedPathway"
        camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>OB_Flow_1_5_1_6</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_1_6_End</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:endEvent id="OB_EndEvent_Phase1Complete" name="Phase 1 Complete&#10;(Proceed to Phase 2)">
      <bpmn:incoming>OB_Flow_1_6_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="OB_Flow_Start_1_1" sourceRef="OB_StartEvent_IntakeRequest" targetRef="OB_Task_1_1_InitiativeRequest" />
    <bpmn:sequenceFlow id="OB_Flow_1_1_1_2" sourceRef="OB_Task_1_1_InitiativeRequest" targetRef="OB_Task_1_2_AIPreScreening" />
    <bpmn:sequenceFlow id="OB_Flow_SLA_Escalation" sourceRef="OB_BoundaryEvent_PhaseSLA" targetRef="OB_EndEvent_SLAEscalation" />
    <bpmn:sequenceFlow id="OB_Flow_1_2_1_3" sourceRef="OB_Task_1_2_AIPreScreening" targetRef="OB_Task_1_3_PreliminaryCategorization" />
    <bpmn:sequenceFlow id="OB_Flow_1_3_1_4" sourceRef="OB_Task_1_3_PreliminaryCategorization" targetRef="OB_Task_1_4_CapabilityReuseAssessment" />
    <bpmn:sequenceFlow id="OB_Flow_1_4_1_5" sourceRef="OB_Task_1_4_CapabilityReuseAssessment" targetRef="OB_Task_1_5_KnowledgeHarvesting" />
    <bpmn:sequenceFlow id="OB_Flow_1_5_1_6" sourceRef="OB_Task_1_5_KnowledgeHarvesting" targetRef="OB_Task_1_6_RoutingAssignment" />
    <bpmn:sequenceFlow id="OB_Flow_1_6_End" sourceRef="OB_Task_1_6_RoutingAssignment" targetRef="OB_EndEvent_Phase1Complete" />

    <bpmn:textAnnotation id="OB_Annotation_TaskIO">
      <bpmn:text>Task I/O: 1.1 IN(vendorName, initiativeTitle, businessJustification, estimatedValue) OUT(initiativeId, submissionTimestamp) | 1.2 IN(initiativeId, vendorName) OUT(riskSignals[], vendorReputationScore, sanctionsMatch) | 1.3 IN(riskSignals[], aiFlags[]) OUT(initiativeCategory, isAIInitiative, softwareAssetType) | 1.4 IN(initiativeCategory) OUT(capabilityReuseScore, existingCapabilityId) | 1.5 IN(initiativeId, vendorName) OUT(knowledgeBaseEntryId) | 1.6 IN(capabilityReuseScore, buildVsBuyAnalysis, orgCapacity, strategicAlignment, timeToValue, isExistingVendor) OUT(selectedPathway)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="OB_Assoc_TaskIO" sourceRef="OB_Task_1_2_AIPreScreening" targetRef="OB_Annotation_TaskIO" />

    <bpmn:textAnnotation id="OB_Annotation_Regulatory">
      <bpmn:text>Regulatory: OCC 2023-17 (vendor reputation scan) | GDPR/CCPA (data classification flags) | EU AI Act (AI system classification) | SR 11-7 (model risk identification)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="OB_Assoc_Regulatory" sourceRef="OB_Task_1_3_PreliminaryCategorization" targetRef="OB_Annotation_Regulatory" />

    <bpmn:textAnnotation id="OB_Annotation_SLA">
      <bpmn:text>Onboarding SLA: 1 day (accelerated from 2-day standard) | Automation Target: 75% | Activities 1.2-1.6 fully automated</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="OB_Assoc_SLA" sourceRef="OB_Task_1_5_KnowledgeHarvesting" targetRef="OB_Annotation_SLA" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_OB_Phase1">
    <bpmndi:BPMNPlane id="BPMNPlane_OB_Phase1" bpmnElement="Collaboration_OB_Phase1">

      <bpmndi:BPMNShape id="Participant_EnterpriseGovernance_di" bpmnElement="Participant_EnterpriseGovernance" isHorizontal="true">
        <dc:Bounds x="155" y="47" width="1620" height="1210" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Lane_Business_di" bpmnElement="Lane_Business" isHorizontal="true">
        <dc:Bounds x="185" y="47" width="1590" height="125" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Governance_di" bpmnElement="Lane_Governance" isHorizontal="true">
        <dc:Bounds x="185" y="172" width="1590" height="125" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Contracting_di" bpmnElement="Lane_Contracting" isHorizontal="true">
        <dc:Bounds x="185" y="297" width="1590" height="125" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_TechnicalAssessment_di" bpmnElement="Lane_TechnicalAssessment" isHorizontal="true">
        <dc:Bounds x="185" y="422" width="1590" height="125" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_AIReview_di" bpmnElement="Lane_AIReview" isHorizontal="true">
        <dc:Bounds x="185" y="547" width="1590" height="125" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Compliance_di" bpmnElement="Lane_Compliance" isHorizontal="true">
        <dc:Bounds x="185" y="672" width="1590" height="125" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Oversight_di" bpmnElement="Lane_Oversight" isHorizontal="true">
        <dc:Bounds x="185" y="797" width="1590" height="125" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Automation_di" bpmnElement="Lane_Automation" isHorizontal="true">
        <dc:Bounds x="185" y="922" width="1590" height="125" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_StartEvent_IntakeRequest_di" bpmnElement="OB_StartEvent_IntakeRequest">
        <dc:Bounds x="248" y="91" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="225" y="134" width="83" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_Task_1_1_di" bpmnElement="OB_Task_1_1_InitiativeRequest">
        <dc:Bounds x="340" y="69" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_BoundaryEvent_PhaseSLA_di" bpmnElement="OB_BoundaryEvent_PhaseSLA">
        <dc:Bounds x="372" y="131" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="416" y="135" width="48" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_EndEvent_SLAEscalation_di" bpmnElement="OB_EndEvent_SLAEscalation">
        <dc:Bounds x="460" y="131" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="504" y="135" width="73" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_Task_1_2_di" bpmnElement="OB_Task_1_2_AIPreScreening">
        <dc:Bounds x="520" y="944" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_Task_1_3_di" bpmnElement="OB_Task_1_3_PreliminaryCategorization">
        <dc:Bounds x="680" y="944" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_Task_1_4_di" bpmnElement="OB_Task_1_4_CapabilityReuseAssessment">
        <dc:Bounds x="840" y="944" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_Task_1_5_di" bpmnElement="OB_Task_1_5_KnowledgeHarvesting">
        <dc:Bounds x="1000" y="944" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_Task_1_6_di" bpmnElement="OB_Task_1_6_RoutingAssignment">
        <dc:Bounds x="1160" y="944" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_EndEvent_Phase1Complete_di" bpmnElement="OB_EndEvent_Phase1Complete">
        <dc:Bounds x="1332" y="966" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1309" y="1009" width="83" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_Annotation_TaskIO_di" bpmnElement="OB_Annotation_TaskIO">
        <dc:Bounds x="230" y="1060" width="700" height="55" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_Annotation_Regulatory_di" bpmnElement="OB_Annotation_Regulatory">
        <dc:Bounds x="230" y="1125" width="700" height="40" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_Annotation_SLA_di" bpmnElement="OB_Annotation_SLA">
        <dc:Bounds x="230" y="1175" width="500" height="40" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="OB_Flow_Start_1_1_di" bpmnElement="OB_Flow_Start_1_1">
        <di:waypoint x="284" y="109" />
        <di:waypoint x="340" y="109" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="OB_Flow_1_1_1_2_di" bpmnElement="OB_Flow_1_1_1_2">
        <di:waypoint x="440" y="109" />
        <di:waypoint x="480" y="109" />
        <di:waypoint x="480" y="984" />
        <di:waypoint x="520" y="984" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="OB_Flow_SLA_Escalation_di" bpmnElement="OB_Flow_SLA_Escalation">
        <di:waypoint x="408" y="149" />
        <di:waypoint x="460" y="149" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="OB_Flow_1_2_1_3_di" bpmnElement="OB_Flow_1_2_1_3">
        <di:waypoint x="620" y="984" />
        <di:waypoint x="680" y="984" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="OB_Flow_1_3_1_4_di" bpmnElement="OB_Flow_1_3_1_4">
        <di:waypoint x="780" y="984" />
        <di:waypoint x="840" y="984" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="OB_Flow_1_4_1_5_di" bpmnElement="OB_Flow_1_4_1_5">
        <di:waypoint x="940" y="984" />
        <di:waypoint x="1000" y="984" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="OB_Flow_1_5_1_6_di" bpmnElement="OB_Flow_1_5_1_6">
        <di:waypoint x="1100" y="984" />
        <di:waypoint x="1160" y="984" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="OB_Flow_1_6_End_di" bpmnElement="OB_Flow_1_6_End">
        <di:waypoint x="1260" y="984" />
        <di:waypoint x="1332" y="984" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="OB_Assoc_TaskIO_di" bpmnElement="OB_Assoc_TaskIO">
        <di:waypoint x="570" y="1024" />
        <di:waypoint x="570" y="1060" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="OB_Assoc_Regulatory_di" bpmnElement="OB_Assoc_Regulatory">
        <di:waypoint x="730" y="1024" />
        <di:waypoint x="730" y="1125" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="OB_Assoc_SLA_di" bpmnElement="OB_Assoc_SLA">
        <di:waypoint x="1050" y="1024" />
        <di:waypoint x="1050" y="1175" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNShape id="Participant_VendorThirdParty_di" bpmnElement="Participant_VendorThirdParty" isHorizontal="true">
        <dc:Bounds x="155" y="1300" width="1620" height="125" />
      </bpmndi:BPMNShape>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
