{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "Form_DefineBuildReqs",
  "components": [
    {
      "type": "text",
      "text": "## Define Build Requirements",
      "id": "Field_001"
    },
    {
      "type": "group",
      "label": "Build Requirements",
      "id": "Field_002",
      "components": [
        {
          "type": "textarea",
          "key": "solutionArchitecture",
          "label": "Solution Architecture",
          "validate": {
            "required": true
          },
          "id": "Field_003"
        },
        {
          "type": "textarea",
          "key": "functionalRequirements",
          "label": "Functional Requirements",
          "validate": {
            "required": true
          },
          "id": "Field_004"
        },
        {
          "type": "textarea",
          "key": "nonFunctionalRequirements",
          "label": "Non-Functional Requirements",
          "validate": {
            "required": true
          },
          "id": "Field_005"
        },
        {
          "type": "textarea",
          "key": "securityRequirements",
          "label": "Security Requirements",
          "validate": {
            "required": true
          },
          "id": "Field_006"
        },
        {
          "type": "textarea",
          "key": "privacyRequirements",
          "label": "Privacy Requirements",
          "id": "Field_007"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_008"
    },
    {
      "type": "group",
      "label": "Build Planning",
      "id": "Field_009",
      "components": [
        {
          "type": "textfield",
          "key": "estimatedDevelopmentEffort",
          "label": "Estimated Development Effort",
          "validate": {
            "required": true
          },
          "id": "Field_010"
        },
        {
          "type": "textfield",
          "key": "technologyStack",
          "label": "Technology Stack",
          "validate": {
            "required": true
          },
          "id": "Field_011"
        },
        {
          "type": "textarea",
          "key": "teamComposition",
          "label": "Team Composition",
          "id": "Field_012"
        },
        {
          "type": "textarea",
          "key": "sprintIterationPlan",
          "label": "Sprint/Iteration Plan",
          "id": "Field_013"
        },
        {
          "type": "textarea",
          "key": "definitionOfDone",
          "label": "Definition of Done",
          "validate": {
            "required": true
          },
          "id": "Field_014"
        }
      ]
    },
    {
      "type": "separator",
      "id": "Field_015"
    },
    {
      "type": "radio",
      "key": "buildRequirementsApproved",
      "label": "Build Requirements Approved?",
      "validate": {
        "required": true
      },
      "values": [
        {
          "label": "Yes",
          "value": "yes"
        },
        {
          "label": "No",
          "value": "no"
        }
      ],
      "id": "Field_016"
    }
  ],
  "type": "default"
}
