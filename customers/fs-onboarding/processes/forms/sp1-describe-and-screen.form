{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "Form_DescribeAndScreen",
  "components": [
    {
      "type": "text",
      "text": "## Describe & Screen Need\nCapture the business need, screen against existing solutions, and certify the submission. This combines intake, portfolio screening, and submission into a single step.",
      "id": "Field_DS01"
    },
    {
      "type": "separator",
      "id": "Field_DS02"
    },
    {
      "type": "group",
      "label": "Business Need",
      "components": [
        {
          "type": "textarea",
          "key": "businessProblem",
          "label": "Business Problem Description",
          "validate": {
            "required": true
          },
          "description": "Describe the business problem or opportunity this software addresses.",
          "id": "Field_DS03"
        },
        {
          "type": "select",
          "key": "urgencyLevel",
          "label": "Urgency",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Critical \u2014 regulatory deadline or compliance gap",
              "value": "critical"
            },
            {
              "label": "High \u2014 significant business impact if delayed",
              "value": "high"
            },
            {
              "label": "Standard \u2014 normal business priority",
              "value": "standard"
            },
            {
              "label": "Exploratory \u2014 research or proof of concept",
              "value": "exploratory"
            }
          ],
          "id": "Field_DS04"
        },
        {
          "type": "select",
          "key": "pathwayPreference",
          "label": "Pathway Preference",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Buy \u2014 procure from vendor",
              "value": "buy"
            },
            {
              "label": "Build \u2014 develop internally",
              "value": "build"
            },
            {
              "label": "Hybrid \u2014 combination of buy and build",
              "value": "hybrid"
            },
            {
              "label": "Unsure \u2014 need evaluation",
              "value": "unsure"
            }
          ],
          "id": "Field_DS05"
        },
        {
          "type": "textarea",
          "key": "intendedUseCases",
          "label": "Intended Use Cases",
          "validate": {
            "required": true
          },
          "description": "Describe how the software will be used and by whom.",
          "id": "Field_DS06"
        },
        {
          "type": "select",
          "key": "criticality",
          "label": "Business Criticality",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Critical \u2014 failure causes significant financial or regulatory impact",
              "value": "critical"
            },
            {
              "label": "Significant \u2014 failure disrupts key business processes",
              "value": "significant"
            },
            {
              "label": "Moderate \u2014 failure causes inconvenience but workarounds exist",
              "value": "moderate"
            },
            {
              "label": "Low \u2014 minimal business impact if unavailable",
              "value": "low"
            }
          ],
          "id": "Field_DS07"
        }
      ],
      "id": "Field_DS08"
    },
    {
      "type": "separator",
      "id": "Field_DS09"
    },
    {
      "type": "group",
      "label": "Financial Information",
      "components": [
        {
          "type": "select",
          "key": "estimatedBudget",
          "label": "Estimated Annual Budget",
          "values": [
            {
              "label": "Under $25,000",
              "value": "under25k"
            },
            {
              "label": "$25,000 - $100,000",
              "value": "25k-100k"
            },
            {
              "label": "$100,000 - $500,000",
              "value": "100k-500k"
            },
            {
              "label": "Over $500,000",
              "value": "500k+"
            },
            {
              "label": "Unknown",
              "value": "unknown"
            }
          ],
          "id": "Field_DS10"
        },
        {
          "type": "textfield",
          "key": "costCenter",
          "label": "Cost Center",
          "id": "Field_DS11"
        }
      ],
      "id": "Field_DS12"
    },
    {
      "type": "separator",
      "id": "Field_DS13"
    },
    {
      "type": "group",
      "label": "Data and Compliance",
      "components": [
        {
          "type": "radio",
          "key": "hasAI",
          "label": "Does this software involve AI/ML capabilities?",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            },
            {
              "label": "Unsure",
              "value": "unsure"
            }
          ],
          "id": "Field_DS14"
        },
        {
          "type": "checklist",
          "key": "dataTypes",
          "label": "Data Types Processed",
          "values": [
            {
              "label": "PII (Personally Identifiable Information)",
              "value": "PII"
            },
            {
              "label": "PHI (Protected Health Information)",
              "value": "PHI"
            },
            {
              "label": "Financial / SOX-regulated",
              "value": "Financial"
            },
            {
              "label": "Public / Non-sensitive",
              "value": "Public"
            },
            {
              "label": "Intellectual Property",
              "value": "IP"
            },
            {
              "label": "Other Regulated Data",
              "value": "OtherRegulated"
            }
          ],
          "id": "Field_DS15"
        },
        {
          "type": "checklist",
          "key": "applicableRegulations",
          "label": "Applicable Regulations",
          "values": [
            {
              "label": "GDPR",
              "value": "GDPR"
            },
            {
              "label": "CCPA",
              "value": "CCPA"
            },
            {
              "label": "HIPAA",
              "value": "HIPAA"
            },
            {
              "label": "SOX",
              "value": "SOX"
            },
            {
              "label": "EU AI Act",
              "value": "EU_AI_Act"
            },
            {
              "label": "DORA",
              "value": "DORA"
            },
            {
              "label": "OCC 2023-17",
              "value": "OCC_2023_17"
            }
          ],
          "id": "Field_DS16"
        }
      ],
      "id": "Field_DS17"
    },
    {
      "type": "separator",
      "id": "Field_DS18"
    },
    {
      "type": "group",
      "label": "Organizational Details",
      "components": [
        {
          "type": "textfield",
          "key": "businessUnit",
          "label": "Business Unit",
          "validate": {
            "required": true
          },
          "id": "Field_DS19"
        },
        {
          "type": "number",
          "key": "expectedUserCount",
          "label": "Expected User Count",
          "id": "Field_DS20"
        },
        {
          "type": "select",
          "key": "deploymentModel",
          "label": "Deployment Model Preference",
          "values": [
            {
              "label": "Cloud (SaaS)",
              "value": "cloud"
            },
            {
              "label": "On-Premise",
              "value": "on-premise"
            },
            {
              "label": "Hybrid",
              "value": "hybrid"
            }
          ],
          "id": "Field_DS21"
        },
        {
          "type": "textarea",
          "key": "integrationRequirements",
          "label": "Integration Requirements",
          "description": "Describe systems this software must integrate with.",
          "id": "Field_DS22"
        }
      ],
      "id": "Field_DS23"
    },
    {
      "type": "separator",
      "id": "Field_DS24"
    },
    {
      "type": "group",
      "label": "Executive Sponsor",
      "components": [
        {
          "type": "textfield",
          "key": "executiveSponsorName",
          "label": "Executive Sponsor Name",
          "validate": {
            "required": true
          },
          "id": "Field_DS25"
        },
        {
          "type": "textfield",
          "key": "executiveSponsorEmail",
          "label": "Executive Sponsor Email",
          "id": "Field_DS26"
        }
      ],
      "id": "Field_DS27"
    },
    {
      "type": "separator",
      "id": "Field_DS28"
    },
    {
      "type": "group",
      "label": "Existing Solution Screening",
      "components": [
        {
          "type": "text",
          "text": "Search the enterprise software catalog for existing solutions that may fulfill the need before initiating a new procurement or build.",
          "id": "Field_DS29"
        },
        {
          "type": "textarea",
          "key": "catalogSearchResults",
          "label": "Search Results from Software Catalog",
          "description": "Paste or summarize results from the enterprise software catalog search.",
          "id": "Field_DS30"
        },
        {
          "type": "radio",
          "key": "existingSolutionFound",
          "label": "Existing Solution Found?",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "id": "Field_DS31"
        },
        {
          "type": "textfield",
          "key": "existingSolutionName",
          "label": "Existing Solution Name",
          "conditional": {
            "hide": "=existingSolutionFound != \"yes\""
          },
          "id": "Field_DS32"
        },
        {
          "type": "textfield",
          "key": "existingSolutionVersion",
          "label": "Version",
          "conditional": {
            "hide": "=existingSolutionFound != \"yes\""
          },
          "id": "Field_DS33"
        },
        {
          "type": "textfield",
          "key": "existingLicenseStatus",
          "label": "License Status",
          "conditional": {
            "hide": "=existingSolutionFound != \"yes\""
          },
          "id": "Field_DS34"
        },
        {
          "type": "number",
          "key": "existingUtilizationRate",
          "label": "Current Utilization Rate (%)",
          "conditional": {
            "hide": "=existingSolutionFound != \"yes\""
          },
          "id": "Field_DS35"
        },
        {
          "type": "textarea",
          "key": "gapAnalysis",
          "label": "Gap Analysis",
          "description": "What does the existing solution cover vs. what is missing?",
          "conditional": {
            "hide": "=existingSolutionFound != \"yes\""
          },
          "id": "Field_DS36"
        },
        {
          "type": "radio",
          "key": "existingSolutionSufficient",
          "label": "Is the existing solution sufficient?",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Sufficient \u2014 can be leveraged as-is or with minor configuration",
              "value": "sufficient"
            },
            {
              "label": "Insufficient \u2014 new procurement or build required",
              "value": "insufficient"
            }
          ],
          "conditional": {
            "hide": "=existingSolutionFound != \"yes\""
          },
          "id": "Field_DS37"
        },
        {
          "type": "number",
          "key": "estimatedCostAvoidance",
          "label": "Estimated Cost Avoidance if Leveraged ($)",
          "conditional": {
            "hide": "=existingSolutionFound != \"yes\""
          },
          "id": "Field_DS38"
        }
      ],
      "id": "Field_DS39"
    },
    {
      "type": "separator",
      "id": "Field_DS40"
    },
    {
      "type": "group",
      "label": "Certification",
      "components": [
        {
          "type": "checkbox",
          "key": "submitterCertification",
          "label": "I certify the information provided is accurate and complete",
          "validate": {
            "required": true
          },
          "id": "Field_DS41"
        },
        {
          "type": "textfield",
          "key": "submitterName",
          "label": "Submitter Name",
          "validate": {
            "required": true
          },
          "id": "Field_DS42"
        },
        {
          "type": "textfield",
          "key": "submitterTitle",
          "label": "Submitter Title",
          "id": "Field_DS43"
        }
      ],
      "id": "Field_DS44"
    }
  ],
  "type": "default"
}