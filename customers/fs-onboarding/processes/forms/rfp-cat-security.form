{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "Form_RFP_Cat3",
  "components": [
    {
      "type": "text",
      "text": "## Category 3: Security and Compliance\nSecurity posture, certifications, and compliance controls.\n\n**Governance topics**: Cyber, Compliance, TPRM",
      "id": "Field_Cat3_Header"
    },
    {
      "type": "separator",
      "id": "Field_Cat3_Sep1"
    },
    {
      "id": "Field_C3_1",
      "label": "C3.1: ISO 27001 certification status and expiry",
      "type": "textarea",
      "key": "c3_1"
    },
    {
      "id": "Field_C3_2",
      "label": "C3.2: SOC 2 Type II report available",
      "type": "radio",
      "key": "c3_2",
      "values": [
        {
          "label": "Yes",
          "value": "yes"
        },
        {
          "label": "No",
          "value": "no"
        },
        {
          "label": "Partial",
          "value": "partial"
        }
      ]
    },
    {
      "id": "Field_C3_3",
      "label": "C3.3: Encryption at rest \u2014 algorithm and key length",
      "type": "textfield",
      "key": "c3_3"
    },
    {
      "id": "Field_C3_4",
      "label": "C3.4: Encryption in transit \u2014 protocol",
      "type": "textfield",
      "key": "c3_4"
    },
    {
      "id": "Field_C3_5",
      "label": "C3.5: MFA enforcement percentage",
      "type": "textfield",
      "key": "c3_5"
    },
    {
      "id": "Field_C3_6",
      "label": "C3.6: Incident response SLA",
      "type": "textfield",
      "key": "c3_6"
    },
    {
      "id": "Field_C3_7",
      "label": "C3.7: Security breaches in past 3 years",
      "type": "textarea",
      "key": "c3_7"
    },
    {
      "id": "Field_C3_8",
      "label": "C3.8: Vulnerability disclosure policy",
      "type": "radio",
      "key": "c3_8",
      "values": [
        {
          "label": "Yes",
          "value": "yes"
        },
        {
          "label": "No",
          "value": "no"
        },
        {
          "label": "Partial",
          "value": "partial"
        }
      ]
    },
    {
      "id": "Field_C3_9",
      "label": "C3.9: Privileged access management",
      "type": "textarea",
      "key": "c3_9"
    },
    {
      "id": "Field_C3_10",
      "label": "C3.10: Access review frequency",
      "type": "textfield",
      "key": "c3_10"
    },
    {
      "id": "Field_C3_11",
      "label": "C3.11: Last penetration test date and executive summary",
      "type": "textarea",
      "key": "c3_11"
    },
    {
      "id": "Field_C3_12",
      "label": "C3.12: Mean time to patch critical vulnerabilities",
      "type": "textfield",
      "key": "c3_12"
    },
    {
      "id": "Field_C3_13",
      "label": "C3.13: BCP/DR plan",
      "type": "radio",
      "key": "c3_13",
      "values": [
        {
          "label": "Yes",
          "value": "yes"
        },
        {
          "label": "No",
          "value": "no"
        },
        {
          "label": "Partial",
          "value": "partial"
        }
      ]
    },
    {
      "id": "Field_C3_14",
      "label": "C3.14: RTO and RPO commitments",
      "type": "textfield",
      "key": "c3_14"
    },
    {
      "id": "Field_C3_15",
      "label": "C3.15: DR test frequency",
      "type": "textfield",
      "key": "c3_15"
    },
    {
      "id": "Field_C3_16",
      "label": "C3.16: SSO/SAML/OIDC integration support",
      "type": "checklist",
      "key": "c3_16",
      "values": [
        {
          "label": "SSO",
          "value": "sso"
        },
        {
          "label": "SAML 2.0",
          "value": "saml_2.0"
        },
        {
          "label": "OIDC",
          "value": "oidc"
        },
        {
          "label": "LDAP",
          "value": "ldap"
        },
        {
          "label": "None",
          "value": "none"
        }
      ]
    },
    {
      "id": "Field_C3_17",
      "label": "C3.17: PCI DSS compliance",
      "type": "radio",
      "key": "c3_17",
      "values": [
        {
          "label": "Yes",
          "value": "yes"
        },
        {
          "label": "No",
          "value": "no"
        },
        {
          "label": "Partial",
          "value": "partial"
        }
      ]
    },
    {
      "id": "Field_C3_18",
      "label": "C3.18: Data center locations and certifications",
      "type": "textarea",
      "key": "c3_18"
    },
    {
      "id": "Field_C3_19",
      "label": "C3.19: Security Operations Center (SOC) \u2014 24/7 monitoring",
      "type": "textarea",
      "key": "c3_19"
    },
    {
      "id": "Field_C3_20",
      "label": "C3.20: Third-party security audit frequency",
      "type": "textfield",
      "key": "c3_20"
    },
    {
      "id": "Field_C3_21",
      "label": "C3.21: Supply chain security controls",
      "type": "textarea",
      "key": "c3_21"
    },
    {
      "id": "Field_C3_22",
      "label": "C3.22: FedRAMP or equivalent government certification",
      "type": "radio",
      "key": "c3_22",
      "values": [
        {
          "label": "Yes",
          "value": "yes"
        },
        {
          "label": "No",
          "value": "no"
        },
        {
          "label": "Partial",
          "value": "partial"
        }
      ]
    },
    {
      "id": "Field_C3_23",
      "label": "C3.23: Adversarial attack evaluation (model inversion, prompt injection)",
      "type": "textarea",
      "key": "c3_23"
    },
    {
      "id": "Field_C3_24",
      "label": "C3.24: Model drift and data poisoning detection controls",
      "type": "textarea",
      "key": "c3_24"
    },
    {
      "id": "Field_C3_25",
      "label": "C3.25: Network segmentation and micro-segmentation",
      "type": "textarea",
      "key": "c3_25"
    },
    {
      "type": "separator",
      "id": "Field_Cat3_EvidSep"
    },
    {
      "type": "text",
      "text": "### Evidence Uploads\nPlease attach relevant certifications, audit reports, or assessment summaries below.",
      "id": "Field_Cat3_EvidHeader"
    },
    {
      "type": "textarea",
      "key": "cat3_evidence_description",
      "label": "Evidence Description",
      "description": "List the documents you are attaching (e.g., SOC 2 Type II report, ISO 27001 certificate).",
      "id": "Field_Cat3_EvidDesc"
    }
  ]
