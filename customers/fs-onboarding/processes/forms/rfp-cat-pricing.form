    },
    {
      "type": "separator",
      "id": "Field_Cat7_Sep1"
    },
    {
      "id": "Field_C7_1",
      "label": "C7.1: Pricing model",
      "type": "select",
      "key": "c7_1",
      "values": [
        {
          "label": "Per User",
          "value": "per_user"
        },
        {
          "label": "Per Transaction",
          "value": "per_transaction"
        },
        {
          "label": "Flat Fee",
          "value": "flat_fee"
        },
        {
          "label": "Consumption-based",
          "value": "consumption-based"
        },
        {
          "label": "Enterprise License",
          "value": "enterprise_license"
        }
      ]
    },
    {
