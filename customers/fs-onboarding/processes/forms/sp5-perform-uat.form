{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "Form_PerformUAT",
  "components": [
    {
      "type": "group",
      "label": "UAT Execution",
      "id": "Field_001",
      "components": [
        {
          "type": "radio",
          "key": "uatPlanExecuted",
          "label": "UAT plan executed",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "validate": {
            "required": true
          },
          "id": "Field_002"
        },
        {
          "type": "number",
          "key": "testScenariosTotal",
          "label": "Test scenarios total",
          "validate": {
            "required": true
          },
          "id": "Field_003"
        },
        {
          "type": "number",
          "key": "testScenariosPassed",
          "label": "Test scenarios passed",
          "validate": {
            "required": true
          },
          "id": "Field_004"
        },
        {
          "type": "number",
          "key": "testScenariosFailed",
          "label": "Test scenarios failed",
          "validate": {
            "required": true
          },
          "id": "Field_005"
        },
        {
          "type": "number",
          "key": "criticalDefectsFound",
          "label": "Critical defects found",
          "validate": {
            "required": true
          },
          "id": "Field_006"
        },
        {
          "type": "number",
          "key": "defectsResolvedBeforeSignoff",
          "label": "Defects resolved before sign-off",
          "id": "Field_007"
        },
        {
          "type": "textarea",
          "key": "defectsDeferredWithRiskAcceptance",
          "label": "Defects deferred with risk acceptance",
          "id": "Field_008"
        }
      ]
    },
    {
      "type": "group",
      "label": "User Feedback",
      "id": "Field_009",
      "components": [
        {
          "type": "number",
          "key": "pilotUserCount",
          "label": "Pilot user count",
          "id": "Field_010"
        },
        {
          "type": "number",
          "key": "pilotDurationDays",
          "label": "Pilot duration days",
          "id": "Field_011"
        },
        {
          "type": "number",
          "key": "userSatisfactionScore",
          "label": "User satisfaction score (1-10)",
          "id": "Field_012"
        },
        {
          "type": "textarea",
          "key": "userFeedbackSummary",
          "label": "User feedback summary",
          "validate": {
            "required": true
          },
          "id": "Field_013"
        }
      ]
    },
    {
      "type": "group",
      "label": "UAT Decision",
      "id": "Field_014",
      "components": [
        {
          "type": "textfield",
          "key": "trainingCompletionRate",
          "label": "Training completion rate",
          "id": "Field_015"
        },
        {
          "type": "radio",
          "key": "uatSignOff",
          "label": "UAT sign-off",
          "values": [
            {
              "label": "Yes",
              "value": "yes"
            },
            {
              "label": "No",
              "value": "no"
            }
          ],
          "validate": {
            "required": true
          },
          "id": "Field_016"
        },
        {
          "type": "textfield",
          "key": "businessOwnerSignOffName",
          "label": "Business owner sign-off name",
          "validate": {
            "required": true
          },
          "id": "Field_017"
        },
        {
          "type": "textarea",
          "key": "uatNotes",
          "label": "UAT notes",
          "id": "Field_018"
        }
      ]
    }
  ],
  "type": "default"
}
