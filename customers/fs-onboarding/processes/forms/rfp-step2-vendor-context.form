{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.28.0"
  },
  "schemaVersion": 16,
  "id": "Form_RFP_Step2",
  "components": [
    {
      "type": "text",
      "text": "## Step 2: Vendor Context\nTell us about the vendor and deployment context. This refines which questions are selected and at what depth.",
      "id": "Field_S2_01"
    },
    {
      "type": "separator",
      "id": "Field_S2_02"
    },
    {
      "type": "radio",
      "key": "knownVendor",
      "label": "Do you have a specific vendor in mind?",
      "validate": { "required": true },
      "values": [
        { "label": "Yes", "value": "yes" },
        { "label": "No", "value": "no" }
      ],
      "id": "Field_S2_03"
    },
    {
      "type": "textfield",
      "key": "vendorName",
      "label": "Vendor Name",
      "conditional": { "hide": "=knownVendor != \"yes\"" },
      "id": "Field_S2_04"
    },
    {
      "type": "radio",
      "key": "competitiveBid",
      "label": "Will you evaluate multiple vendors?",
      "description": "Competitive bid enables side-by-side comparison of vendor responses.",
      "validate": { "required": true },
      "values": [
        { "label": "Yes — multiple vendors", "value": "yes" },
        { "label": "No — single vendor", "value": "no" }
      ],
      "id": "Field_S2_05"
    },
    {
      "type": "radio",
      "key": "existingRelationship",
      "label": "Does the organization already use this vendor?",
      "validate": { "required": true },
      "values": [
        { "label": "Yes — existing relationship", "value": "yes" },
        { "label": "No — new vendor", "value": "no" }
      ],
      "id": "Field_S2_06"
    },
    {
      "type": "select",
      "key": "deploymentModel",
      "label": "Deployment Model",
      "validate": { "required": true },
      "values": [
        { "label": "Cloud (SaaS)", "value": "cloud" },
        { "label": "On-Premise", "value": "on-premise" },
        { "label": "Hybrid", "value": "hybrid" },
        { "label": "Unknown", "value": "unknown" }
      ],
      "id": "Field_S2_07"
    },
    {
      "type": "select",
      "key": "dataClassification",
      "label": "Data Classification",
      "description": "Highest classification of data this system will process.",
      "validate": { "required": true },
      "values": [
        { "label": "Public", "value": "public" },
        { "label": "Internal", "value": "internal" },
        { "label": "Confidential", "value": "confidential" },
        { "label": "Restricted", "value": "restricted" }
      ],
      "id": "Field_S2_08"
    },
    {
      "type": "checklist",
      "key": "regulatoryScope",
      "label": "Applicable Regulatory Frameworks",
      "description": "Select all regulations that may apply to this engagement.",
      "validate": { "required": true },
      "values": [
        { "label": "GDPR", "value": "GDPR" },
        { "label": "CCPA", "value": "CCPA" },
        { "label": "HIPAA", "value": "HIPAA" },
        { "label": "SOX", "value": "SOX" },
        { "label": "EU AI Act", "value": "EU_AI_Act" },
        { "label": "DORA", "value": "DORA" },
        { "label": "OCC 2023-17", "value": "OCC_2023_17" },
        { "label": "None Known", "value": "None" }
      ],
      "id": "Field_S2_09"
    },
    {
      "type": "checklist",
      "key": "dataTypes",
      "label": "Data Types Processed",
      "description": "What types of data will this system handle?",
      "validate": { "required": true },
      "values": [
        { "label": "Personally Identifiable Information (PII)", "value": "PII" },
        { "label": "Protected Health Information (PHI)", "value": "PHI" },
        { "label": "Financial Data", "value": "Financial" },
        { "label": "Public Data", "value": "Public" },
        { "label": "Intellectual Property", "value": "IP" },
        { "label": "Other Regulated Data", "value": "OtherRegulated" }
      ],
      "id": "Field_S2_10"
    },
    {
      "type": "checklist",
      "key": "existingAssessments",
      "label": "Existing Vendor Assessments",
      "description": "Does the vendor already have any of these assessments? If so, we can skip duplicate questions.",
      "values": [
        { "label": "SIG Lite", "value": "SIG_Lite" },
        { "label": "SOC 2 Type II", "value": "SOC2_TypeII" },
        { "label": "ISO 27001", "value": "ISO_27001" },
        { "label": "PCI DSS", "value": "PCI_DSS" },
        { "label": "HITRUST", "value": "HITRUST" },
        { "label": "None", "value": "None" }
      ],
      "id": "Field_S2_11"
    }
  ]
}