{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.6.0",
  "exporter": { "name": "Camunda Modeler", "version": "5.28.0" },
  "schemaVersion": 16,
  "id": "Form_VendorOnboarding",
  "components": [
    {
      "type": "group",
      "label": "Access Setup",
      "id": "Field_001",
      "components": [
        { "type": "textarea", "key": "systemsToAccess", "label": "Systems to access", "validate": { "required": true }, "id": "Field_002" },
        { "type": "textarea", "key": "accessLevelPerSystem", "label": "Access level per system", "validate": { "required": true }, "id": "Field_003" },
        { "type": "checkbox", "key": "mfaConfigured", "label": "MFA configured", "validate": { "required": true }, "id": "Field_004" },
        { "type": "checkbox", "key": "leastPrivilegeVerified", "label": "Least-privilege verified", "validate": { "required": true }, "id": "Field_005" }
      ]
    },
    {
      "type": "group",
      "label": "Data Configuration",
      "id": "Field_006",
      "components": [
        { "type": "textarea", "key": "dataCategoriesToProcess", "label": "Data categories to process", "validate": { "required": true }, "id": "Field_007" },
        { "type": "textarea", "key": "dataFlowEndpointsDocumented", "label": "Data flow endpoints documented", "validate": { "required": true }, "id": "Field_008" },
        { "type": "checkbox", "key": "dpaControlsActivated", "label": "DPA controls activated", "validate": { "required": true }, "id": "Field_009" }
      ]
    },
    {
      "type": "group",
      "label": "Operational Setup",
      "id": "Field_010",
      "components": [
        { "type": "checkbox", "key": "securityAwarenessAcknowledged", "label": "Security awareness acknowledged", "validate": { "required": true }, "id": "Field_011" },
        { "type": "checkbox", "key": "acceptableUsePolicyAccepted", "label": "Acceptable use policy accepted", "validate": { "required": true }, "id": "Field_012" },
        { "type": "checkbox", "key": "emergencyContactRegistered", "label": "Emergency contact registered", "validate": { "required": true }, "id": "Field_013" },
        { "type": "checkbox", "key": "monitoringBaselineCaptured", "label": "Monitoring baseline captured", "id": "Field_014" }
      ]
    },
    { "type": "separator", "id": "Field_015" },
    { "type": "radio", "key": "vendorOnboardingComplete", "label": "Vendor onboarding complete", "values": [{ "label": "Yes", "value": "yes" }, { "label": "No", "value": "no" }], "validate": { "required": true }, "id": "Field_016" }
  ]
}