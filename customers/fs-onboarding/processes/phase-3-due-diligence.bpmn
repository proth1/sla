<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_OB_Phase3DueDiligence"
                  targetNamespace="http://sla.governance/bpmn/onboarding"
                  exporter="Camunda Modeler"
                  exporterVersion="5.25.0">

  <bpmn:collaboration id="OB_Collaboration_Phase3DD">
    <bpmn:participant id="OB_Participant_EnterpriseGov" name="Enterprise Governance — OB Phase 3: Due Diligence and Swarm Evaluation" processRef="Process_OB_Phase3_DueDiligence" />
    <bpmn:participant id="OB_Participant_VendorThirdParty" name="Vendor / Third Party" processRef="OB_Process_VendorResponse" />
    <bpmn:messageFlow id="OB_MsgFlow_DDRequest" name="Due Diligence Request" sourceRef="OB_Task_31_EvidenceCollection" targetRef="OB_Participant_VendorThirdParty" />
    <bpmn:messageFlow id="OB_MsgFlow_VendorAttestation" name="Vendor Response / Attestation" sourceRef="OB_Participant_VendorThirdParty" targetRef="OB_Task_38_SwarmAggregation" />
  </bpmn:collaboration>

  <bpmn:process id="Process_OB_Phase3_DueDiligence" name="OB Phase 3: Due Diligence and Swarm Evaluation" isExecutable="false" camunda:historyTimeToLive="180">

    <bpmn:laneSet id="OB_LaneSet_Phase3">

      <bpmn:lane id="OB_Lane_Business" name="Business">
        <bpmn:flowNodeRef>OB_Task_36_FinancialStability</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_EndEvent_36SLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="OB_Lane_Governance" name="Governance">
        <bpmn:flowNodeRef>OB_EndEvent_Phase3Complete</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="OB_Lane_Contracting" name="Contracting" />

      <bpmn:lane id="OB_Lane_TechnicalAssessment" name="Technical Assessment">
        <bpmn:flowNodeRef>OB_Task_FT_33_SecurityAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_EndEvent_FT33SLAEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Task_33_SecurityAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_EndEvent_33SLAEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Task_37_OperationalResilience</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_EndEvent_37SLAEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Task_39_ArchitectureFeasibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_EndEvent_39SLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="OB_Lane_AIReview" name="AI Review">
        <bpmn:flowNodeRef>OB_Task_FT_35_AIModelRisk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_EndEvent_FT35SLAEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Task_35_AIModelRisk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_EndEvent_35SLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="OB_Lane_Compliance" name="Compliance">
        <bpmn:flowNodeRef>OB_Task_FT_34_ComplianceAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_EndEvent_FT34SLAEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Task_34_ComplianceAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_EndEvent_34SLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="OB_Lane_Oversight" name="Oversight" />

      <bpmn:lane id="OB_Lane_Automation" name="Automation">
        <bpmn:flowNodeRef>OB_StartEvent_Phase3Initiated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Task_31_EvidenceCollection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Task_32_AgentSwarmDeployment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Timer_ProcessSLA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_EndEvent_ProcessSLAEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Gateway_FastTrackCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Gateway_FTParallelSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Gateway_FTParallelJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Gateway_FullParallelSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Gateway_FullParallelJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Gateway_PathMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Task_38_SwarmAggregation</bpmn:flowNodeRef>
      </bpmn:lane>

    </bpmn:laneSet>

    <bpmn:startEvent id="OB_StartEvent_Phase3Initiated" name="Phase 2 Complete&#10;(Pathway Assigned)">
      <bpmn:outgoing>OB_Flow_Start_31</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="OB_Task_31_EvidenceCollection" name="3.1 Evidence&#10;Collection" camunda:type="external" camunda:topic="evidence-collection">
      <bpmn:incoming>OB_Flow_Start_31</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_31_32</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="OB_Task_32_AgentSwarmDeployment" name="3.2 Agent Swarm&#10;Deployment" camunda:type="external" camunda:topic="swarm-deployment">
      <bpmn:incoming>OB_Flow_31_32</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_32_FTCheck</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:boundaryEvent id="OB_Timer_ProcessSLA" name="5 Day&#10;SLA" attachedToRef="OB_Task_32_AgentSwarmDeployment" cancelActivity="false">
      <bpmn:outgoing>OB_Flow_ProcessSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="OB_TimerDef_ProcessSLA">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:exclusiveGateway id="OB_Gateway_FastTrackCheck" name="Fast-Track&#10;Pathway?" default="OB_Flow_FullPath">
      <bpmn:incoming>OB_Flow_32_FTCheck</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_FastTrackYes</bpmn:outgoing>
      <bpmn:outgoing>OB_Flow_FullPath</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:parallelGateway id="OB_Gateway_FTParallelSplit" name="Fast-Track&#10;Assessment Split">
      <bpmn:incoming>OB_Flow_FastTrackYes</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_FTSplit_Security</bpmn:outgoing>
      <bpmn:outgoing>OB_Flow_FTSplit_Compliance</bpmn:outgoing>
      <bpmn:outgoing>OB_Flow_FTSplit_AI</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:userTask id="OB_Task_FT_33_SecurityAssessment" name="3.3 Security&#10;Assessment" camunda:candidateGroups="technical-assessment">
      <bpmn:incoming>OB_Flow_FTSplit_Security</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_FT33_Join</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="OB_Timer_FT33_SLA" name="1 Day&#10;SLA" attachedToRef="OB_Task_FT_33_SecurityAssessment" cancelActivity="false">
      <bpmn:outgoing>OB_Flow_FT33SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="OB_TimerDef_FT33">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="OB_Task_FT_34_ComplianceAssessment" name="3.4 Compliance&#10;Assessment" camunda:type="external" camunda:topic="compliance-assessment">
      <bpmn:incoming>OB_Flow_FTSplit_Compliance</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_FT34_Join</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:boundaryEvent id="OB_Timer_FT34_SLA" name="1 Day&#10;SLA" attachedToRef="OB_Task_FT_34_ComplianceAssessment" cancelActivity="false">
      <bpmn:outgoing>OB_Flow_FT34SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="OB_TimerDef_FT34">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:userTask id="OB_Task_FT_35_AIModelRisk" name="3.5 AI Model&#10;Risk Assessment" camunda:candidateGroups="ai-review">
      <bpmn:incoming>OB_Flow_FTSplit_AI</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_FT35_Join</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="OB_Timer_FT35_SLA" name="2 Day&#10;SLA" attachedToRef="OB_Task_FT_35_AIModelRisk" cancelActivity="false">
      <bpmn:outgoing>OB_Flow_FT35SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="OB_TimerDef_FT35">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P2D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:parallelGateway id="OB_Gateway_FTParallelJoin">
      <bpmn:incoming>OB_Flow_FT33_Join</bpmn:incoming>
      <bpmn:incoming>OB_Flow_FT34_Join</bpmn:incoming>
      <bpmn:incoming>OB_Flow_FT35_Join</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_FTJoin_PathMerge</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:parallelGateway id="OB_Gateway_FullParallelSplit" name="Full Assessment&#10;Split">
      <bpmn:incoming>OB_Flow_FullPath</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_FullSplit_Security</bpmn:outgoing>
      <bpmn:outgoing>OB_Flow_FullSplit_Compliance</bpmn:outgoing>
      <bpmn:outgoing>OB_Flow_FullSplit_AI</bpmn:outgoing>
      <bpmn:outgoing>OB_Flow_FullSplit_Financial</bpmn:outgoing>
      <bpmn:outgoing>OB_Flow_FullSplit_Resilience</bpmn:outgoing>
      <bpmn:outgoing>OB_Flow_FullSplit_Architecture</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:userTask id="OB_Task_33_SecurityAssessment" name="3.3 Security&#10;Assessment" camunda:candidateGroups="technical-assessment">
      <bpmn:incoming>OB_Flow_FullSplit_Security</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_33_FullJoin</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="OB_Timer_33_SLA" name="1 Day&#10;SLA" attachedToRef="OB_Task_33_SecurityAssessment" cancelActivity="false">
      <bpmn:outgoing>OB_Flow_33SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="OB_TimerDef_33">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="OB_Task_34_ComplianceAssessment" name="3.4 Compliance&#10;Assessment" camunda:type="external" camunda:topic="compliance-assessment">
      <bpmn:incoming>OB_Flow_FullSplit_Compliance</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_34_FullJoin</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:boundaryEvent id="OB_Timer_34_SLA" name="1 Day&#10;SLA" attachedToRef="OB_Task_34_ComplianceAssessment" cancelActivity="false">
      <bpmn:outgoing>OB_Flow_34SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="OB_TimerDef_34">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:userTask id="OB_Task_35_AIModelRisk" name="3.5 AI Model&#10;Risk Assessment" camunda:candidateGroups="ai-review">
      <bpmn:incoming>OB_Flow_FullSplit_AI</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_35_FullJoin</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="OB_Timer_35_SLA" name="2 Day&#10;SLA" attachedToRef="OB_Task_35_AIModelRisk" cancelActivity="false">
      <bpmn:outgoing>OB_Flow_35SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="OB_TimerDef_35">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P2D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:userTask id="OB_Task_36_FinancialStability" name="3.6 Financial&#10;Stability Review" camunda:candidateGroups="business-lane">
      <bpmn:incoming>OB_Flow_FullSplit_Financial</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_36_FullJoin</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="OB_Timer_36_SLA" name="1 Day&#10;SLA" attachedToRef="OB_Task_36_FinancialStability" cancelActivity="false">
      <bpmn:outgoing>OB_Flow_36SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="OB_TimerDef_36">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:userTask id="OB_Task_37_OperationalResilience" name="3.7 Operational&#10;Resilience Verification" camunda:candidateGroups="technical-assessment">
      <bpmn:incoming>OB_Flow_FullSplit_Resilience</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_37_FullJoin</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="OB_Timer_37_SLA" name="1 Day&#10;SLA" attachedToRef="OB_Task_37_OperationalResilience" cancelActivity="false">
      <bpmn:outgoing>OB_Flow_37SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="OB_TimerDef_37">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:userTask id="OB_Task_39_ArchitectureFeasibility" name="3.9 Architecture&#10;Feasibility Assessment" camunda:candidateGroups="technical-assessment">
      <bpmn:incoming>OB_Flow_FullSplit_Architecture</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_39_FullJoin</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="OB_Timer_39_SLA" name="2 Day&#10;SLA" attachedToRef="OB_Task_39_ArchitectureFeasibility" cancelActivity="false">
      <bpmn:outgoing>OB_Flow_39SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="OB_TimerDef_39">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P2D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:parallelGateway id="OB_Gateway_FullParallelJoin">
      <bpmn:incoming>OB_Flow_33_FullJoin</bpmn:incoming>
      <bpmn:incoming>OB_Flow_34_FullJoin</bpmn:incoming>
      <bpmn:incoming>OB_Flow_35_FullJoin</bpmn:incoming>
      <bpmn:incoming>OB_Flow_36_FullJoin</bpmn:incoming>
      <bpmn:incoming>OB_Flow_37_FullJoin</bpmn:incoming>
      <bpmn:incoming>OB_Flow_39_FullJoin</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_FullJoin_PathMerge</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:exclusiveGateway id="OB_Gateway_PathMerge">
      <bpmn:incoming>OB_Flow_FTJoin_PathMerge</bpmn:incoming>
      <bpmn:incoming>OB_Flow_FullJoin_PathMerge</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_PathMerge_38</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="OB_Task_38_SwarmAggregation" name="3.8 Swarm Results&#10;Aggregation" camunda:type="external" camunda:topic="swarm-aggregation">
      <bpmn:incoming>OB_Flow_PathMerge_38</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_38_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="OB_EndEvent_Phase3Complete" name="Phase 3 Complete&#10;(Due Diligence Approved)">
      <bpmn:incoming>OB_Flow_38_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="OB_EndEvent_ProcessSLAEscalated" name="Process SLA&#10;Escalated (P5D)">
      <bpmn:incoming>OB_Flow_ProcessSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="OB_EndEvent_FT33SLAEscalated" name="Security Assessment&#10;SLA Escalated">
      <bpmn:incoming>OB_Flow_FT33SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="OB_EndEvent_FT34SLAEscalated" name="Compliance Assessment&#10;SLA Escalated">
      <bpmn:incoming>OB_Flow_FT34SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="OB_EndEvent_FT35SLAEscalated" name="AI Risk Assessment&#10;SLA Escalated">
      <bpmn:incoming>OB_Flow_FT35SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="OB_EndEvent_33SLAEscalated" name="Security Assessment&#10;SLA Escalated">
      <bpmn:incoming>OB_Flow_33SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="OB_EndEvent_34SLAEscalated" name="Compliance Assessment&#10;SLA Escalated">
      <bpmn:incoming>OB_Flow_34SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="OB_EndEvent_35SLAEscalated" name="AI Risk Assessment&#10;SLA Escalated">
      <bpmn:incoming>OB_Flow_35SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="OB_EndEvent_36SLAEscalated" name="Financial Review&#10;SLA Escalated">
      <bpmn:incoming>OB_Flow_36SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="OB_EndEvent_37SLAEscalated" name="Operational Resilience&#10;SLA Escalated">
      <bpmn:incoming>OB_Flow_37SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="OB_EndEvent_39SLAEscalated" name="Architecture Feasibility&#10;SLA Escalated">
      <bpmn:incoming>OB_Flow_39SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:textAnnotation id="OB_Annotation_OCC">
      <bpmn:text>OCC 2023-17: Third-party risk management due diligence — security assessment and evidence collection required for all vendor engagements prior to contract execution.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="OB_Assoc_OCC" sourceRef="OB_Task_33_SecurityAssessment" targetRef="OB_Annotation_OCC" />

    <bpmn:textAnnotation id="OB_Annotation_SOX">
      <bpmn:text>SOX: Financial stability review documents vendor financial controls, audit readiness, and going-concern viability. All financial analysis logged for audit trail compliance.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="OB_Assoc_SOX" sourceRef="OB_Task_36_FinancialStability" targetRef="OB_Annotation_SOX" />

    <bpmn:textAnnotation id="OB_Annotation_NIST">
      <bpmn:text>NIST CSF 2.0: Security assessment validates vendor cybersecurity controls across Identify, Protect, Detect, Respond, and Recover functions per NIST CSF 2.0 framework.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="OB_Assoc_NIST" sourceRef="OB_Task_33_SecurityAssessment" targetRef="OB_Annotation_NIST" />

    <bpmn:textAnnotation id="OB_Annotation_DORA">
      <bpmn:text>DORA: Operational resilience verification validates ICT risk management, incident response capabilities, and digital operational resilience per EU DORA requirements for financial services.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="OB_Assoc_DORA" sourceRef="OB_Task_37_OperationalResilience" targetRef="OB_Annotation_DORA" />

    <bpmn:textAnnotation id="OB_Annotation_TaskIO">
      <bpmn:text>Task I/O: 3.1 IN(vendorName, knowledgeBaseEntryId) OUT(evidencePackageId) | 3.2 IN(evidencePackageId, pathway, riskTier) OUT(swarmTaskIds[]) | 3.3 IN(evidencePackageId) OUT(securityScore) | 3.4 IN(evidencePackageId, regulations[]) OUT(complianceScore) | 3.5 IN(evidencePackageId, aiRiskClassification) OUT(modelRiskScore) | 3.6 IN(vendorName) OUT(financialHealthScore) | 3.7 IN(evidencePackageId) OUT(resilienceScore) | 3.8 IN(all scores) OUT(aggregatedRiskScore) | 3.9 IN(technicalScope) OUT(architectureFeasible)</bpmn:text>
    </bpmn:textAnnotation>

    <bpmn:sequenceFlow id="OB_Flow_Start_31" sourceRef="OB_StartEvent_Phase3Initiated" targetRef="OB_Task_31_EvidenceCollection" />
    <bpmn:sequenceFlow id="OB_Flow_31_32" sourceRef="OB_Task_31_EvidenceCollection" targetRef="OB_Task_32_AgentSwarmDeployment" />
    <bpmn:sequenceFlow id="OB_Flow_32_FTCheck" sourceRef="OB_Task_32_AgentSwarmDeployment" targetRef="OB_Gateway_FastTrackCheck" />
    <bpmn:sequenceFlow id="OB_Flow_ProcessSLAEscalate" sourceRef="OB_Timer_ProcessSLA" targetRef="OB_EndEvent_ProcessSLAEscalated" />

    <bpmn:sequenceFlow id="OB_Flow_FastTrackYes" name="Yes" sourceRef="OB_Gateway_FastTrackCheck" targetRef="OB_Gateway_FTParallelSplit">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${selectedPathway == 'FAST_TRACK'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="OB_Flow_FullPath" name="No" sourceRef="OB_Gateway_FastTrackCheck" targetRef="OB_Gateway_FullParallelSplit" />

    <bpmn:sequenceFlow id="OB_Flow_FTSplit_Security" sourceRef="OB_Gateway_FTParallelSplit" targetRef="OB_Task_FT_33_SecurityAssessment" />
    <bpmn:sequenceFlow id="OB_Flow_FTSplit_Compliance" sourceRef="OB_Gateway_FTParallelSplit" targetRef="OB_Task_FT_34_ComplianceAssessment" />
    <bpmn:sequenceFlow id="OB_Flow_FTSplit_AI" sourceRef="OB_Gateway_FTParallelSplit" targetRef="OB_Task_FT_35_AIModelRisk" />

    <bpmn:sequenceFlow id="OB_Flow_FT33_Join" sourceRef="OB_Task_FT_33_SecurityAssessment" targetRef="OB_Gateway_FTParallelJoin" />
    <bpmn:sequenceFlow id="OB_Flow_FT34_Join" sourceRef="OB_Task_FT_34_ComplianceAssessment" targetRef="OB_Gateway_FTParallelJoin" />
    <bpmn:sequenceFlow id="OB_Flow_FT35_Join" sourceRef="OB_Task_FT_35_AIModelRisk" targetRef="OB_Gateway_FTParallelJoin" />
    <bpmn:sequenceFlow id="OB_Flow_FTJoin_PathMerge" sourceRef="OB_Gateway_FTParallelJoin" targetRef="OB_Gateway_PathMerge" />

