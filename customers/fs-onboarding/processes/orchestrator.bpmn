<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_OB_Orchestrator"
                  targetNamespace="http://sla.governance/bpmn/onboarding"
                  exporter="Camunda Modeler"
                  exporterVersion="5.25.0">

  <bpmn:message id="Message_OnboardingInitiated" name="OnboardingInitiated" />
  <bpmn:signal id="Signal_EmergencyCessation" name="EmergencyCessation" />

  <bpmn:collaboration id="Collaboration_OB_Orchestrator">
    <bpmn:participant id="Participant_EnterpriseGovernance" name="Enterprise Governance — Onboarding Orchestrator" processRef="Process_OB_OnboardingOrchestrator" />
    <bpmn:participant id="Participant_VendorThirdParty" name="Vendor / Third Party" />
    <bpmn:messageFlow id="OB_MsgFlow_DDRequest" name="Due Diligence Request" sourceRef="OB_SP_Phase3" targetRef="Participant_VendorThirdParty" />
    <bpmn:messageFlow id="OB_MsgFlow_VendorResponse" name="Vendor Response" sourceRef="Participant_VendorThirdParty" targetRef="OB_SP_Phase3" />
    <bpmn:messageFlow id="OB_MsgFlow_ContractDraft" name="Contract Draft" sourceRef="OB_SP_Phase5" targetRef="Participant_VendorThirdParty" />
    <bpmn:messageFlow id="OB_MsgFlow_SignedContract" name="Signed Contract" sourceRef="Participant_VendorThirdParty" targetRef="OB_SP_Phase5" />
  </bpmn:collaboration>

  <bpmn:process id="Process_OB_OnboardingOrchestrator" name="Onboarding Orchestrator — Phases 1 through 5" isExecutable="false" camunda:historyTimeToLive="180">

    <bpmn:laneSet id="LaneSet_OB_Orchestrator">
      <bpmn:lane id="Lane_Business" name="Business">
        <bpmn:flowNodeRef>OB_StartEvent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_SP_Phase2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Gateway_RiskTier</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_EndEvent_Rejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Governance" name="Governance">
        <bpmn:flowNodeRef>OB_SP_Phase4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_Gateway_Governance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_EndEvent_Rejected_Gov</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Contracting" name="Contracting">
        <bpmn:flowNodeRef>OB_SP_Phase5</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_TechnicalAssessment" name="Technical Assessment" />
      <bpmn:lane id="Lane_AIReview" name="AI Review" />
      <bpmn:lane id="Lane_Compliance" name="Compliance">
        <bpmn:flowNodeRef>OB_SP_Phase3</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Oversight" name="Oversight" />
      <bpmn:lane id="Lane_Automation" name="Automation">
        <bpmn:flowNodeRef>OB_SP_Phase1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_EndEvent_Onboarded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_EndEvent_Terminated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_BoundaryEvent_TotalSLA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>OB_EndEvent_SLAEscalation</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="OB_StartEvent" name="Onboarding&#10;Initiated">
      <bpmn:outgoing>OB_Flow_Start_Phase1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="OB_MsgDef_Start" messageRef="Message_OnboardingInitiated" />
    </bpmn:startEvent>

    <bpmn:subProcess id="OB_SP_Phase1" name="Phase 1:&#10;Initiation &amp; Intake">
      <bpmn:incoming>OB_Flow_Start_Phase1</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_Phase1_Phase2</bpmn:outgoing>

      <bpmn:startEvent id="OB_SP1_Start" name="Start">
        <bpmn:outgoing>OB_Flow_SP1_Start_Task</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:businessRuleTask id="OB_SP1_Task_Classify" name="Classify &amp;&#10;Route Request"
          camunda:decisionRef="OB_DMN_PathwayRouting"
          camunda:decisionRefBinding="latest"
          camunda:resultVariable="selectedPathway"
          camunda:mapDecisionResult="singleResult">
        <bpmn:incoming>OB_Flow_SP1_Start_Task</bpmn:incoming>
        <bpmn:outgoing>OB_Flow_SP1_Task_End</bpmn:outgoing>
      </bpmn:businessRuleTask>
      <bpmn:endEvent id="OB_SP1_End" name="Intake&#10;Complete">
        <bpmn:incoming>OB_Flow_SP1_Task_End</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="OB_Flow_SP1_Start_Task" sourceRef="OB_SP1_Start" targetRef="OB_SP1_Task_Classify" />
      <bpmn:sequenceFlow id="OB_Flow_SP1_Task_End" sourceRef="OB_SP1_Task_Classify" targetRef="OB_SP1_End" />
    </bpmn:subProcess>

    <bpmn:boundaryEvent id="OB_BoundaryEvent_TotalSLA" name="25 Day&#10;Onboarding SLA"
        attachedToRef="OB_SP_Phase1" cancelActivity="false">
      <bpmn:outgoing>OB_Flow_TotalSLA_Escalation</bpmn:outgoing>
      <bpmn:timerEventDefinition id="OB_TimerDef_TotalSLA">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P25D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:endEvent id="OB_EndEvent_SLAEscalation" name="Total SLA&#10;Escalation">
      <bpmn:incoming>OB_Flow_TotalSLA_Escalation</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:subProcess id="OB_SP_Phase2" name="Phase 2:&#10;Planning &amp; Risk">
      <bpmn:incoming>OB_Flow_Phase1_Phase2</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_Phase2_RiskGateway</bpmn:outgoing>

      <bpmn:startEvent id="OB_SP2_Start" name="Start">
        <bpmn:outgoing>OB_Flow_SP2_Start_Task</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:businessRuleTask id="OB_SP2_Task_RiskTier" name="Risk Tier&#10;Classification"
          camunda:decisionRef="OB_DMN_RiskTierClassification"
          camunda:decisionRefBinding="latest"
          camunda:resultVariable="riskTier"
          camunda:mapDecisionResult="singleResult">
        <bpmn:incoming>OB_Flow_SP2_Start_Task</bpmn:incoming>
        <bpmn:outgoing>OB_Flow_SP2_Task_End</bpmn:outgoing>
      </bpmn:businessRuleTask>
      <bpmn:endEvent id="OB_SP2_End" name="Planning&#10;Complete">
        <bpmn:incoming>OB_Flow_SP2_Task_End</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="OB_Flow_SP2_Start_Task" sourceRef="OB_SP2_Start" targetRef="OB_SP2_Task_RiskTier" />
      <bpmn:sequenceFlow id="OB_Flow_SP2_Task_End" sourceRef="OB_SP2_Task_RiskTier" targetRef="OB_SP2_End" />
    </bpmn:subProcess>

    <bpmn:exclusiveGateway id="OB_Gateway_RiskTier" name="Risk Tier&#10;Acceptable?">
      <bpmn:incoming>OB_Flow_Phase2_RiskGateway</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_RiskAccepted</bpmn:outgoing>
      <bpmn:outgoing>OB_Flow_RiskRejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="OB_EndEvent_Rejected" name="End&#10;Rejected">
      <bpmn:incoming>OB_Flow_RiskRejected</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:subProcess id="OB_SP_Phase3" name="Phase 3:&#10;Due Diligence">
      <bpmn:incoming>OB_Flow_RiskAccepted</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_Phase3_Phase4</bpmn:outgoing>

      <bpmn:startEvent id="OB_SP3_Start" name="Start">
        <bpmn:outgoing>OB_Flow_SP3_Start_Task</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:userTask id="OB_SP3_Task_DD" name="Execute&#10;Due Diligence" camunda:candidateGroups="compliance-lane">
        <bpmn:incoming>OB_Flow_SP3_Start_Task</bpmn:incoming>
        <bpmn:outgoing>OB_Flow_SP3_Task_End</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:endEvent id="OB_SP3_End" name="DD&#10;Complete">
        <bpmn:incoming>OB_Flow_SP3_Task_End</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="OB_Flow_SP3_Start_Task" sourceRef="OB_SP3_Start" targetRef="OB_SP3_Task_DD" />
      <bpmn:sequenceFlow id="OB_Flow_SP3_Task_End" sourceRef="OB_SP3_Task_DD" targetRef="OB_SP3_End" />
    </bpmn:subProcess>

    <bpmn:subProcess id="OB_SP_Phase4" name="Phase 4:&#10;Governance Review">
      <bpmn:incoming>OB_Flow_Phase3_Phase4</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_Phase4_GovGateway</bpmn:outgoing>

      <bpmn:startEvent id="OB_SP4_Start" name="Start">
        <bpmn:outgoing>OB_Flow_SP4_Start_Task</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:businessRuleTask id="OB_SP4_Task_Review" name="Governance&#10;Review Routing"
          camunda:decisionRef="OB_DMN_GovernanceReviewRouting"
          camunda:decisionRefBinding="latest"
          camunda:resultVariable="reviewAuthority"
          camunda:mapDecisionResult="singleResult">
        <bpmn:incoming>OB_Flow_SP4_Start_Task</bpmn:incoming>
        <bpmn:outgoing>OB_Flow_SP4_Task_End</bpmn:outgoing>
      </bpmn:businessRuleTask>
      <bpmn:endEvent id="OB_SP4_End" name="Review&#10;Complete">
        <bpmn:incoming>OB_Flow_SP4_Task_End</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="OB_Flow_SP4_Start_Task" sourceRef="OB_SP4_Start" targetRef="OB_SP4_Task_Review" />
      <bpmn:sequenceFlow id="OB_Flow_SP4_Task_End" sourceRef="OB_SP4_Task_Review" targetRef="OB_SP4_End" />
    </bpmn:subProcess>

    <bpmn:exclusiveGateway id="OB_Gateway_Governance" name="Governance&#10;Decision?">
      <bpmn:incoming>OB_Flow_Phase4_GovGateway</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_GovApproved</bpmn:outgoing>
      <bpmn:outgoing>OB_Flow_GovRejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="OB_EndEvent_Rejected_Gov" name="End&#10;Rejected">
      <bpmn:incoming>OB_Flow_GovRejected</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:subProcess id="OB_SP_Phase5" name="Phase 5:&#10;Contracting &amp; Controls">
      <bpmn:incoming>OB_Flow_GovApproved</bpmn:incoming>
      <bpmn:outgoing>OB_Flow_Phase5_End</bpmn:outgoing>

      <bpmn:startEvent id="OB_SP5_Start" name="Start">
        <bpmn:outgoing>OB_Flow_SP5_Start_Task</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:userTask id="OB_SP5_Task_Contract" name="Contract&#10;Negotiation &amp; Controls" camunda:candidateGroups="contracting-lane">
        <bpmn:incoming>OB_Flow_SP5_Start_Task</bpmn:incoming>
        <bpmn:outgoing>OB_Flow_SP5_Task_End</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:endEvent id="OB_SP5_End" name="Contracting&#10;Complete">
        <bpmn:incoming>OB_Flow_SP5_Task_End</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="OB_Flow_SP5_Start_Task" sourceRef="OB_SP5_Start" targetRef="OB_SP5_Task_Contract" />
      <bpmn:sequenceFlow id="OB_Flow_SP5_Task_End" sourceRef="OB_SP5_Task_Contract" targetRef="OB_SP5_End" />
    </bpmn:subProcess>

    <bpmn:endEvent id="OB_EndEvent_Onboarded" name="End&#10;Onboarded">
      <bpmn:incoming>OB_Flow_Phase5_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="OB_EndEvent_Terminated" name="Emergency&#10;Termination">
      <bpmn:signalEventDefinition signalRef="Signal_EmergencyCessation" />
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="OB_Flow_Start_Phase1" sourceRef="OB_StartEvent" targetRef="OB_SP_Phase1" />
    <bpmn:sequenceFlow id="OB_Flow_Phase1_Phase2" sourceRef="OB_SP_Phase1" targetRef="OB_SP_Phase2" />
    <bpmn:sequenceFlow id="OB_Flow_Phase2_RiskGateway" sourceRef="OB_SP_Phase2" targetRef="OB_Gateway_RiskTier" />
    <bpmn:sequenceFlow id="OB_Flow_RiskAccepted" name="Yes" sourceRef="OB_Gateway_RiskTier" targetRef="OB_SP_Phase3">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${riskTier != 'Unacceptable'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="OB_Flow_RiskRejected" name="Unacceptable" sourceRef="OB_Gateway_RiskTier" targetRef="OB_EndEvent_Rejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${riskTier == 'Unacceptable'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="OB_Flow_Phase3_Phase4" sourceRef="OB_SP_Phase3" targetRef="OB_SP_Phase4" />
    <bpmn:sequenceFlow id="OB_Flow_Phase4_GovGateway" sourceRef="OB_SP_Phase4" targetRef="OB_Gateway_Governance" />
    <bpmn:sequenceFlow id="OB_Flow_GovApproved" name="Approved" sourceRef="OB_Gateway_Governance" targetRef="OB_SP_Phase5">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${governanceDecision == 'Approved' || governanceDecision == 'Conditional'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="OB_Flow_GovRejected" name="Rejected" sourceRef="OB_Gateway_Governance" targetRef="OB_EndEvent_Rejected_Gov">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${governanceDecision == 'Rejected'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="OB_Flow_Phase5_End" sourceRef="OB_SP_Phase5" targetRef="OB_EndEvent_Onboarded" />
    <bpmn:sequenceFlow id="OB_Flow_TotalSLA_Escalation" sourceRef="OB_BoundaryEvent_TotalSLA" targetRef="OB_EndEvent_SLAEscalation" />

    <bpmn:textAnnotation id="OB_Annotation_Orchestrator">
      <bpmn:text>Onboarding Orchestrator: 5-phase journey (Intake → Planning → Due Diligence → Governance → Contracting) | Total SLA: 25 days | 3 terminal states: Onboarded, Rejected, Terminated | DMN tables: OB_DMN_PathwayRouting, OB_DMN_RiskTierClassification, OB_DMN_GovernanceReviewRouting, OB_DMN_OnboardingSLABreach</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="OB_Assoc_Orchestrator" sourceRef="OB_SP_Phase1" targetRef="OB_Annotation_Orchestrator" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_OB_Orchestrator">
    <bpmndi:BPMNPlane id="BPMNPlane_OB_Orchestrator" bpmnElement="Collaboration_OB_Orchestrator">

      <bpmndi:BPMNShape id="Participant_EnterpriseGovernance_di" bpmnElement="Participant_EnterpriseGovernance" isHorizontal="true">
        <dc:Bounds x="155" y="47" width="2100" height="1210" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Lane_Business_di" bpmnElement="Lane_Business" isHorizontal="true">
        <dc:Bounds x="185" y="47" width="2070" height="125" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Governance_di" bpmnElement="Lane_Governance" isHorizontal="true">
        <dc:Bounds x="185" y="172" width="2070" height="125" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Contracting_di" bpmnElement="Lane_Contracting" isHorizontal="true">
        <dc:Bounds x="185" y="297" width="2070" height="125" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_TechnicalAssessment_di" bpmnElement="Lane_TechnicalAssessment" isHorizontal="true">
        <dc:Bounds x="185" y="422" width="2070" height="125" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_AIReview_di" bpmnElement="Lane_AIReview" isHorizontal="true">
        <dc:Bounds x="185" y="547" width="2070" height="125" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Compliance_di" bpmnElement="Lane_Compliance" isHorizontal="true">
        <dc:Bounds x="185" y="672" width="2070" height="125" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Oversight_di" bpmnElement="Lane_Oversight" isHorizontal="true">
        <dc:Bounds x="185" y="797" width="2070" height="125" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Automation_di" bpmnElement="Lane_Automation" isHorizontal="true">
        <dc:Bounds x="185" y="922" width="2070" height="125" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_StartEvent_di" bpmnElement="OB_StartEvent">
        <dc:Bounds x="248" y="91" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="233" y="134" width="66" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_SP_Phase1_di" bpmnElement="OB_SP_Phase1" isExpanded="false">
        <dc:Bounds x="360" y="944" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_BoundaryEvent_TotalSLA_di" bpmnElement="OB_BoundaryEvent_TotalSLA">
        <dc:Bounds x="392" y="1006" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="436" y="1010" width="73" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_EndEvent_SLAEscalation_di" bpmnElement="OB_EndEvent_SLAEscalation">
        <dc:Bounds x="500" y="1006" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="544" y="1010" width="55" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_SP_Phase2_di" bpmnElement="OB_SP_Phase2" isExpanded="false">
        <dc:Bounds x="560" y="69" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_Gateway_RiskTier_di" bpmnElement="OB_Gateway_RiskTier" isMarkerVisible="true">
        <dc:Bounds x="735" y="84" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="727" y="54" width="66" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_EndEvent_Rejected_di" bpmnElement="OB_EndEvent_Rejected">
        <dc:Bounds x="742" y="148" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="786" y="152" width="48" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_SP_Phase3_di" bpmnElement="OB_SP_Phase3" isExpanded="false">
        <dc:Bounds x="880" y="694" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_SP_Phase4_di" bpmnElement="OB_SP_Phase4" isExpanded="false">
        <dc:Bounds x="1080" y="194" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_Gateway_Governance_di" bpmnElement="OB_Gateway_Governance" isMarkerVisible="true">
        <dc:Bounds x="1255" y="209" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1243" y="179" width="73" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_EndEvent_Rejected_Gov_di" bpmnElement="OB_EndEvent_Rejected_Gov">
        <dc:Bounds x="1262" y="259" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1306" y="263" width="48" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_SP_Phase5_di" bpmnElement="OB_SP_Phase5" isExpanded="false">
        <dc:Bounds x="1400" y="319" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_EndEvent_Onboarded_di" bpmnElement="OB_EndEvent_Onboarded">
        <dc:Bounds x="1600" y="966" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1593" y="1009" width="50" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_EndEvent_Terminated_di" bpmnElement="OB_EndEvent_Terminated">
        <dc:Bounds x="1700" y="966" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1687" y="1009" width="62" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="OB_Annotation_Orchestrator_di" bpmnElement="OB_Annotation_Orchestrator">
        <dc:Bounds x="230" y="1060" width="800" height="55" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="OB_Flow_Start_Phase1_di" bpmnElement="OB_Flow_Start_Phase1">
        <di:waypoint x="284" y="109" />
        <di:waypoint x="322" y="109" />
        <di:waypoint x="322" y="984" />
        <di:waypoint x="360" y="984" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="OB_Flow_Phase1_Phase2_di" bpmnElement="OB_Flow_Phase1_Phase2">
        <di:waypoint x="460" y="984" />
        <di:waypoint x="510" y="984" />
        <di:waypoint x="510" y="109" />
        <di:waypoint x="560" y="109" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="OB_Flow_Phase2_RiskGateway_di" bpmnElement="OB_Flow_Phase2_RiskGateway">
        <di:waypoint x="660" y="109" />
        <di:waypoint x="735" y="109" />
