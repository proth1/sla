{
  "processDefinitionKey": "Process_JiraSync_Test_v1",
  "jira": {
    "baseUrl": "https://agentic-sdlc.atlassian.net",
    "projectKey": "AP",
    "issueType": "Task",
    "doneStatusCategory": "done"
  },
  "polling": {
    "outboundIntervalMs": 15000,
    "inboundIntervalMs": 15000,
    "slaCheckIntervalMs": 30000
  },
  "candidateGroupLabels": {
    "technical-assessment": "security-review",
    "compliance-lane": "compliance-check",
    "business-lane": "business-approval",
    "governance-lane": "governance-signoff",
    "oversight-lane": "oversight-audit"
  },
  "raci": {
    "technical-assessment": {
      "accountable": "governance-lane",
      "consulted": ["compliance-lane"],
      "informed": ["business-lane"],
      "sla": "PT4H",
      "escalationChain": ["governance-lane", "oversight-lane"]
    },
    "compliance-lane": {
      "accountable": "governance-lane",
      "consulted": ["technical-assessment"],
      "informed": ["business-lane"],
      "sla": "P1D",
      "escalationChain": ["governance-lane", "oversight-lane"]
    },
    "business-lane": {
      "accountable": "governance-lane",
      "consulted": [],
      "informed": ["compliance-lane"],
      "sla": "P2D",
      "escalationChain": ["governance-lane", "oversight-lane"]
    },
    "governance-lane": {
      "accountable": "oversight-lane",
      "consulted": ["business-lane"],
      "informed": [],
      "sla": "P2D",
      "escalationChain": ["oversight-lane"]
    },
    "oversight-lane": {
      "accountable": "oversight-lane",
      "consulted": [],
      "informed": ["governance-lane"],
      "sla": "P5D",
      "escalationChain": []
    }
  }
}
