<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_Phase4GovernanceReview"
                  targetNamespace="http://sla.governance/bpmn"
                  exporter="Camunda Modeler"
                  exporterVersion="5.25.0">

  <bpmn:collaboration id="Collaboration_Phase4">
    <bpmn:participant id="Participant_EnterpriseGov" name="Phase 4: Governance Review and Approval — Enterprise Governance Pool" processRef="Process_GovernanceReview" />
    <bpmn:participant id="Participant_VendorParty" name="Vendor / Third Party" processRef="Process_VendorResponse" />
    <bpmn:messageFlow id="MsgFlow_VendorToReview" sourceRef="Task_VendorResponseReceipt" targetRef="Task_AssessmentPackageAssembly" />
  </bpmn:collaboration>

  <bpmn:process id="Process_GovernanceReview" name="Phase 4: Governance Review and Approval" isExecutable="false" camunda:historyTimeToLive="180">

    <bpmn:laneSet id="LaneSet_Phase4">
      <bpmn:lane id="Lane_Business" name="Business">
        <bpmn:flowNodeRef>StartEvent_Phase4Initiated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FastPathReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_FastPathSLAEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Phase5Approved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Phase5ApprovedConditions</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Governance" name="Governance">
        <bpmn:flowNodeRef>Task_AdvisoryBoardReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_AdvisorySLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Contracting" name="Contracting">
      </bpmn:lane>
      <bpmn:lane id="Lane_TechnicalAssessment" name="Technical Assessment">
      </bpmn:lane>
      <bpmn:lane id="Lane_AIReview" name="AI Review">
        <bpmn:flowNodeRef>Task_EthicalImpactAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_AIReviewSLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Compliance" name="Compliance">
        <bpmn:flowNodeRef>Task_GovernanceCommitteeReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_CommitteeSLAEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Rejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Oversight" name="Oversight">
        <bpmn:flowNodeRef>Task_Phase4_OversightValidation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Phase4_OversightComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Phase4_OversightSLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Automation" name="Automation">
        <bpmn:flowNodeRef>Task_AssessmentPackageAssembly</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RiskTieredReviewRouting</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ReviewAuthority</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ReviewMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AIReviewRouting</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AICheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AIMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DecisionDocumentation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Phase4_Complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Phase4_QualityGate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_OversightValidationSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_GovernanceDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ProcessSLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_Phase4Initiated" name="Phase 3&#10;Complete">
      <bpmn:outgoing>Flow_Start_Assembly</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="Task_AssessmentPackageAssembly" name="4.1 Assessment Package&#10;Assembly (BPM Package&#10;Assembly — 4 Hours)" camunda:type="external" camunda:topic="bpm-package-assembly">
      <bpmn:incoming>Flow_Start_Assembly</bpmn:incoming>
      <bpmn:outgoing>Flow_Assembly_Routing</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:boundaryEvent id="Timer_ProcessSLA" name="P5D&#10;SLA" attachedToRef="Task_AssessmentPackageAssembly" cancelActivity="false">
      <bpmn:outgoing>Flow_ProcessSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_ProcessSLA">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:businessRuleTask id="Task_RiskTieredReviewRouting" name="4.2 Risk-Tiered&#10;Review Routing" camunda:decisionRef="DMN_GovernanceReviewRouting" camunda:decisionRefBinding="latest" camunda:resultVariable="reviewAuthority" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>Flow_Assembly_Routing</bpmn:incoming>
      <bpmn:outgoing>Flow_Routing_AuthGateway</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:exclusiveGateway id="Gateway_ReviewAuthority" name="Review Authority?" default="Flow_AuthGateway_Committee">
      <bpmn:incoming>Flow_Routing_AuthGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_AuthGateway_FastPath</bpmn:outgoing>
      <bpmn:outgoing>Flow_AuthGateway_Committee</bpmn:outgoing>
      <bpmn:outgoing>Flow_AuthGateway_Advisory</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_FastPathReview" name="4.3a Fast Path&#10;Review" camunda:candidateGroups="governance-lane">
      <bpmn:incoming>Flow_AuthGateway_FastPath</bpmn:incoming>
      <bpmn:outgoing>Flow_FastPath_Merge</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="Timer_FastPathSLA" name="2D&#10;SLA" attachedToRef="Task_FastPathReview" cancelActivity="false">
      <bpmn:outgoing>Flow_FastPathSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_FastPath">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P2D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:userTask id="Task_GovernanceCommitteeReview" name="4.3b Committee&#10;Review" camunda:candidateGroups="governance-lane">
      <bpmn:incoming>Flow_AuthGateway_Committee</bpmn:incoming>
      <bpmn:outgoing>Flow_Committee_Merge</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="Timer_CommitteeSLA" name="5D&#10;SLA" attachedToRef="Task_GovernanceCommitteeReview" cancelActivity="false">
      <bpmn:outgoing>Flow_CommitteeSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Committee">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:userTask id="Task_AdvisoryBoardReview" name="4.3c Advisory&#10;Board Review" camunda:candidateGroups="governance-lane">
      <bpmn:incoming>Flow_AuthGateway_Advisory</bpmn:incoming>
      <bpmn:outgoing>Flow_Advisory_Merge</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="Timer_AdvisorySLA" name="10D&#10;SLA" attachedToRef="Task_AdvisoryBoardReview" cancelActivity="false">
      <bpmn:outgoing>Flow_AdvisorySLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Advisory">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P10D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:exclusiveGateway id="Gateway_ReviewMerge">
      <bpmn:incoming>Flow_FastPath_Merge</bpmn:incoming>
      <bpmn:incoming>Flow_Committee_Merge</bpmn:incoming>
      <bpmn:incoming>Flow_Advisory_Merge</bpmn:incoming>
      <bpmn:outgoing>Flow_ReviewMerge_AICheck</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:businessRuleTask id="Task_AIReviewRouting" name="AI Review Routing"
      camunda:decisionRef="DMN_GovernanceReviewRouting"
      camunda:decisionRefBinding="latest"
      camunda:resultVariable="requiresEthicsReview"
      camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>Flow_ReviewMerge_AICheck</bpmn:incoming>
      <bpmn:outgoing>Flow_AIRouting_Gateway</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:exclusiveGateway id="Gateway_AICheck" name="AI High /&#10;Critical?" default="Flow_AICheck_Skip">
      <bpmn:incoming>Flow_AIRouting_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_AICheck_Ethics</bpmn:outgoing>
      <bpmn:outgoing>Flow_AICheck_Skip</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_EthicalImpactAssessment" name="4.4 Ethical Impact&#10;Assessment" camunda:candidateGroups="ai-review">
      <bpmn:incoming>Flow_AICheck_Ethics</bpmn:incoming>
      <bpmn:outgoing>Flow_Ethics_AIMerge</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="Timer_EthicsSLA" name="5D&#10;SLA" attachedToRef="Task_EthicalImpactAssessment" cancelActivity="false">
      <bpmn:outgoing>Flow_EthicsSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Ethics">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:exclusiveGateway id="Gateway_AIMerge">
      <bpmn:incoming>Flow_Ethics_AIMerge</bpmn:incoming>
      <bpmn:incoming>Flow_AICheck_Skip</bpmn:incoming>
      <bpmn:outgoing>Flow_AIMerge_DecisionDoc</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_DecisionDocumentation" name="4.5 Decision Documentation&#10;(BPM State Update — 1 Hour)" camunda:type="external" camunda:topic="bpm-state-update">
      <bpmn:incoming>Flow_AIMerge_DecisionDoc</bpmn:incoming>
      <bpmn:outgoing>Flow_DecisionDoc_Complete</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_Phase4_Complete" name="Phase 4&#10;Complete?">
      <bpmn:incoming>Flow_DecisionDoc_Complete</bpmn:incoming>
      <bpmn:outgoing>Flow_Phase4Complete_QualityGate</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:businessRuleTask id="Task_Phase4_QualityGate" name="Phase 4&#10;Quality Gate" camunda:decisionRef="DMN_AutomationTierAssignment" camunda:decisionRefBinding="latest" camunda:resultVariable="qualityGateResult" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>Flow_Phase4Complete_QualityGate</bpmn:incoming>
      <bpmn:outgoing>Flow_Phase4QualityGate_OversightSplit</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:parallelGateway id="Gateway_OversightValidationSplit">
      <bpmn:incoming>Flow_Phase4QualityGate_OversightSplit</bpmn:incoming>
      <bpmn:outgoing>Flow_OversightSplit_GovernanceDecision</bpmn:outgoing>
      <bpmn:outgoing>Flow_OversightSplit_Validation</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:userTask id="Task_Phase4_OversightValidation" name="Independent&#10;Decision Validation" camunda:candidateGroups="oversight-lane">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="regulation" value="OCC 2023-17: Independent validation of governance decisions" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_OversightSplit_Validation</bpmn:incoming>
      <bpmn:outgoing>Flow_Phase4_OversightEnd</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="Timer_Phase4_OversightSLA" name="P3D&#10;SLA" attachedToRef="Task_Phase4_OversightValidation" cancelActivity="false">
      <bpmn:outgoing>Flow_Phase4_OversightSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Phase4_OversightSLA">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:endEvent id="EndEvent_Phase4_OversightComplete" name="Decision Validation&#10;Complete">
      <bpmn:incoming>Flow_Phase4_OversightEnd</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Phase4_OversightSLAEscalated" name="Oversight SLA&#10;Escalated">
      <bpmn:incoming>Flow_Phase4_OversightSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="Gateway_GovernanceDecision" name="Governance&#10;Decision?" default="Flow_Decision_ApprovedConditions">
      <bpmn:incoming>Flow_OversightSplit_GovernanceDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_Decision_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_Decision_ApprovedConditions</bpmn:outgoing>
      <bpmn:outgoing>Flow_Decision_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_Phase5Approved" name="Approved —&#10;Proceed to Phase 5">
      <bpmn:incoming>Flow_Decision_Approved</bpmn:incoming>
      <bpmn:signalEventDefinition id="Signal_Phase4Approved" signalRef="Signal_Phase4Complete" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Phase5ApprovedConditions" name="Approved with&#10;Conditions — Phase 5">
      <bpmn:incoming>Flow_Decision_ApprovedConditions</bpmn:incoming>
      <bpmn:signalEventDefinition id="Signal_Phase4Conditions" signalRef="Signal_Phase4Complete" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Rejected" name="Rejected —&#10;Request Terminated">
      <bpmn:incoming>Flow_Decision_Rejected</bpmn:incoming>
      <bpmn:terminateEventDefinition id="TerminateDef_Rejected" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_ProcessSLAEscalated" name="Process SLA&#10;Escalated">
      <bpmn:incoming>Flow_ProcessSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_FastPathSLAEscalated" name="Fast Path SLA&#10;Escalated">
      <bpmn:incoming>Flow_FastPathSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_CommitteeSLAEscalated" name="Committee SLA&#10;Escalated">
      <bpmn:incoming>Flow_CommitteeSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_AdvisorySLAEscalated" name="Advisory SLA&#10;Escalated">
      <bpmn:incoming>Flow_AdvisorySLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_AIReviewSLAEscalated" name="Ethics Review SLA&#10;Escalated">
      <bpmn:incoming>Flow_EthicsSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:textAnnotation id="Annotation_SOX">
      <bpmn:text>SOX: Governance committee review and advisory board approval constitute mandatory financial control checkpoints. Decision documentation (4.5) is an immutable audit artifact required for SOX compliance.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_SOX" sourceRef="Task_GovernanceCommitteeReview" targetRef="Annotation_SOX" />

    <bpmn:textAnnotation id="Annotation_OCC">
      <bpmn:text>OCC 2023-17: Third-party governance review must document risk tier rationale, reviewer authority, and approval conditions. Risk-tiered routing (4.2) ensures proportionate oversight per vendor criticality.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_OCC" sourceRef="Task_RiskTieredReviewRouting" targetRef="Annotation_OCC" />

    <bpmn:textAnnotation id="Annotation_AIAct_SR117">
      <bpmn:text>EU AI Act + SR 11-7: Ethical Impact Assessment (4.4) is mandatory for AI/model systems classified as High or Critical risk. Ethics Committee review documents model risk acceptance and AI Act conformity assessment.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_AIAct" sourceRef="Task_EthicalImpactAssessment" targetRef="Annotation_AIAct_SR117" />

    <bpmn:sequenceFlow id="Flow_Start_Assembly" sourceRef="StartEvent_Phase4Initiated" targetRef="Task_AssessmentPackageAssembly" />
    <bpmn:sequenceFlow id="Flow_Assembly_Routing" sourceRef="Task_AssessmentPackageAssembly" targetRef="Task_RiskTieredReviewRouting" />
    <bpmn:sequenceFlow id="Flow_Routing_AuthGateway" sourceRef="Task_RiskTieredReviewRouting" targetRef="Gateway_ReviewAuthority" />

    <bpmn:sequenceFlow id="Flow_AuthGateway_FastPath" name="Fast Path" sourceRef="Gateway_ReviewAuthority" targetRef="Task_FastPathReview">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${reviewAuthority == 'FAST_PATH'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AuthGateway_Committee" name="Committee" sourceRef="Gateway_ReviewAuthority" targetRef="Task_GovernanceCommitteeReview" />
    <bpmn:sequenceFlow id="Flow_AuthGateway_Advisory" name="Advisory Board" sourceRef="Gateway_ReviewAuthority" targetRef="Task_AdvisoryBoardReview">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${reviewAuthority == 'ADVISORY_BOARD'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_FastPath_Merge" sourceRef="Task_FastPathReview" targetRef="Gateway_ReviewMerge" />
    <bpmn:sequenceFlow id="Flow_Committee_Merge" sourceRef="Task_GovernanceCommitteeReview" targetRef="Gateway_ReviewMerge" />
    <bpmn:sequenceFlow id="Flow_Advisory_Merge" sourceRef="Task_AdvisoryBoardReview" targetRef="Gateway_ReviewMerge" />

    <bpmn:sequenceFlow id="Flow_ReviewMerge_AICheck" sourceRef="Gateway_ReviewMerge" targetRef="Task_AIReviewRouting" />
    <bpmn:sequenceFlow id="Flow_AIRouting_Gateway" sourceRef="Task_AIReviewRouting" targetRef="Gateway_AICheck" />

    <bpmn:sequenceFlow id="Flow_AICheck_Ethics" name="Yes" sourceRef="Gateway_AICheck" targetRef="Task_EthicalImpactAssessment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${requiresEthicsReview == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AICheck_Skip" name="No" sourceRef="Gateway_AICheck" targetRef="Gateway_AIMerge" />

    <bpmn:sequenceFlow id="Flow_Ethics_AIMerge" sourceRef="Task_EthicalImpactAssessment" targetRef="Gateway_AIMerge" />
    <bpmn:sequenceFlow id="Flow_AIMerge_DecisionDoc" sourceRef="Gateway_AIMerge" targetRef="Task_DecisionDocumentation" />
    <bpmn:sequenceFlow id="Flow_DecisionDoc_Complete" sourceRef="Task_DecisionDocumentation" targetRef="Gateway_Phase4_Complete" />
    <bpmn:sequenceFlow id="Flow_Phase4Complete_QualityGate" name="Yes" sourceRef="Gateway_Phase4_Complete" targetRef="Task_Phase4_QualityGate">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${phaseComplete == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Phase4QualityGate_OversightSplit" sourceRef="Task_Phase4_QualityGate" targetRef="Gateway_OversightValidationSplit" />
    <bpmn:sequenceFlow id="Flow_OversightSplit_GovernanceDecision" sourceRef="Gateway_OversightValidationSplit" targetRef="Gateway_GovernanceDecision" />
    <bpmn:sequenceFlow id="Flow_OversightSplit_Validation" sourceRef="Gateway_OversightValidationSplit" targetRef="Task_Phase4_OversightValidation" />
    <bpmn:sequenceFlow id="Flow_Phase4_OversightEnd" sourceRef="Task_Phase4_OversightValidation" targetRef="EndEvent_Phase4_OversightComplete" />
    <bpmn:sequenceFlow id="Flow_Phase4_OversightSLAEscalate" sourceRef="Timer_Phase4_OversightSLA" targetRef="EndEvent_Phase4_OversightSLAEscalated" />

    <bpmn:sequenceFlow id="Flow_Decision_Approved" name="Approved" sourceRef="Gateway_GovernanceDecision" targetRef="EndEvent_Phase5Approved">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${governanceDecision == 'APPROVED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Decision_ApprovedConditions" name="Approved with Conditions" sourceRef="Gateway_GovernanceDecision" targetRef="EndEvent_Phase5ApprovedConditions" />
    <bpmn:sequenceFlow id="Flow_Decision_Rejected" name="Rejected" sourceRef="Gateway_GovernanceDecision" targetRef="EndEvent_Rejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${governanceDecision == 'REJECTED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_ProcessSLAEscalate" sourceRef="Timer_ProcessSLA" targetRef="EndEvent_ProcessSLAEscalated" />
    <bpmn:sequenceFlow id="Flow_FastPathSLAEscalate" sourceRef="Timer_FastPathSLA" targetRef="EndEvent_FastPathSLAEscalated" />
    <bpmn:sequenceFlow id="Flow_CommitteeSLAEscalate" sourceRef="Timer_CommitteeSLA" targetRef="EndEvent_CommitteeSLAEscalated" />
    <bpmn:sequenceFlow id="Flow_AdvisorySLAEscalate" sourceRef="Timer_AdvisorySLA" targetRef="EndEvent_AdvisorySLAEscalated" />
    <bpmn:sequenceFlow id="Flow_EthicsSLAEscalate" sourceRef="Timer_EthicsSLA" targetRef="EndEvent_AIReviewSLAEscalated" />

  </bpmn:process>

  <bpmn:process id="Process_VendorResponse" name="Vendor / Third Party Response" isExecutable="false" camunda:historyTimeToLive="180">
    <bpmn:laneSet id="LaneSet_Vendor">
      <bpmn:lane id="Lane_VendorResponse" name="Vendor Response">
        <bpmn:flowNodeRef>StartEvent_VendorRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VendorResponseReceipt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_VendorResponseSent</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_VendorRequest" name="Vendor Assessment&#10;Request Received">
      <bpmn:outgoing>Flow_VendorStart_Response</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_VendorResponseReceipt" name="Vendor Response&#10;Package Submission" camunda:candidateGroups="vendor-response">
      <bpmn:incoming>Flow_VendorStart_Response</bpmn:incoming>
      <bpmn:outgoing>Flow_VendorResponse_End</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndEvent_VendorResponseSent" name="Response Package&#10;Submitted">
      <bpmn:incoming>Flow_VendorResponse_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_VendorStart_Response" sourceRef="StartEvent_VendorRequest" targetRef="Task_VendorResponseReceipt" />
    <bpmn:sequenceFlow id="Flow_VendorResponse_End" sourceRef="Task_VendorResponseReceipt" targetRef="EndEvent_VendorResponseSent" />

  </bpmn:process>

