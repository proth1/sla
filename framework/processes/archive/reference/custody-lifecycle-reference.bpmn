<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_CustodyLifecycle" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.42.0">
  <bpmn:collaboration id="Collaboration_Custody">
    <bpmn:participant id="Participant_Custody" name="Asset Custody Lifecycle" processRef="Process_CustodyLifecycle" />
  </bpmn:collaboration>
  <bpmn:process id="Process_CustodyLifecycle" isExecutable="false">
    <bpmn:documentation>
      Reference model: Asset Custody Lifecycle Governance Pattern.
      Demonstrates: multi-lane governance process with compliance lane, timer boundary events,
      error boundary events, parallel settlement verification, and regulatory reporting.
      Use as structural reference for SLA governance processes involving asset-level controls.
    </bpmn:documentation>
    <bpmn:laneSet id="LaneSet_Custody">
      <bpmn:lane id="Lane_AssetManager" name="Asset Manager">
        <bpmn:flowNodeRef>StartEvent_AssetReceived</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VerifyAssetDetails</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AuthorizeTransfer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_AssetReleased</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_CustodyOps" name="Custody Operations">
        <bpmn:flowNodeRef>Task_AssetOnboarding</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_OnboardingComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RemedyOnboarding</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RemedyMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SafekeepingRegistration</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ValuationProcessing</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ValuationApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SettlementInstruction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SettlementExecution</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SettlementComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FailedSettlement</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SettlementFailed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AssetReconciliation</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_RiskControl" name="Risk &amp; Control">
        <bpmn:flowNodeRef>Task_RiskAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RiskAcceptable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RiskRemediation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RiskMerge</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Compliance" name="Compliance">
        <bpmn:flowNodeRef>Task_ComplianceScreening</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_CompliancePassed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ComplianceBlocked</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegulatoryReporting</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_LifecycleComplete</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_AssetReceived" name="Asset&#10;Received">
      <bpmn:documentation>Asset custody lifecycle initiated upon receipt of asset transfer instruction from Asset Manager.</bpmn:documentation>
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_VerifyAssetDetails" name="Verify Asset&#10;Details" camunda:candidateGroups="asset-managers">
      <bpmn:documentation>Asset Manager verifies asset details: ISIN, quantity, settlement date, counterparty, and custodian account designation.</bpmn:documentation>
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="Task_AssetOnboarding" name="Asset Onboarding&#10;Validation">
      <bpmn:documentation>Automated validation of asset details against custody system: ISIN lookup, asset class determination, eligible custodian check, and eligibility verification.</bpmn:documentation>
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_OnboardingComplete" name="Onboarding&#10;Valid?">
      <bpmn:documentation>Evaluates whether all onboarding validations passed. Routes to remediation if any validation fails.</bpmn:documentation>
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_OnboardNo</bpmn:outgoing>
      <bpmn:outgoing>Flow_OnboardYes</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_RemedyOnboarding" name="Remedy Onboarding&#10;Exception" camunda:candidateGroups="custody-ops">
      <bpmn:documentation>Custody Operations manually resolves onboarding exceptions: incorrect ISIN, missing custodian designation, ineligible asset class. SLA: 2 business days.</bpmn:documentation>
      <bpmn:incoming>Flow_OnboardNo</bpmn:incoming>
      <bpmn:outgoing>Flow_RemedyMerge</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Timer_OnboardingRemedySLA" name="2-Day&#10;Remedy SLA" cancelActivity="false" attachedToRef="Task_RemedyOnboarding">
      <bpmn:documentation>Non-interrupting SLA timer. If remedy exceeds 2 business days, escalation event is raised to Risk &amp; Control.</bpmn:documentation>
      <bpmn:outgoing>Flow_RemedySLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P2D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="Event_RemedyEscalated" name="Remedy&#10;Escalated">
      <bpmn:documentation>Escalation end event when onboarding remedy SLA is breached.</bpmn:documentation>
      <bpmn:incoming>Flow_RemedySLAEscalate</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_RemedySLAEscalate" sourceRef="Timer_OnboardingRemedySLA" targetRef="Event_RemedyEscalated" />

    <bpmn:exclusiveGateway id="Gateway_RemedyMerge">
      <bpmn:documentation>Merge gateway: converges successful onboarding path and remediated exception path.</bpmn:documentation>
      <bpmn:incoming>Flow_OnboardYes</bpmn:incoming>
      <bpmn:incoming>Flow_RemedyMerge</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_ComplianceScreening" name="Compliance&#10;Screening">
      <bpmn:documentation>
        Automated compliance screening: sanctions list check (OFAC, EU, UN), PEP screening, AML red flag detection, regulatory eligibility verification.
        Reference: OCC 2023-17 §III.B (Due Diligence), DORA Art. 6 (ICT risk controls).
      </bpmn:documentation>
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_CompliancePassed" name="Compliance&#10;Passed?">
      <bpmn:documentation>Routes to compliance block (end event) if any screening flag is raised, or continues to risk assessment on pass.</bpmn:documentation>
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_ComplianceNo</bpmn:outgoing>
      <bpmn:outgoing>Flow_ComplianceYes</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_ComplianceBlocked" name="Compliance&#10;Blocked">
      <bpmn:documentation>Terminal state: asset custody blocked due to compliance screening failure. Compliance team notifies Asset Manager with reason and regulatory citation.</bpmn:documentation>
      <bpmn:incoming>Flow_ComplianceNo</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="Task_RiskAssessment" name="Risk Assessment&#10;&amp; Classification" camunda:candidateGroups="risk-control">
      <bpmn:documentation>
        Risk &amp; Control assesses asset-level risk: counterparty credit risk, market risk, concentration risk, operational risk.
        Outputs: risk rating (Low/Medium/High), required controls.
        Reference: OCC 2023-17 §III.A (Risk Assessment).
      </bpmn:documentation>
      <bpmn:incoming>Flow_ComplianceYes</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Timer_RiskAssessmentSLA" name="3-Day&#10;Risk SLA" cancelActivity="false" attachedToRef="Task_RiskAssessment">
      <bpmn:documentation>Non-interrupting SLA timer. Risk assessment must complete within 3 business days.</bpmn:documentation>
      <bpmn:outgoing>Flow_RiskSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="Event_RiskEscalated" name="Risk Assessment&#10;Escalated">
      <bpmn:documentation>Escalation end event when risk assessment SLA is breached.</bpmn:documentation>
      <bpmn:incoming>Flow_RiskSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_RiskSLAEscalate" sourceRef="Timer_RiskAssessmentSLA" targetRef="Event_RiskEscalated" />

    <bpmn:exclusiveGateway id="Gateway_RiskAcceptable" name="Risk&#10;Acceptable?">
      <bpmn:documentation>Routes to risk remediation if High risk rating, or to safekeeping if Low/Medium risk rating.</bpmn:documentation>
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_RiskNo</bpmn:outgoing>
      <bpmn:outgoing>Flow_RiskYes</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_RiskRemediation" name="Risk Remediation&#10;&amp; Approval" camunda:candidateGroups="risk-control">
      <bpmn:documentation>For High risk assets: Risk &amp; Control defines additional controls, obtains senior approval, and documents remediation plan before proceeding to safekeeping.</bpmn:documentation>
      <bpmn:incoming>Flow_RiskNo</bpmn:incoming>
      <bpmn:outgoing>Flow_RiskRemediationMerge</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_RiskMerge">
      <bpmn:documentation>Merge gateway: converges acceptable risk path and remediated high-risk path.</bpmn:documentation>
      <bpmn:incoming>Flow_RiskYes</bpmn:incoming>
      <bpmn:incoming>Flow_RiskRemediationMerge</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_SafekeepingRegistration" name="Safekeeping&#10;Registration">
      <bpmn:documentation>Registers asset in the custody safekeeping system: assigns custody account, records position, generates custody reference number, and sends confirmation to Asset Manager.</bpmn:documentation>
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_ValuationProcessing" name="Valuation&#10;Processing">
      <bpmn:documentation>Calculates current market value of asset using pricing service. Applies valuation methodology per asset class (mark-to-market, fair value, amortized cost).</bpmn:documentation>
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_ValuationApproved" name="Valuation&#10;Approved?">
      <bpmn:documentation>Routes to settlement if valuation within tolerance, or back to Risk &amp; Control if valuation anomaly detected (price variance > threshold).</bpmn:documentation>
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:outgoing>Flow_ValYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_ValNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="Event_ValuationAnomaly" name="Valuation&#10;Anomaly Raised">
      <bpmn:documentation>Valuation anomaly end event — triggers investigation workflow outside this process scope.</bpmn:documentation>
      <bpmn:incoming>Flow_ValNo</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:userTask id="Task_AuthorizeTransfer" name="Authorize&#10;Settlement" camunda:candidateGroups="asset-managers">
      <bpmn:documentation>Asset Manager reviews valuation and authorizes settlement. Dual-control authorization required for transactions > $1M.</bpmn:documentation>
      <bpmn:incoming>Flow_ValYes</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="Task_SettlementInstruction" name="Generate Settlement&#10;Instructions">
      <bpmn:documentation>Generates SWIFT settlement instructions (MT540/MT541/MT542/MT543) and transmits to Central Securities Depository (CSD) or counterparty custodian.</bpmn:documentation>
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_SettlementExecution" name="Settlement&#10;Execution">
      <bpmn:documentation>Monitors settlement status with CSD/ICSD. Handles DVP (Delivery vs Payment) or FOP (Free of Payment) settlement per instruction type. SLA: T+2 standard settlement cycle.</bpmn:documentation>
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="Timer_SettlementSLA" name="T+2 Settlement&#10;Deadline" cancelActivity="false" attachedToRef="Task_SettlementExecution">
      <bpmn:documentation>Non-interrupting SLA timer. Settlement must complete within T+2 (2 business days). Breach triggers failed settlement handling.</bpmn:documentation>
      <bpmn:outgoing>Flow_SettleSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P2D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="Event_SettlementDeadlineBreached" name="Settlement Deadline&#10;Breached">
      <bpmn:documentation>SLA breach escalation for settlement deadline. Triggers fail management process.</bpmn:documentation>
      <bpmn:incoming>Flow_SettleSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_SettleSLAEscalate" sourceRef="Timer_SettlementSLA" targetRef="Event_SettlementDeadlineBreached" />

    <bpmn:boundaryEvent id="Error_SettlementFail" name="Settlement&#10;Error" attachedToRef="Task_SettlementExecution">
      <bpmn:documentation>Interrupting error boundary event. Catches hard settlement errors (CSD rejection, insufficient funds, invalid account). Routes to failed settlement handling.</bpmn:documentation>
      <bpmn:outgoing>Flow_ErrorToFailed</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_SettlementRejection" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_ErrorToFailed" sourceRef="Error_SettlementFail" targetRef="Task_FailedSettlement" />

    <bpmn:exclusiveGateway id="Gateway_SettlementComplete" name="Settlement&#10;Complete?">
      <bpmn:documentation>Routes to failed settlement handling if settlement did not complete, or to reconciliation on success.</bpmn:documentation>
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_SettleNo</bpmn:outgoing>
      <bpmn:outgoing>Flow_SettleYes</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_FailedSettlement" name="Handle Failed&#10;Settlement">
      <bpmn:documentation>Custody Operations investigates and resolves settlement failures: buy-in process, partial settlement, or cancellation. Notifies Asset Manager and Risk &amp; Control.</bpmn:documentation>
      <bpmn:incoming>Flow_SettleNo</bpmn:incoming>
      <bpmn:incoming>Flow_ErrorToFailed</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSettleFailed</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_SettlementFailed" name="Settlement&#10;Failed">
      <bpmn:documentation>Terminal failure state. Asset position remains with original owner. Full incident report generated.</bpmn:documentation>
      <bpmn:incoming>Flow_ToSettleFailed</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:serviceTask id="Task_AssetReconciliation" name="Asset&#10;Reconciliation">
      <bpmn:documentation>Performs end-of-day reconciliation: custody position vs. external depository, valuation cross-check, and cash reconciliation. Generates reconciliation report.</bpmn:documentation>
      <bpmn:incoming>Flow_SettleYes</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_RegulatoryReporting" name="Regulatory&#10;Reporting">
      <bpmn:documentation>
        Generates regulatory reports: EMIR trade reporting, SFTR securities financing, UCITS fund reporting, custody confirmation to Asset Manager.
        Reference: DORA Arts. 17-23 (Incident Reporting), OCC 2023-17 §III.D (Ongoing Monitoring).
      </bpmn:documentation>
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent_LifecycleComplete" name="Custody Lifecycle&#10;Complete">
      <bpmn:documentation>Asset has been received, screened, risk-assessed, registered, valued, settled, reconciled, and reported. Lifecycle event recorded.</bpmn:documentation>
      <bpmn:incoming>Flow_14</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_AssetReleased" name="Asset&#10;Released">
      <bpmn:documentation>Asset Manager has authorized release. Lifecycle terminates after transfer authorization.</bpmn:documentation>
      <bpmn:incoming>Flow_AuthorizeEnd</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_AssetReceived" targetRef="Task_VerifyAssetDetails" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_VerifyAssetDetails" targetRef="Task_AssetOnboarding" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Task_AssetOnboarding" targetRef="Gateway_OnboardingComplete" />
    <bpmn:sequenceFlow id="Flow_OnboardNo" name="No" sourceRef="Gateway_OnboardingComplete" targetRef="Task_RemedyOnboarding" />
    <bpmn:sequenceFlow id="Flow_OnboardYes" name="Yes" sourceRef="Gateway_OnboardingComplete" targetRef="Gateway_RemedyMerge" />
    <bpmn:sequenceFlow id="Flow_RemedyMerge" sourceRef="Task_RemedyOnboarding" targetRef="Gateway_RemedyMerge" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Gateway_RemedyMerge" targetRef="Task_ComplianceScreening" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Task_ComplianceScreening" targetRef="Gateway_CompliancePassed" />
    <bpmn:sequenceFlow id="Flow_ComplianceNo" name="No" sourceRef="Gateway_CompliancePassed" targetRef="EndEvent_ComplianceBlocked" />
    <bpmn:sequenceFlow id="Flow_ComplianceYes" name="Yes" sourceRef="Gateway_CompliancePassed" targetRef="Task_RiskAssessment" />
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Task_RiskAssessment" targetRef="Gateway_RiskAcceptable" />
    <bpmn:sequenceFlow id="Flow_RiskNo" name="High Risk" sourceRef="Gateway_RiskAcceptable" targetRef="Task_RiskRemediation" />
    <bpmn:sequenceFlow id="Flow_RiskYes" name="Acceptable" sourceRef="Gateway_RiskAcceptable" targetRef="Gateway_RiskMerge" />
    <bpmn:sequenceFlow id="Flow_RiskRemediationMerge" sourceRef="Task_RiskRemediation" targetRef="Gateway_RiskMerge" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="Gateway_RiskMerge" targetRef="Task_SafekeepingRegistration" />
    <bpmn:sequenceFlow id="Flow_08" sourceRef="Task_SafekeepingRegistration" targetRef="Task_ValuationProcessing" />
    <bpmn:sequenceFlow id="Flow_09" sourceRef="Task_ValuationProcessing" targetRef="Gateway_ValuationApproved" />
    <bpmn:sequenceFlow id="Flow_ValYes" name="Yes" sourceRef="Gateway_ValuationApproved" targetRef="Task_AuthorizeTransfer" />
    <bpmn:sequenceFlow id="Flow_ValNo" name="Anomaly" sourceRef="Gateway_ValuationApproved" targetRef="Event_ValuationAnomaly" />
    <bpmn:sequenceFlow id="Flow_AuthorizeEnd" sourceRef="Task_AuthorizeTransfer" targetRef="EndEvent_AssetReleased" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_AuthorizeTransfer" targetRef="Task_SettlementInstruction" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_SettlementInstruction" targetRef="Task_SettlementExecution" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_SettlementExecution" targetRef="Gateway_SettlementComplete" />
    <bpmn:sequenceFlow id="Flow_SettleNo" name="No" sourceRef="Gateway_SettlementComplete" targetRef="Task_FailedSettlement" />
    <bpmn:sequenceFlow id="Flow_SettleYes" name="Yes" sourceRef="Gateway_SettlementComplete" targetRef="Task_AssetReconciliation" />
    <bpmn:sequenceFlow id="Flow_ToSettleFailed" sourceRef="Task_FailedSettlement" targetRef="EndEvent_SettlementFailed" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_AssetReconciliation" targetRef="Task_RegulatoryReporting" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_RegulatoryReporting" targetRef="EndEvent_LifecycleComplete" />
  </bpmn:process>

  <bpmn:error id="Error_SettlementRejection" name="Settlement Rejection" errorCode="SETTLE_REJECT" />

  <bpmndi:BPMNDiagram id="BPMNDiagram_Custody">
    <bpmndi:BPMNPlane id="BPMNPlane_Custody" bpmnElement="Collaboration_Custody">
      <bpmndi:BPMNShape id="Participant_Custody_di" bpmnElement="Participant_Custody" isHorizontal="true">
        <dc:Bounds x="155" y="47" width="2100" height="910" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_AssetManager_di" bpmnElement="Lane_AssetManager" isHorizontal="true">
        <dc:Bounds x="185" y="47" width="2070" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_CustodyOps_di" bpmnElement="Lane_CustodyOps" isHorizontal="true">
        <dc:Bounds x="185" y="247" width="2070" height="250" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_RiskControl_di" bpmnElement="Lane_RiskControl" isHorizontal="true">
        <dc:Bounds x="185" y="497" width="2070" height="210" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Compliance_di" bpmnElement="Lane_Compliance" isHorizontal="true">
        <dc:Bounds x="185" y="707" width="2070" height="250" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_AssetReceived_di" bpmnElement="StartEvent_AssetReceived">
        <dc:Bounds x="247" y="129" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="240" y="172" width="50" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_VerifyAssetDetails_di" bpmnElement="Task_VerifyAssetDetails">
        <dc:Bounds x="335" y="107" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_AssetReleased_di" bpmnElement="EndEvent_AssetReleased">
        <dc:Bounds x="1757" y="129" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1746" y="172" width="58" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_AssetOnboarding_di" bpmnElement="Task_AssetOnboarding">
        <dc:Bounds x="487" y="322" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_OnboardingComplete_di" bpmnElement="Gateway_OnboardingComplete" isMarkerVisible="true">
