        <di:waypoint x="1630" y="842" />
        <di:waypoint x="1630" y="102" />
        <di:waypoint x="1740" y="102" />
      </bpmndi:BPMNEdge>

      <!-- Timer_BoardApprovalSLA → BoardApprovalSLAEscalated -->
      <bpmndi:BPMNEdge id="Edge_Flow_BoardApprovalTimer" bpmnElement="Flow_BoardApprovalTimer">
        <di:waypoint x="1844" y="142" />
        <di:waypoint x="1888" y="142" />
        <di:waypoint x="1888" y="114" />
      </bpmndi:BPMNEdge>

      <!-- RetirementBoardApproval → RetirementApproved Gateway -->
      <bpmndi:BPMNEdge id="Edge_Flow_BoardApprovalToGateway" bpmnElement="Flow_BoardApprovalToGateway">
        <di:waypoint x="1840" y="102" />
        <di:waypoint x="1960" y="87" />
      </bpmndi:BPMNEdge>

      <!-- RetirementApproved Gateway → RetirementRejected End (right) -->
      <bpmndi:BPMNEdge id="Edge_Flow_ApprovedNo" bpmnElement="Flow_ApprovedNo">
        <di:waypoint x="2010" y="87" />
        <di:waypoint x="2060" y="96" />
      </bpmndi:BPMNEdge>

      <!-- RetirementApproved Gateway → StakeholderCommsPlanning (cross-lane GB→BO, down) -->
      <bpmndi:BPMNEdge id="Edge_Flow_ApprovedYes" bpmnElement="Flow_ApprovedYes">
        <di:waypoint x="1985" y="112" />
        <di:waypoint x="1985" y="242" />
        <di:waypoint x="2120" y="242" />
      </bpmndi:BPMNEdge>

      <!-- StakeholderCommsPlanning → UserMigrationPlan -->
      <bpmndi:BPMNEdge id="Edge_Flow_CommsToUserMig" bpmnElement="Flow_CommsToUserMig">
        <di:waypoint x="2220" y="242" />
        <di:waypoint x="2280" y="242" />
      </bpmndi:BPMNEdge>

      <!-- UserMigrationPlan → ContractTermination (cross-lane BO→Proc, down) -->
      <bpmndi:BPMNEdge id="Edge_Flow_UserMigToContractTerm" bpmnElement="Flow_UserMigToContractTerm">
        <di:waypoint x="2380" y="242" />
        <di:waypoint x="2440" y="242" />
        <di:waypoint x="2440" y="522" />
      </bpmndi:BPMNEdge>

      <!-- ContractTermination → LicenseReclamation -->
      <bpmndi:BPMNEdge id="Edge_Flow_ContractToLicense" bpmnElement="Flow_ContractToLicense">
        <di:waypoint x="2540" y="562" />
        <di:waypoint x="2600" y="562" />
      </bpmndi:BPMNEdge>

      <!-- LicenseReclamation → VendorOffboarding -->
      <bpmndi:BPMNEdge id="Edge_Flow_LicenseToVendorOff" bpmnElement="Flow_LicenseToVendorOff">
        <di:waypoint x="2700" y="562" />
        <di:waypoint x="2760" y="562" />
      </bpmndi:BPMNEdge>

      <!-- VendorOffboarding → CostRecovery -->
      <bpmndi:BPMNEdge id="Edge_Flow_VendorOffToCostRec" bpmnElement="Flow_VendorOffToCostRec">
        <di:waypoint x="2860" y="562" />
        <di:waypoint x="2920" y="562" />
      </bpmndi:BPMNEdge>

      <!-- CostRecovery → SLATermination (cross-lane Proc→VM, down) -->
      <bpmndi:BPMNEdge id="Edge_Flow_CostRecToSLATerm" bpmnElement="Flow_CostRecToSLATerm">
        <di:waypoint x="2970" y="602" />
        <di:waypoint x="2970" y="1002" />
        <di:waypoint x="2540" y="1042" />
      </bpmndi:BPMNEdge>

      <!-- SLATermination → FinalPerformanceReport -->
      <bpmndi:BPMNEdge id="Edge_Flow_SLATermToFinalRep" bpmnElement="Flow_SLATermToFinalRep">
        <di:waypoint x="2540" y="1042" />
        <di:waypoint x="2600" y="1042" />
      </bpmndi:BPMNEdge>

      <!-- FinalPerformanceReport → VendorScoreCardFinal -->
      <bpmndi:BPMNEdge id="Edge_Flow_FinalRepToScorecard" bpmnElement="Flow_FinalRepToScorecard">
        <di:waypoint x="2700" y="1042" />
        <di:waypoint x="2760" y="1042" />
      </bpmndi:BPMNEdge>

      <!-- VendorScoreCardFinal → CMDBDecommission -->
      <bpmndi:BPMNEdge id="Edge_Flow_ScorecardToCMDB" bpmnElement="Flow_ScorecardToCMDB">
        <di:waypoint x="2860" y="1042" />
        <di:waypoint x="2920" y="1042" />
      </bpmndi:BPMNEdge>

      <!-- CMDBDecommission → AccessRevocation (cross-lane VM→IS, up) -->
      <bpmndi:BPMNEdge id="Edge_Flow_CMDBToAccessRevoke" bpmnElement="Flow_CMDBToAccessRevoke">
        <di:waypoint x="3020" y="1042" />
        <di:waypoint x="3080" y="1042" />
        <di:waypoint x="3080" y="922" />
      </bpmndi:BPMNEdge>

      <!-- AccessRevocation → SecureDataDestruction -->
      <bpmndi:BPMNEdge id="Edge_Flow_AccessToDataDestruct" bpmnElement="Flow_AccessToDataDestruct">
        <di:waypoint x="3180" y="882" />
        <di:waypoint x="3240" y="882" />
      </bpmndi:BPMNEdge>

      <!-- SecureDataDestruction → SecurityCertification -->
      <bpmndi:BPMNEdge id="Edge_Flow_DataDestructToSecCert" bpmnElement="Flow_DataDestructToSecCert">
        <di:waypoint x="3340" y="882" />
        <di:waypoint x="3400" y="882" />
      </bpmndi:BPMNEdge>

      <!-- SecurityCertification → RegulatoryNotification (cross-lane IS→LC, up) -->
      <!-- RegNotif is at x=3080 which is LEFT of SecurityCert at x=3400. Need to route backward. -->
      <!-- Actually, to avoid backflow confusion, place RegNotif after SecurityCert. Use x=3080 is wrong. -->
      <!-- Fix: move RegNotif to x=3080 LC lane is different lane — since it's cross-lane it can go left-ward. -->
      <!-- For visual clarity, let's use RegNotif at x=3080 same column but LC lane. The edge goes up-left. -->
      <bpmndi:BPMNEdge id="Edge_Flow_SecCertToRegNotif" bpmnElement="Flow_SecCertToRegNotif">
        <di:waypoint x="3450" y="842" />
        <di:waypoint x="3450" y="722" />
        <di:waypoint x="3180" y="722" />
      </bpmndi:BPMNEdge>

      <!-- RegulatoryNotification → ComplianceClosure -->
      <bpmndi:BPMNEdge id="Edge_Flow_RegNotifToCompClosure" bpmnElement="Flow_RegNotifToCompClosure">
        <di:waypoint x="3180" y="722" />
        <di:waypoint x="3240" y="722" />
      </bpmndi:BPMNEdge>

      <!-- ComplianceClosure → ArchitectureCleanup (cross-lane LC→ITA, up) -->
      <bpmndi:BPMNEdge id="Edge_Flow_CompClosureToArchClean" bpmnElement="Flow_CompClosureToArchClean">
        <di:waypoint x="3290" y="682" />
        <di:waypoint x="3290" y="442" />
        <di:waypoint x="3130" y="442" />
        <di:waypoint x="3130" y="402" />
      </bpmndi:BPMNEdge>

      <!-- ArchitectureCleanup → TechDebtClosure -->
      <bpmndi:BPMNEdge id="Edge_Flow_ArchCleanToTechDebt" bpmnElement="Flow_ArchCleanToTechDebt">
        <di:waypoint x="3180" y="402" />
        <di:waypoint x="3240" y="402" />
      </bpmndi:BPMNEdge>

      <!-- TechDebtClosure → FinalGovernanceSignOff (cross-lane ITA→GB, up) -->
      <bpmndi:BPMNEdge id="Edge_Flow_TechDebtToFinalSignOff" bpmnElement="Flow_TechDebtToFinalSignOff">
        <di:waypoint x="3340" y="362" />
        <di:waypoint x="3350" y="362" />
        <di:waypoint x="3350" y="102" />
      </bpmndi:BPMNEdge>

      <!-- FinalGovernanceSignOff → AssetRetired End (FinalSignOff: x=3300, right edge=3400; End at x=3440) -->
      <bpmndi:BPMNEdge id="Edge_Flow_FinalSignOffToEnd" bpmnElement="Flow_FinalSignOffToEnd">
        <di:waypoint x="3400" y="102" />
        <di:waypoint x="3440" y="98" />
      </bpmndi:BPMNEdge>

      <!-- Associations -->
      <bpmndi:BPMNEdge id="Edge_Assoc_Regulatory" bpmnElement="Assoc_Regulatory">
        <di:waypoint x="1790" y="142" />
        <di:waypoint x="1790" y="1170" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Assoc_Security" bpmnElement="Assoc_Security">
        <di:waypoint x="3290" y="922" />
        <di:waypoint x="3290" y="1170" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
