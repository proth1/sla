<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_RetirementMgmt"
                  targetNamespace="http://sla.governance/processes"
                  exporter="SLA Governance Platform"
                  exporterVersion="2025.03.1">

  <bpmn:collaboration id="Collab_RetirementMgmt">
    <bpmn:participant id="Participant_RetirementMgmt"
                      name="Phase 6: Software Asset Retirement Management"
                      processRef="Process_RetirementMgmt" />
  </bpmn:collaboration>

  <bpmn:process id="Process_RetirementMgmt"
                name="Software Asset Retirement Management"
                isExecutable="false"
                camunda:historyTimeToLive="365">

    <bpmn:laneSet id="LaneSet_RetirementMgmt">
      <bpmn:lane id="Lane_GB" name="Governance Board">
        <bpmn:flowNodeRef>StartEvent_RetirementTriggered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RetirementBoardApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RetirementApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_RetirementRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FinalGovernanceSignOff</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_AssetRetired</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Timer_BoardApprovalSLA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_BoardApprovalSLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_BO" name="Business Owner">
        <bpmn:flowNodeRef>Task_RetirementImpactAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_StakeholderCommsPlanning</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UserMigrationPlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>DMN_RetirementEligibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_EligibilityGateway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_NotEligible</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ITA" name="IT Architecture">
        <bpmn:flowNodeRef>Task_DependencyMapping</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DecommissionPlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DataMigrationDesign</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ArchitectureCleanup</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TechDebtClosure</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Proc" name="Procurement">
        <bpmn:flowNodeRef>Task_ContractTermination</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LicenseReclamation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VendorOffboarding</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CostRecovery</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_LC" name="Legal &amp; Compliance">
        <bpmn:flowNodeRef>Task_LegalObligationReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DataRetentionCompliance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegulatoryNotification</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ComplianceClosure</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_LegalClearanceGate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_LegalHold</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_IS" name="Information Security">
        <bpmn:flowNodeRef>Task_DataPurgePlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AccessRevocation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SecureDataDestruction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SecurityCertification</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Timer_DataPurgeSLA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_DataPurgeSLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_VM" name="Vendor Management">
        <bpmn:flowNodeRef>Task_SLATermination</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FinalPerformanceReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VendorScoreCardFinal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CMDBDecommission</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Start Event -->
    <bpmn:startEvent id="StartEvent_RetirementTriggered" name="Retirement Trigger Received">
      <bpmn:outgoing>Flow_StartToImpactAssess</bpmn:outgoing>
      <bpmn:signalEventDefinition signalRef="Signal_P5Complete" />
    </bpmn:startEvent>

    <!-- Business Owner: Impact Assessment and DMN Eligibility -->
    <bpmn:userTask id="Task_RetirementImpactAssessment"
                   name="Retirement Impact Assessment"
                   camunda:candidateGroups="business-owner">
      <bpmn:incoming>Flow_StartToImpactAssess</bpmn:incoming>
      <bpmn:outgoing>Flow_ImpactToEligibility</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:businessRuleTask id="DMN_RetirementEligibility"
                           name="Evaluate Retirement Eligibility"
                           camunda:decisionRef="DMN_17_RetirementEligibility"
                           camunda:resultVariable="retirementEligible"
                           camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>Flow_ImpactToEligibility</bpmn:incoming>
      <bpmn:outgoing>Flow_EligibilityToGateway</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:exclusiveGateway id="Gateway_EligibilityGateway" name="Eligible for Retirement?">
      <bpmn:incoming>Flow_EligibilityToGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_EligibilityYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_EligibilityNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_NotEligible" name="Not Eligible - Return to Operations">
      <bpmn:incoming>Flow_EligibilityNo</bpmn:incoming>
    </bpmn:endEvent>

    <!-- IT Architecture: Dependency Mapping & Decommission Plan -->
    <bpmn:userTask id="Task_DependencyMapping"
                   name="Dependency and Integration Mapping"
                   camunda:candidateGroups="it-architecture">
      <bpmn:incoming>Flow_EligibilityYes</bpmn:incoming>
      <bpmn:outgoing>Flow_DepMapToDecomPlan</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_DecommissionPlan"
                   name="Develop Decommission Plan"
                   camunda:candidateGroups="it-architecture">
      <bpmn:incoming>Flow_DepMapToDecomPlan</bpmn:incoming>
      <bpmn:outgoing>Flow_DecomPlanToDataMig</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_DataMigrationDesign"
                   name="Data Migration Design"
                   camunda:candidateGroups="it-architecture">
      <bpmn:incoming>Flow_DecomPlanToDataMig</bpmn:incoming>
      <bpmn:outgoing>Flow_DataMigToLegal</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Legal & Compliance: Legal Obligations -->
    <bpmn:userTask id="Task_LegalObligationReview"
                   name="Legal Obligation Review"
                   camunda:candidateGroups="legal-compliance">
      <bpmn:incoming>Flow_DataMigToLegal</bpmn:incoming>
      <bpmn:outgoing>Flow_LegalObToDataRet</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_DataRetentionCompliance"
                   name="Data Retention Compliance Review"
                   camunda:candidateGroups="legal-compliance">
      <bpmn:incoming>Flow_LegalObToDataRet</bpmn:incoming>
      <bpmn:outgoing>Flow_DataRetToLegalGate</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_LegalClearanceGate" name="Legal Clearance Granted?">
      <bpmn:incoming>Flow_DataRetToLegalGate</bpmn:incoming>
      <bpmn:outgoing>Flow_LegalClearPass</bpmn:outgoing>
      <bpmn:outgoing>Flow_LegalClearFail</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_LegalHold" name="Legal Hold - Cannot Retire">
      <bpmn:incoming>Flow_LegalClearFail</bpmn:incoming>
      <bpmn:errorEventDefinition errorRef="Error_LegalHold" />
    </bpmn:endEvent>

    <!-- IS: Data Purge Planning -->
    <bpmn:userTask id="Task_DataPurgePlan"
                   name="Data Purge Plan Development"
                   camunda:candidateGroups="information-security">
      <bpmn:incoming>Flow_LegalClearPass</bpmn:incoming>
      <bpmn:outgoing>Flow_DataPurgeToBoardApproval</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="Timer_DataPurgeSLA" attachedToRef="Task_DataPurgePlan" cancelActivity="false">
      <bpmn:outgoing>Flow_DataPurgeTimer</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration>P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:endEvent id="EndEvent_DataPurgeSLAEscalated" name="Data Purge SLA Escalated">
      <bpmn:incoming>Flow_DataPurgeTimer</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Governance Board: Retirement Approval -->
    <bpmn:userTask id="Task_RetirementBoardApproval"
                   name="Retirement Board Approval"
                   camunda:candidateGroups="sla-governance-board">
      <bpmn:incoming>Flow_DataPurgeToBoardApproval</bpmn:incoming>
      <bpmn:outgoing>Flow_BoardApprovalToGateway</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="Timer_BoardApprovalSLA" attachedToRef="Task_RetirementBoardApproval" cancelActivity="false">
      <bpmn:outgoing>Flow_BoardApprovalTimer</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration>P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:endEvent id="EndEvent_BoardApprovalSLAEscalated" name="Board Approval SLA Escalated">
      <bpmn:incoming>Flow_BoardApprovalTimer</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="Gateway_RetirementApproved" name="Retirement Approved?">
      <bpmn:incoming>Flow_BoardApprovalToGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_ApprovedYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_ApprovedNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_RetirementRejected" name="Retirement Rejected - Asset Continues">
      <bpmn:incoming>Flow_ApprovedNo</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Business Owner: Comms and Migration -->
    <bpmn:userTask id="Task_StakeholderCommsPlanning"
                   name="Stakeholder Communications Planning"
                   camunda:candidateGroups="business-owner">
      <bpmn:incoming>Flow_ApprovedYes</bpmn:incoming>
      <bpmn:outgoing>Flow_CommsToUserMig</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_UserMigrationPlan"
                   name="User Migration and Transition Plan"
                   camunda:candidateGroups="business-owner">
      <bpmn:incoming>Flow_CommsToUserMig</bpmn:incoming>
      <bpmn:outgoing>Flow_UserMigToContractTerm</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Procurement: Contract and License -->
    <bpmn:userTask id="Task_ContractTermination"
                   name="Contract Termination Processing"
                   camunda:candidateGroups="procurement">
      <bpmn:incoming>Flow_UserMigToContractTerm</bpmn:incoming>
      <bpmn:outgoing>Flow_ContractToLicense</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_LicenseReclamation"
                   name="License Reclamation"
                   camunda:candidateGroups="procurement">
      <bpmn:incoming>Flow_ContractToLicense</bpmn:incoming>
      <bpmn:outgoing>Flow_LicenseToVendorOff</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_VendorOffboarding"
                   name="Vendor Offboarding"
                   camunda:candidateGroups="procurement">
      <bpmn:incoming>Flow_LicenseToVendorOff</bpmn:incoming>
      <bpmn:outgoing>Flow_VendorOffToCostRec</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_CostRecovery"
                   name="Cost Recovery and Savings Capture"
                   camunda:candidateGroups="procurement">
      <bpmn:incoming>Flow_VendorOffToCostRec</bpmn:incoming>
      <bpmn:outgoing>Flow_CostRecToSLATerm</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Vendor Management: SLA Termination and Final Reports -->
    <bpmn:userTask id="Task_SLATermination"
                   name="SLA Agreement Termination"
                   camunda:candidateGroups="vendor-management">
      <bpmn:incoming>Flow_CostRecToSLATerm</bpmn:incoming>
      <bpmn:outgoing>Flow_SLATermToFinalRep</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_FinalPerformanceReport"
                   name="Final Vendor Performance Report"
                   camunda:candidateGroups="vendor-management">
      <bpmn:incoming>Flow_SLATermToFinalRep</bpmn:incoming>
      <bpmn:outgoing>Flow_FinalRepToScorecard</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_VendorScoreCardFinal"
                   name="Final Vendor Scorecard Update"
                   camunda:candidateGroups="vendor-management">
      <bpmn:incoming>Flow_FinalRepToScorecard</bpmn:incoming>
      <bpmn:outgoing>Flow_ScorecardToCMDB</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_CMDBDecommission"
                   name="CMDB Decommission Record Update"
                   camunda:candidateGroups="vendor-management">
      <bpmn:incoming>Flow_ScorecardToCMDB</bpmn:incoming>
      <bpmn:outgoing>Flow_CMDBToAccessRevoke</bpmn:outgoing>
    </bpmn:userTask>

    <!-- IS: Access Revocation and Data Destruction -->
    <bpmn:userTask id="Task_AccessRevocation"
                   name="Access Revocation and Credential Purge"
                   camunda:candidateGroups="information-security">
      <bpmn:incoming>Flow_CMDBToAccessRevoke</bpmn:incoming>
      <bpmn:outgoing>Flow_AccessToDataDestruct</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_SecureDataDestruction"
                   name="Secure Data Destruction (NIST 800-88)"
                   camunda:candidateGroups="information-security">
      <bpmn:incoming>Flow_AccessToDataDestruct</bpmn:incoming>
      <bpmn:outgoing>Flow_DataDestructToSecCert</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_SecurityCertification"
                   name="Security Decommission Certification"
                   camunda:candidateGroups="information-security">
      <bpmn:incoming>Flow_DataDestructToSecCert</bpmn:incoming>
      <bpmn:outgoing>Flow_SecCertToRegNotif</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Legal & Compliance: Regulatory Notification and Closure -->
    <bpmn:userTask id="Task_RegulatoryNotification"
                   name="Regulatory Retirement Notification"
                   camunda:candidateGroups="legal-compliance">
      <bpmn:incoming>Flow_SecCertToRegNotif</bpmn:incoming>
      <bpmn:outgoing>Flow_RegNotifToCompClosure</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_ComplianceClosure"
                   name="Compliance Closure and Audit Trail"
                   camunda:candidateGroups="legal-compliance">
      <bpmn:incoming>Flow_RegNotifToCompClosure</bpmn:incoming>
      <bpmn:outgoing>Flow_CompClosureToArchClean</bpmn:outgoing>
    </bpmn:userTask>

    <!-- IT Architecture: Architecture Cleanup -->
    <bpmn:userTask id="Task_ArchitectureCleanup"
                   name="Architecture Repository Cleanup"
                   camunda:candidateGroups="it-architecture">
      <bpmn:incoming>Flow_CompClosureToArchClean</bpmn:incoming>
      <bpmn:outgoing>Flow_ArchCleanToTechDebt</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_TechDebtClosure"
                   name="Technical Debt Closure and Registry Update"
                   camunda:candidateGroups="it-architecture">
      <bpmn:incoming>Flow_ArchCleanToTechDebt</bpmn:incoming>
      <bpmn:outgoing>Flow_TechDebtToFinalSignOff</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Governance Board: Final Sign-Off -->
    <bpmn:userTask id="Task_FinalGovernanceSignOff"
                   name="Final Governance Sign-Off"
                   camunda:candidateGroups="sla-governance-board">
      <bpmn:incoming>Flow_TechDebtToFinalSignOff</bpmn:incoming>
      <bpmn:outgoing>Flow_FinalSignOffToEnd</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndEvent_AssetRetired" name="Asset Successfully Retired">
      <bpmn:incoming>Flow_FinalSignOffToEnd</bpmn:incoming>
      <bpmn:terminateEventDefinition />
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="Flow_StartToImpactAssess" sourceRef="StartEvent_RetirementTriggered" targetRef="Task_RetirementImpactAssessment" />
    <bpmn:sequenceFlow id="Flow_ImpactToEligibility" sourceRef="Task_RetirementImpactAssessment" targetRef="DMN_RetirementEligibility" />
    <bpmn:sequenceFlow id="Flow_EligibilityToGateway" sourceRef="DMN_RetirementEligibility" targetRef="Gateway_EligibilityGateway" />
    <bpmn:sequenceFlow id="Flow_EligibilityYes" name="Eligible" sourceRef="Gateway_EligibilityGateway" targetRef="Task_DependencyMapping">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${retirementEligible == 'eligible'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_EligibilityNo" name="Not Eligible" sourceRef="Gateway_EligibilityGateway" targetRef="EndEvent_NotEligible">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${retirementEligible == 'not-eligible'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_DepMapToDecomPlan" sourceRef="Task_DependencyMapping" targetRef="Task_DecommissionPlan" />
    <bpmn:sequenceFlow id="Flow_DecomPlanToDataMig" sourceRef="Task_DecommissionPlan" targetRef="Task_DataMigrationDesign" />
    <bpmn:sequenceFlow id="Flow_DataMigToLegal" sourceRef="Task_DataMigrationDesign" targetRef="Task_LegalObligationReview" />
    <bpmn:sequenceFlow id="Flow_LegalObToDataRet" sourceRef="Task_LegalObligationReview" targetRef="Task_DataRetentionCompliance" />
    <bpmn:sequenceFlow id="Flow_DataRetToLegalGate" sourceRef="Task_DataRetentionCompliance" targetRef="Gateway_LegalClearanceGate" />
    <bpmn:sequenceFlow id="Flow_LegalClearPass" name="Cleared" sourceRef="Gateway_LegalClearanceGate" targetRef="Task_DataPurgePlan">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${legalClearance == 'cleared'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_LegalClearFail" name="Legal Hold" sourceRef="Gateway_LegalClearanceGate" targetRef="EndEvent_LegalHold">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${legalClearance == 'hold'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_DataPurgeTimer" sourceRef="Timer_DataPurgeSLA" targetRef="EndEvent_DataPurgeSLAEscalated" />
    <bpmn:sequenceFlow id="Flow_DataPurgeToBoardApproval" sourceRef="Task_DataPurgePlan" targetRef="Task_RetirementBoardApproval" />
    <bpmn:sequenceFlow id="Flow_BoardApprovalTimer" sourceRef="Timer_BoardApprovalSLA" targetRef="EndEvent_BoardApprovalSLAEscalated" />
    <bpmn:sequenceFlow id="Flow_BoardApprovalToGateway" sourceRef="Task_RetirementBoardApproval" targetRef="Gateway_RetirementApproved" />
    <bpmn:sequenceFlow id="Flow_ApprovedYes" name="Approved" sourceRef="Gateway_RetirementApproved" targetRef="Task_StakeholderCommsPlanning">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${retirementApproved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ApprovedNo" name="Rejected" sourceRef="Gateway_RetirementApproved" targetRef="EndEvent_RetirementRejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${retirementApproved == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_CommsToUserMig" sourceRef="Task_StakeholderCommsPlanning" targetRef="Task_UserMigrationPlan" />
    <bpmn:sequenceFlow id="Flow_UserMigToContractTerm" sourceRef="Task_UserMigrationPlan" targetRef="Task_ContractTermination" />
    <bpmn:sequenceFlow id="Flow_ContractToLicense" sourceRef="Task_ContractTermination" targetRef="Task_LicenseReclamation" />
    <bpmn:sequenceFlow id="Flow_LicenseToVendorOff" sourceRef="Task_LicenseReclamation" targetRef="Task_VendorOffboarding" />
    <bpmn:sequenceFlow id="Flow_VendorOffToCostRec" sourceRef="Task_VendorOffboarding" targetRef="Task_CostRecovery" />
    <bpmn:sequenceFlow id="Flow_CostRecToSLATerm" sourceRef="Task_CostRecovery" targetRef="Task_SLATermination" />
    <bpmn:sequenceFlow id="Flow_SLATermToFinalRep" sourceRef="Task_SLATermination" targetRef="Task_FinalPerformanceReport" />
    <bpmn:sequenceFlow id="Flow_FinalRepToScorecard" sourceRef="Task_FinalPerformanceReport" targetRef="Task_VendorScoreCardFinal" />
    <bpmn:sequenceFlow id="Flow_ScorecardToCMDB" sourceRef="Task_VendorScoreCardFinal" targetRef="Task_CMDBDecommission" />
    <bpmn:sequenceFlow id="Flow_CMDBToAccessRevoke" sourceRef="Task_CMDBDecommission" targetRef="Task_AccessRevocation" />
    <bpmn:sequenceFlow id="Flow_AccessToDataDestruct" sourceRef="Task_AccessRevocation" targetRef="Task_SecureDataDestruction" />
    <bpmn:sequenceFlow id="Flow_DataDestructToSecCert" sourceRef="Task_SecureDataDestruction" targetRef="Task_SecurityCertification" />
    <bpmn:sequenceFlow id="Flow_SecCertToRegNotif" sourceRef="Task_SecurityCertification" targetRef="Task_RegulatoryNotification" />
    <bpmn:sequenceFlow id="Flow_RegNotifToCompClosure" sourceRef="Task_RegulatoryNotification" targetRef="Task_ComplianceClosure" />
    <bpmn:sequenceFlow id="Flow_CompClosureToArchClean" sourceRef="Task_ComplianceClosure" targetRef="Task_ArchitectureCleanup" />
    <bpmn:sequenceFlow id="Flow_ArchCleanToTechDebt" sourceRef="Task_ArchitectureCleanup" targetRef="Task_TechDebtClosure" />
    <bpmn:sequenceFlow id="Flow_TechDebtToFinalSignOff" sourceRef="Task_TechDebtClosure" targetRef="Task_FinalGovernanceSignOff" />
    <bpmn:sequenceFlow id="Flow_FinalSignOffToEnd" sourceRef="Task_FinalGovernanceSignOff" targetRef="EndEvent_AssetRetired" />

    <!-- Text Annotations -->
    <bpmn:textAnnotation id="Annotation_Regulatory">
      <bpmn:text>Regulatory: OCC 2023-17 §V (exit planning), GDPR Art.17 (right to erasure), NIST 800-88 (media sanitization), SOX §802 (records destruction), DORA Art.28 (exit strategies). Board approval required before decommission.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_Regulatory" sourceRef="Task_RetirementBoardApproval" targetRef="Annotation_Regulatory" />

    <bpmn:textAnnotation id="Annotation_Security">
      <bpmn:text>Security: NIST 800-88 media sanitization. Access revocation within 24 hours of approval. Secure data destruction certificate required. Cryptographic erasure acceptable for cloud assets. Audit trail retained 7 years.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_Security" sourceRef="Task_SecureDataDestruction" targetRef="Annotation_Security" />

  </bpmn:process>

  <bpmn:error id="Error_LegalHold" name="Legal Hold" errorCode="LEGAL_HOLD" />
