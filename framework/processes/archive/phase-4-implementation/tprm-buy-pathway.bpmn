<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_Phase5B"
                  targetNamespace="http://sla.governance/bpmn"
                  exporter="Camunda Modeler"
                  exporterVersion="5.42.0">

  <bpmn:collaboration id="Collaboration_Phase5B">
    <bpmn:participant id="Participant_Phase5B" name="Phase 5B: TPRM Buy Pathway (Full OCC 2023-17 Lifecycle)" processRef="Process_TPRMBuyPathway" />
  </bpmn:collaboration>

  <bpmn:process id="Process_TPRMBuyPathway" name="Phase 5B: TPRM Buy Pathway" isExecutable="false" camunda:historyTimeToLive="180">

    <bpmn:laneSet id="LaneSet_Phase5B">
      <bpmn:lane id="Lane_GB_P5B" name="Governance Board">
        <bpmn:flowNodeRef>Task_ExecutiveVendorApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PhaseTransitionP5B</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Phase5BComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_VendorTerminated</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_BO_P5B" name="Business Owner">
        <bpmn:flowNodeRef>StartEvent_Phase5BInitiated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VendorEnablement</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GoLiveValidation</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ITA_P5B" name="IT Architecture">
        <bpmn:flowNodeRef>Task_TechnicalIntegration</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SBOMVendorRegistration</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Proc_P5B" name="Procurement">
        <bpmn:flowNodeRef>Task_RFPConstruction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SourcingEvent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VendorEvaluation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DMN07_VendorSelectionRAE</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ContractNegotiation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DMN08_FundingConfirmation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_FundingConfirmed</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_LC_P5B" name="Legal &amp; Compliance">
        <bpmn:flowNodeRef>Task_LegalMSADPAReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ContractExecution</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ComplianceControlsConfig</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_IS_P5B" name="Information Security">
        <bpmn:flowNodeRef>Task_DMN06_VendorRiskTier</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SecurityDueDiligence</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PenTestReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ControlsImplementation</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_VM_P5B" name="Vendor Management">
        <bpmn:flowNodeRef>Task_VendorRegisterEntry</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OngoingMonitoringSetup</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DMN14_MonitoringFreq</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PeriodicReassessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ReassessmentOutcome</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Phase5BInitiated" name="Buy Pathway&#10;Initiated (Budget&#10;Released)">
      <bpmn:outgoing>Flow_Start_RFP</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_RFPConstruction" name="RFP Construction&#10;(Legal Knowledge Graph&#10;Clause Selection)" camunda:candidateGroups="procurement">
      <bpmn:incoming>Flow_Start_RFP</bpmn:incoming>
      <bpmn:outgoing>Flow_RFP_SourcingEvent</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Timer_RFPConstructionSLA" attachedToRef="Task_RFPConstruction" cancelActivity="false">
      <bpmn:outgoing>Flow_RFPSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_RFPConstruction">
        <bpmn:timeDuration>P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:userTask id="Task_SourcingEvent" name="Sourcing Event&#10;(RFP Issued, Vendor&#10;Responses Collected)" camunda:candidateGroups="procurement">
      <bpmn:incoming>Flow_RFP_SourcingEvent</bpmn:incoming>
      <bpmn:outgoing>Flow_SourcingEvent_VendorEval</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Timer_SourcingEventSLA" attachedToRef="Task_SourcingEvent" cancelActivity="false">
      <bpmn:outgoing>Flow_SourcingEventSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_SourcingEvent">
        <bpmn:timeDuration>P10D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:userTask id="Task_VendorEvaluation" name="Vendor Evaluation&#10;(Scoring Matrix,&#10;Demonstrations)" camunda:candidateGroups="procurement">
      <bpmn:incoming>Flow_SourcingEvent_VendorEval</bpmn:incoming>
      <bpmn:outgoing>Flow_VendorEval_DMN06</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:businessRuleTask id="Task_DMN06_VendorRiskTier" name="DMN-06: Vendor Risk&#10;Tier Assignment" camunda:decisionRef="DMN_06_VendorRiskTier" camunda:resultVariable="vendorRiskTier" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>Flow_VendorEval_DMN06</bpmn:incoming>
      <bpmn:outgoing>Flow_DMN06_SecurityDD</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:userTask id="Task_SecurityDueDiligence" name="Security Due Diligence&#10;(SOC 2, BitSight,&#10;SBOM Review)" camunda:candidateGroups="information-security">
      <bpmn:incoming>Flow_DMN06_SecurityDD</bpmn:incoming>
      <bpmn:outgoing>Flow_SecurityDD_PenTest</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Timer_SecurityDDSLA" attachedToRef="Task_SecurityDueDiligence" cancelActivity="false">
      <bpmn:outgoing>Flow_SecurityDDSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_SecurityDD">
        <bpmn:timeDuration>P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:userTask id="Task_PenTestReview" name="Penetration Test&#10;Results Review + SBOM&#10;Vulnerability Scan" camunda:candidateGroups="information-security">
      <bpmn:incoming>Flow_SecurityDD_PenTest</bpmn:incoming>
      <bpmn:outgoing>Flow_PenTest_DMN07</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:businessRuleTask id="Task_DMN07_VendorSelectionRAE" name="DMN-07: Vendor Selection&#10;Risk Assessment Evaluation" camunda:decisionRef="DMN_07_VendorSelectionRAE" camunda:resultVariable="raeDecision" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>Flow_PenTest_DMN07</bpmn:incoming>
      <bpmn:outgoing>Flow_DMN07_LegalMSA</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:userTask id="Task_LegalMSADPAReview" name="Legal MSA/DPA Review&#10;(Legal KB Clause&#10;Validation)" camunda:candidateGroups="legal-compliance">
      <bpmn:incoming>Flow_DMN07_LegalMSA</bpmn:incoming>
      <bpmn:outgoing>Flow_LegalMSA_ContractNeg</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Timer_LegalReviewSLA" attachedToRef="Task_LegalMSADPAReview" cancelActivity="false">
      <bpmn:outgoing>Flow_LegalReviewSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_LegalReview">
        <bpmn:timeDuration>P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:userTask id="Task_ContractNegotiation" name="Contract Negotiation&#10;(MSA, SLA, Right to Audit,&#10;Step-in Rights)" camunda:candidateGroups="procurement">
      <bpmn:incoming>Flow_LegalMSA_ContractNeg</bpmn:incoming>
      <bpmn:outgoing>Flow_ContractNeg_DMN08</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:businessRuleTask id="Task_DMN08_FundingConfirmation" name="DMN-08: Funding&#10;Confirmation" camunda:decisionRef="DMN_08_FundingConfirmation" camunda:resultVariable="fundingStatus" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>Flow_ContractNeg_DMN08</bpmn:incoming>
      <bpmn:outgoing>Flow_DMN08_Gateway</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_FundingConfirmed" name="Funding&#10;Confirmed?" default="Flow_FundingConfirmed">
      <bpmn:incoming>Flow_DMN08_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_FundingNotConfirmed</bpmn:outgoing>
      <bpmn:outgoing>Flow_FundingConfirmed</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ExecutiveVendorApproval" name="Executive Vendor&#10;Approval (Tier 1 Critical&#10;Activity OCC Sign-Off)" camunda:candidateGroups="sla-governance-board">
      <bpmn:incoming>Flow_FundingConfirmed</bpmn:incoming>
      <bpmn:outgoing>Flow_ExecutiveApproval_ContractExec</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Timer_ExecutiveApprovalSLA" attachedToRef="Task_ExecutiveVendorApproval" cancelActivity="false">
      <bpmn:outgoing>Flow_ExecApprovalSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_ExecutiveApproval">
        <bpmn:timeDuration>P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:userTask id="Task_ContractExecution" name="Contract Execution&#10;(MSA, DPA, SLAs Signed)" camunda:candidateGroups="legal-compliance">
      <bpmn:incoming>Flow_ExecutiveApproval_ContractExec</bpmn:incoming>
      <bpmn:outgoing>Flow_ContractExec_ControlsImpl</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ControlsImplementation" name="Controls Implementation&#10;(Evidence Collection&#10;Configured)" camunda:candidateGroups="information-security">
      <bpmn:incoming>Flow_ContractExec_ControlsImpl</bpmn:incoming>
      <bpmn:outgoing>Flow_ControlsImpl_TechIntegration</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_TechnicalIntegration" name="Technical Integration&#10;(API, SSO, Network&#10;Segmentation)" camunda:candidateGroups="it-architecture">
      <bpmn:incoming>Flow_ControlsImpl_TechIntegration</bpmn:incoming>
      <bpmn:outgoing>Flow_TechIntegration_SBOM</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_SBOMVendorRegistration" name="SBOM Vendor Registration&#10;(P0 Registry Update)" camunda:type="external" camunda:topic="sbom-vendor-registration">
      <bpmn:incoming>Flow_TechIntegration_SBOM</bpmn:incoming>
      <bpmn:outgoing>Flow_SBOM_ComplianceControls</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ComplianceControlsConfig" name="Compliance Controls&#10;Configuration (Control&#10;Mapping)" camunda:type="external" camunda:topic="compliance-controls">
      <bpmn:incoming>Flow_SBOM_ComplianceControls</bpmn:incoming>
      <bpmn:outgoing>Flow_ComplianceControls_VendorReg</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_VendorRegisterEntry" name="Vendor Register Entry&#10;(OCC TPRM Register&#10;Updated)" camunda:type="external" camunda:topic="vendor-register">
      <bpmn:incoming>Flow_ComplianceControls_VendorReg</bpmn:incoming>
      <bpmn:outgoing>Flow_VendorReg_Enablement</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_VendorEnablement" name="Vendor Enablement&#10;(Onboarding, Training,&#10;API Key Provisioning)" camunda:candidateGroups="business-owner">
      <bpmn:incoming>Flow_VendorReg_Enablement</bpmn:incoming>
      <bpmn:outgoing>Flow_Enablement_GoLive</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_GoLiveValidation" name="Go-Live Validation&#10;(Production Readiness&#10;Confirmed)" camunda:candidateGroups="business-owner">
      <bpmn:incoming>Flow_Enablement_GoLive</bpmn:incoming>
      <bpmn:outgoing>Flow_GoLive_OngoingMonitoring</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_OngoingMonitoringSetup" name="Ongoing Monitoring&#10;Setup (Automated&#10;Evidence Collection)" camunda:type="external" camunda:topic="monitoring-setup">
      <bpmn:incoming>Flow_GoLive_OngoingMonitoring</bpmn:incoming>
      <bpmn:outgoing>Flow_OngoingMonitoring_DMN14</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:businessRuleTask id="Task_DMN14_MonitoringFreq" name="DMN-14: TPRM Monitoring&#10;Frequency Calibration" camunda:decisionRef="DMN_14_TPRMMonitoringFreq" camunda:resultVariable="monitoringFrequency" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>Flow_OngoingMonitoring_DMN14</bpmn:incoming>
      <bpmn:outgoing>Flow_DMN14_Reassessment</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:userTask id="Task_PeriodicReassessment" name="Periodic Vendor&#10;Reassessment (Risk-Tiered&#10;Cadence)" camunda:candidateGroups="vendor-management">
      <bpmn:incoming>Flow_DMN14_Reassessment</bpmn:incoming>
      <bpmn:outgoing>Flow_Reassessment_Gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Timer_ReassessmentSLA" attachedToRef="Task_PeriodicReassessment" cancelActivity="false">
      <bpmn:outgoing>Flow_ReassessmentSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Reassessment">
        <bpmn:timeDuration>P10D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="Gateway_ReassessmentOutcome" name="Reassessment&#10;Outcome?" default="Flow_ContinueMonitoring">
      <bpmn:incoming>Flow_Reassessment_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_ContinueMonitoring</bpmn:outgoing>
      <bpmn:outgoing>Flow_TerminateVendor</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_PhaseTransitionP5B" name="Phase 5B Quality Gate&#10;+ Ongoing Monitoring Active" camunda:candidateGroups="sla-governance-board">
      <bpmn:incoming>Flow_ContinueMonitoring</bpmn:incoming>
      <bpmn:outgoing>Flow_PhaseTransition_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_Phase5BComplete" name="Phase 5B Complete&#10;(Vendor Active,&#10;Monitoring Live)">
      <bpmn:incoming>Flow_PhaseTransition_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_VendorTerminated" name="Vendor Terminated&#10;(OCC Notification)">
      <bpmn:incoming>Flow_TerminateVendor</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_FundingNotConfirmed" name="Funding Not&#10;Confirmed">
      <bpmn:incoming>Flow_FundingNotConfirmed</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_RFPSLAEscalated" name="RFP SLA Escalated">
      <bpmn:incoming>Flow_RFPSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_SecurityDDSLAEscalated" name="Security DD&#10;SLA Escalated">
      <bpmn:incoming>Flow_SecurityDDSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_ExecApprovalSLAEscalated" name="Exec Approval&#10;SLA Escalated">
      <bpmn:incoming>Flow_ExecApprovalSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_SourcingEventSLAEscalated" name="Sourcing Event&#10;SLA Escalated">
      <bpmn:incoming>Flow_SourcingEventSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_LegalSLAEscalated" name="Legal Review&#10;SLA Escalated">
      <bpmn:incoming>Flow_LegalReviewSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_ReassessmentSLAEscalated" name="Reassessment&#10;SLA Escalated">
      <bpmn:incoming>Flow_ReassessmentSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:textAnnotation id="Annotation_P5B_OCC">
      <bpmn:text>OCC 2023-17: Full TPRM lifecycle - vendor risk tiering (DMN-06), RAE (DMN-07), funding confirmation (DMN-08), monitoring frequency (DMN-14). Critical activity designation triggers OCC notification. Right to Audit in all MSAs.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_P5B_OCC" sourceRef="Task_DMN06_VendorRiskTier" targetRef="Annotation_P5B_OCC" />

    <bpmn:textAnnotation id="Annotation_P5B_DORA">
      <bpmn:text>DORA: Vendor operational resilience assessment. BCBS d577: Concentration risk tracked in vendor register. GDPR/CCPA: DPA mandatory for data processing vendors. SR 11-7: AI vendor model governance separate from TPRM track.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_P5B_DORA" sourceRef="Task_OngoingMonitoringSetup" targetRef="Annotation_P5B_DORA" />
    <bpmn:sequenceFlow id="Flow_Start_RFP" sourceRef="StartEvent_Phase5BInitiated" targetRef="Task_RFPConstruction" />
    <bpmn:sequenceFlow id="Flow_RFP_SourcingEvent" sourceRef="Task_RFPConstruction" targetRef="Task_SourcingEvent" />
    <bpmn:sequenceFlow id="Flow_SourcingEvent_VendorEval" sourceRef="Task_SourcingEvent" targetRef="Task_VendorEvaluation" />
    <bpmn:sequenceFlow id="Flow_VendorEval_DMN06" sourceRef="Task_VendorEvaluation" targetRef="Task_DMN06_VendorRiskTier" />
    <bpmn:sequenceFlow id="Flow_DMN06_SecurityDD" sourceRef="Task_DMN06_VendorRiskTier" targetRef="Task_SecurityDueDiligence" />
    <bpmn:sequenceFlow id="Flow_SecurityDD_PenTest" sourceRef="Task_SecurityDueDiligence" targetRef="Task_PenTestReview" />
    <bpmn:sequenceFlow id="Flow_PenTest_DMN07" sourceRef="Task_PenTestReview" targetRef="Task_DMN07_VendorSelectionRAE" />
    <bpmn:sequenceFlow id="Flow_DMN07_LegalMSA" sourceRef="Task_DMN07_VendorSelectionRAE" targetRef="Task_LegalMSADPAReview" />
    <bpmn:sequenceFlow id="Flow_LegalMSA_ContractNeg" sourceRef="Task_LegalMSADPAReview" targetRef="Task_ContractNegotiation" />
    <bpmn:sequenceFlow id="Flow_ContractNeg_DMN08" sourceRef="Task_ContractNegotiation" targetRef="Task_DMN08_FundingConfirmation" />
    <bpmn:sequenceFlow id="Flow_DMN08_Gateway" sourceRef="Task_DMN08_FundingConfirmation" targetRef="Gateway_FundingConfirmed" />
    <bpmn:sequenceFlow id="Flow_FundingNotConfirmed" name="Not Confirmed" sourceRef="Gateway_FundingConfirmed" targetRef="EndEvent_FundingNotConfirmed">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${fundingStatus == 'NOT_CONFIRMED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_FundingConfirmed" name="Confirmed" sourceRef="Gateway_FundingConfirmed" targetRef="Task_ExecutiveVendorApproval" />
    <bpmn:sequenceFlow id="Flow_ExecutiveApproval_ContractExec" sourceRef="Task_ExecutiveVendorApproval" targetRef="Task_ContractExecution" />
    <bpmn:sequenceFlow id="Flow_ContractExec_ControlsImpl" sourceRef="Task_ContractExecution" targetRef="Task_ControlsImplementation" />
    <bpmn:sequenceFlow id="Flow_ControlsImpl_TechIntegration" sourceRef="Task_ControlsImplementation" targetRef="Task_TechnicalIntegration" />
    <bpmn:sequenceFlow id="Flow_TechIntegration_SBOM" sourceRef="Task_TechnicalIntegration" targetRef="Task_SBOMVendorRegistration" />
    <bpmn:sequenceFlow id="Flow_SBOM_ComplianceControls" sourceRef="Task_SBOMVendorRegistration" targetRef="Task_ComplianceControlsConfig" />
    <bpmn:sequenceFlow id="Flow_ComplianceControls_VendorReg" sourceRef="Task_ComplianceControlsConfig" targetRef="Task_VendorRegisterEntry" />
    <bpmn:sequenceFlow id="Flow_VendorReg_Enablement" sourceRef="Task_VendorRegisterEntry" targetRef="Task_VendorEnablement" />
    <bpmn:sequenceFlow id="Flow_Enablement_GoLive" sourceRef="Task_VendorEnablement" targetRef="Task_GoLiveValidation" />
    <bpmn:sequenceFlow id="Flow_GoLive_OngoingMonitoring" sourceRef="Task_GoLiveValidation" targetRef="Task_OngoingMonitoringSetup" />
    <bpmn:sequenceFlow id="Flow_OngoingMonitoring_DMN14" sourceRef="Task_OngoingMonitoringSetup" targetRef="Task_DMN14_MonitoringFreq" />
    <bpmn:sequenceFlow id="Flow_DMN14_Reassessment" sourceRef="Task_DMN14_MonitoringFreq" targetRef="Task_PeriodicReassessment" />
    <bpmn:sequenceFlow id="Flow_Reassessment_Gateway" sourceRef="Task_PeriodicReassessment" targetRef="Gateway_ReassessmentOutcome" />
    <bpmn:sequenceFlow id="Flow_ContinueMonitoring" name="Continue" sourceRef="Gateway_ReassessmentOutcome" targetRef="Task_PhaseTransitionP5B" />
    <bpmn:sequenceFlow id="Flow_TerminateVendor" name="Terminate" sourceRef="Gateway_ReassessmentOutcome" targetRef="EndEvent_VendorTerminated">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${vendorTerminated == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_PhaseTransition_End" sourceRef="Task_PhaseTransitionP5B" targetRef="EndEvent_Phase5BComplete" />
    <bpmn:sequenceFlow id="Flow_RFPSLAEscalate" sourceRef="Timer_RFPConstructionSLA" targetRef="EndEvent_RFPSLAEscalated" />
    <bpmn:sequenceFlow id="Flow_SourcingEventSLAEscalate" sourceRef="Timer_SourcingEventSLA" targetRef="EndEvent_SourcingEventSLAEscalated" />
    <bpmn:sequenceFlow id="Flow_SecurityDDSLAEscalate" sourceRef="Timer_SecurityDDSLA" targetRef="EndEvent_SecurityDDSLAEscalated" />
    <bpmn:sequenceFlow id="Flow_LegalReviewSLAEscalate" sourceRef="Timer_LegalReviewSLA" targetRef="EndEvent_LegalSLAEscalated" />
    <bpmn:sequenceFlow id="Flow_ExecApprovalSLAEscalate" sourceRef="Timer_ExecutiveApprovalSLA" targetRef="EndEvent_ExecApprovalSLAEscalated" />
    <bpmn:sequenceFlow id="Flow_ReassessmentSLAEscalate" sourceRef="Timer_ReassessmentSLA" targetRef="EndEvent_ReassessmentSLAEscalated" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Phase5B">
    <bpmndi:BPMNPlane id="BPMNPlane_Phase5B" bpmnElement="Collaboration_Phase5B">

      <bpmndi:BPMNShape id="Participant_Phase5B_di" bpmnElement="Participant_Phase5B" isHorizontal="true">
