<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_ESG_Master_v4" targetNamespace="http://sla.governance/bpmn" exporter="Camunda Modeler" exporterVersion="5.25.0">

  <bpmn:message id="Message_GovernancePortal" name="GovernancePortalSubmission" />
  <bpmn:signal id="Signal_EmergencyCessation" name="EmergencyCessation" />

  <bpmn:collaboration id="Collaboration_ESG_Master">
    <bpmn:participant id="Participant_EnterpriseGovernance" name="Enterprise Governance" processRef="Process_ESG_Master" />
    <bpmn:participant id="Participant_VendorThirdParty" name="Vendor / Third Party" processRef="Process_VendorResponse" />
    <bpmn:messageFlow id="MsgFlow_RFP_Vendor" name="RFP / Due Diligence Request" sourceRef="SP_Phase3_DueDiligence" targetRef="Participant_VendorThirdParty" />
    <bpmn:messageFlow id="MsgFlow_Vendor_Response" name="Vendor Response / Attestation" sourceRef="Participant_VendorThirdParty" targetRef="SP_Phase3_DueDiligence" />
  </bpmn:collaboration>

  <bpmn:process id="Process_ESG_Master" name="Enterprise Software Governance — Intake to Retirement" isExecutable="false" camunda:historyTimeToLive="180">

    <bpmn:laneSet id="LaneSet_ESG">
      <bpmn:lane id="Lane_Business" name="Business">
        <bpmn:flowNodeRef>StartEvent_InitiativeRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_Phase2_Planning</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Rejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Governance" name="Governance">
        <bpmn:flowNodeRef>SP_Phase4_GovernanceReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Governance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_GovMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Rejected_Gov</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Contracting" name="Contracting">
        <bpmn:flowNodeRef>SP_Phase5_Contracting</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_TechnicalAssessment" name="Technical Assessment">
        <bpmn:flowNodeRef>SP_Phase6_SDLC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_Phase7_Deployment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Deployment</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_AIReview" name="AI Review">
        <bpmn:flowNodeRef>Gateway_RiskTier</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Compliance" name="Compliance">
        <bpmn:flowNodeRef>SP_Phase3_DueDiligence</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Oversight" name="Oversight">
        <bpmn:flowNodeRef>StartEvent_OversightAudit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OversightPlaceholder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_OversightComplete</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Automation" name="Automation">
        <bpmn:flowNodeRef>SP_Phase1_Intake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_Phase8_Operations</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Monitoring</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Retired</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Terminated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SubProcess_Emergency</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryEvent_Phase1_SLA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryEvent_Phase8_Periodic</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Escalation_P1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_PeriodicReview</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_InitiativeRequest" name="Initiative Request&#10;Received">
      <bpmn:outgoing>Flow_Start_Phase1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_InitiativeRequest" messageRef="Message_GovernancePortal" />
    </bpmn:startEvent>

    <bpmn:subProcess id="SP_Phase1_Intake" name="Phase 1: Initiation &amp; Intake">
      <bpmn:incoming>Flow_Start_Phase1</bpmn:incoming>
      <bpmn:outgoing>Flow_Phase1_Phase2</bpmn:outgoing>

      <bpmn:startEvent id="SP1_Start" name="Start">
        <bpmn:outgoing>Flow_SP1_Start_Classify</bpmn:outgoing>
      </bpmn:startEvent>

      <bpmn:businessRuleTask id="SP1_Task_ClassifyRequest" name="Classify Governance Request"
        camunda:decisionRef="DMN_PathwayRouting"
        camunda:decisionRefBinding="latest"
        camunda:resultVariable="governancePathway"
        camunda:mapDecisionResult="singleResult">
        <bpmn:incoming>Flow_SP1_Start_Classify</bpmn:incoming>
        <bpmn:outgoing>Flow_SP1_Classify_Register</bpmn:outgoing>
      </bpmn:businessRuleTask>

      <bpmn:userTask id="SP1_Task_RegisterInitiative" name="Register Initiative&#10;in Governance Portal" camunda:candidateGroups="business-lane">
        <bpmn:incoming>Flow_SP1_Classify_Register</bpmn:incoming>
        <bpmn:outgoing>Flow_SP1_Register_End</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:endEvent id="SP1_End" name="Intake&#10;Complete">
        <bpmn:incoming>Flow_SP1_Register_End</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="Flow_SP1_Start_Classify" sourceRef="SP1_Start" targetRef="SP1_Task_ClassifyRequest" />
      <bpmn:sequenceFlow id="Flow_SP1_Classify_Register" sourceRef="SP1_Task_ClassifyRequest" targetRef="SP1_Task_RegisterInitiative" />
      <bpmn:sequenceFlow id="Flow_SP1_Register_End" sourceRef="SP1_Task_RegisterInitiative" targetRef="SP1_End" />
    </bpmn:subProcess>

    <bpmn:boundaryEvent id="BoundaryEvent_Phase1_SLA" name="2 Day&#10;SLA" cancelActivity="false" attachedToRef="SP_Phase1_Intake">
      <bpmn:outgoing>Flow_P1_SLA_Escalation</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_P1">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P2D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:endEvent id="EndEvent_Escalation_P1" name="Phase 1&#10;SLA Escalation">
      <bpmn:incoming>Flow_P1_SLA_Escalation</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:subProcess id="SP_Phase2_Planning" name="Phase 2: Planning &amp; Risk Scoping">
      <bpmn:incoming>Flow_Phase1_Phase2</bpmn:incoming>
      <bpmn:outgoing>Flow_Phase2_RiskGateway</bpmn:outgoing>

      <bpmn:startEvent id="SP2_Start" name="Start">
        <bpmn:outgoing>Flow_SP2_Start_RiskClass</bpmn:outgoing>
      </bpmn:startEvent>

      <bpmn:businessRuleTask id="SP2_Task_RiskClassification" name="Risk Classification"
        camunda:decisionRef="DMN_RiskTierClassification"
        camunda:decisionRefBinding="latest"
        camunda:resultVariable="riskTier"
        camunda:mapDecisionResult="singleResult">
        <bpmn:incoming>Flow_SP2_Start_RiskClass</bpmn:incoming>
        <bpmn:outgoing>Flow_SP2_RiskClass_Scope</bpmn:outgoing>
      </bpmn:businessRuleTask>

      <bpmn:userTask id="SP2_Task_ScopeDefinition" name="Define Scope &amp;&#10;Business Justification" camunda:candidateGroups="business-lane">
        <bpmn:incoming>Flow_SP2_RiskClass_Scope</bpmn:incoming>
        <bpmn:outgoing>Flow_SP2_Scope_End</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:endEvent id="SP2_End" name="Planning&#10;Complete">
        <bpmn:incoming>Flow_SP2_Scope_End</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="Flow_SP2_Start_RiskClass" sourceRef="SP2_Start" targetRef="SP2_Task_RiskClassification" />
      <bpmn:sequenceFlow id="Flow_SP2_RiskClass_Scope" sourceRef="SP2_Task_RiskClassification" targetRef="SP2_Task_ScopeDefinition" />
      <bpmn:sequenceFlow id="Flow_SP2_Scope_End" sourceRef="SP2_Task_ScopeDefinition" targetRef="SP2_End" />
    </bpmn:subProcess>

    <bpmn:exclusiveGateway id="Gateway_RiskTier" name="Risk Tier Decision" default="Flow_RiskTier_Phase3">
      <bpmn:incoming>Flow_Phase2_RiskGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_RiskTier_Rejected</bpmn:outgoing>
      <bpmn:outgoing>Flow_RiskTier_Phase3</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_Rejected" name="Use Case Rejected&#10;(Unacceptable Risk)">
      <bpmn:incoming>Flow_RiskTier_Rejected</bpmn:incoming>
      <bpmn:terminateEventDefinition id="TermDef_Rejected" />
    </bpmn:endEvent>

    <bpmn:subProcess id="SP_Phase3_DueDiligence" name="Phase 3: Due Diligence &amp; Swarm">
      <bpmn:incoming>Flow_RiskTier_Phase3</bpmn:incoming>
      <bpmn:outgoing>Flow_Phase3_Phase4</bpmn:outgoing>

      <bpmn:startEvent id="SP3_Start" name="Start">
        <bpmn:outgoing>Flow_SP3_Start_DD</bpmn:outgoing>
      </bpmn:startEvent>

      <bpmn:userTask id="SP3_Task_DueDiligence" name="Vendor Due Diligence&#10;Assessment" camunda:candidateGroups="compliance-lane">
        <bpmn:incoming>Flow_SP3_Start_DD</bpmn:incoming>
        <bpmn:outgoing>Flow_SP3_DD_DataClass</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:userTask id="SP3_Task_DataClassification" name="Data Classification" camunda:candidateGroups="compliance-lane">
        <bpmn:incoming>Flow_SP3_DD_DataClass</bpmn:incoming>
        <bpmn:outgoing>Flow_SP3_DataClass_End</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:endEvent id="SP3_End" name="Due Diligence&#10;Complete">
        <bpmn:incoming>Flow_SP3_DataClass_End</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="Flow_SP3_Start_DD" sourceRef="SP3_Start" targetRef="SP3_Task_DueDiligence" />
      <bpmn:sequenceFlow id="Flow_SP3_DD_DataClass" sourceRef="SP3_Task_DueDiligence" targetRef="SP3_Task_DataClassification" />
      <bpmn:sequenceFlow id="Flow_SP3_DataClass_End" sourceRef="SP3_Task_DataClassification" targetRef="SP3_End" />
    </bpmn:subProcess>

    <bpmn:subProcess id="SP_Phase4_GovernanceReview" name="Phase 4: Governance Review">
      <bpmn:incoming>Flow_Phase3_Phase4</bpmn:incoming>
      <bpmn:outgoing>Flow_Phase4_GovGateway</bpmn:outgoing>

      <bpmn:startEvent id="SP4_Start" name="Start">
        <bpmn:outgoing>Flow_SP4_Start_ApprAuth</bpmn:outgoing>
      </bpmn:startEvent>

      <bpmn:businessRuleTask id="SP4_Task_ApprovalAuthority" name="Determine Approval&#10;Authority"
        camunda:decisionRef="DMN_GovernanceReviewRouting"
        camunda:decisionRefBinding="latest"
        camunda:resultVariable="approvalAuthority"
        camunda:mapDecisionResult="singleResult">
        <bpmn:incoming>Flow_SP4_Start_ApprAuth</bpmn:incoming>
        <bpmn:outgoing>Flow_SP4_ApprAuth_Review</bpmn:outgoing>
      </bpmn:businessRuleTask>

      <bpmn:userTask id="SP4_Task_GovernanceReview" name="Governance Committee&#10;Review &amp; Decision" camunda:candidateGroups="governance-lane">
        <bpmn:incoming>Flow_SP4_ApprAuth_Review</bpmn:incoming>
        <bpmn:outgoing>Flow_SP4_Review_End</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:endEvent id="SP4_End" name="Governance Review&#10;Complete">
        <bpmn:incoming>Flow_SP4_Review_End</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="Flow_SP4_Start_ApprAuth" sourceRef="SP4_Start" targetRef="SP4_Task_ApprovalAuthority" />
      <bpmn:sequenceFlow id="Flow_SP4_ApprAuth_Review" sourceRef="SP4_Task_ApprovalAuthority" targetRef="SP4_Task_GovernanceReview" />
      <bpmn:sequenceFlow id="Flow_SP4_Review_End" sourceRef="SP4_Task_GovernanceReview" targetRef="SP4_End" />
    </bpmn:subProcess>

    <bpmn:exclusiveGateway id="Gateway_Governance" name="Governance Decision" default="Flow_Gov_Approved">
      <bpmn:incoming>Flow_Phase4_GovGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Gov_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gov_ApprovedConditions</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gov_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_Rejected_Gov" name="Use Case Rejected&#10;(Governance)">
      <bpmn:incoming>Flow_Gov_Rejected</bpmn:incoming>
      <bpmn:terminateEventDefinition id="TermDef_Rejected_Gov" />
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="Gateway_GovMerge">
      <bpmn:incoming>Flow_Gov_Approved</bpmn:incoming>
      <bpmn:incoming>Flow_Gov_ApprovedConditions</bpmn:incoming>
      <bpmn:outgoing>Flow_GovMerge_Phase5</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:subProcess id="SP_Phase5_Contracting" name="Phase 5: Contracting &amp; Controls">
      <bpmn:incoming>Flow_GovMerge_Phase5</bpmn:incoming>
      <bpmn:outgoing>Flow_Phase5_Phase6</bpmn:outgoing>

      <bpmn:startEvent id="SP5_Start" name="Start">
        <bpmn:outgoing>Flow_SP5_Start_CompReq</bpmn:outgoing>
      </bpmn:startEvent>

      <bpmn:userTask id="SP5_Task_ComplianceRequirements" name="Identify Compliance&#10;Requirements" camunda:candidateGroups="compliance-lane">
        <bpmn:incoming>Flow_SP5_Start_CompReq</bpmn:incoming>
        <bpmn:outgoing>Flow_SP5_CompReq_Contract</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:userTask id="SP5_Task_ContractNegotiation" name="Contract Negotiation&#10;&amp; Controls Setup" camunda:candidateGroups="contracting-lane">
        <bpmn:incoming>Flow_SP5_CompReq_Contract</bpmn:incoming>
        <bpmn:outgoing>Flow_SP5_Contract_End</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:endEvent id="SP5_End" name="Contracting&#10;Complete">
        <bpmn:incoming>Flow_SP5_Contract_End</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="Flow_SP5_Start_CompReq" sourceRef="SP5_Start" targetRef="SP5_Task_ComplianceRequirements" />
      <bpmn:sequenceFlow id="Flow_SP5_CompReq_Contract" sourceRef="SP5_Task_ComplianceRequirements" targetRef="SP5_Task_ContractNegotiation" />
      <bpmn:sequenceFlow id="Flow_SP5_Contract_End" sourceRef="SP5_Task_ContractNegotiation" targetRef="SP5_End" />
    </bpmn:subProcess>

    <bpmn:subProcess id="SP_Phase6_SDLC" name="Phase 6: SDLC Development">
      <bpmn:incoming>Flow_Phase5_Phase6</bpmn:incoming>
      <bpmn:incoming>Flow_Deploy_Rejected</bpmn:incoming>
      <bpmn:outgoing>Flow_Phase6_Phase7</bpmn:outgoing>

      <bpmn:startEvent id="SP6_Start" name="Start">
        <bpmn:outgoing>Flow_SP6_Start_TestReq</bpmn:outgoing>
      </bpmn:startEvent>

      <bpmn:userTask id="SP6_Task_TestingRequirements" name="Determine Testing&#10;Requirements" camunda:candidateGroups="technical-assessment">
        <bpmn:incoming>Flow_SP6_Start_TestReq</bpmn:incoming>
        <bpmn:outgoing>Flow_SP6_TestReq_Build</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:userTask id="SP6_Task_BuildConfigure" name="Build / Configure&#10;Solution" camunda:candidateGroups="technical-assessment">
        <bpmn:incoming>Flow_SP6_TestReq_Build</bpmn:incoming>
        <bpmn:outgoing>Flow_SP6_Build_End</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:endEvent id="SP6_End" name="SDLC&#10;Complete">
        <bpmn:incoming>Flow_SP6_Build_End</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="Flow_SP6_Start_TestReq" sourceRef="SP6_Start" targetRef="SP6_Task_TestingRequirements" />
      <bpmn:sequenceFlow id="Flow_SP6_TestReq_Build" sourceRef="SP6_Task_TestingRequirements" targetRef="SP6_Task_BuildConfigure" />
      <bpmn:sequenceFlow id="Flow_SP6_Build_End" sourceRef="SP6_Task_BuildConfigure" targetRef="SP6_End" />
    </bpmn:subProcess>

    <bpmn:subProcess id="SP_Phase7_Deployment" name="Phase 7: Deployment &amp; Go-Live">
      <bpmn:incoming>Flow_Phase6_Phase7</bpmn:incoming>
      <bpmn:outgoing>Flow_Phase7_DeployGateway</bpmn:outgoing>

      <bpmn:startEvent id="SP7_Start" name="Start">
        <bpmn:outgoing>Flow_SP7_Start_SLAPriority</bpmn:outgoing>
      </bpmn:startEvent>

      <bpmn:userTask id="SP7_Task_SLAPriority" name="Set SLA Priority" camunda:candidateGroups="automation-lane">
        <bpmn:incoming>Flow_SP7_Start_SLAPriority</bpmn:incoming>
        <bpmn:outgoing>Flow_SP7_SLAPriority_Deploy</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:userTask id="SP7_Task_ProductionDeployment" name="Production Deployment&#10;&amp; Go-Live Approval" camunda:candidateGroups="technical-assessment">
        <bpmn:incoming>Flow_SP7_SLAPriority_Deploy</bpmn:incoming>
        <bpmn:outgoing>Flow_SP7_Deploy_End</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:endEvent id="SP7_End" name="Deployment&#10;Complete">
        <bpmn:incoming>Flow_SP7_Deploy_End</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="Flow_SP7_Start_SLAPriority" sourceRef="SP7_Start" targetRef="SP7_Task_SLAPriority" />
      <bpmn:sequenceFlow id="Flow_SP7_SLAPriority_Deploy" sourceRef="SP7_Task_SLAPriority" targetRef="SP7_Task_ProductionDeployment" />
      <bpmn:sequenceFlow id="Flow_SP7_Deploy_End" sourceRef="SP7_Task_ProductionDeployment" targetRef="SP7_End" />
    </bpmn:subProcess>

    <bpmn:exclusiveGateway id="Gateway_Deployment" name="Deployment Decision" default="Flow_Deploy_Approved">
      <bpmn:incoming>Flow_Phase7_DeployGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Deploy_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_Deploy_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:subProcess id="SP_Phase8_Operations" name="Phase 8: Operations &amp; Retirement">
      <bpmn:incoming>Flow_Deploy_Approved</bpmn:incoming>
      <bpmn:outgoing>Flow_Phase8_MonitoringGateway</bpmn:outgoing>

      <bpmn:startEvent id="SP8_Start" name="Start">
        <bpmn:outgoing>Flow_SP8_Start_AuditFreq</bpmn:outgoing>
      </bpmn:startEvent>

      <bpmn:businessRuleTask id="SP8_Task_AuditFrequency" name="Set Audit Frequency"
        camunda:decisionRef="DMN_MonitoringCadenceAssignment"
        camunda:decisionRefBinding="latest"
        camunda:resultVariable="auditFrequency"
        camunda:mapDecisionResult="singleResult">
        <bpmn:incoming>Flow_SP8_Start_AuditFreq</bpmn:incoming>
        <bpmn:outgoing>Flow_SP8_AuditFreq_Monitor</bpmn:outgoing>
      </bpmn:businessRuleTask>

      <bpmn:userTask id="SP8_Task_OngoingMonitoring" name="Ongoing SLA Monitoring&#10;&amp; Performance Review" camunda:candidateGroups="automation-lane">
        <bpmn:incoming>Flow_SP8_AuditFreq_Monitor</bpmn:incoming>
        <bpmn:outgoing>Flow_SP8_Monitor_End</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:endEvent id="SP8_End" name="Operations Review&#10;Complete">
        <bpmn:incoming>Flow_SP8_Monitor_End</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="Flow_SP8_Start_AuditFreq" sourceRef="SP8_Start" targetRef="SP8_Task_AuditFrequency" />
      <bpmn:sequenceFlow id="Flow_SP8_AuditFreq_Monitor" sourceRef="SP8_Task_AuditFrequency" targetRef="SP8_Task_OngoingMonitoring" />
      <bpmn:sequenceFlow id="Flow_SP8_Monitor_End" sourceRef="SP8_Task_OngoingMonitoring" targetRef="SP8_End" />
    </bpmn:subProcess>

    <bpmn:boundaryEvent id="BoundaryEvent_Phase8_Periodic" name="Periodic&#10;Review" cancelActivity="false" attachedToRef="SP_Phase8_Operations">
      <bpmn:outgoing>Flow_P8_Periodic_Review</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_P8">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P1M</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:endEvent id="EndEvent_PeriodicReview" name="Periodic Review&#10;Triggered">
      <bpmn:incoming>Flow_P8_Periodic_Review</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="Gateway_Monitoring" name="Monitoring Outcome" default="Flow_Monitor_Continue">
      <bpmn:incoming>Flow_Phase8_MonitoringGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Monitor_Continue</bpmn:outgoing>
      <bpmn:outgoing>Flow_Monitor_Retire</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_Retired" name="Use Case&#10;Retired">
      <bpmn:incoming>Flow_Monitor_Retire</bpmn:incoming>
      <bpmn:terminateEventDefinition id="TermDef_Retired" />
    </bpmn:endEvent>

    <bpmn:subProcess id="SubProcess_Emergency" name="Emergency Termination" triggeredByEvent="true">
      <bpmn:outgoing>Flow_Emergency_Terminated</bpmn:outgoing>

      <bpmn:startEvent id="SP_Emergency_Start" name="Compliance Breach /&#10;Security Incident" isInterrupting="true">
        <bpmn:outgoing>Flow_Emergency_Start_End</bpmn:outgoing>
        <bpmn:signalEventDefinition id="SigDef_Emergency" signalRef="Signal_EmergencyCessation" />
      </bpmn:startEvent>

      <bpmn:endEvent id="SP_Emergency_End" name="Cessation&#10;Triggered">
        <bpmn:incoming>Flow_Emergency_Start_End</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="Flow_Emergency_Start_End" sourceRef="SP_Emergency_Start" targetRef="SP_Emergency_End" />
    </bpmn:subProcess>

    <bpmn:endEvent id="EndEvent_Terminated" name="Use Case Terminated&#10;(Emergency Cessation)">
      <bpmn:incoming>Flow_Emergency_Terminated</bpmn:incoming>
      <bpmn:terminateEventDefinition id="TermDef_Terminated" />
    </bpmn:endEvent>

    <bpmn:startEvent id="StartEvent_OversightAudit" name="Periodic Audit&#10;Trigger">
      <bpmn:outgoing>Flow_Oversight_Start_Task</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_OversightPlaceholder" name="Oversight &amp; Audit&#10;Monitoring" camunda:candidateGroups="oversight-lane">
      <bpmn:incoming>Flow_Oversight_Start_Task</bpmn:incoming>
      <bpmn:outgoing>Flow_Oversight_Task_End</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndEvent_OversightComplete" name="Audit&#10;Complete">
      <bpmn:incoming>Flow_Oversight_Task_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:textAnnotation id="Annotation_MultiStart">
      <bpmn:text>Dual start events: Each creates an independent process instance per Camunda 7 multi-start-event semantics</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_MultiStart" sourceRef="StartEvent_OversightAudit" targetRef="Annotation_MultiStart" />

    <bpmn:textAnnotation id="TextAnnotation_Regulatory">
      <bpmn:text>Regulatory Alignment: OCC Bulletin 2023-17 (Third-Party Risk) | SR 11-7 (Model Risk Management) | SOX (Financial Controls) | GDPR/CCPA (Data Privacy) | EU AI Act (AI System Risk) | DORA (Digital Operational Resilience)</bpmn:text>
    </bpmn:textAnnotation>

    <bpmn:textAnnotation id="TextAnnotation_DMN">
      <bpmn:text>DMN Decision Tables: PathwaySelection | RiskClassification | VendorTier | AIRiskLevel | ComplianceRequirements | ApprovalAuthority | SLAPriority | EscalationLevel | RetirementReadiness | DataClassification | SecurityControls | TestingRequirements | DocumentationLevel | AuditFrequency</bpmn:text>
    </bpmn:textAnnotation>

    <bpmn:association id="Assoc_Regulatory" sourceRef="SP_Phase3_DueDiligence" targetRef="TextAnnotation_Regulatory" />
    <bpmn:association id="Assoc_DMN" sourceRef="SP_Phase2_Planning" targetRef="TextAnnotation_DMN" />

    <bpmn:sequenceFlow id="Flow_Start_Phase1" sourceRef="StartEvent_InitiativeRequest" targetRef="SP_Phase1_Intake" />
    <bpmn:sequenceFlow id="Flow_Phase1_Phase2" sourceRef="SP_Phase1_Intake" targetRef="SP_Phase2_Planning" />
    <bpmn:sequenceFlow id="Flow_Phase2_RiskGateway" sourceRef="SP_Phase2_Planning" targetRef="Gateway_RiskTier" />
    <bpmn:sequenceFlow id="Flow_RiskTier_Rejected" name="Unacceptable Risk" sourceRef="Gateway_RiskTier" targetRef="EndEvent_Rejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{riskTier == 'Unacceptable'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_RiskTier_Phase3" name="Acceptable" sourceRef="Gateway_RiskTier" targetRef="SP_Phase3_DueDiligence" />
    <bpmn:sequenceFlow id="Flow_Phase3_Phase4" sourceRef="SP_Phase3_DueDiligence" targetRef="SP_Phase4_GovernanceReview" />
    <bpmn:sequenceFlow id="Flow_Phase4_GovGateway" sourceRef="SP_Phase4_GovernanceReview" targetRef="Gateway_Governance" />
    <bpmn:sequenceFlow id="Flow_Gov_Approved" name="Approved" sourceRef="Gateway_Governance" targetRef="Gateway_GovMerge" />
    <bpmn:sequenceFlow id="Flow_Gov_ApprovedConditions" name="Approved w/ Conditions" sourceRef="Gateway_Governance" targetRef="Gateway_GovMerge">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{governanceDecision == 'approved-conditions'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Gov_Rejected" name="Rejected" sourceRef="Gateway_Governance" targetRef="EndEvent_Rejected_Gov">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{governanceDecision == 'rejected'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_GovMerge_Phase5" sourceRef="Gateway_GovMerge" targetRef="SP_Phase5_Contracting" />
    <bpmn:sequenceFlow id="Flow_Phase5_Phase6" sourceRef="SP_Phase5_Contracting" targetRef="SP_Phase6_SDLC" />
    <bpmn:sequenceFlow id="Flow_Phase6_Phase7" sourceRef="SP_Phase6_SDLC" targetRef="SP_Phase7_Deployment" />
    <bpmn:sequenceFlow id="Flow_Phase7_DeployGateway" sourceRef="SP_Phase7_Deployment" targetRef="Gateway_Deployment" />
    <bpmn:sequenceFlow id="Flow_Deploy_Approved" name="Approved" sourceRef="Gateway_Deployment" targetRef="SP_Phase8_Operations" />
    <bpmn:sequenceFlow id="Flow_Deploy_Rejected" name="Rejected — Rework" sourceRef="Gateway_Deployment" targetRef="SP_Phase6_SDLC">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{deploymentDecision == 'rejected'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Phase8_MonitoringGateway" sourceRef="SP_Phase8_Operations" targetRef="Gateway_Monitoring" />
    <bpmn:sequenceFlow id="Flow_Monitor_Continue" name="Loop: Continue Operations" sourceRef="Gateway_Monitoring" targetRef="SP_Phase8_Operations" />
    <bpmn:sequenceFlow id="Flow_Monitor_Retire" name="Retire" sourceRef="Gateway_Monitoring" targetRef="EndEvent_Retired">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{monitoringOutcome == 'retire'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Emergency_Terminated" sourceRef="SubProcess_Emergency" targetRef="EndEvent_Terminated" />
    <bpmn:sequenceFlow id="Flow_P1_SLA_Escalation" sourceRef="BoundaryEvent_Phase1_SLA" targetRef="EndEvent_Escalation_P1" />
    <bpmn:sequenceFlow id="Flow_P8_Periodic_Review" sourceRef="BoundaryEvent_Phase8_Periodic" targetRef="EndEvent_PeriodicReview" />

    <bpmn:sequenceFlow id="Flow_Oversight_Start_Task" sourceRef="StartEvent_OversightAudit" targetRef="Task_OversightPlaceholder" />
    <bpmn:sequenceFlow id="Flow_Oversight_Task_End" sourceRef="Task_OversightPlaceholder" targetRef="EndEvent_OversightComplete" />

  </bpmn:process>

  <bpmn:process id="Process_VendorResponse" name="Vendor / Third Party Response" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Vendor">
      <bpmn:lane id="Lane_VendorResponse" name="Vendor Response">
        <bpmn:flowNodeRef>VendorStart</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VendorAttestation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>VendorEnd</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="VendorStart" name="RFP&#10;Received">
      <bpmn:outgoing>Flow_Vendor_Start_Task</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_VendorAttestation" name="Submit Due Diligence&#10;Attestation / Response" camunda:candidateGroups="vendor-response">
      <bpmn:incoming>Flow_Vendor_Start_Task</bpmn:incoming>
      <bpmn:outgoing>Flow_Vendor_Task_End</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="VendorEnd" name="Response&#10;Submitted">
      <bpmn:incoming>Flow_Vendor_Task_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Vendor_Start_Task" sourceRef="VendorStart" targetRef="Task_VendorAttestation" />
    <bpmn:sequenceFlow id="Flow_Vendor_Task_End" sourceRef="Task_VendorAttestation" targetRef="VendorEnd" />
  </bpmn:process>

