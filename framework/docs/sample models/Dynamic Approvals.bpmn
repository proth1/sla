<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1igvcwu" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.30.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.20.0">
  <bpmn:process id="DynamicApprovalsProcess" name="Dynamic Approvals" isExecutable="true" camunda:historyTimeToLive="10">
    <bpmn:startEvent id="startApproval" name="Start Request&#10;for Approval" camunda:formHandlerClass="org.softcannery.camunda.FormioStartFormHandler" camunda:formKey="embedded:app:formio.html">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="formio.variable" value="StartEvent_1" />
          <camunda:property name="formio.outputDataSource" value="ApprovalData" />
          <camunda:property name="formio.file" value="Dynamic Approvals.formio" />
          <camunda:property name="formio.form" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_1nng5ro</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_00k4f9y">
        <bpmn:targetRef>approvalData</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_0qn0d0v">
        <bpmn:targetRef>approvalData</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:startEvent>
    <bpmn:dataStoreReference id="approvalData" name="ApprovalData" />
    <bpmn:subProcess id="Activity_1r2o32n" name="Approval Task for each Approver">
      <bpmn:extensionElements />
      <bpmn:incoming>Flow_0cifwaq</bpmn:incoming>
      <bpmn:outgoing>Flow_1gm9axg</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics camunda:collection="${formio.ApprovalData.data.approvers}" camunda:elementVariable="approver" />
      <bpmn:intermediateThrowEvent id="Event_1vm3enj" name="Increment Approval Count">
        <bpmn:extensionElements>
          <camunda:executionListener expression="${execution.setVariable(&#39;approvalCount&#39;, approvalCount + 1)}" event="start" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0fr86sd</bpmn:incoming>
        <bpmn:outgoing>Flow_06635tt</bpmn:outgoing>
      </bpmn:intermediateThrowEvent>
      <bpmn:exclusiveGateway id="Gateway_18vmepe">
        <bpmn:incoming>Flow_0lp8g3b</bpmn:incoming>
        <bpmn:incoming>Flow_0ob64ep</bpmn:incoming>
        <bpmn:outgoing>Flow_179y0qs</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:exclusiveGateway id="Gateway_19c9osz">
        <bpmn:incoming>Flow_1ttwvxd</bpmn:incoming>
        <bpmn:outgoing>Flow_0rig6z2</bpmn:outgoing>
        <bpmn:outgoing>Flow_0fr86sd</bpmn:outgoing>
        <bpmn:outgoing>Flow_087uym3</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:sequenceFlow id="Flow_0rig6z2" name="Declined" sourceRef="Gateway_19c9osz" targetRef="Event_14uegql">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${formio.ApproverData[loopCounter].data.isApproved == "Not Approved"}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_0fr86sd" name="Approved" sourceRef="Gateway_19c9osz" targetRef="Event_1vm3enj">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${formio.ApproverData[loopCounter].data.isApproved == "Approved"}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:startEvent id="Event_1wsjp2r" name="Start an&#10;Approval&#10;Request">
        <bpmn:extensionElements />
        <bpmn:outgoing>Flow_0lp8g3b</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:sequenceFlow id="Flow_0lp8g3b" sourceRef="Event_1wsjp2r" targetRef="Gateway_18vmepe" />
      <bpmn:intermediateThrowEvent id="Event_14uegql" name="Increment Decline Count">
        <bpmn:extensionElements>
          <camunda:executionListener expression="${execution.setVariable(&#39;declineCount&#39;, declineCount + 1)}" event="start" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0rig6z2</bpmn:incoming>
        <bpmn:outgoing>Flow_19he22q</bpmn:outgoing>
      </bpmn:intermediateThrowEvent>
      <bpmn:sequenceFlow id="Flow_087uym3" sourceRef="Gateway_19c9osz" targetRef="Event_1j7vtze">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${formio.ApproverData[loopCounter].data.isApproved == "Need More Info"}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:intermediateThrowEvent id="Event_1j7vtze" name="Increment Q&#38;A Count">
        <bpmn:extensionElements>
          <camunda:executionListener expression="${execution.setVariable(&#39;questionAndAnswerLoopCount&#39;, questionAndAnswerLoopCount + 1)}" event="start" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_087uym3</bpmn:incoming>
        <bpmn:outgoing>Flow_1kls7zk</bpmn:outgoing>
      </bpmn:intermediateThrowEvent>
      <bpmn:intermediateThrowEvent id="Event_1x4xolx" name="Decline Requirements Satisfied">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:outputParameter name="cancelOutstandingApprovalTasks">${true}</camunda:outputParameter>
            <camunda:outputParameter name="cancelOutstandingNeedMoreInfoTasks">${true}</camunda:outputParameter>
            <camunda:outputParameter name="isRequestDeclined">${true}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0w93f4b</bpmn:incoming>
        <bpmn:outgoing>Flow_08csngx</bpmn:outgoing>
      </bpmn:intermediateThrowEvent>
      <bpmn:intermediateThrowEvent id="Event_0f0zm6l" name="More Approvals Required">
        <bpmn:incoming>Flow_1f8ec1t</bpmn:incoming>
        <bpmn:outgoing>Flow_1356yop</bpmn:outgoing>
      </bpmn:intermediateThrowEvent>
      <bpmn:intermediateThrowEvent id="Event_15vuj2l" name="Approval Requirements Satisfied">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:outputParameter name="cancelOutstandingApprovalTasks">${true}</camunda:outputParameter>
            <camunda:outputParameter name="cancelOutstandingNeedMoreInfoTasks">${true}</camunda:outputParameter>
            <camunda:outputParameter name="isRequestApproved">${true}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_138ty3v</bpmn:incoming>
        <bpmn:outgoing>Flow_1ifvml4</bpmn:outgoing>
      </bpmn:intermediateThrowEvent>
      <bpmn:endEvent id="Event_0t5nhan" name="Approval&#10;Declined">
        <bpmn:incoming>Flow_1soqf0p</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:exclusiveGateway id="Gateway_1pa4i7y">
        <bpmn:incoming>Flow_1356yop</bpmn:incoming>
        <bpmn:incoming>Flow_1ifvml4</bpmn:incoming>
        <bpmn:outgoing>Flow_0wscg5g</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:exclusiveGateway id="Gateway_0e5f0oq" name="Met Required Approval Count ?">
        <bpmn:incoming>Flow_06635tt</bpmn:incoming>
        <bpmn:outgoing>Flow_1f8ec1t</bpmn:outgoing>
        <bpmn:outgoing>Flow_138ty3v</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:endEvent id="Event_0wbmwex" name="Approval Approved">
        <bpmn:incoming>Flow_0wscg5g</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_08csngx" sourceRef="Event_1x4xolx" targetRef="Gateway_1kysxua" />
      <bpmn:sequenceFlow id="Flow_1f8ec1t" name="No" sourceRef="Gateway_0e5f0oq" targetRef="Event_0f0zm6l">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${numberOfRequiredApprovers != approvalCount}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_1356yop" sourceRef="Event_0f0zm6l" targetRef="Gateway_1pa4i7y" />
      <bpmn:sequenceFlow id="Flow_0wscg5g" sourceRef="Gateway_1pa4i7y" targetRef="Event_0wbmwex" />
      <bpmn:sequenceFlow id="Flow_19he22q" sourceRef="Event_14uegql" targetRef="Gateway_1nj9524" />
      <bpmn:exclusiveGateway id="Gateway_1nj9524" name="Met Required&#10;Decline Count ?">
        <bpmn:incoming>Flow_19he22q</bpmn:incoming>
        <bpmn:outgoing>Flow_0w93f4b</bpmn:outgoing>
        <bpmn:outgoing>Flow_04t45i8</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:sequenceFlow id="Flow_0w93f4b" name="Yes" sourceRef="Gateway_1nj9524" targetRef="Event_1x4xolx">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${numberOfRequiredDecliners == declineCount}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:exclusiveGateway id="Gateway_1kysxua">
        <bpmn:incoming>Flow_08csngx</bpmn:incoming>
        <bpmn:incoming>Flow_1387368</bpmn:incoming>
        <bpmn:outgoing>Flow_1soqf0p</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:sequenceFlow id="Flow_1soqf0p" sourceRef="Gateway_1kysxua" targetRef="Event_0t5nhan" />
      <bpmn:sequenceFlow id="Flow_04t45i8" name="No" sourceRef="Gateway_1nj9524" targetRef="Event_0c6vmus">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${numberOfRequiredDecliners != declineCount}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_06635tt" sourceRef="Event_1vm3enj" targetRef="Gateway_0e5f0oq" />
      <bpmn:sequenceFlow id="Flow_138ty3v" sourceRef="Gateway_0e5f0oq" targetRef="Event_15vuj2l">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${numberOfRequiredApprovers == approvalCount}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_1ifvml4" sourceRef="Event_15vuj2l" targetRef="Gateway_1pa4i7y" />
      <bpmn:intermediateThrowEvent id="Event_0c6vmus" name="More Declines Required">
        <bpmn:incoming>Flow_04t45i8</bpmn:incoming>
        <bpmn:outgoing>Flow_1387368</bpmn:outgoing>
      </bpmn:intermediateThrowEvent>
      <bpmn:sequenceFlow id="Flow_1387368" sourceRef="Event_0c6vmus" targetRef="Gateway_1kysxua" />
      <bpmn:subProcess id="Activity_1c7gh9s">
        <bpmn:incoming>Flow_179y0qs</bpmn:incoming>
        <bpmn:outgoing>Flow_1ttwvxd</bpmn:outgoing>
        <bpmn:startEvent id="Event_1ckf8nc">
          <bpmn:outgoing>Flow_14sndoq</bpmn:outgoing>
        </bpmn:startEvent>
        <bpmn:subProcess id="Activity_06csgoo" name="Request for Approval">
          <bpmn:incoming>Flow_14sndoq</bpmn:incoming>
          <bpmn:outgoing>Flow_1lokwui</bpmn:outgoing>
          <bpmn:subProcess id="Activity_03r5a7t">
            <bpmn:incoming>Flow_0dfjr79</bpmn:incoming>
            <bpmn:outgoing>Flow_0cj71nh</bpmn:outgoing>
            <bpmn:startEvent id="Event_1kq405n">
              <bpmn:outgoing>Flow_0r7q4u8</bpmn:outgoing>
            </bpmn:startEvent>
            <bpmn:userTask id="approvalTask" name="Request for Approval" camunda:formKey="embedded:app:formio.html" camunda:assignee="${approver.approverEmail}">
              <bpmn:extensionElements>
                <camunda:inputOutput>
                  <camunda:inputParameter name="approvalTask">${questionAndAnswerLoopCount == 0 ? formio.ApprovalData.json : formio.ApproverData[loopCounter].json}</camunda:inputParameter>
                </camunda:inputOutput>
                <camunda:properties>
                  <camunda:property name="formio.variable" value="approvalTask" />
                  <camunda:property name="formio.inputDataSource" value="ApprovalData" />
                  <camunda:property name="formio.outputDataSource" value="ApproverData" />
                  <camunda:property name="formio.file" value="Dynamic Approvals.formio" />
                  <camunda:property name="formio.form" value="q2CAdHocApprovalResponse" />
                </camunda:properties>
              </bpmn:extensionElements>
              <bpmn:incoming>Flow_0r7q4u8</bpmn:incoming>
              <bpmn:outgoing>Flow_1b4axe9</bpmn:outgoing>
              <bpmn:property id="Property_0pu5b72" name="__targetRef_placeholder" />
              <bpmn:dataInputAssociation id="DataInputAssociation_1issqkl">
                <bpmn:sourceRef>DataStoreReference_1jj67nc</bpmn:sourceRef>
                <bpmn:targetRef>Property_0pu5b72</bpmn:targetRef>
              </bpmn:dataInputAssociation>
              <bpmn:dataOutputAssociation id="DataOutputAssociation_1jokki7">
                <bpmn:targetRef>DataStoreReference_12eofc4</bpmn:targetRef>
              </bpmn:dataOutputAssociation>
            </bpmn:userTask>
            <bpmn:dataStoreReference id="DataStoreReference_1jj67nc" name="ApprovalData" />
            <bpmn:dataStoreReference id="DataStoreReference_12eofc4" name="ApproverData" />
            <bpmn:sequenceFlow id="Flow_0r7q4u8" sourceRef="Event_1kq405n" targetRef="approvalTask" />
            <bpmn:endEvent id="Event_1j3f0lt">
              <bpmn:incoming>Flow_0eaxgbo</bpmn:incoming>
            </bpmn:endEvent>
            <bpmn:sequenceFlow id="Flow_1b4axe9" sourceRef="approvalTask" targetRef="Event_0yxwfnp" />
            <bpmn:intermediateThrowEvent id="Event_0yxwfnp" name="Update ApprovalData">
              <bpmn:extensionElements>
                <camunda:executionListener event="start">
                  <camunda:script scriptFormat="groovy">def approverStatus = formio.ApproverData[loopCounter].data.approvers[loopCounter].isApproved
def approverResponse = formio.ApproverData[loopCounter].data.response

if (approverStatus == 'Need More Info') {
    formio.ApprovalData.data.approvers[loopCounter]
          .questionsAndAnswers[questionAndAnswerLoopCount]
          .question = approverResponse
}

formio.ApprovalData.data.approvers[loopCounter].with {
    response   = approverResponse
    isApproved = approverStatus
}
</camunda:script>
                </camunda:executionListener>
              </bpmn:extensionElements>
              <bpmn:incoming>Flow_1b4axe9</bpmn:incoming>
              <bpmn:outgoing>Flow_0eaxgbo</bpmn:outgoing>
            </bpmn:intermediateThrowEvent>
            <bpmn:sequenceFlow id="Flow_0eaxgbo" sourceRef="Event_0yxwfnp" targetRef="Event_1j3f0lt" />
          </bpmn:subProcess>
          <bpmn:startEvent id="Event_0z11vy3">
            <bpmn:outgoing>Flow_0dfjr79</bpmn:outgoing>
          </bpmn:startEvent>
          <bpmn:endEvent id="Event_1et7ccq">
            <bpmn:incoming>Flow_0cj71nh</bpmn:incoming>
          </bpmn:endEvent>
          <bpmn:sequenceFlow id="Flow_0cj71nh" sourceRef="Activity_03r5a7t" targetRef="Event_1et7ccq" />
          <bpmn:sequenceFlow id="Flow_0dfjr79" sourceRef="Event_0z11vy3" targetRef="Activity_03r5a7t" />
        </bpmn:subProcess>
        <bpmn:sequenceFlow id="Flow_14sndoq" sourceRef="Event_1ckf8nc" targetRef="Activity_06csgoo" />
        <bpmn:sequenceFlow id="Flow_1lokwui" sourceRef="Activity_06csgoo" targetRef="Event_0dp8eg1" />
        <bpmn:endEvent id="Event_0dp8eg1">
          <bpmn:extensionElements>
            <camunda:inputOutput>
              <camunda:inputParameter name="commentBody">${formio.ApproverData[loopCounter].metadata.updatedBy} | ${approvalTaskNameForDisplay} Response: ${formio.ApproverData[loopCounter].data.isApproved} | Response: ${formio.ApproverData[loopCounter].data.response}</camunda:inputParameter>
            </camunda:inputOutput>
          </bpmn:extensionElements>
          <bpmn:incoming>Flow_1lokwui</bpmn:incoming>
        </bpmn:endEvent>
      </bpmn:subProcess>
      <bpmn:subProcess id="Activity_1geb6ho">
        <bpmn:incoming>Flow_1kls7zk</bpmn:incoming>
        <bpmn:outgoing>Flow_0ob64ep</bpmn:outgoing>
        <bpmn:startEvent id="Event_0mnyvzi">
          <bpmn:outgoing>Flow_1388xuf</bpmn:outgoing>
        </bpmn:startEvent>
        <bpmn:subProcess id="Activity_0epd826" name="Need More Info from Requester">
          <bpmn:incoming>Flow_1388xuf</bpmn:incoming>
          <bpmn:outgoing>Flow_0z3vpfx</bpmn:outgoing>
          <bpmn:endEvent id="Event_02xcyot" name="Cancel&#10;Request">
            <bpmn:incoming>Flow_1v8i7w3</bpmn:incoming>
            <bpmn:escalationEventDefinition id="EscalationEventDefinition_0c5r5ah" escalationRef="Escalation_0kmhh33" />
          </bpmn:endEvent>
          <bpmn:exclusiveGateway id="Gateway_1qdpnt0" name="Cancel ?">
            <bpmn:incoming>Flow_0taq67f</bpmn:incoming>
            <bpmn:outgoing>Flow_1v8i7w3</bpmn:outgoing>
            <bpmn:outgoing>Flow_0it703u</bpmn:outgoing>
          </bpmn:exclusiveGateway>
          <bpmn:userTask id="needMoreInfo" name="Need More Info" camunda:formKey="embedded:app:formio.html" camunda:candidateGroups="${execution.getVariable(&#34;requesterGroup&#34;)}">
            <bpmn:extensionElements>
              <camunda:properties>
                <camunda:property name="formio.variable" value="needMoreInfo" />
                <camunda:property name="formio.inputDataSource" value="ApproverData" />
                <camunda:property name="formio.outputDataSource" value="ApproverData" />
                <camunda:property name="formio.file" value="Dynamic Approvals.formio" />
                <camunda:property name="formio.form" value="q2CAdHocApprovalNeedMoreInfo" />
              </camunda:properties>
              <camunda:inputOutput>
                <camunda:inputParameter name="needMoreInfo">${formio.ApproverData[loopCounter].json}</camunda:inputParameter>
              </camunda:inputOutput>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_1oev6v0</bpmn:incoming>
            <bpmn:outgoing>Flow_0taq67f</bpmn:outgoing>
          </bpmn:userTask>
          <bpmn:sequenceFlow id="Flow_1v8i7w3" name="Yes" sourceRef="Gateway_1qdpnt0" targetRef="Event_02xcyot">
            <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${formio.ApproverData[loopCounter].data.nextStep == "cancelled"}</bpmn:conditionExpression>
          </bpmn:sequenceFlow>
          <bpmn:startEvent id="Event_1ypnwwp">
            <bpmn:outgoing>Flow_0yf9zfo</bpmn:outgoing>
          </bpmn:startEvent>
          <bpmn:sequenceFlow id="Flow_0taq67f" sourceRef="needMoreInfo" targetRef="Gateway_1qdpnt0" />
          <bpmn:endEvent id="Event_0zbpozk">
            <bpmn:incoming>Flow_1pnp4u9</bpmn:incoming>
          </bpmn:endEvent>
          <bpmn:sequenceFlow id="Flow_0it703u" name="No" sourceRef="Gateway_1qdpnt0" targetRef="Event_04y1zlb">
            <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${formio.ApproverData[loopCounter].data.nextStep != "cancelled"}</bpmn:conditionExpression>
          </bpmn:sequenceFlow>
          <bpmn:sequenceFlow id="Flow_0yf9zfo" sourceRef="Event_1ypnwwp" targetRef="Event_1svo7g8" />
          <bpmn:intermediateThrowEvent id="Event_1svo7g8" name="Reset form" camunda:asyncAfter="true">
            <bpmn:extensionElements>
              <camunda:executionListener expression="${formio.ApproverData[loopCounter].data.remove(&#34;nextStep&#34;)}" event="start" />
              <camunda:executionListener expression="${formio.ApproverData[loopCounter].data.remove(&#34;responseReview&#34;)}" event="start" />
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_0yf9zfo</bpmn:incoming>
            <bpmn:outgoing>Flow_1oev6v0</bpmn:outgoing>
          </bpmn:intermediateThrowEvent>
          <bpmn:sequenceFlow id="Flow_1oev6v0" sourceRef="Event_1svo7g8" targetRef="needMoreInfo" />
          <bpmn:intermediateThrowEvent id="Event_04y1zlb" name="Reset form">
            <bpmn:extensionElements>
              <camunda:executionListener expression="${formio.ApproverData[loopCounter].data.remove(&#34;response&#34;)}" event="end" />
              <camunda:executionListener expression="${formio.ApproverData[loopCounter].data.remove(&#34;isApproved&#34;)}" event="end" />
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_0it703u</bpmn:incoming>
            <bpmn:outgoing>Flow_1pnp4u9</bpmn:outgoing>
          </bpmn:intermediateThrowEvent>
          <bpmn:sequenceFlow id="Flow_1pnp4u9" sourceRef="Event_04y1zlb" targetRef="Event_0zbpozk" />
          <bpmn:textAnnotation id="TextAnnotation_098kkz6">
            <bpmn:text>response
responseReview
nextStep</bpmn:text>
          </bpmn:textAnnotation>
          <bpmn:association id="Association_1vgga2o" associationDirection="None" sourceRef="needMoreInfo" targetRef="TextAnnotation_098kkz6" />
          <bpmn:textAnnotation id="TextAnnotation_1kmpsq0">
            <bpmn:text>responseReview
nextStep</bpmn:text>
          </bpmn:textAnnotation>
          <bpmn:association id="Association_0m1a4ry" associationDirection="None" sourceRef="Event_1svo7g8" targetRef="TextAnnotation_1kmpsq0" />
        </bpmn:subProcess>
        <bpmn:endEvent id="Event_042f4is">
          <bpmn:incoming>Flow_0z3vpfx</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:sequenceFlow id="Flow_0z3vpfx" sourceRef="Activity_0epd826" targetRef="Event_042f4is" />
        <bpmn:sequenceFlow id="Flow_1388xuf" sourceRef="Event_0mnyvzi" targetRef="Activity_0epd826" />
      </bpmn:subProcess>
      <bpmn:sequenceFlow id="Flow_1kls7zk" sourceRef="Event_1j7vtze" targetRef="Activity_1geb6ho" />
      <bpmn:sequenceFlow id="Flow_0ob64ep" sourceRef="Activity_1geb6ho" targetRef="Gateway_18vmepe" />
      <bpmn:sequenceFlow id="Flow_1ttwvxd" sourceRef="Activity_1c7gh9s" targetRef="Gateway_19c9osz" />
      <bpmn:boundaryEvent id="Event_0x54c7o" attachedToRef="Activity_1c7gh9s">
        <bpmn:outgoing>Flow_03xdicn</bpmn:outgoing>
