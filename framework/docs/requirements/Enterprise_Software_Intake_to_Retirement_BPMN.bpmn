Actor: Data Engineer / Data Steward | SLA: 4 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:endEvent id="End_SP34" />

      <bpmn:sequenceFlow id="f_sp34_1" sourceRef="Start_SP34" targetRef="Task_T3411" />
      <bpmn:sequenceFlow id="f_sp34_2" sourceRef="Task_T3411" targetRef="Task_T3412" />
