<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  id="Definitions_1"
  targetNamespace="http://bpmn.io/schema/bpmn"
  exporter="Enterprise_Software_Governance_BPMN_Generator"
  exporterVersion="1.0">

  <!-- ================================================================== -->
  <!-- COLLABORATION: All Pools and Message Flows                         -->
  <!-- ================================================================== -->
  <bpmn:collaboration id="Collaboration_IntakeToRetirement">
    <bpmn:documentation>Enterprise Software Intake to Retirement Lifecycle - Complete BPMN 2.0 Process Model.
Process ID: PRC-E2E-001. Owner: Enterprise Architecture Governance Board.
Target Cycle Time: 29-45 days (Standard) from intake to Phase 3 exit, vs. industry baseline of 90-120 days.
This model includes all 8 lifecycle phases, 15+ sub-processes, 80+ tasks, 9 DMN decision tables,
5 cross-cutting event sub-processes, and comprehensive SLA timer boundary events.</bpmn:documentation>

    <bpmn:participant id="Pool_Requestor" name="Requestor Pool (Business Units)" processRef="Process_Requestor" />
    <bpmn:participant id="Pool_Governance" name="Governance Pool (Enterprise Governance Board)" processRef="Process_Governance" />
    <bpmn:participant id="Pool_Technical" name="Technical Pool (Architecture / Security / Development)" processRef="Process_Technical" />
    <bpmn:participant id="Pool_Vendor" name="Vendor Pool (Third-Party Vendors)" processRef="Process_Vendor" />
    <bpmn:participant id="Pool_Operations" name="Operations Pool (IT Operations / SRE)" processRef="Process_Operations" />
    <bpmn:participant id="Pool_AI" name="AI Platform Pool (AI Agents &amp; DMN Engine)" processRef="Process_AI" />

    <!-- Message Flows Between Pools -->
    <bpmn:messageFlow id="MF_001" name="Intake Request Submission" sourceRef="Task_T1111" targetRef="Task_T1121" />
    <bpmn:messageFlow id="MF_002" name="Validation Rejection Return" sourceRef="Task_T1123" targetRef="Task_T1111" />
    <bpmn:messageFlow id="MF_003" name="AI Pre-population Results" sourceRef="Task_T1113_AI" targetRef="Task_T1111" />
    <bpmn:messageFlow id="MF_004" name="Risk Triage Request to AI" sourceRef="Task_T1211" targetRef="Task_T1211_AI" />
    <bpmn:messageFlow id="MF_005" name="AI Risk Score Response" sourceRef="Task_T1211_AI" targetRef="Task_T1212" />
    <bpmn:messageFlow id="MF_006" name="Vendor Assessment Request" sourceRef="SP_2_3" targetRef="Pool_Vendor" />
    <bpmn:messageFlow id="MF_007" name="Vendor Questionnaire Response" sourceRef="Pool_Vendor" targetRef="Task_T2321" />
    <bpmn:messageFlow id="MF_008" name="Provisioning Instructions" sourceRef="SP_3_1" targetRef="Pool_Operations" />
    <bpmn:messageFlow id="MF_009" name="Environment Ready Notification" sourceRef="Pool_Operations" targetRef="Task_T3131" />
    <bpmn:messageFlow id="MF_010" name="Gate Decision Notification" sourceRef="Task_T1331" targetRef="Pool_Requestor" />
    <bpmn:messageFlow id="MF_011" name="Phase 2 Gate Notification" sourceRef="Task_T2522" targetRef="Pool_Requestor" />
    <bpmn:messageFlow id="MF_012" name="SLA Breach Escalation" sourceRef="EventSP_SLA_Breach" targetRef="Pool_Governance" />
  </bpmn:collaboration>

  <!-- ================================================================== -->
  <!-- PROCESS: Main Orchestration (Governance Pool - Primary Flow)       -->
  <!-- ================================================================== -->
  <bpmn:process id="Process_Governance" name="Enterprise Software Intake to Retirement Lifecycle" isExecutable="true">

    <!-- ================================================================ -->
    <!-- DATA STORES (Knowledge Bases)                                    -->
    <!-- ================================================================ -->
    <bpmn:dataStoreReference id="DS_KB001" name="KB-001: Enterprise Data Classification Schema" />
    <bpmn:dataStoreReference id="DS_KB002" name="KB-002: Technology Radar" />
    <bpmn:dataStoreReference id="DS_KB003" name="KB-003: Regulatory Requirements Registry" />
    <bpmn:dataStoreReference id="DS_KB004" name="KB-004: Enterprise Reference Architecture" />
    <bpmn:dataStoreReference id="DS_KB005" name="KB-005: Vendor Risk Intelligence Database" />
    <bpmn:dataStoreReference id="DS_KB006" name="KB-006: Security Controls Catalog" />
    <bpmn:dataStoreReference id="DS_KB007" name="KB-007: Historical Initiative Repository" />
    <bpmn:dataStoreReference id="DS_KB008" name="KB-008: AI Model Registry" />
    <bpmn:dataStoreReference id="DS_KB009" name="KB-009: SLA and Performance Baseline Library" />
    <bpmn:dataStoreReference id="DS_KB010" name="KB-010: Compliance-as-Code Policy Library" />

    <!-- ================================================================ -->
    <!-- DATA OBJECTS                                                      -->
    <!-- ================================================================ -->
    <bpmn:dataObjectReference id="DO_InitiativeRecord" name="Initiative Record (INI-YYYY-NNNN)" dataObjectRef="DataObj_Initiative" />
    <bpmn:dataObject id="DataObj_Initiative" name="Initiative Record" />
    <bpmn:dataObjectReference id="DO_RiskAssessment" name="Consolidated Risk Assessment Report" dataObjectRef="DataObj_Risk" />
    <bpmn:dataObject id="DataObj_Risk" name="Risk Assessment" />
    <bpmn:dataObjectReference id="DO_OnboardingPlan" name="Onboarding Plan with Resource Allocation" dataObjectRef="DataObj_Onboard" />
    <bpmn:dataObject id="DataObj_Onboard" name="Onboarding Plan" />
    <bpmn:dataObjectReference id="DO_ScopeMatrix" name="Assessment Scope Matrix" dataObjectRef="DataObj_Scope" />
    <bpmn:dataObject id="DataObj_Scope" name="Scope Matrix" />

    <!-- ================================================================ -->
    <!-- LANES within Governance Process                                   -->
    <!-- ================================================================ -->
    <bpmn:laneSet id="LaneSet_Gov">
      <bpmn:lane id="Lane_IntakeCoord" name="Intake Coordination">
        <bpmn:flowNodeRef>StartEvent_Intake</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_1_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_1_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_RiskGov" name="Risk &amp; Governance">
        <bpmn:flowNodeRef>SP_1_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_1_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_1_3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_1_3</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Assessment" name="Assessment &amp; Classification">
        <bpmn:flowNodeRef>SP_2_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_2_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_2_3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_2_4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_2_5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_2_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_2_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_2_3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_2_4</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Onboarding" name="Onboarding &amp; Provisioning">
        <bpmn:flowNodeRef>SP_3_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_3_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_3_3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_3_4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_3_5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_3_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_3_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_3_3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_3_4</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_PostOnboard" name="Post-Onboarding Lifecycle">
        <bpmn:flowNodeRef>SP_Phase4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_Phase5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_Phase6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_Phase7</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_Phase8</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Retirement</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- ================================================================ -->
    <!-- START EVENT                                                       -->
    <!-- ================================================================ -->
    <bpmn:startEvent id="StartEvent_Intake" name="New Software Initiative Request Received">
      <bpmn:documentation>Trigger: New software initiative request submitted via Intake Portal, email, or API.
Process: PRC-E2E-001 | Enterprise Software Intake to Retirement Lifecycle</bpmn:documentation>
      <bpmn:outgoing>Flow_Start_SP11</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgEvtDef_Intake" />
    </bpmn:startEvent>

    <!-- ================================================================ -->
    <!-- PHASE 1: INITIATION & IDEA INTAKE (PRC-PH1-001)                  -->
    <!-- Phase SLA: 3-5 days (Standard) | 1-2 days (Low) | 5-7 (Critical) -->
    <!-- ================================================================ -->

    <!-- ============================================================== -->
    <!-- SP-1.1: Request Capture & Validation | SLA: 0.5-1 day         -->
    <!-- ============================================================== -->
    <bpmn:subProcess id="SP_1_1" name="SP-1.1: Request Capture &amp; Validation">
      <bpmn:documentation>Sub-Process ID: SP-1.1 | SLA: 0.5-1 business day
Lane: Requestor Pool → Governance Pool
Activities: Submit Initiative Request, Validate Request Completeness, Register Initiative</bpmn:documentation>
      <bpmn:incoming>Flow_Start_SP11</bpmn:incoming>
      <bpmn:outgoing>Flow_SP11_GW11</bpmn:outgoing>

      <bpmn:startEvent id="Start_SP11" name="Request Received" />

      <!-- A-1.1.1: Submit Initiative Request -->
      <bpmn:task id="Task_T1111" name="T-1.1.1.1: Complete Intake Form">
        <bpmn:documentation>Requestor completes intake form: initiative name, description, business unit, sponsor, estimated budget range, requested timeline.
Actor: Requestor | SLA: Self-service</bpmn:documentation>
      </bpmn:task>
      <bpmn:task id="Task_T1112" name="T-1.1.1.2: Attach Supporting Documents">
        <bpmn:documentation>Attach supporting documents: business case draft, market analysis, preliminary requirements.
Actor: Requestor | SLA: Self-service</bpmn:documentation>
      </bpmn:task>
      <bpmn:serviceTask id="Task_T1113_AI" name="T-1.1.1.3: AI Auto-Classification &amp; Pre-Population">
        <bpmn:documentation>AI auto-classification engine pre-populates fields based on historical patterns and NLP analysis of description.
Actor: AI Intake Agent | SLA: &lt; 30 seconds
Reads from: KB-007 (Historical Initiative Repository)</bpmn:documentation>
      </bpmn:serviceTask>

      <!-- A-1.1.2: Validate Request Completeness -->
      <bpmn:serviceTask id="Task_T1121" name="T-1.1.2.1: Validate Mandatory Fields">
        <bpmn:documentation>System validates all mandatory fields are completed against intake schema.
Actor: System (Automated) | SLA: &lt; 5 seconds</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_T1122" name="T-1.1.2.2: AI Duplicate Detection">
        <bpmn:documentation>AI agent checks for duplicate or similar existing initiatives using semantic similarity scoring.
Actor: AI Intake Agent | SLA: &lt; 15 seconds
Reads from: KB-007 (Historical Initiative Repository)</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:task id="Task_T1123" name="T-1.1.2.3: Route Incomplete/Duplicate">
        <bpmn:documentation>If incomplete: return to requestor with specific field-level guidance.
If duplicate detected: route to merge/append workflow.
Actor: System / Requestor | SLA: &lt; 1 hour turnaround</bpmn:documentation>
      </bpmn:task>

      <!-- A-1.1.3: Register Initiative -->
      <bpmn:serviceTask id="Task_T1131" name="T-1.1.3.1: Assign Unique Initiative ID">
        <bpmn:documentation>Assign unique initiative ID (format: INI-YYYY-NNNN).
Actor: System (Automated) | SLA: Immediate</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_T1132" name="T-1.1.3.2: Create Initiative Record">
        <bpmn:documentation>Create initiative record in governance repository with audit trail.
Actor: System (Automated) | SLA: Immediate
Writes to: Governance Repository (TP-002)</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:sendTask id="Task_T1133" name="T-1.1.3.3: Notify Intake Coordinator">
        <bpmn:documentation>Notify intake coordinator and assigned governance analyst.
Actor: System (Automated) | SLA: &lt; 2 minutes
Uses: Communication &amp; Notification Engine (TP-012)</bpmn:documentation>
      </bpmn:sendTask>

      <bpmn:endEvent id="End_SP11" name="Request Captured &amp; Registered" />

      <!-- Internal Sequence Flows for SP-1.1 -->
      <bpmn:sequenceFlow id="Flow_SP11_1" sourceRef="Start_SP11" targetRef="Task_T1111" />
      <bpmn:sequenceFlow id="Flow_SP11_2" sourceRef="Task_T1111" targetRef="Task_T1112" />
      <bpmn:sequenceFlow id="Flow_SP11_3" sourceRef="Task_T1112" targetRef="Task_T1113_AI" />
      <bpmn:sequenceFlow id="Flow_SP11_4" sourceRef="Task_T1113_AI" targetRef="Task_T1121" />
      <bpmn:sequenceFlow id="Flow_SP11_5" sourceRef="Task_T1121" targetRef="Task_T1122" />
      <bpmn:sequenceFlow id="Flow_SP11_6" sourceRef="Task_T1122" targetRef="Task_T1123" />
      <bpmn:sequenceFlow id="Flow_SP11_7" sourceRef="Task_T1123" targetRef="Task_T1131" />
      <bpmn:sequenceFlow id="Flow_SP11_8" sourceRef="Task_T1131" targetRef="Task_T1132" />
      <bpmn:sequenceFlow id="Flow_SP11_9" sourceRef="Task_T1132" targetRef="Task_T1133" />
      <bpmn:sequenceFlow id="Flow_SP11_10" sourceRef="Task_T1133" targetRef="End_SP11" />
    </bpmn:subProcess>

    <!-- SLA Timer on SP-1.1: 0.5-1 business day -->
    <bpmn:boundaryEvent id="Timer_SP11_50" name="SLA 50% Warning (4h)" attachedToRef="SP_1_1" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>PT4H</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Timer_SP11_75" name="SLA 75% Alert (6h)" attachedToRef="SP_1_1" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>PT6H</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Timer_SP11_100" name="SLA Breach (8h)" attachedToRef="SP_1_1" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>PT8H</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- GW-1.1: Post-Validation Gateway -->
    <bpmn:exclusiveGateway id="GW_1_1" name="GW-1.1: Validation Result">
      <bpmn:documentation>Gateway ID: GW-1.1 | Type: Exclusive (XOR) | Location: After SP-1.1
Routing: Complete → SP-1.2 | Incomplete → loop back to Requestor | Duplicate → Merge sub-process</bpmn:documentation>
      <bpmn:incoming>Flow_SP11_GW11</bpmn:incoming>
      <bpmn:outgoing>Flow_GW11_SP12</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW11_Incomplete</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW11_Duplicate</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ============================================================== -->
    <!-- SP-1.2: Initial Risk Triage | SLA: 0.5-1 day                   -->
    <!-- ============================================================== -->
    <bpmn:subProcess id="SP_1_2" name="SP-1.2: Initial Risk Triage">
      <bpmn:documentation>Sub-Process ID: SP-1.2 | SLA: 0.5-1 business day | Lane: Governance Pool
Activities: Preliminary Risk Screening, Human Review of AI Triage, Pathway Determination
DMN Tables Invoked: DMN-DT-001 (Risk Tier), DMN-DT-002 (Pathway Determination)</bpmn:documentation>
      <bpmn:incoming>Flow_GW11_SP12</bpmn:incoming>
      <bpmn:outgoing>Flow_SP12_GW12</bpmn:outgoing>

      <bpmn:startEvent id="Start_SP12" name="Validated Request Received" />

      <!-- A-1.2.1: Preliminary Risk Screening -->
      <bpmn:serviceTask id="Task_T1211" name="T-1.2.1.1: AI 6-Dimension Risk Scoring">
        <bpmn:documentation>AI Risk Agent scores initiative across 6 dimensions: data sensitivity, regulatory exposure, integration complexity, vendor dependency, business criticality, technology novelty.
Actor: AI Risk Agent | SLA: &lt; 2 minutes
Reads from: KB-001 (Data Classification), KB-003 (Regulatory Registry)</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_T1212" name="T-1.2.1.2: Generate Composite Risk Score">
        <bpmn:documentation>Generate composite risk score (0-100) and preliminary tier assignment (Critical/High/Medium/Low).
Executes: DMN-DT-001 (Risk Tier Classification) | Hit Policy: Priority
Actor: AI Risk Agent | SLA: &lt; 1 minute</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_T1213" name="T-1.2.1.3: Flag Regulatory Triggers">
        <bpmn:documentation>Flag any regulatory triggers: GDPR, HIPAA, PCI-DSS, SOX, AI Act based on data and domain classification.
Executes: DMN-DT-007 (Regulatory Applicability) | Hit Policy: Collect (C+)
Actor: AI Compliance Agent | SLA: &lt; 1 minute</bpmn:documentation>
      </bpmn:serviceTask>

      <!-- A-1.2.2: Human Review of AI Triage -->
      <bpmn:userTask id="Task_T1221" name="T-1.2.2.1: Review AI Risk Scoring">
        <bpmn:documentation>Governance analyst reviews AI risk scoring with supporting rationale.
Actor: Governance Analyst | SLA: 2-4 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T1222" name="T-1.2.2.2: Validate/Override AI Tier">
        <bpmn:documentation>Validate or override AI tier assignment with documented justification.
Actor: Governance Analyst | SLA: Included in T-1.2.2.1</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T1223" name="T-1.2.2.3: Escalate Low-Confidence Triage">
        <bpmn:documentation>If AI confidence &lt; 85%: escalate to Senior Governance Lead for second opinion.
Actor: Sr. Governance Lead | SLA: 4 hours
BLIND SPOT ADDRESSED: Added confidence threshold check as exclusive gateway</bpmn:documentation>
      </bpmn:userTask>

      <!-- Confidence Check Gateway (Blind spot: making this explicit) -->
      <bpmn:exclusiveGateway id="GW_Confidence" name="AI Confidence ≥ 85%?">
        <bpmn:documentation>BLIND SPOT ADDRESSED: Explicit gateway for AI confidence threshold check.
If confidence ≥ 85%, proceed directly to pathway determination.
If confidence &lt; 85%, escalate to Sr. Governance Lead.</bpmn:documentation>
      </bpmn:exclusiveGateway>

      <!-- A-1.2.3: Pathway Determination -->
      <bpmn:businessRuleTask id="Task_T1231" name="T-1.2.3.1: Execute DMN-DT-002 (Pathway)">
        <bpmn:documentation>Execute DMN-DT-002 (Pathway Determination) based on confirmed risk tier, initiative type, and regulatory flags.
Actor: System (DMN Engine) | SLA: &lt; 5 seconds | Hit Policy: Unique (U)</bpmn:documentation>
      </bpmn:businessRuleTask>
      <bpmn:serviceTask id="Task_T1232" name="T-1.2.3.2: Assign Governance Pathway">
        <bpmn:documentation>Assign governance pathway: Express (Low), Standard, Enhanced (High), Full (Critical).
Actor: System (DMN Engine) | SLA: &lt; 5 seconds</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_T1233" name="T-1.2.3.3: Generate Phase 2 Scope Matrix">
        <bpmn:documentation>Generate Phase 2 assessment scope matrix based on pathway.
Actor: System (Automated) | SLA: &lt; 30 seconds
Output: Assessment Scope Matrix (data object)</bpmn:documentation>
      </bpmn:serviceTask>

      <bpmn:endEvent id="End_SP12" name="Risk Tier &amp; Pathway Assigned" />

      <!-- SP-1.2 Internal Flows -->
      <bpmn:sequenceFlow id="Flow_SP12_1" sourceRef="Start_SP12" targetRef="Task_T1211" />
      <bpmn:sequenceFlow id="Flow_SP12_2" sourceRef="Task_T1211" targetRef="Task_T1212" />
      <bpmn:sequenceFlow id="Flow_SP12_3" sourceRef="Task_T1212" targetRef="Task_T1213" />
      <bpmn:sequenceFlow id="Flow_SP12_4" sourceRef="Task_T1213" targetRef="Task_T1221" />
      <bpmn:sequenceFlow id="Flow_SP12_5" sourceRef="Task_T1221" targetRef="Task_T1222" />
      <bpmn:sequenceFlow id="Flow_SP12_6" sourceRef="Task_T1222" targetRef="GW_Confidence" />
      <bpmn:sequenceFlow id="Flow_SP12_7a" name="Confidence ≥ 85%" sourceRef="GW_Confidence" targetRef="Task_T1231" />
      <bpmn:sequenceFlow id="Flow_SP12_7b" name="Confidence &lt; 85%" sourceRef="GW_Confidence" targetRef="Task_T1223" />
      <bpmn:sequenceFlow id="Flow_SP12_7c" sourceRef="Task_T1223" targetRef="Task_T1231" />
      <bpmn:sequenceFlow id="Flow_SP12_8" sourceRef="Task_T1231" targetRef="Task_T1232" />
      <bpmn:sequenceFlow id="Flow_SP12_9" sourceRef="Task_T1232" targetRef="Task_T1233" />
      <bpmn:sequenceFlow id="Flow_SP12_10" sourceRef="Task_T1233" targetRef="End_SP12" />
    </bpmn:subProcess>

    <!-- SLA Timers on SP-1.2 -->
    <bpmn:boundaryEvent id="Timer_SP12_50" name="SLA 50% (4h)" attachedToRef="SP_1_2" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>PT4H</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Timer_SP12_100" name="SLA Breach (8h)" attachedToRef="SP_1_2" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>PT8H</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- GW-1.2: Post-Triage Routing -->
    <bpmn:exclusiveGateway id="GW_1_2" name="GW-1.2: Risk Tier Pathway Routing">
      <bpmn:documentation>Gateway ID: GW-1.2 | Type: Exclusive (XOR) | Location: After SP-1.2
Low Risk → Express pathway (skip detailed business case to Phase 2)
Medium/High/Critical → proceed to SP-1.3 (Business Case Evaluation)</bpmn:documentation>
      <bpmn:incoming>Flow_SP12_GW12</bpmn:incoming>
      <bpmn:outgoing>Flow_GW12_SP13</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW12_Express</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ============================================================== -->
    <!-- SP-1.3: Business Case Evaluation | SLA: 1-2 days               -->
    <!-- ============================================================== -->
    <bpmn:subProcess id="SP_1_3" name="SP-1.3: Business Case Evaluation">
      <bpmn:documentation>Sub-Process ID: SP-1.3 | SLA: 1-2 business days
Lane: Governance Pool + Requestor Pool
Activities: Strategic Alignment Review, Financial Viability Assessment, Initiation Gate Decision
DMN Table: DMN-DT-003 (Governance Gate Decision)</bpmn:documentation>
      <bpmn:incoming>Flow_GW12_SP13</bpmn:incoming>
      <bpmn:outgoing>Flow_SP13_GW13</bpmn:outgoing>

      <bpmn:startEvent id="Start_SP13" name="Business Case Review Initiated" />

      <!-- A-1.3.1: Strategic Alignment Review -->
      <bpmn:userTask id="Task_T1311" name="T-1.3.1.1: Map to Strategic Objectives">
        <bpmn:documentation>Map initiative to enterprise strategic objectives and portfolio priorities.
Actor: Portfolio Manager | SLA: 4 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T1312" name="T-1.3.1.2: Score Strategic Alignment">
        <bpmn:documentation>Score strategic alignment (1-5 scale) across 4 dimensions: revenue impact, operational efficiency, risk reduction, innovation.
Actor: Portfolio Manager | SLA: Included</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T1313" name="T-1.3.1.3: Identify Portfolio Dependencies">
        <bpmn:documentation>Identify portfolio conflicts, dependencies, and synergies with existing initiatives.
Actor: Portfolio Manager | SLA: Included</bpmn:documentation>
      </bpmn:userTask>

      <!-- A-1.3.2: Financial Viability Assessment -->
      <bpmn:userTask id="Task_T1321" name="T-1.3.2.1: Validate Budget &amp; Funding">
        <bpmn:documentation>Validate estimated budget against portfolio allocation and funding availability.
Actor: Finance Analyst | SLA: 4 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T1322" name="T-1.3.2.2: Calculate Preliminary ROI">
        <bpmn:documentation>Calculate preliminary ROI using standard model (NPV, IRR, payback period).
Actor: Finance Analyst | SLA: Included</bpmn:documentation>
      </bpmn:userTask>

      <!-- A-1.3.3: Initiation Gate Decision -->
      <bpmn:businessRuleTask id="Task_T1331" name="T-1.3.3.1: Execute DMN-DT-003 (Gate Decision)">
        <bpmn:documentation>Execute DMN-DT-003 (Governance Gate Decision): Approve / Conditional Approve / Defer / Reject.
Hit Policy: Priority (P)
Actor: DMN Engine + Governance Board | SLA: &lt; 5 sec (engine) + 1 day (board review for Critical)</bpmn:documentation>
      </bpmn:businessRuleTask>
      <bpmn:task id="Task_T1332" name="T-1.3.3.2: Generate Phase 2 Work Order">
        <bpmn:documentation>If approved: generate Phase 2 work order with scope matrix.
If conditional: return to requestor with conditions.
If deferred: schedule re-review. If rejected: archive with rationale.
Actor: System / Governance Board | SLA: Immediate (system) / 1 day (board)</bpmn:documentation>
      </bpmn:task>

      <bpmn:endEvent id="End_SP13" name="Gate Decision Rendered" />

      <!-- SP-1.3 Internal Flows -->
      <bpmn:sequenceFlow id="Flow_SP13_1" sourceRef="Start_SP13" targetRef="Task_T1311" />
      <bpmn:sequenceFlow id="Flow_SP13_2" sourceRef="Task_T1311" targetRef="Task_T1312" />
      <bpmn:sequenceFlow id="Flow_SP13_3" sourceRef="Task_T1312" targetRef="Task_T1313" />
      <bpmn:sequenceFlow id="Flow_SP13_4" sourceRef="Task_T1313" targetRef="Task_T1321" />
      <bpmn:sequenceFlow id="Flow_SP13_5" sourceRef="Task_T1321" targetRef="Task_T1322" />
      <bpmn:sequenceFlow id="Flow_SP13_6" sourceRef="Task_T1322" targetRef="Task_T1331" />
      <bpmn:sequenceFlow id="Flow_SP13_7" sourceRef="Task_T1331" targetRef="Task_T1332" />
      <bpmn:sequenceFlow id="Flow_SP13_8" sourceRef="Task_T1332" targetRef="End_SP13" />
    </bpmn:subProcess>

    <!-- SLA Timers on SP-1.3 -->
    <bpmn:boundaryEvent id="Timer_SP13_50" name="SLA 50% (8h)" attachedToRef="SP_1_3" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>PT8H</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Timer_SP13_100" name="SLA Breach (16h)" attachedToRef="SP_1_3" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>PT16H</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- GW-1.3: Post-Gate Decision -->
    <bpmn:exclusiveGateway id="GW_1_3" name="GW-1.3: Initiation Gate Decision">
      <bpmn:documentation>Gateway ID: GW-1.3 | Type: Exclusive (XOR) | Location: After SP-1.3
Approved → Phase 2 | Conditional → loop to Requestor | Deferred → Backlog | Rejected → Archive</bpmn:documentation>
      <bpmn:incoming>Flow_SP13_GW13</bpmn:incoming>
      <bpmn:outgoing>Flow_GW13_Phase2</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW13_Conditional</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW13_Deferred</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW13_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Deferred and Rejected End Events -->
    <bpmn:endEvent id="End_Deferred" name="Initiative Deferred to Backlog">
      <bpmn:incoming>Flow_GW13_Deferred</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Rejected" name="Initiative Rejected &amp; Archived">
      <bpmn:incoming>Flow_GW13_Rejected</bpmn:incoming>
      <bpmn:incoming>Flow_GW24_Rejected</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ================================================================ -->
    <!-- PHASE 2: ASSESSMENT & CLASSIFICATION (PRC-PH2-001)               -->
    <!-- Phase SLA: 5-10 days (Standard) | 2-3 (Express) | 10-15 (Full)  -->
    <!-- ================================================================ -->

    <!-- GW-2.1: Parallel Split into Assessment Tracks -->
    <bpmn:parallelGateway id="GW_2_1" name="GW-2.1: Parallel Assessment Split">
      <bpmn:documentation>Gateway ID: GW-2.1 | Type: Parallel (AND-split)
Splits into parallel assessment tracks: SP-2.1 (Technical), SP-2.2 (Security), SP-2.3 (Vendor, conditional), SP-2.4 (Compliance)</bpmn:documentation>
      <bpmn:incoming>Flow_GW13_Phase2</bpmn:incoming>
      <bpmn:incoming>Flow_GW12_Express</bpmn:incoming>
      <bpmn:outgoing>Flow_GW21_SP21</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW21_SP22</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW21_GW22</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW21_SP24</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- ============================================================== -->
    <!-- SP-2.1: Technical Assessment | SLA: 3-5 days (Standard)        -->
    <!-- ============================================================== -->
    <bpmn:subProcess id="SP_2_1" name="SP-2.1: Technical Assessment">
      <bpmn:documentation>Sub-Process ID: SP-2.1 | SLA: 3-5 business days (Standard) | 1-2 days (Express)
Lane: Technical Pool - Architecture Lane
Activities: Architecture Compatibility Review, Infrastructure Requirements, Technology Stack Validation
DMN Table: DMN-DT-004 (Technology Approval Decision)</bpmn:documentation>
      <bpmn:incoming>Flow_GW21_SP21</bpmn:incoming>
      <bpmn:outgoing>Flow_SP21_GW23</bpmn:outgoing>

      <bpmn:startEvent id="Start_SP21" />
      <bpmn:userTask id="Task_T2111" name="T-2.1.1.1: Evaluate Architecture Compatibility">
        <bpmn:documentation>Evaluate proposed solution against enterprise reference architecture patterns and standards.
Actor: Enterprise Architect | SLA: 1 day | Reads: KB-004</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T2112" name="T-2.1.1.2: Identify Integration Touchpoints">
        <bpmn:documentation>Identify integration touchpoints with existing systems (API contracts, data flows, event streams).
Actor: Integration Architect | SLA: 1 day | Reads: CMDB (DI-003)</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:serviceTask id="Task_T2113" name="T-2.1.1.3: AI Architecture Compatibility Score">
        <bpmn:documentation>AI Architecture Agent generates compatibility score and flags deviations from standards.
Actor: AI Architecture Agent | SLA: &lt; 5 minutes</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:userTask id="Task_T2121" name="T-2.1.2.1: Define Infrastructure Requirements">
        <bpmn:documentation>Define compute, storage, network, and platform requirements.
Actor: Cloud Engineer | SLA: 4 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T2122" name="T-2.1.2.2: Capacity Planning &amp; Cost Projection">
        <bpmn:documentation>Capacity planning and cost projection for target deployment model.
Actor: FinOps Analyst | SLA: 4 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T2131" name="T-2.1.3.1: Validate Technology Stack">
        <bpmn:documentation>Validate proposed technologies against approved technology radar and lifecycle status.
Actor: Enterprise Architect | SLA: 2 hours | Reads: KB-002</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:businessRuleTask id="Task_T2132" name="T-2.1.3.2: Execute DMN-DT-004 (Tech Approval)">
        <bpmn:documentation>Execute DMN-DT-004 (Technology Approval Decision) for any non-standard technology requests.
Hit Policy: Unique (U) | Actor: DMN Engine | SLA: &lt; 5 seconds</bpmn:documentation>
      </bpmn:businessRuleTask>
      <bpmn:endEvent id="End_SP21" />

      <bpmn:sequenceFlow id="f_sp21_1" sourceRef="Start_SP21" targetRef="Task_T2111" />
      <bpmn:sequenceFlow id="f_sp21_2" sourceRef="Task_T2111" targetRef="Task_T2112" />
      <bpmn:sequenceFlow id="f_sp21_3" sourceRef="Task_T2112" targetRef="Task_T2113" />
      <bpmn:sequenceFlow id="f_sp21_4" sourceRef="Task_T2113" targetRef="Task_T2121" />
      <bpmn:sequenceFlow id="f_sp21_5" sourceRef="Task_T2121" targetRef="Task_T2122" />
      <bpmn:sequenceFlow id="f_sp21_6" sourceRef="Task_T2122" targetRef="Task_T2131" />
      <bpmn:sequenceFlow id="f_sp21_7" sourceRef="Task_T2131" targetRef="Task_T2132" />
      <bpmn:sequenceFlow id="f_sp21_8" sourceRef="Task_T2132" targetRef="End_SP21" />
    </bpmn:subProcess>

    <!-- SLA Timers on SP-2.1 -->
    <bpmn:boundaryEvent id="Timer_SP21_50" name="SLA 50% (2.5d)" attachedToRef="SP_2_1" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P2DT12H</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Timer_SP21_100" name="SLA Breach (5d)" attachedToRef="SP_2_1" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P5D</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- ============================================================== -->
    <!-- SP-2.2: Security Assessment | SLA: 3-7 days (Standard)         -->
    <!-- ============================================================== -->
    <bpmn:subProcess id="SP_2_2" name="SP-2.2: Security Assessment">
      <bpmn:documentation>Sub-Process ID: SP-2.2 | SLA: 3-7 business days (Standard) | 1-2 days (Express) | 7-10 days (Critical)
Lane: Technical Pool - Security Lane
Activities: Threat Modeling, Data Classification &amp; Privacy, Security Controls Mapping
DMN Table: DMN-DT-005 (Security Controls Mapping)</bpmn:documentation>
      <bpmn:incoming>Flow_GW21_SP22</bpmn:incoming>
      <bpmn:outgoing>Flow_SP22_GW23</bpmn:outgoing>

      <bpmn:startEvent id="Start_SP22" />
      <bpmn:userTask id="Task_T2211" name="T-2.2.1.1: STRIDE Threat Modeling">
        <bpmn:documentation>Identify threat actors, attack vectors, and attack surfaces using STRIDE methodology.
Actor: Security Architect | SLA: 1-2 days</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:serviceTask id="Task_T2212" name="T-2.2.1.2: AI Threat Model Generation">
        <bpmn:documentation>AI Threat Agent auto-generates initial threat model based on architecture patterns and data classification.
Actor: AI Security Agent | SLA: &lt; 10 minutes</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:userTask id="Task_T2213" name="T-2.2.1.3: Human Threat Model Review">
        <bpmn:documentation>Human review and augmentation of AI-generated threat model.
Actor: Security Architect | SLA: 4 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T2221" name="T-2.2.2.1: Data Element Classification">
        <bpmn:documentation>Classify all data elements per enterprise data classification schema (Public, Internal, Confidential, Restricted).
Actor: Data Privacy Officer | SLA: 1 day | Reads: KB-001</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T2222" name="T-2.2.2.2: DPIA Execution (if PII)">
        <bpmn:documentation>Execute Data Protection Impact Assessment (DPIA) if personal data is involved.
Actor: Data Privacy Officer | SLA: 1-2 days</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:businessRuleTask id="Task_T2231" name="T-2.2.3.1: Execute DMN-DT-005 (Controls)">
        <bpmn:documentation>Map required security controls based on risk tier and data classification using DMN-DT-005.
Hit Policy: Collect (C+) | Actor: DMN Engine + Security Analyst | SLA: &lt; 1 hour | Reads: KB-006</bpmn:documentation>
      </bpmn:businessRuleTask>
      <bpmn:userTask id="Task_T2232" name="T-2.2.3.2: Define Security Requirements">
        <bpmn:documentation>Define authentication, authorization, encryption, logging, and monitoring requirements.
Actor: Security Analyst | SLA: 4 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:endEvent id="End_SP22" />

      <bpmn:sequenceFlow id="f_sp22_1" sourceRef="Start_SP22" targetRef="Task_T2211" />
      <bpmn:sequenceFlow id="f_sp22_2" sourceRef="Task_T2211" targetRef="Task_T2212" />
      <bpmn:sequenceFlow id="f_sp22_3" sourceRef="Task_T2212" targetRef="Task_T2213" />
      <bpmn:sequenceFlow id="f_sp22_4" sourceRef="Task_T2213" targetRef="Task_T2221" />
      <bpmn:sequenceFlow id="f_sp22_5" sourceRef="Task_T2221" targetRef="Task_T2222" />
      <bpmn:sequenceFlow id="f_sp22_6" sourceRef="Task_T2222" targetRef="Task_T2231" />
      <bpmn:sequenceFlow id="f_sp22_7" sourceRef="Task_T2231" targetRef="Task_T2232" />
      <bpmn:sequenceFlow id="f_sp22_8" sourceRef="Task_T2232" targetRef="End_SP22" />
    </bpmn:subProcess>

    <!-- SLA Timers on SP-2.2 -->
    <bpmn:boundaryEvent id="Timer_SP22_50" name="SLA 50% (3.5d)" attachedToRef="SP_2_2" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P3DT12H</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Timer_SP22_100" name="SLA Breach (7d)" attachedToRef="SP_2_2" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P7D</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- GW-2.2: Vendor Assessment Conditional Gateway -->
    <bpmn:inclusiveGateway id="GW_2_2" name="GW-2.2: Vendor Involvement Check">
      <bpmn:documentation>Gateway ID: GW-2.2 | Type: Inclusive (OR)
Vendor assessment activated if third-party software/services detected; skipped otherwise.</bpmn:documentation>
      <bpmn:incoming>Flow_GW21_GW22</bpmn:incoming>
      <bpmn:outgoing>Flow_GW22_SP23</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW22_Skip</bpmn:outgoing>
    </bpmn:inclusiveGateway>

    <!-- ============================================================== -->
    <!-- SP-2.3: Vendor Assessment (Conditional) | SLA: 5-10 days       -->
    <!-- ============================================================== -->
    <bpmn:subProcess id="SP_2_3" name="SP-2.3: Vendor Assessment (Conditional)">
      <bpmn:documentation>Sub-Process ID: SP-2.3 | Condition: Activated only when third-party software/services involved
SLA: 5-10 business days (Standard) | 10-15 days (Critical Vendor)
Lane: Vendor Pool + Governance Pool
DMN Table: DMN-DT-006 (Vendor Risk Classification)</bpmn:documentation>
      <bpmn:incoming>Flow_GW22_SP23</bpmn:incoming>
      <bpmn:outgoing>Flow_SP23_GW23</bpmn:outgoing>

      <bpmn:startEvent id="Start_SP23" />
      <bpmn:businessRuleTask id="Task_T2311" name="T-2.3.1.1: Execute DMN-DT-006 (Vendor Tier)">
        <bpmn:documentation>Execute four-tier vendor classification: Critical, High, Medium, Low based on DMN-DT-006.
Hit Policy: Priority (P) | Actor: DMN Engine + TPRM Analyst | SLA: 4 hours | Reads: KB-005</bpmn:documentation>
      </bpmn:businessRuleTask>
      <bpmn:userTask id="Task_T2312" name="T-2.3.1.2: Quantitative Risk Scoring (8 Domains)">
        <bpmn:documentation>Quantitative risk scoring across 8 domains: financial stability, security posture, compliance, operational resilience, geographic risk, concentration risk, technology maturity, reputation.
Actor: TPRM Analyst + AI Risk Agent | SLA: 1-2 days</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T2321" name="T-2.3.2.1: Vendor Security Questionnaire (SIG/CAIQ)">
        <bpmn:documentation>Collect and validate vendor security questionnaire (SIG/CAIQ).
Actor: Vendor + TPRM Analyst | SLA: 3-5 days</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T2322" name="T-2.3.2.2: Review Compliance Certifications">
        <bpmn:documentation>Review SOC 2 Type II, ISO 27001, and relevant compliance certifications.
Actor: TPRM Analyst | SLA: 1 day</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T2323" name="T-2.3.2.3: Fourth-Party Risk Assessment">
        <bpmn:documentation>Fourth-party risk assessment: identify and evaluate vendor's critical sub-processors.
Actor: TPRM Analyst | SLA: 1 day
BLIND SPOT ADDRESSED: Added explicit sub-processor data flow tracking</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T2331" name="T-2.3.3.1: Contract Terms Review">
        <bpmn:documentation>Review contract terms against enterprise requirements (data ownership, exit provisions, SLAs, liability).
Actor: Legal / Procurement | SLA: 2-3 days</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T2332" name="T-2.3.3.2: Negotiate &amp; Finalize SLAs">
        <bpmn:documentation>Negotiate and finalize SLA terms with vendor.
Actor: Procurement Manager | SLA: Variable</bpmn:documentation>
      </bpmn:userTask>
      <!-- BLIND SPOT: Exit Strategy Validation -->
      <bpmn:userTask id="Task_T2333_BS" name="T-2.3.3.3: Validate Exit Strategy &amp; Data Portability">
        <bpmn:documentation>BLIND SPOT ADDRESSED: Validate vendor exit strategy, data portability plan, and transition SLAs.
Ensures data can be extracted in standard formats and services can be transitioned within defined timelines.
Actor: Enterprise Architect + Legal | SLA: 1 day</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:endEvent id="End_SP23" />

      <bpmn:sequenceFlow id="f_sp23_1" sourceRef="Start_SP23" targetRef="Task_T2311" />
      <bpmn:sequenceFlow id="f_sp23_2" sourceRef="Task_T2311" targetRef="Task_T2312" />
      <bpmn:sequenceFlow id="f_sp23_3" sourceRef="Task_T2312" targetRef="Task_T2321" />
      <bpmn:sequenceFlow id="f_sp23_4" sourceRef="Task_T2321" targetRef="Task_T2322" />
      <bpmn:sequenceFlow id="f_sp23_5" sourceRef="Task_T2322" targetRef="Task_T2323" />
      <bpmn:sequenceFlow id="f_sp23_6" sourceRef="Task_T2323" targetRef="Task_T2331" />
      <bpmn:sequenceFlow id="f_sp23_7" sourceRef="Task_T2331" targetRef="Task_T2332" />
      <bpmn:sequenceFlow id="f_sp23_8" sourceRef="Task_T2332" targetRef="Task_T2333_BS" />
      <bpmn:sequenceFlow id="f_sp23_9" sourceRef="Task_T2333_BS" targetRef="End_SP23" />
    </bpmn:subProcess>

    <!-- SLA Timers on SP-2.3 -->
    <bpmn:boundaryEvent id="Timer_SP23_50" name="SLA 50% (5d)" attachedToRef="SP_2_3" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P5D</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Timer_SP23_100" name="SLA Breach (10d)" attachedToRef="SP_2_3" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P10D</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- ============================================================== -->
    <!-- SP-2.4: Compliance Assessment | SLA: 3-5 days                  -->
    <!-- ============================================================== -->
    <bpmn:subProcess id="SP_2_4" name="SP-2.4: Compliance Assessment">
      <bpmn:documentation>Sub-Process ID: SP-2.4 | SLA: 3-5 business days | Lane: Governance Pool
Activities: Regulatory Mapping, Compliance Gap Analysis, AI Governance Assessment
DMN Table: DMN-DT-007 (Regulatory Applicability Mapping)</bpmn:documentation>
      <bpmn:incoming>Flow_GW21_SP24</bpmn:incoming>
      <bpmn:outgoing>Flow_SP24_GW23</bpmn:outgoing>

      <bpmn:startEvent id="Start_SP24" />
      <bpmn:businessRuleTask id="Task_T2411" name="T-2.4.1.1: Execute DMN-DT-007 (Regulatory Map)">
        <bpmn:documentation>Identify applicable regulations based on data types, geographies, and industry verticals using DMN-DT-007.
Hit Policy: Collect (C+) | Actor: DMN Engine + Compliance Analyst | SLA: 4 hours | Reads: KB-003</bpmn:documentation>
      </bpmn:businessRuleTask>
      <bpmn:userTask id="Task_T2412" name="T-2.4.1.2: Map Regulatory Control Obligations">
        <bpmn:documentation>Map regulatory requirements to specific control obligations.
Actor: Compliance Analyst | SLA: 1 day</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T2421" name="T-2.4.2.1: Assess Control Coverage Gaps">
        <bpmn:documentation>Assess current control coverage against required controls.
Actor: Compliance Analyst | SLA: 1-2 days</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T2422" name="T-2.4.2.2: Generate Remediation Plan">
        <bpmn:documentation>Generate remediation plan for identified gaps with effort estimates.
Actor: Compliance Analyst | SLA: Included</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T2431" name="T-2.4.3.1: AI Risk Classification (EU AI Act)">
        <bpmn:documentation>If AI/ML components present: execute AI risk classification per EU AI Act risk tiers (Unacceptable, High, Limited, Minimal).
Actor: AI Ethics Officer | SLA: 1 day</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T2432" name="T-2.4.3.2: Define AI Governance Requirements">
        <bpmn:documentation>Define model governance requirements: explainability, bias testing, human oversight, monitoring.
Actor: AI Ethics Officer | SLA: Included | Reads: KB-008</bpmn:documentation>
      </bpmn:userTask>
      <!-- BLIND SPOT: Cross-border data transfer assessment -->
      <bpmn:userTask id="Task_T2433_BS" name="T-2.4.3.3: Cross-Border Data Transfer Assessment">
        <bpmn:documentation>BLIND SPOT ADDRESSED: Assess cross-border data transfer requirements including adequacy decisions, SCCs, BCRs, and data localization mandates.
Actor: Data Privacy Officer + Legal | SLA: 1 day</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:endEvent id="End_SP24" />

      <bpmn:sequenceFlow id="f_sp24_1" sourceRef="Start_SP24" targetRef="Task_T2411" />
      <bpmn:sequenceFlow id="f_sp24_2" sourceRef="Task_T2411" targetRef="Task_T2412" />
      <bpmn:sequenceFlow id="f_sp24_3" sourceRef="Task_T2412" targetRef="Task_T2421" />
      <bpmn:sequenceFlow id="f_sp24_4" sourceRef="Task_T2421" targetRef="Task_T2422" />
      <bpmn:sequenceFlow id="f_sp24_5" sourceRef="Task_T2422" targetRef="Task_T2431" />
      <bpmn:sequenceFlow id="f_sp24_6" sourceRef="Task_T2431" targetRef="Task_T2432" />
      <bpmn:sequenceFlow id="f_sp24_7" sourceRef="Task_T2432" targetRef="Task_T2433_BS" />
      <bpmn:sequenceFlow id="f_sp24_8" sourceRef="Task_T2433_BS" targetRef="End_SP24" />
    </bpmn:subProcess>

    <!-- SLA Timers on SP-2.4 -->
    <bpmn:boundaryEvent id="Timer_SP24_50" name="SLA 50% (2.5d)" attachedToRef="SP_2_4" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P2DT12H</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Timer_SP24_100" name="SLA Breach (5d)" attachedToRef="SP_2_4" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P5D</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- GW-2.3: Parallel Join (All assessments must complete) -->
    <bpmn:parallelGateway id="GW_2_3" name="GW-2.3: Assessment Convergence (AND-join)">
      <bpmn:documentation>Gateway ID: GW-2.3 | Type: Parallel (AND-join)
All active assessment tracks must complete before convergence to SP-2.5.</bpmn:documentation>
      <bpmn:incoming>Flow_SP21_GW23</bpmn:incoming>
      <bpmn:incoming>Flow_SP22_GW23</bpmn:incoming>
      <bpmn:incoming>Flow_SP23_GW23</bpmn:incoming>
      <bpmn:incoming>Flow_GW22_Skip</bpmn:incoming>
      <bpmn:incoming>Flow_SP24_GW23</bpmn:incoming>
      <bpmn:outgoing>Flow_GW23_SP25</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- ============================================================== -->
    <!-- SP-2.5: Assessment Convergence & Gate Decision | SLA: 1-2 days -->
    <!-- ============================================================== -->
    <bpmn:subProcess id="SP_2_5" name="SP-2.5: Assessment Convergence &amp; Gate Decision">
      <bpmn:documentation>Sub-Process ID: SP-2.5 | SLA: 1-2 business days | Lane: Governance Pool
Synthesizes all assessment findings and executes Phase 2 gate decision.
DMN Table: DMN-DT-003 (Governance Gate Decision)</bpmn:documentation>
      <bpmn:incoming>Flow_GW23_SP25</bpmn:incoming>
      <bpmn:outgoing>Flow_SP25_GW24</bpmn:outgoing>

      <bpmn:startEvent id="Start_SP25" />
      <bpmn:userTask id="Task_T2511" name="T-2.5.1.1: Consolidate Assessment Findings">
        <bpmn:documentation>Consolidate findings from all assessment tracks into unified risk and readiness report.
Actor: Governance Analyst | SLA: 4 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T2512" name="T-2.5.1.2: Finalize Risk Classification">
        <bpmn:documentation>Finalize risk classification with composite score incorporating all assessment dimensions.
Actor: Governance Analyst | SLA: 2 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:serviceTask id="Task_T2513" name="T-2.5.1.3: Generate Onboarding Checklist">
        <bpmn:documentation>Generate onboarding requirements checklist based on assessment outcomes.
Actor: System (Automated) | SLA: &lt; 5 minutes</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:userTask id="Task_T2521" name="T-2.5.2.1: Present to Governance Board">
        <bpmn:documentation>Present consolidated assessment to Governance Board (Critical/High risk) or delegated authority (Medium/Low).
Actor: Governance Board / Delegate | SLA: 1 day (Critical) / 4 hours (Standard)</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:businessRuleTask id="Task_T2522" name="T-2.5.2.2: Execute DMN-DT-003 (Phase 2 Gate)">
        <bpmn:documentation>Execute DMN-DT-003: Approve to Onboard / Conditional / Remediate / Reject.
Hit Policy: Priority (P) | Actor: DMN Engine + Governance Board | SLA: &lt; 5 seconds (engine)</bpmn:documentation>
      </bpmn:businessRuleTask>
      <bpmn:userTask id="Task_T2523" name="T-2.5.2.3: Generate Phase 3 Onboarding Plan">
        <bpmn:documentation>Generate Phase 3 onboarding plan with resource allocation, timeline, and provisioning scope.
Actor: System / Project Manager | SLA: 4 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:endEvent id="End_SP25" />

      <bpmn:sequenceFlow id="f_sp25_1" sourceRef="Start_SP25" targetRef="Task_T2511" />
      <bpmn:sequenceFlow id="f_sp25_2" sourceRef="Task_T2511" targetRef="Task_T2512" />
      <bpmn:sequenceFlow id="f_sp25_3" sourceRef="Task_T2512" targetRef="Task_T2513" />
      <bpmn:sequenceFlow id="f_sp25_4" sourceRef="Task_T2513" targetRef="Task_T2521" />
      <bpmn:sequenceFlow id="f_sp25_5" sourceRef="Task_T2521" targetRef="Task_T2522" />
      <bpmn:sequenceFlow id="f_sp25_6" sourceRef="Task_T2522" targetRef="Task_T2523" />
      <bpmn:sequenceFlow id="f_sp25_7" sourceRef="Task_T2523" targetRef="End_SP25" />
    </bpmn:subProcess>

    <!-- SLA Timers on SP-2.5 -->
    <bpmn:boundaryEvent id="Timer_SP25_50" name="SLA 50% (1d)" attachedToRef="SP_2_5" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P1D</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Timer_SP25_100" name="SLA Breach (2d)" attachedToRef="SP_2_5" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P2D</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- GW-2.4: Phase 2 Gate Decision Routing -->
    <bpmn:exclusiveGateway id="GW_2_4" name="GW-2.4: Phase 2 Gate Decision">
      <bpmn:documentation>Gateway ID: GW-2.4 | Type: Exclusive (XOR)
Approved → Phase 3 | Conditional → remediation loop | Remediate → return to specific assessment | Reject → Archive</bpmn:documentation>
      <bpmn:incoming>Flow_SP25_GW24</bpmn:incoming>
      <bpmn:outgoing>Flow_GW24_Phase3</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW24_Remediate</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW24_Rejected</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW24_Conditional</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ================================================================ -->
    <!-- PHASE 3: ONBOARDING & PROVISIONING (PRC-PH3-001)                 -->
    <!-- Phase SLA: 10-20 days (Standard) | 5-8 (Express) | 15-25 (Crit) -->
    <!-- ================================================================ -->

    <!-- GW-3.1: Parallel Provisioning Split -->
    <bpmn:parallelGateway id="GW_3_1" name="GW-3.1: Parallel Provisioning Split">
      <bpmn:documentation>Gateway ID: GW-3.1 | Type: Parallel (AND-split)
SP-3.1, SP-3.2, SP-3.3, SP-3.4 execute concurrently.</bpmn:documentation>
      <bpmn:incoming>Flow_GW24_Phase3</bpmn:incoming>
      <bpmn:outgoing>Flow_GW31_SP31</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW31_SP32</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW31_SP33</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW31_SP34</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- ============================================================== -->
    <!-- SP-3.1: Environment Provisioning | SLA: 2-5 days (automated)   -->
    <!-- ============================================================== -->
    <bpmn:subProcess id="SP_3_1" name="SP-3.1: Environment Provisioning">
      <bpmn:documentation>Sub-Process ID: SP-3.1 | SLA: 2-5 business days (automated) | 5-10 days (complex/hybrid)
Lane: Operations Pool
Activities: Infrastructure Provisioning, Security Infrastructure, Environment Validation</bpmn:documentation>
      <bpmn:incoming>Flow_GW31_SP31</bpmn:incoming>
      <bpmn:outgoing>Flow_SP31_GW33</bpmn:outgoing>

      <bpmn:startEvent id="Start_SP31" />
      <bpmn:serviceTask id="Task_T3111" name="T-3.1.1.1: Execute IaC Templates">
        <bpmn:documentation>Execute Infrastructure-as-Code templates for dev, staging, and production environments.
Actor: AI Deployment Agent / DevOps | SLA: 1-2 hours (automated) | Uses: TP-006</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:userTask id="Task_T3112" name="T-3.1.1.2: Configure Networking">
        <bpmn:documentation>Configure networking: VPC, subnets, security groups, load balancers, DNS per architecture blueprint.
Actor: Cloud Engineer | SLA: 4 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:serviceTask id="Task_T3113" name="T-3.1.1.3: Provision Container Orchestration">
        <bpmn:documentation>Provision Kubernetes namespaces, resource quotas, network policies.
Actor: Platform Engineer | SLA: 2 hours</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:userTask id="Task_T3121" name="T-3.1.2.1: Configure IAM &amp; RBAC">
        <bpmn:documentation>Configure identity and access management: service accounts, RBAC policies, secrets management.
Actor: Security Engineer | SLA: 4 hours | Uses: TP-005</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:serviceTask id="Task_T3122" name="T-3.1.2.2: Deploy Security Monitoring">
        <bpmn:documentation>Deploy security monitoring agents: SIEM integration, log forwarding, vulnerability scanning.
Actor: Security Engineer | SLA: 2 hours | Uses: TP-010</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:userTask id="Task_T3123" name="T-3.1.2.3: Configure Encryption">
        <bpmn:documentation>Configure encryption: TLS certificates, at-rest encryption, key management per data classification.
Actor: Security Engineer | SLA: 2 hours | Uses: DI-004</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:serviceTask id="Task_T3131" name="T-3.1.3.1: Automated Health Checks">
        <bpmn:documentation>Execute automated environment health checks and smoke tests.
Actor: System (Automated) | SLA: 30 minutes</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:userTask id="Task_T3132" name="T-3.1.3.2: Infrastructure Security Validation">
        <bpmn:documentation>Validate security controls are operational (penetration test of infrastructure layer).
Actor: Security Engineer | SLA: 1 day</bpmn:documentation>
      </bpmn:userTask>
      <!-- BLIND SPOT: Disaster Recovery Validation -->
      <bpmn:userTask id="Task_T3133_BS" name="T-3.1.3.3: DR/Backup Configuration Validation">
        <bpmn:documentation>BLIND SPOT ADDRESSED: Validate disaster recovery configuration, backup schedules, RTO/RPO targets, and failover procedures for provisioned environments.
Actor: SRE / Cloud Engineer | SLA: 4 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:endEvent id="End_SP31" />

      <bpmn:sequenceFlow id="f_sp31_1" sourceRef="Start_SP31" targetRef="Task_T3111" />
      <bpmn:sequenceFlow id="f_sp31_2" sourceRef="Task_T3111" targetRef="Task_T3112" />
      <bpmn:sequenceFlow id="f_sp31_3" sourceRef="Task_T3112" targetRef="Task_T3113" />
      <bpmn:sequenceFlow id="f_sp31_4" sourceRef="Task_T3113" targetRef="Task_T3121" />
      <bpmn:sequenceFlow id="f_sp31_5" sourceRef="Task_T3121" targetRef="Task_T3122" />
