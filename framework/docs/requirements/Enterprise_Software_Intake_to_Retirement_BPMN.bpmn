    <!-- ============================================================== -->
    <bpmn:subProcess id="SP_3_4" name="SP-3.4: Data &amp; Integration Onboarding">
      <bpmn:documentation>Sub-Process ID: SP-3.4 | SLA: 3-5 business days
Lane: Technical Pool + Operations Pool
Activities: Data Environment Setup, Integration Configuration, Test Data Provisioning</bpmn:documentation>
      <bpmn:incoming>Flow_GW31_SP34</bpmn:incoming>
      <bpmn:outgoing>Flow_SP34_GW33</bpmn:outgoing>

      <bpmn:startEvent id="Start_SP34" />
      <bpmn:userTask id="Task_T3411" name="T-3.4.1.1: Provision Databases &amp; Data Stores">
