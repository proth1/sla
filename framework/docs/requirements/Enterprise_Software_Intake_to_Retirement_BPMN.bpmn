      <bpmn:sequenceFlow id="f_sp34_6" sourceRef="Task_T3423" targetRef="Task_T3431" />
      <bpmn:sequenceFlow id="f_sp34_7" sourceRef="Task_T3431" targetRef="Task_T3432_BS" />
      <bpmn:sequenceFlow id="f_sp34_8" sourceRef="Task_T3432_BS" targetRef="End_SP34" />
    </bpmn:subProcess>

    <bpmn:boundaryEvent id="Timer_SP34_100" name="SLA Breach (5d)" attachedToRef="SP_3_4" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P5D</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- GW-3.3: Parallel Join (All provisioning complete) -->
    <bpmn:parallelGateway id="GW_3_3" name="GW-3.3: Provisioning Convergence (AND-join)">
      <bpmn:documentation>All provisioning tracks must complete before team onboarding and kickoff.</bpmn:documentation>
      <bpmn:incoming>Flow_SP31_GW33</bpmn:incoming>
      <bpmn:incoming>Flow_SP32_GW33</bpmn:incoming>
      <bpmn:incoming>Flow_SP33_GW33</bpmn:incoming>
      <bpmn:incoming>Flow_SP34_GW33</bpmn:incoming>
      <bpmn:outgoing>Flow_GW33_SP35</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- ============================================================== -->
    <!-- SP-3.5: Team Onboarding & Kickoff | SLA: 2-3 days              -->
    <!-- ============================================================== -->
    <bpmn:subProcess id="SP_3_5" name="SP-3.5: Team Onboarding &amp; Kickoff">
      <bpmn:documentation>Sub-Process ID: SP-3.5 | SLA: 2-3 business days | Lane: All Pools
Activities: Team Formation, Knowledge Transfer, Initiative Kickoff
DMN Table: DMN-DT-003 (Phase 3 Exit Gate)</bpmn:documentation>
      <bpmn:incoming>Flow_GW33_SP35</bpmn:incoming>
      <bpmn:outgoing>Flow_SP35_GW34</bpmn:outgoing>

      <bpmn:startEvent id="Start_SP35" />
      <bpmn:userTask id="Task_T3511" name="T-3.5.1.1: Confirm Team Composition">
        <bpmn:documentation>Confirm team composition: product owner, tech lead, developers, QA, security champion, SRE.
Actor: Resource Manager | SLA: 1 day</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T3512" name="T-3.5.1.2: Assign RACI Matrix">
        <bpmn:documentation>Assign RACI matrix for all governance, development, and operational responsibilities.
Actor: Project Manager | SLA: 4 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T3521" name="T-3.5.2.1: Governance &amp; Compliance Briefing">
        <bpmn:documentation>Conduct governance and compliance briefing: applicable regulations, required controls, SLAs.
Actor: Governance Analyst | SLA: 2 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T3522" name="T-3.5.2.2: Technical Onboarding">
        <bpmn:documentation>Conduct technical onboarding: architecture decisions, standards, toolchain walkthrough.
Actor: Tech Lead / Enterprise Architect | SLA: 4 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T3523" name="T-3.5.2.3: AI Agent Training Session">
        <bpmn:documentation>AI agent training session: how to work with agentic development tools, confidence thresholds, override procedures.
Actor: AI Platform Team | SLA: 2 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T3531" name="T-3.5.3.1: Formal Kickoff Meeting">
        <bpmn:documentation>Formal kickoff meeting: scope review, timeline confirmation, risk register walkthrough, escalation procedures.
Actor: Project Manager + All Stakeholders | SLA: 2 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:businessRuleTask id="Task_T3532" name="T-3.5.3.2: Execute Phase 3 Exit Gate (DMN-DT-003)">
        <bpmn:documentation>Confirm Phase 4 entry criteria are met; execute Phase 3 exit gate via DMN-DT-003.
Actor: DMN Engine + PM | SLA: &lt; 5 seconds (engine)</bpmn:documentation>
      </bpmn:businessRuleTask>
      <!-- BLIND SPOT: Risk register handoff -->
      <bpmn:userTask id="Task_T3533_BS" name="T-3.5.3.3: Risk Register Handoff &amp; Acceptance">
        <bpmn:documentation>BLIND SPOT ADDRESSED: Formal handoff of risk register from governance to project team. Project team acknowledges all open risks, mitigations, and residual risk acceptance.
Actor: Project Manager + Governance Analyst | SLA: 1 hour</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:endEvent id="End_SP35" />

      <bpmn:sequenceFlow id="f_sp35_1" sourceRef="Start_SP35" targetRef="Task_T3511" />
      <bpmn:sequenceFlow id="f_sp35_2" sourceRef="Task_T3511" targetRef="Task_T3512" />
      <bpmn:sequenceFlow id="f_sp35_3" sourceRef="Task_T3512" targetRef="Task_T3521" />
      <bpmn:sequenceFlow id="f_sp35_4" sourceRef="Task_T3521" targetRef="Task_T3522" />
      <bpmn:sequenceFlow id="f_sp35_5" sourceRef="Task_T3522" targetRef="Task_T3523" />
      <bpmn:sequenceFlow id="f_sp35_6" sourceRef="Task_T3523" targetRef="Task_T3531" />
      <bpmn:sequenceFlow id="f_sp35_7" sourceRef="Task_T3531" targetRef="Task_T3532" />
      <bpmn:sequenceFlow id="f_sp35_8" sourceRef="Task_T3532" targetRef="Task_T3533_BS" />
      <bpmn:sequenceFlow id="f_sp35_9" sourceRef="Task_T3533_BS" targetRef="End_SP35" />
    </bpmn:subProcess>

    <bpmn:boundaryEvent id="Timer_SP35_100" name="SLA Breach (3d)" attachedToRef="SP_3_5" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P3D</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- GW-3.4: Phase 3 Exit Gate -->
    <bpmn:exclusiveGateway id="GW_3_4" name="GW-3.4: Phase 3 Exit Gate">
      <bpmn:documentation>All criteria met → Phase 4 | Outstanding items → remediation loop | Critical block → escalate to Governance Board</bpmn:documentation>
      <bpmn:incoming>Flow_SP35_GW34</bpmn:incoming>
      <bpmn:outgoing>Flow_GW34_Phase4</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW34_Remediate</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW34_Escalate</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ================================================================ -->
    <!-- PHASES 4-8: Post-Onboarding Lifecycle (Collapsed Sub-Processes)  -->
    <!-- ================================================================ -->

    <bpmn:subProcess id="SP_Phase4" name="Phase 4: Architecture &amp; Design (PRC-PH4-001)">
      <bpmn:documentation>Process ID: PRC-PH4-001 | SLA: 10-15 business days
Sub-processes: Solution Architecture Design (SP-4.1), Integration Architecture (SP-4.2), Security Architecture (SP-4.3), Data Architecture (SP-4.4), Architecture Review Board Gate (SP-4.5).
ARB gate: Architecture agent generates compliance score; 90% confidence threshold for human validation.</bpmn:documentation>
      <bpmn:incoming>Flow_GW34_Phase4</bpmn:incoming>
      <bpmn:outgoing>Flow_Ph4_Ph5</bpmn:outgoing>
    </bpmn:subProcess>
    <bpmn:boundaryEvent id="Timer_Ph4_100" name="SLA Breach (15d)" attachedToRef="SP_Phase4" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P15D</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:subProcess id="SP_Phase5" name="Phase 5: Development &amp; Build (PRC-PH5-001)">
      <bpmn:documentation>Process ID: PRC-PH5-001 | SLA: Variable (Sprint-based)
Sub-processes: Sprint Planning with AI Agents (SP-5.1), Agentic Development Pipeline (SP-5.2), Code Review with AI Agent (SP-5.3), 7-Stage DevSecOps Pipeline (SP-5.4), 5 Compliance Validation Gates (SP-5.5).
9 specialized AI agent roles operate as BPMN call activities with confidence-based escalation.</bpmn:documentation>
      <bpmn:incoming>Flow_Ph4_Ph5</bpmn:incoming>
      <bpmn:outgoing>Flow_Ph5_Ph6</bpmn:outgoing>
    </bpmn:subProcess>

    <bpmn:subProcess id="SP_Phase6" name="Phase 6: Testing &amp; Validation (PRC-PH6-001)">
      <bpmn:documentation>Process ID: PRC-PH6-001 | SLA: 5-15 business days
Sub-processes: AI-Augmented Test Strategy (SP-6.1), Performance/Load Testing (SP-6.2), Security Validation/Pen Test (SP-6.3), UAT (SP-6.4), Compliance Certification (SP-6.5).</bpmn:documentation>
      <bpmn:incoming>Flow_Ph5_Ph6</bpmn:incoming>
      <bpmn:outgoing>Flow_Ph6_Ph7</bpmn:outgoing>
    </bpmn:subProcess>
    <bpmn:boundaryEvent id="Timer_Ph6_100" name="SLA Breach (15d)" attachedToRef="SP_Phase6" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P15D</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:subProcess id="SP_Phase7" name="Phase 7: Deployment &amp; Release (PRC-PH7-001)">
      <bpmn:documentation>Process ID: PRC-PH7-001 | SLA: 2-5 business days
Sub-processes: Release Readiness Verification (SP-7.1), Deployment Execution (SP-7.2), Production Validation (SP-7.3), Go-Live Gate (SP-7.4).
DMN-DT-009 governs deployment strategy selection based on risk tier, change scope, and production impact.</bpmn:documentation>
      <bpmn:incoming>Flow_Ph6_Ph7</bpmn:incoming>
      <bpmn:outgoing>Flow_Ph7_Ph8</bpmn:outgoing>
    </bpmn:subProcess>
    <bpmn:boundaryEvent id="Timer_Ph7_100" name="SLA Breach (5d)" attachedToRef="SP_Phase7" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P5D</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:subProcess id="SP_Phase8" name="Phase 8: Operations through Retirement (PRC-PH8-001)">
      <bpmn:documentation>Process ID: PRC-PH8-001 | SLA: Ongoing
Sub-processes: Monitoring &amp; Incident Response (SP-8.1), Change Management (SP-8.2), Continuous Improvement Cycles (SP-8.3), Lifecycle Review &amp; Health Assessment (SP-8.4), 6-Phase Vendor and Software Retirement (SP-8.5).
Retirement: Trigger Assessment → Impact Analysis → Migration Planning → Data Archival → Decommissioning → Post-Retirement Validation.</bpmn:documentation>
      <bpmn:incoming>Flow_Ph7_Ph8</bpmn:incoming>
      <bpmn:outgoing>Flow_Ph8_End</bpmn:outgoing>
    </bpmn:subProcess>

    <!-- END EVENT -->
    <bpmn:endEvent id="EndEvent_Retirement" name="Software Asset Fully Decommissioned &amp; Archived">
      <bpmn:incoming>Flow_Ph8_End</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ================================================================ -->
    <!-- CROSS-CUTTING EVENT SUB-PROCESSES                                 -->
    <!-- ================================================================ -->

    <!-- 1. SLA Breach Management -->
    <bpmn:subProcess id="EventSP_SLA_Breach" name="SLA Breach Management" triggeredByEvent="true">
      <bpmn:documentation>Cross-cutting event sub-process: SLA Breach Management
Trigger: Timer Boundary (Non-Interrupting) at 50%, 75%, 90%, 100% thresholds
SLA: Response within 2 hours
Progressive escalation at each threshold level.</bpmn:documentation>
      <bpmn:startEvent id="Start_SLA" name="SLA Threshold Reached" isInterrupting="false">
        <bpmn:timerEventDefinition />
      </bpmn:startEvent>
      <bpmn:exclusiveGateway id="GW_SLA_Level" name="SLA Breach Level?" />
      <bpmn:sendTask id="Task_SLA_50" name="50% Warning: Notify Activity Owner" />
      <bpmn:sendTask id="Task_SLA_75" name="75% Alert: Escalate to Manager" />
      <bpmn:sendTask id="Task_SLA_90" name="90% Critical: Escalate to Governance Lead" />
      <bpmn:task id="Task_SLA_100" name="100% Breach: Formal SLA Breach Record + RCA" />
      <bpmn:endEvent id="End_SLA" />
      <bpmn:sequenceFlow id="f_sla_1" sourceRef="Start_SLA" targetRef="GW_SLA_Level" />
      <bpmn:sequenceFlow id="f_sla_2a" name="50%" sourceRef="GW_SLA_Level" targetRef="Task_SLA_50" />
      <bpmn:sequenceFlow id="f_sla_2b" name="75%" sourceRef="GW_SLA_Level" targetRef="Task_SLA_75" />
      <bpmn:sequenceFlow id="f_sla_2c" name="90%" sourceRef="GW_SLA_Level" targetRef="Task_SLA_90" />
      <bpmn:sequenceFlow id="f_sla_2d" name="100%" sourceRef="GW_SLA_Level" targetRef="Task_SLA_100" />
      <bpmn:sequenceFlow id="f_sla_3a" sourceRef="Task_SLA_50" targetRef="End_SLA" />
      <bpmn:sequenceFlow id="f_sla_3b" sourceRef="Task_SLA_75" targetRef="End_SLA" />
      <bpmn:sequenceFlow id="f_sla_3c" sourceRef="Task_SLA_90" targetRef="End_SLA" />
      <bpmn:sequenceFlow id="f_sla_3d" sourceRef="Task_SLA_100" targetRef="End_SLA" />
    </bpmn:subProcess>

    <!-- 2. Vulnerability Remediation -->
    <bpmn:subProcess id="EventSP_Vuln" name="Vulnerability Remediation" triggeredByEvent="true">
      <bpmn:documentation>Cross-cutting event sub-process: Vulnerability Remediation
Trigger: Signal (Interrupting) - critical vulnerability discovery
SLA: Critical: 4 hours / High: 24 hours
Suspends current activities pending remediation.</bpmn:documentation>
      <bpmn:startEvent id="Start_Vuln" name="Critical Vulnerability Discovered" isInterrupting="true">
        <bpmn:signalEventDefinition />
      </bpmn:startEvent>
      <bpmn:task id="Task_Vuln_Assess" name="Assess Vulnerability Impact &amp; Severity" />
      <bpmn:task id="Task_Vuln_Contain" name="Implement Containment Measures" />
      <bpmn:task id="Task_Vuln_Remediate" name="Execute Remediation &amp; Patch" />
      <bpmn:task id="Task_Vuln_Validate" name="Validate Remediation Effectiveness" />
      <bpmn:endEvent id="End_Vuln" />
      <bpmn:sequenceFlow id="f_vuln_1" sourceRef="Start_Vuln" targetRef="Task_Vuln_Assess" />
      <bpmn:sequenceFlow id="f_vuln_2" sourceRef="Task_Vuln_Assess" targetRef="Task_Vuln_Contain" />
      <bpmn:sequenceFlow id="f_vuln_3" sourceRef="Task_Vuln_Contain" targetRef="Task_Vuln_Remediate" />
      <bpmn:sequenceFlow id="f_vuln_4" sourceRef="Task_Vuln_Remediate" targetRef="Task_Vuln_Validate" />
      <bpmn:sequenceFlow id="f_vuln_5" sourceRef="Task_Vuln_Validate" targetRef="End_Vuln" />
    </bpmn:subProcess>

    <!-- 3. Incident Response -->
    <bpmn:subProcess id="EventSP_Incident" name="Incident Response" triggeredByEvent="true">
      <bpmn:documentation>Cross-cutting event sub-process: Incident Response
Trigger: Signal (Interrupting) - security or operational incident
SLA: Severity 1: 15 minutes | Severity 2: 1 hour | Severity 3: 4 hours</bpmn:documentation>
      <bpmn:startEvent id="Start_Incident" name="Security/Operational Incident" isInterrupting="true">
        <bpmn:signalEventDefinition />
      </bpmn:startEvent>
      <bpmn:task id="Task_Inc_Triage" name="Incident Triage &amp; Severity Classification" />
      <bpmn:task id="Task_Inc_Contain" name="Immediate Containment" />
      <bpmn:task id="Task_Inc_Investigate" name="Root Cause Investigation" />
      <bpmn:task id="Task_Inc_Resolve" name="Resolution &amp; Recovery" />
      <bpmn:task id="Task_Inc_PIR" name="Post-Incident Review &amp; Lessons Learned" />
      <bpmn:endEvent id="End_Incident" />
      <bpmn:sequenceFlow id="f_inc_1" sourceRef="Start_Incident" targetRef="Task_Inc_Triage" />
      <bpmn:sequenceFlow id="f_inc_2" sourceRef="Task_Inc_Triage" targetRef="Task_Inc_Contain" />
      <bpmn:sequenceFlow id="f_inc_3" sourceRef="Task_Inc_Contain" targetRef="Task_Inc_Investigate" />
      <bpmn:sequenceFlow id="f_inc_4" sourceRef="Task_Inc_Investigate" targetRef="Task_Inc_Resolve" />
      <bpmn:sequenceFlow id="f_inc_5" sourceRef="Task_Inc_Resolve" targetRef="Task_Inc_PIR" />
      <bpmn:sequenceFlow id="f_inc_6" sourceRef="Task_Inc_PIR" targetRef="End_Incident" />
    </bpmn:subProcess>

    <!-- 4. Regulatory Change -->
    <bpmn:subProcess id="EventSP_RegChange" name="Regulatory Change Management" triggeredByEvent="true">
      <bpmn:documentation>Cross-cutting event sub-process: Regulatory Change Management
Trigger: Message (Non-Interrupting) - regulatory/compliance requirement change
SLA: Impact assessment within 5 business days</bpmn:documentation>
      <bpmn:startEvent id="Start_RegChange" name="Regulatory Change Notification" isInterrupting="false">
        <bpmn:messageEventDefinition />
      </bpmn:startEvent>
      <bpmn:task id="Task_Reg_Assess" name="Assess Regulatory Change Impact" />
      <bpmn:task id="Task_Reg_Update" name="Update KB-003 &amp; DMN Rules" />
      <bpmn:task id="Task_Reg_Notify" name="Notify Affected Initiatives" />
      <bpmn:task id="Task_Reg_Implement" name="Implement Required Process Changes" />
      <bpmn:endEvent id="End_RegChange" />
      <bpmn:sequenceFlow id="f_reg_1" sourceRef="Start_RegChange" targetRef="Task_Reg_Assess" />
      <bpmn:sequenceFlow id="f_reg_2" sourceRef="Task_Reg_Assess" targetRef="Task_Reg_Update" />
      <bpmn:sequenceFlow id="f_reg_3" sourceRef="Task_Reg_Update" targetRef="Task_Reg_Notify" />
      <bpmn:sequenceFlow id="f_reg_4" sourceRef="Task_Reg_Notify" targetRef="Task_Reg_Implement" />
      <bpmn:sequenceFlow id="f_reg_5" sourceRef="Task_Reg_Implement" targetRef="End_RegChange" />
    </bpmn:subProcess>

    <!-- 5. Continuous Improvement -->
    <bpmn:subProcess id="EventSP_CI" name="Continuous Improvement" triggeredByEvent="true">
      <bpmn:documentation>Cross-cutting event sub-process: Continuous Improvement
Trigger: Timer (Non-Interrupting) - 8 parallel improvement cycles
Cadence: Operational (daily) through Innovation (continuous)</bpmn:documentation>
      <bpmn:startEvent id="Start_CI" name="Improvement Cycle Trigger" isInterrupting="false">
        <bpmn:timerEventDefinition><bpmn:timeCycle>R/P1M</bpmn:timeCycle></bpmn:timerEventDefinition>
      </bpmn:startEvent>
      <bpmn:task id="Task_CI_Collect" name="Collect Process Metrics &amp; Feedback" />
      <bpmn:task id="Task_CI_Analyze" name="Analyze Performance Against KPIs" />
      <bpmn:task id="Task_CI_Identify" name="Identify Improvement Opportunities" />
      <bpmn:task id="Task_CI_Implement" name="Implement Process Improvements" />
      <bpmn:task id="Task_CI_Validate" name="Validate Improvement Impact" />
      <bpmn:endEvent id="End_CI" />
      <bpmn:sequenceFlow id="f_ci_1" sourceRef="Start_CI" targetRef="Task_CI_Collect" />
      <bpmn:sequenceFlow id="f_ci_2" sourceRef="Task_CI_Collect" targetRef="Task_CI_Analyze" />
      <bpmn:sequenceFlow id="f_ci_3" sourceRef="Task_CI_Analyze" targetRef="Task_CI_Identify" />
      <bpmn:sequenceFlow id="f_ci_4" sourceRef="Task_CI_Identify" targetRef="Task_CI_Implement" />
      <bpmn:sequenceFlow id="f_ci_5" sourceRef="Task_CI_Implement" targetRef="Task_CI_Validate" />
      <bpmn:sequenceFlow id="f_ci_6" sourceRef="Task_CI_Validate" targetRef="End_CI" />
    </bpmn:subProcess>

    <!-- BLIND SPOT: 6. Stakeholder Communication Event Sub-Process -->
    <bpmn:subProcess id="EventSP_StakeholderComm" name="Stakeholder Communication &amp; Status Reporting" triggeredByEvent="true">
      <bpmn:documentation>BLIND SPOT ADDRESSED: Cross-cutting event sub-process for automated stakeholder status reporting.
Trigger: Timer (Non-Interrupting) - Weekly status cadence
Ensures all stakeholders receive consistent progress updates with SLA status, risk changes, and blockers.</bpmn:documentation>
      <bpmn:startEvent id="Start_StakeComm" name="Weekly Status Cycle" isInterrupting="false">
        <bpmn:timerEventDefinition><bpmn:timeCycle>R/P1W</bpmn:timeCycle></bpmn:timerEventDefinition>
      </bpmn:startEvent>
      <bpmn:task id="Task_SC_Gather" name="Gather Status from All Active Sub-Processes" />
      <bpmn:task id="Task_SC_Generate" name="Auto-Generate Status Report with SLA Dashboard" />
      <bpmn:sendTask id="Task_SC_Distribute" name="Distribute to Stakeholders by Role" />
      <bpmn:endEvent id="End_StakeComm" />
      <bpmn:sequenceFlow id="f_sc_1" sourceRef="Start_StakeComm" targetRef="Task_SC_Gather" />
      <bpmn:sequenceFlow id="f_sc_2" sourceRef="Task_SC_Gather" targetRef="Task_SC_Generate" />
      <bpmn:sequenceFlow id="f_sc_3" sourceRef="Task_SC_Generate" targetRef="Task_SC_Distribute" />
      <bpmn:sequenceFlow id="f_sc_4" sourceRef="Task_SC_Distribute" targetRef="End_StakeComm" />
    </bpmn:subProcess>

    <!-- ================================================================ -->
    <!-- MAIN SEQUENCE FLOWS                                               -->
    <!-- ================================================================ -->
    <bpmn:sequenceFlow id="Flow_Start_SP11" sourceRef="StartEvent_Intake" targetRef="SP_1_1" />
    <bpmn:sequenceFlow id="Flow_SP11_GW11" sourceRef="SP_1_1" targetRef="GW_1_1" />
    <bpmn:sequenceFlow id="Flow_GW11_SP12" name="Complete &amp; Unique" sourceRef="GW_1_1" targetRef="SP_1_2" />
    <bpmn:sequenceFlow id="Flow_GW11_Incomplete" name="Incomplete → Return to Requestor" sourceRef="GW_1_1" targetRef="SP_1_1">
      <bpmn:documentation>Loop back to requestor with specific field-level guidance for completion.</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_GW11_Duplicate" name="Duplicate → Merge Workflow" sourceRef="GW_1_1" targetRef="End_Rejected">
      <bpmn:documentation>Route to merge/append workflow for duplicate initiatives.</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_SP12_GW12" sourceRef="SP_1_2" targetRef="GW_1_2" />
    <bpmn:sequenceFlow id="Flow_GW12_SP13" name="Medium / High / Critical → Business Case" sourceRef="GW_1_2" targetRef="SP_1_3" />
    <bpmn:sequenceFlow id="Flow_GW12_Express" name="Low Risk → Express to Phase 2" sourceRef="GW_1_2" targetRef="GW_2_1" />
    <bpmn:sequenceFlow id="Flow_SP13_GW13" sourceRef="SP_1_3" targetRef="GW_1_3" />
    <bpmn:sequenceFlow id="Flow_GW13_Phase2" name="Approved → Phase 2" sourceRef="GW_1_3" targetRef="GW_2_1" />
    <bpmn:sequenceFlow id="Flow_GW13_Conditional" name="Conditional → Return to Requestor" sourceRef="GW_1_3" targetRef="SP_1_3" />
    <bpmn:sequenceFlow id="Flow_GW13_Deferred" name="Deferred → Backlog" sourceRef="GW_1_3" targetRef="End_Deferred" />
    <bpmn:sequenceFlow id="Flow_GW13_Rejected" name="Rejected → Archive" sourceRef="GW_1_3" targetRef="End_Rejected" />

    <!-- Phase 2 Flows -->
    <bpmn:sequenceFlow id="Flow_GW21_SP21" sourceRef="GW_2_1" targetRef="SP_2_1" />
    <bpmn:sequenceFlow id="Flow_GW21_SP22" sourceRef="GW_2_1" targetRef="SP_2_2" />
    <bpmn:sequenceFlow id="Flow_GW21_GW22" sourceRef="GW_2_1" targetRef="GW_2_2" />
    <bpmn:sequenceFlow id="Flow_GW21_SP24" sourceRef="GW_2_1" targetRef="SP_2_4" />
    <bpmn:sequenceFlow id="Flow_GW22_SP23" name="Vendor Involved → Vendor Assessment" sourceRef="GW_2_2" targetRef="SP_2_3" />
    <bpmn:sequenceFlow id="Flow_GW22_Skip" name="No Vendor → Skip to Join" sourceRef="GW_2_2" targetRef="GW_2_3" />
    <bpmn:sequenceFlow id="Flow_SP21_GW23" sourceRef="SP_2_1" targetRef="GW_2_3" />
    <bpmn:sequenceFlow id="Flow_SP22_GW23" sourceRef="SP_2_2" targetRef="GW_2_3" />
    <bpmn:sequenceFlow id="Flow_SP23_GW23" sourceRef="SP_2_3" targetRef="GW_2_3" />
    <bpmn:sequenceFlow id="Flow_SP24_GW23" sourceRef="SP_2_4" targetRef="GW_2_3" />
    <bpmn:sequenceFlow id="Flow_GW23_SP25" sourceRef="GW_2_3" targetRef="SP_2_5" />
    <bpmn:sequenceFlow id="Flow_SP25_GW24" sourceRef="SP_2_5" targetRef="GW_2_4" />
    <bpmn:sequenceFlow id="Flow_GW24_Phase3" name="Approved → Phase 3" sourceRef="GW_2_4" targetRef="GW_3_1" />
    <bpmn:sequenceFlow id="Flow_GW24_Remediate" name="Remediate → Return to Assessment" sourceRef="GW_2_4" targetRef="GW_2_1" />
    <bpmn:sequenceFlow id="Flow_GW24_Rejected" name="Reject → Archive" sourceRef="GW_2_4" targetRef="End_Rejected" />
    <bpmn:sequenceFlow id="Flow_GW24_Conditional" name="Conditional → Remediation Plan" sourceRef="GW_2_4" targetRef="SP_2_5" />

    <!-- Phase 3 Flows -->
    <bpmn:sequenceFlow id="Flow_GW31_SP31" sourceRef="GW_3_1" targetRef="SP_3_1" />
    <bpmn:sequenceFlow id="Flow_GW31_SP32" sourceRef="GW_3_1" targetRef="SP_3_2" />
    <bpmn:sequenceFlow id="Flow_GW31_SP33" sourceRef="GW_3_1" targetRef="SP_3_3" />
    <bpmn:sequenceFlow id="Flow_GW31_SP34" sourceRef="GW_3_1" targetRef="SP_3_4" />
    <bpmn:sequenceFlow id="Flow_SP31_GW33" sourceRef="SP_3_1" targetRef="GW_3_3" />
    <bpmn:sequenceFlow id="Flow_SP32_GW33" sourceRef="SP_3_2" targetRef="GW_3_3" />
    <bpmn:sequenceFlow id="Flow_SP33_GW33" sourceRef="SP_3_3" targetRef="GW_3_3" />
    <bpmn:sequenceFlow id="Flow_SP34_GW33" sourceRef="SP_3_4" targetRef="GW_3_3" />
    <bpmn:sequenceFlow id="Flow_GW33_SP35" sourceRef="GW_3_3" targetRef="SP_3_5" />
    <bpmn:sequenceFlow id="Flow_SP35_GW34" sourceRef="SP_3_5" targetRef="GW_3_4" />
    <bpmn:sequenceFlow id="Flow_GW34_Phase4" name="All Criteria Met → Phase 4" sourceRef="GW_3_4" targetRef="SP_Phase4" />
    <bpmn:sequenceFlow id="Flow_GW34_Remediate" name="Outstanding → Remediation Loop" sourceRef="GW_3_4" targetRef="GW_3_1" />
    <bpmn:sequenceFlow id="Flow_GW34_Escalate" name="Critical Block → Governance Board" sourceRef="GW_3_4" targetRef="SP_2_5" />

    <!-- Phases 4-8 Flows -->
    <bpmn:sequenceFlow id="Flow_Ph4_Ph5" sourceRef="SP_Phase4" targetRef="SP_Phase5" />
    <bpmn:sequenceFlow id="Flow_Ph5_Ph6" sourceRef="SP_Phase5" targetRef="SP_Phase6" />
    <bpmn:sequenceFlow id="Flow_Ph6_Ph7" sourceRef="SP_Phase6" targetRef="SP_Phase7" />
    <bpmn:sequenceFlow id="Flow_Ph7_Ph8" sourceRef="SP_Phase7" targetRef="SP_Phase8" />
    <bpmn:sequenceFlow id="Flow_Ph8_End" sourceRef="SP_Phase8" targetRef="EndEvent_Retirement" />

  </bpmn:process>

  <!-- ================================================================== -->
  <!-- PROCESS: Requestor Pool (simplified)                                -->
  <!-- ================================================================== -->
  <bpmn:process id="Process_Requestor" name="Requestor Process" isExecutable="false">
    <bpmn:documentation>Business Unit / Requestor: Idea submission, business justification, UAT sign-off</bpmn:documentation>
  </bpmn:process>

  <!-- ================================================================== -->
  <!-- PROCESS: Technical Pool                                             -->
  <!-- ================================================================== -->
  <bpmn:process id="Process_Technical" name="Technical Process" isExecutable="false">
    <bpmn:documentation>Enterprise Architecture, Security &amp; Compliance, Development Teams / AI Agents:
Solution design, integration review, standards compliance, threat modeling, security assessment, build, test, deploy</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_Tech">
      <bpmn:lane id="Lane_Architecture" name="Enterprise Architecture" />
      <bpmn:lane id="Lane_Security" name="Security &amp; Compliance" />
      <bpmn:lane id="Lane_Development" name="Development Teams / AI Agents" />
    </bpmn:laneSet>
  </bpmn:process>

  <!-- ================================================================== -->
  <!-- PROCESS: Vendor Pool                                                -->
  <!-- ================================================================== -->
  <bpmn:process id="Process_Vendor" name="Vendor Process" isExecutable="false">
    <bpmn:documentation>Third-Party Vendors: Vendor assessment, contract negotiation, SLA management</bpmn:documentation>
  </bpmn:process>

  <!-- ================================================================== -->
  <!-- PROCESS: Operations Pool                                            -->
  <!-- ================================================================== -->
  <bpmn:process id="Process_Operations" name="Operations Process" isExecutable="false">
    <bpmn:documentation>IT Operations / SRE: Provisioning, monitoring, incident response, retirement</bpmn:documentation>
  </bpmn:process>

  <!-- ================================================================== -->
  <!-- PROCESS: AI Platform Pool                                           -->
  <!-- ================================================================== -->
  <bpmn:process id="Process_AI" name="AI Platform Process" isExecutable="false">
    <bpmn:documentation>AI Agents &amp; DMN Engine: AI Intake Agent, AI Risk Agent, AI Compliance Agent, AI Architecture Agent, AI Security Agent, AI Code Agent, AI Testing Agent, AI Documentation Agent, AI Deployment Agent. DMN Engine executes all decision tables (DMN-DT-001 through DMN-DT-009).</bpmn:documentation>
  </bpmn:process>

