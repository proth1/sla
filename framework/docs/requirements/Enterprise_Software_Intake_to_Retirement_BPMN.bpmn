      <bpmn:sequenceFlow id="f_sp31_8" sourceRef="Task_T3131" targetRef="Task_T3132" />
      <bpmn:sequenceFlow id="f_sp31_9" sourceRef="Task_T3132" targetRef="Task_T3133_BS" />
      <bpmn:sequenceFlow id="f_sp31_10" sourceRef="Task_T3133_BS" targetRef="End_SP31" />
    </bpmn:subProcess>

    <bpmn:boundaryEvent id="Timer_SP31_50" name="SLA 50% (2.5d)" attachedToRef="SP_3_1" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P2DT12H</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="Timer_SP31_100" name="SLA Breach (5d)" attachedToRef="SP_3_1" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P5D</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- ============================================================== -->
    <!-- SP-3.2: Toolchain & Pipeline Setup | SLA: 2-3 days             -->
    <!-- ============================================================== -->
    <bpmn:subProcess id="SP_3_2" name="SP-3.2: Toolchain &amp; Pipeline Setup">
      <bpmn:documentation>Sub-Process ID: SP-3.2 | SLA: 2-3 business days
Lane: Technical Pool - Development Lane
Activities: Repository &amp; CI/CD Setup, Observability Setup, AI Agent Configuration
DMN Table: DMN-DT-008 (AI Agent Automation Level)</bpmn:documentation>
      <bpmn:incoming>Flow_GW31_SP32</bpmn:incoming>
      <bpmn:outgoing>Flow_SP32_GW33</bpmn:outgoing>

      <bpmn:startEvent id="Start_SP32" />
      <bpmn:userTask id="Task_T3211" name="T-3.2.1.1: Create Source Repositories">
