      <bpmn:sequenceFlow id="f_sp32_7" sourceRef="Task_T3231" targetRef="Task_T3232" />
      <bpmn:sequenceFlow id="f_sp32_8" sourceRef="Task_T3232" targetRef="End_SP32" />
    </bpmn:subProcess>

    <bpmn:boundaryEvent id="Timer_SP32_100" name="SLA Breach (3d)" attachedToRef="SP_3_2" cancelActivity="false">
      <bpmn:timerEventDefinition><bpmn:timeDuration>P3D</bpmn:timeDuration></bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- ============================================================== -->
    <!-- SP-3.3: Access & Identity Provisioning | SLA: 1-2 days         -->
    <!-- ============================================================== -->
    <bpmn:subProcess id="SP_3_3" name="SP-3.3: Access &amp; Identity Provisioning">
      <bpmn:documentation>Sub-Process ID: SP-3.3 | SLA: 1-2 business days
Lane: Operations Pool + Governance Pool
Activities: Team Access Provisioning, Vendor Access (Conditional), Access Certification</bpmn:documentation>
      <bpmn:incoming>Flow_GW31_SP33</bpmn:incoming>
      <bpmn:outgoing>Flow_SP33_GW33</bpmn:outgoing>

      <bpmn:startEvent id="Start_SP33" />
      <bpmn:userTask id="Task_T3311" name="T-3.3.1.1: Create Team Groups &amp; RBAC">
        <bpmn:documentation>Create team groups in identity provider with role-based access control mappings.
Actor: IAM Administrator | SLA: 2 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T3312" name="T-3.3.1.2: Provision Individual Accounts">
        <bpmn:documentation>Provision individual user accounts with least-privilege access per data classification and role.
Actor: IAM Administrator | SLA: 2 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T3313" name="T-3.3.1.3: Configure MFA &amp; Conditional Access">
        <bpmn:documentation>Configure multi-factor authentication and conditional access policies.
Actor: IAM Administrator | SLA: 1 hour</bpmn:documentation>
      </bpmn:userTask>

      <!-- GW-3.2: Vendor Access Conditional -->
      <bpmn:inclusiveGateway id="GW_3_2" name="GW-3.2: Vendor Access Required?">
        <bpmn:documentation>Vendor access provisioning activated only if vendor involvement confirmed in Phase 2.</bpmn:documentation>
      </bpmn:inclusiveGateway>

      <bpmn:userTask id="Task_T3321" name="T-3.3.2.1: Provision Vendor Access (Time-bound)">
        <bpmn:documentation>Provision limited-scope accounts with time-bound access and enhanced monitoring.
Actor: IAM Admin + Security | SLA: 4 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T3322" name="T-3.3.2.2: Configure Vendor Network Segmentation">
        <bpmn:documentation>Configure vendor network segmentation and data access restrictions.
Actor: Network / Security Engineer | SLA: 4 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="Task_T3331" name="T-3.3.3.1: Certify Access Against Matrix">
        <bpmn:documentation>Validate all provisioned access against approved access matrix; certify with governance sign-off.
Actor: Governance Analyst | SLA: 4 hours</bpmn:documentation>
      </bpmn:userTask>
      <!-- BLIND SPOT: Privileged Access Review -->
      <bpmn:userTask id="Task_T3332_BS" name="T-3.3.3.2: Privileged Access Review &amp; JIT Config">
        <bpmn:documentation>BLIND SPOT ADDRESSED: Review all privileged/admin access grants. Configure Just-In-Time (JIT) access policies for elevated permissions. Ensure PAM tool integration.
Actor: IAM Admin + Security Architect | SLA: 2 hours</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:endEvent id="End_SP33" />

      <bpmn:sequenceFlow id="f_sp33_1" sourceRef="Start_SP33" targetRef="Task_T3311" />
      <bpmn:sequenceFlow id="f_sp33_2" sourceRef="Task_T3311" targetRef="Task_T3312" />
