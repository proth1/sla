<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_Phase8Operations"
                  targetNamespace="http://sla.governance/bpmn"
                  exporter="Camunda Modeler"
                  exporterVersion="5.25.0">

  <bpmn:collaboration id="Collaboration_Phase8">
    <bpmn:participant id="Participant_EnterpriseGov" name="Phase 8: Production Operations and Retirement — Enterprise Governance Pool" processRef="Process_Phase8Operations" />
    <bpmn:participant id="Participant_VendorParty" name="Vendor / Third Party" processRef="Process_VendorResponse" />
    <bpmn:messageFlow id="MsgFlow_VendorSLAData" name="SLA Performance Data" sourceRef="Task_VendorSLADataSubmission" targetRef="Task_81_ControlMonitoring" />
    <bpmn:messageFlow id="MsgFlow_VendorRetireNotice" name="Retirement Acknowledgement" sourceRef="Task_VendorRetireAck" targetRef="SubProcess_8R" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Phase8Operations" name="Phase 8: Production Operations and Retirement" isExecutable="false" camunda:historyTimeToLive="180">

    <bpmn:laneSet id="LaneSet_Phase8">

      <bpmn:lane id="Lane_Business" name="Business">
        <bpmn:flowNodeRef>Task_85_VendorPerformance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_85SLAEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EmgStakeholderNotify</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Governance" name="Governance">
        <bpmn:flowNodeRef>EndEvent_Retired</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SubProcess_8R</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EmgImpactAssessment</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Contracting" name="Contracting">
      </bpmn:lane>

      <bpmn:lane id="Lane_TechnicalAssessment" name="Technical Assessment">
        <bpmn:flowNodeRef>Task_EmgContainment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EmgShutdown</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Terminated</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_AIReview" name="AI Review">
        <bpmn:flowNodeRef>Task_82_AIDriftMonitoring</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_82SLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Compliance" name="Compliance">
      </bpmn:lane>

      <bpmn:lane id="Lane_Oversight" name="Oversight">
        <bpmn:flowNodeRef>Task_83_TriggerReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_83SLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Automation" name="Automation">
        <bpmn:flowNodeRef>StartEvent_Phase8Initiated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_81_ControlMonitoring</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_84_SLABreachRCA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_86_ProcessMining</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_87_KnowledgeBase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_88_BenchmarkRecal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_MonitoringCadence</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MonitoringOutcome</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ContinueMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SubProcess_8C</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_EmgDetect</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ProcessSLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>

    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_Phase8Initiated" name="Phase 7&#10;Complete">
      <bpmn:outgoing>Flow_Start_81</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="Task_81_ControlMonitoring" name="8.1 Control-Based&#10;Monitoring (Automated&#10;Compliance Dashboards)" camunda:type="external" camunda:topic="control-based-monitoring">
      <bpmn:incoming>Flow_Start_81</bpmn:incoming>
      <bpmn:incoming>Flow_ContinueMerge_81</bpmn:incoming>
      <bpmn:outgoing>Flow_81_ParallelSplit</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:boundaryEvent id="Timer_81SLA" name="P1D&#10;SLA" attachedToRef="Task_81_ControlMonitoring" cancelActivity="false">
      <bpmn:outgoing>Flow_81SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_81SLA">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:parallelGateway id="Gateway_ParallelSplit" name="Parallel&#10;Monitoring Split">
      <bpmn:incoming>Flow_81_ParallelSplit</bpmn:incoming>
      <bpmn:outgoing>Flow_Split_82</bpmn:outgoing>
      <bpmn:outgoing>Flow_Split_83</bpmn:outgoing>
      <bpmn:outgoing>Flow_Split_84</bpmn:outgoing>
      <bpmn:outgoing>Flow_Split_85</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:userTask id="Task_82_AIDriftMonitoring" name="8.2 AI Model&#10;Drift Monitoring" camunda:candidateGroups="ai-review">
      <bpmn:incoming>Flow_Split_82</bpmn:incoming>
      <bpmn:outgoing>Flow_82_Join</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="Timer_82SLA" name="P2D&#10;SLA" attachedToRef="Task_82_AIDriftMonitoring" cancelActivity="false">
      <bpmn:outgoing>Flow_82SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_82SLA">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P2D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="Task_83_TriggerReview" name="8.3 Trigger Review&#10;on Demand (Event-Driven&#10;Reassessment Triggers)" camunda:type="external" camunda:topic="trigger-review-on-demand">
      <bpmn:incoming>Flow_Split_83</bpmn:incoming>
      <bpmn:outgoing>Flow_83_Join</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:boundaryEvent id="Timer_83SLA" name="PT4H&#10;SLA" attachedToRef="Task_83_TriggerReview" cancelActivity="false">
      <bpmn:outgoing>Flow_83SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_83SLA">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT4H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="Task_84_SLABreachRCA" name="8.4 SLA Breach Root&#10;Cause Analysis (Automated&#10;Pattern Recognition)" camunda:type="external" camunda:topic="sla-breach-rca">
      <bpmn:incoming>Flow_Split_84</bpmn:incoming>
      <bpmn:outgoing>Flow_84_Join</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:userTask id="Task_85_VendorPerformance" name="8.5 Vendor&#10;Performance Management" camunda:candidateGroups="business-lane">
      <bpmn:incoming>Flow_Split_85</bpmn:incoming>
      <bpmn:outgoing>Flow_85_Join</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="Timer_85SLA" name="P5D&#10;SLA" attachedToRef="Task_85_VendorPerformance" cancelActivity="false">
      <bpmn:outgoing>Flow_85SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_85SLA">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:parallelGateway id="Gateway_ParallelJoin">
      <bpmn:incoming>Flow_82_Join</bpmn:incoming>
      <bpmn:incoming>Flow_83_Join</bpmn:incoming>
      <bpmn:incoming>Flow_84_Join</bpmn:incoming>
      <bpmn:incoming>Flow_85_Join</bpmn:incoming>
      <bpmn:outgoing>Flow_Join_86</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:serviceTask id="Task_86_ProcessMining" name="8.6 Process Mining&#10;(Workflow Analytics,&#10;Bottleneck Identification)" camunda:type="external" camunda:topic="process-mining">
      <bpmn:incoming>Flow_Join_86</bpmn:incoming>
      <bpmn:outgoing>Flow_86_87</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_87_KnowledgeBase" name="8.7 Knowledge Base&#10;Enrichment (Governance&#10;Pattern Learning)" camunda:type="external" camunda:topic="knowledge-base-enrichment">
      <bpmn:incoming>Flow_86_87</bpmn:incoming>
      <bpmn:outgoing>Flow_87_88</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_88_BenchmarkRecal" name="8.8 Benchmark&#10;Recalibration (Industry&#10;Benchmark Updates)" camunda:type="external" camunda:topic="benchmark-recalibration">
      <bpmn:incoming>Flow_87_88</bpmn:incoming>
      <bpmn:outgoing>Flow_88_CadenceDMN</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:businessRuleTask id="Task_MonitoringCadence" name="Monitoring Cadence&#10;Assignment" camunda:decisionRef="DMN_MonitoringCadenceAssignment" camunda:decisionRefBinding="latest" camunda:resultVariable="monitoringCadence" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>Flow_88_CadenceDMN</bpmn:incoming>
      <bpmn:outgoing>Flow_CadenceDMN_OutcomeGateway</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:exclusiveGateway id="Gateway_MonitoringOutcome" name="Monitoring&#10;Outcome?" default="Flow_Outcome_Continue">
      <bpmn:incoming>Flow_CadenceDMN_OutcomeGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Outcome_Continue</bpmn:outgoing>
      <bpmn:outgoing>Flow_Outcome_Change</bpmn:outgoing>
      <bpmn:outgoing>Flow_Outcome_Retire</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_ContinueMerge">
      <bpmn:incoming>Flow_Outcome_Continue</bpmn:incoming>
      <bpmn:incoming>Flow_8C_LoopBack</bpmn:incoming>
      <bpmn:outgoing>Flow_ContinueMerge_81</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:subProcess id="SubProcess_8C" name="8C: Change Management">
      <bpmn:incoming>Flow_Outcome_Change</bpmn:incoming>
      <bpmn:outgoing>Flow_8C_LoopBack</bpmn:outgoing>

      <bpmn:startEvent id="StartEvent_8C" name="Change&#10;Required">
        <bpmn:outgoing>Flow_8C_Start_ChangeImpact</bpmn:outgoing>
      </bpmn:startEvent>

      <bpmn:businessRuleTask id="Task_8C_ChangeRisk" name="Change Risk&#10;Scoring" camunda:decisionRef="DMN_ChangeRiskScoring" camunda:decisionRefBinding="latest" camunda:resultVariable="changeRiskScore" camunda:mapDecisionResult="singleResult">
        <bpmn:incoming>Flow_8C_Start_ChangeImpact</bpmn:incoming>
        <bpmn:outgoing>Flow_8C_ChangeRisk_Impact</bpmn:outgoing>
      </bpmn:businessRuleTask>

      <bpmn:userTask id="Task_8C1_ChangeImpact" name="8C.1 Change Impact&#10;Assessment" camunda:candidateGroups="technical-assessment">
        <bpmn:incoming>Flow_8C_ChangeRisk_Impact</bpmn:incoming>
        <bpmn:outgoing>Flow_8C_Impact_Approval</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:userTask id="Task_8C2_ChangeApproval" name="8C.2 Change Approval" camunda:candidateGroups="governance-lane">
        <bpmn:incoming>Flow_8C_Impact_Approval</bpmn:incoming>
        <bpmn:outgoing>Flow_8C_Approval_Impl</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:userTask id="Task_8C3_ChangeImpl" name="8C.3 Change&#10;Implementation" camunda:candidateGroups="technical-assessment">
        <bpmn:incoming>Flow_8C_Approval_Impl</bpmn:incoming>
        <bpmn:outgoing>Flow_8C_Impl_End</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:endEvent id="EndEvent_8C" name="Change&#10;Implemented">
        <bpmn:incoming>Flow_8C_Impl_End</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="Flow_8C_Start_ChangeImpact" sourceRef="StartEvent_8C" targetRef="Task_8C_ChangeRisk" />
      <bpmn:sequenceFlow id="Flow_8C_ChangeRisk_Impact" sourceRef="Task_8C_ChangeRisk" targetRef="Task_8C1_ChangeImpact" />
      <bpmn:sequenceFlow id="Flow_8C_Impact_Approval" sourceRef="Task_8C1_ChangeImpact" targetRef="Task_8C2_ChangeApproval" />
      <bpmn:sequenceFlow id="Flow_8C_Approval_Impl" sourceRef="Task_8C2_ChangeApproval" targetRef="Task_8C3_ChangeImpl" />
      <bpmn:sequenceFlow id="Flow_8C_Impl_End" sourceRef="Task_8C3_ChangeImpl" targetRef="EndEvent_8C" />

    </bpmn:subProcess>

    <bpmn:subProcess id="SubProcess_8R" name="8R: Decommission Plan">
      <bpmn:incoming>Flow_Outcome_Retire</bpmn:incoming>
      <bpmn:outgoing>Flow_8R_End</bpmn:outgoing>

      <bpmn:startEvent id="StartEvent_8R" name="Retire&#10;Decision">
        <bpmn:outgoing>Flow_8R_Start_Assessment</bpmn:outgoing>
      </bpmn:startEvent>

      <bpmn:userTask id="Task_8R1_RetirementAssessment" name="8R.1 Retirement&#10;Assessment" camunda:candidateGroups="business-lane">
        <bpmn:incoming>Flow_8R_Start_Assessment</bpmn:incoming>
        <bpmn:outgoing>Flow_8R1_DataMigration</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:userTask id="Task_8R2_DataMigrationPlan" name="8R.2 Data Migration&#10;Plan" camunda:candidateGroups="technical-assessment">
        <bpmn:incoming>Flow_8R1_DataMigration</bpmn:incoming>
        <bpmn:outgoing>Flow_8R2_VendorNotify</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:userTask id="Task_8R3_VendorNotification" name="8R.3 Vendor Notification&#10;(Buy Pathway)" camunda:candidateGroups="contracting-lane">
        <bpmn:incoming>Flow_8R2_VendorNotify</bpmn:incoming>
        <bpmn:outgoing>Flow_8R3_ArchivePurge</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:parallelGateway id="Gateway_8R_ArchiveSplit">
        <bpmn:incoming>Flow_8R3_ArchivePurge</bpmn:incoming>
        <bpmn:outgoing>Flow_8R_Archive_Tech</bpmn:outgoing>
        <bpmn:outgoing>Flow_8R_Archive_Compliance</bpmn:outgoing>
      </bpmn:parallelGateway>

      <bpmn:userTask id="Task_8R4_DataArchivePurge" name="8R.4 Data Archive&#10;/ Purge (Technical)" camunda:candidateGroups="technical-assessment">
        <bpmn:incoming>Flow_8R_Archive_Tech</bpmn:incoming>
        <bpmn:outgoing>Flow_8R4_ArchiveJoin</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:userTask id="Task_8R4b_ComplianceArchive" name="8R.4b Compliance&#10;Data Archive / Purge" camunda:candidateGroups="compliance-lane">
        <bpmn:incoming>Flow_8R_Archive_Compliance</bpmn:incoming>
        <bpmn:outgoing>Flow_8R4b_ArchiveJoin</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:parallelGateway id="Gateway_8R_ArchiveJoin">
        <bpmn:incoming>Flow_8R4_ArchiveJoin</bpmn:incoming>
        <bpmn:incoming>Flow_8R4b_ArchiveJoin</bpmn:incoming>
        <bpmn:outgoing>Flow_8R_ArchiveJoin_Preserve</bpmn:outgoing>
      </bpmn:parallelGateway>

      <bpmn:serviceTask id="Task_8R5_KnowledgePreserve" name="8R.5 Knowledge&#10;Preservation (Automation)" camunda:type="external" camunda:topic="knowledge-preservation">
        <bpmn:incoming>Flow_8R_ArchiveJoin_Preserve</bpmn:incoming>
        <bpmn:outgoing>Flow_8R5_StakeholderComm</bpmn:outgoing>
      </bpmn:serviceTask>

      <bpmn:userTask id="Task_8R6_StakeholderComm" name="8R.6 Stakeholder&#10;Communication" camunda:candidateGroups="business-lane">
        <bpmn:incoming>Flow_8R5_StakeholderComm</bpmn:incoming>
        <bpmn:outgoing>Flow_8R6_FinalAudit</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:userTask id="Task_8R7_FinalAudit" name="8R.7 Final Audit&#10;(Governance Board)" camunda:candidateGroups="governance-lane">
        <bpmn:incoming>Flow_8R6_FinalAudit</bpmn:incoming>
        <bpmn:outgoing>Flow_8R7_End</bpmn:outgoing>
      </bpmn:userTask>

      <bpmn:endEvent id="EndEvent_8R" name="Retirement&#10;Complete">
        <bpmn:incoming>Flow_8R7_End</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="Flow_8R_Start_Assessment" sourceRef="StartEvent_8R" targetRef="Task_8R1_RetirementAssessment" />
      <bpmn:sequenceFlow id="Flow_8R1_DataMigration" sourceRef="Task_8R1_RetirementAssessment" targetRef="Task_8R2_DataMigrationPlan" />
      <bpmn:sequenceFlow id="Flow_8R2_VendorNotify" sourceRef="Task_8R2_DataMigrationPlan" targetRef="Task_8R3_VendorNotification" />
      <bpmn:sequenceFlow id="Flow_8R3_ArchivePurge" sourceRef="Task_8R3_VendorNotification" targetRef="Gateway_8R_ArchiveSplit" />
      <bpmn:sequenceFlow id="Flow_8R_Archive_Tech" sourceRef="Gateway_8R_ArchiveSplit" targetRef="Task_8R4_DataArchivePurge" />
      <bpmn:sequenceFlow id="Flow_8R_Archive_Compliance" sourceRef="Gateway_8R_ArchiveSplit" targetRef="Task_8R4b_ComplianceArchive" />
      <bpmn:sequenceFlow id="Flow_8R4_ArchiveJoin" sourceRef="Task_8R4_DataArchivePurge" targetRef="Gateway_8R_ArchiveJoin" />
      <bpmn:sequenceFlow id="Flow_8R4b_ArchiveJoin" sourceRef="Task_8R4b_ComplianceArchive" targetRef="Gateway_8R_ArchiveJoin" />
      <bpmn:sequenceFlow id="Flow_8R_ArchiveJoin_Preserve" sourceRef="Gateway_8R_ArchiveJoin" targetRef="Task_8R5_KnowledgePreserve" />
      <bpmn:sequenceFlow id="Flow_8R5_StakeholderComm" sourceRef="Task_8R5_KnowledgePreserve" targetRef="Task_8R6_StakeholderComm" />
      <bpmn:sequenceFlow id="Flow_8R6_FinalAudit" sourceRef="Task_8R6_StakeholderComm" targetRef="Task_8R7_FinalAudit" />
      <bpmn:sequenceFlow id="Flow_8R7_End" sourceRef="Task_8R7_FinalAudit" targetRef="EndEvent_8R" />

    </bpmn:subProcess>

    <bpmn:exclusiveGateway id="Gateway_EmgDetect" name="Emergency&#10;Detected?" default="Flow_EmgNo_Skip">
      <bpmn:incoming>Flow_81SLAEscalate</bpmn:incoming>
      <bpmn:outgoing>Flow_EmgYes_Contain</bpmn:outgoing>
      <bpmn:outgoing>Flow_EmgNo_Skip</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_EmgContainment" name="Emergency&#10;Containment" camunda:candidateGroups="technical-assessment">
      <bpmn:incoming>Flow_EmgYes_Contain</bpmn:incoming>
      <bpmn:outgoing>Flow_Emg_Contain_Impact</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_EmgImpactAssessment" name="Emergency Impact&#10;Assessment" camunda:candidateGroups="governance-lane">
      <bpmn:incoming>Flow_Emg_Contain_Impact</bpmn:incoming>
      <bpmn:outgoing>Flow_Emg_Impact_Notify</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_EmgStakeholderNotify" name="Emergency Stakeholder&#10;Notification" camunda:candidateGroups="business-lane">
      <bpmn:incoming>Flow_Emg_Impact_Notify</bpmn:incoming>
      <bpmn:outgoing>Flow_Emg_Notify_Shutdown</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_EmgShutdown" name="Emergency&#10;Shutdown" camunda:candidateGroups="technical-assessment">
      <bpmn:incoming>Flow_Emg_Notify_Shutdown</bpmn:incoming>
      <bpmn:outgoing>Flow_Emg_Shutdown_End</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndEvent_ProcessSLAEscalated" name="Process SLA&#10;Escalated">
      <bpmn:incoming>Flow_EmgNo_Skip</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Terminated" name="System&#10;Terminated">
      <bpmn:incoming>Flow_Emg_Shutdown_End</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorDef_Terminated" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Retired" name="System&#10;Retired">
      <bpmn:incoming>Flow_8R_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_85SLAEscalated" name="Vendor Performance&#10;SLA Escalated">
      <bpmn:incoming>Flow_85SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_82SLAEscalated" name="AI Drift Monitoring&#10;SLA Escalated">
      <bpmn:incoming>Flow_82SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_83SLAEscalated" name="Trigger Review&#10;SLA Escalated">
      <bpmn:incoming>Flow_83SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:textAnnotation id="Annotation_DORA">
      <bpmn:text>DORA (EU 2022/2554): Operational resilience monitoring, ICT-related incident management, and third-party ICT risk oversight. Tasks 8.1-8.4 fulfil DORA Article 13 continuous monitoring obligations and Article 28 third-party concentration risk reporting requirements.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_DORA" sourceRef="Task_81_ControlMonitoring" targetRef="Annotation_DORA" />

    <bpmn:textAnnotation id="Annotation_OCC">
      <bpmn:text>OCC 2023-17: Ongoing third-party risk management requires continuous performance monitoring (8.5), root cause analysis of SLA breaches (8.4), and documented escalation paths. Vendor scorecard reviews must be conducted at frequency defined by DMN-8 Monitoring Cadence Assignment.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_OCC" sourceRef="Task_85_VendorPerformance" targetRef="Annotation_OCC" />

    <bpmn:textAnnotation id="Annotation_NIST">
      <bpmn:text>NIST CSF 2.0 (Govern, Identify, Detect, Respond, Recover): Process Mining (8.6) and Benchmark Recalibration (8.8) fulfil NIST CSF Govern function continuous improvement obligations. Emergency Termination path implements Respond and Recover functions. Knowledge Base Enrichment (8.7) supports organisational learning per NIST CSF Govern GV.OC-05.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_NIST" sourceRef="Task_86_ProcessMining" targetRef="Annotation_NIST" />

    <bpmn:sequenceFlow id="Flow_Start_81" sourceRef="StartEvent_Phase8Initiated" targetRef="Task_81_ControlMonitoring" />
    <bpmn:sequenceFlow id="Flow_81_ParallelSplit" sourceRef="Task_81_ControlMonitoring" targetRef="Gateway_ParallelSplit" />
    <bpmn:sequenceFlow id="Flow_Split_82" sourceRef="Gateway_ParallelSplit" targetRef="Task_82_AIDriftMonitoring" />
    <bpmn:sequenceFlow id="Flow_Split_83" sourceRef="Gateway_ParallelSplit" targetRef="Task_83_TriggerReview" />
    <bpmn:sequenceFlow id="Flow_Split_84" sourceRef="Gateway_ParallelSplit" targetRef="Task_84_SLABreachRCA" />
    <bpmn:sequenceFlow id="Flow_Split_85" sourceRef="Gateway_ParallelSplit" targetRef="Task_85_VendorPerformance" />
    <bpmn:sequenceFlow id="Flow_82_Join" sourceRef="Task_82_AIDriftMonitoring" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_83_Join" sourceRef="Task_83_TriggerReview" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_84_Join" sourceRef="Task_84_SLABreachRCA" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_85_Join" sourceRef="Task_85_VendorPerformance" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_Join_86" sourceRef="Gateway_ParallelJoin" targetRef="Task_86_ProcessMining" />
    <bpmn:sequenceFlow id="Flow_86_87" sourceRef="Task_86_ProcessMining" targetRef="Task_87_KnowledgeBase" />
    <bpmn:sequenceFlow id="Flow_87_88" sourceRef="Task_87_KnowledgeBase" targetRef="Task_88_BenchmarkRecal" />
    <bpmn:sequenceFlow id="Flow_88_CadenceDMN" sourceRef="Task_88_BenchmarkRecal" targetRef="Task_MonitoringCadence" />
    <bpmn:sequenceFlow id="Flow_CadenceDMN_OutcomeGateway" sourceRef="Task_MonitoringCadence" targetRef="Gateway_MonitoringOutcome" />

    <bpmn:sequenceFlow id="Flow_Outcome_Continue" name="Loop: Continue Operations" sourceRef="Gateway_MonitoringOutcome" targetRef="Gateway_ContinueMerge" />
    <bpmn:sequenceFlow id="Flow_Outcome_Change" name="Change Required" sourceRef="Gateway_MonitoringOutcome" targetRef="SubProcess_8C">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${monitoringCadence == 'CHANGE_REQUIRED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Outcome_Retire" name="Retire" sourceRef="Gateway_MonitoringOutcome" targetRef="SubProcess_8R">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${monitoringCadence == 'RETIRE'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_8C_LoopBack" name="Loop: Return to Monitoring" sourceRef="SubProcess_8C" targetRef="Gateway_ContinueMerge" />
    <bpmn:sequenceFlow id="Flow_ContinueMerge_81" sourceRef="Gateway_ContinueMerge" targetRef="Task_81_ControlMonitoring" />

    <bpmn:sequenceFlow id="Flow_8R_End" sourceRef="SubProcess_8R" targetRef="EndEvent_Retired" />

    <bpmn:sequenceFlow id="Flow_81SLAEscalate" sourceRef="Timer_81SLA" targetRef="Gateway_EmgDetect" />
    <bpmn:sequenceFlow id="Flow_EmgYes_Contain" name="Yes" sourceRef="Gateway_EmgDetect" targetRef="Task_EmgContainment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${emergencyDetected == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_EmgNo_Skip" name="No" sourceRef="Gateway_EmgDetect" targetRef="EndEvent_ProcessSLAEscalated" />
    <bpmn:sequenceFlow id="Flow_Emg_Contain_Impact" sourceRef="Task_EmgContainment" targetRef="Task_EmgImpactAssessment" />
    <bpmn:sequenceFlow id="Flow_Emg_Impact_Notify" sourceRef="Task_EmgImpactAssessment" targetRef="Task_EmgStakeholderNotify" />
    <bpmn:sequenceFlow id="Flow_Emg_Notify_Shutdown" sourceRef="Task_EmgStakeholderNotify" targetRef="Task_EmgShutdown" />
    <bpmn:sequenceFlow id="Flow_Emg_Shutdown_End" sourceRef="Task_EmgShutdown" targetRef="EndEvent_Terminated" />

    <bpmn:sequenceFlow id="Flow_82SLAEscalate" sourceRef="Timer_82SLA" targetRef="EndEvent_82SLAEscalated" />
    <bpmn:sequenceFlow id="Flow_83SLAEscalate" sourceRef="Timer_83SLA" targetRef="EndEvent_83SLAEscalated" />
    <bpmn:sequenceFlow id="Flow_85SLAEscalate" sourceRef="Timer_85SLA" targetRef="EndEvent_85SLAEscalated" />

  </bpmn:process>

  <bpmn:process id="Process_VendorResponse" name="Vendor / Third Party Response" isExecutable="false" camunda:historyTimeToLive="180">
    <bpmn:laneSet id="LaneSet_Vendor">
      <bpmn:lane id="Lane_VendorResponse" name="Vendor Response">
        <bpmn:flowNodeRef>StartEvent_VendorEngaged</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VendorSLADataSubmission</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VendorRetireAck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_VendorComplete</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_VendorEngaged" name="Vendor Engaged&#10;for Operations">
      <bpmn:outgoing>Flow_VendorStart_SLA</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_VendorSLADataSubmission" name="SLA Performance&#10;Data Submission" camunda:candidateGroups="vendor-response">
      <bpmn:incoming>Flow_VendorStart_SLA</bpmn:incoming>
      <bpmn:outgoing>Flow_VendorSLA_RetireAck</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_VendorRetireAck" name="Retirement&#10;Acknowledgement" camunda:candidateGroups="vendor-response">
      <bpmn:incoming>Flow_VendorSLA_RetireAck</bpmn:incoming>
      <bpmn:outgoing>Flow_VendorRetire_End</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndEvent_VendorComplete" name="Vendor Response&#10;Complete">
      <bpmn:incoming>Flow_VendorRetire_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_VendorStart_SLA" sourceRef="StartEvent_VendorEngaged" targetRef="Task_VendorSLADataSubmission" />
    <bpmn:sequenceFlow id="Flow_VendorSLA_RetireAck" sourceRef="Task_VendorSLADataSubmission" targetRef="Task_VendorRetireAck" />
    <bpmn:sequenceFlow id="Flow_VendorRetire_End" sourceRef="Task_VendorRetireAck" targetRef="EndEvent_VendorComplete" />

  </bpmn:process>

