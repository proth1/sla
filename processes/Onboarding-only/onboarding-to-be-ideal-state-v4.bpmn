<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_IdealState" targetNamespace="http://sla.governance/bpmn/onboarding" exporter="Camunda Modeler" exporterVersion="5.42.0">
  <bpmn:collaboration id="Collaboration_IdealState">
    <bpmn:participant id="Participant_ProductMgmt" name="Software Onboarding" processRef="Process_ProductMgmt" />
    <bpmn:participant id="Participant_Vendor" name="Vendor / Third Party — External Software or Contracting" processRef="Process_Vendor" />
    <bpmn:messageFlow id="MsgFlow_DDRequest" name="Due Diligence Request" sourceRef="Task_VendorDueDiligence" targetRef="Start_VendorEngagement" />
    <bpmn:messageFlow id="MsgFlow_VendorResponse" name="Vendor Response" sourceRef="Task_VendorProposal" targetRef="Receive_VendorResponse" />
    <bpmn:messageFlow id="MsgFlow_ContractDraft" name="Contract Draft" sourceRef="Task_NegotiateContract" targetRef="Task_VendorContractReview" />
    <bpmn:messageFlow id="MsgFlow_SignedContract" name="Signed Contract" sourceRef="Task_VendorContractSign" targetRef="Receive_SignedContract" />
  </bpmn:collaboration>
  <bpmn:process id="Process_ProductMgmt" name="Product Management — Software Onboarding" isExecutable="false" camunda:historyTimeToLive="180">
    <bpmn:laneSet id="LaneSet_ProductMgmt">
      <bpmn:lane id="Lane_Procurement" name="Procurement &#38; Vendor Management">
        <bpmn:flowNodeRef>Task_AssessVendorLandscape</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EvaluateVendorResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VendorDueDiligence</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_VendorSelected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NegotiateContract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FinalizeContract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_VendorNotSelected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Receive_VendorResponse</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_VendorResponseSLABreach</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Timer_VendorResponseSLA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Receive_SignedContract</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_ContractSLABreach</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Timer_ContractSLA</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ProductMgmt" name="Product Management">
        <bpmn:flowNodeRef>Task_InitialTriage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_TriageDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PrelimAnalysis</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_NeedsAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Backlog</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_MergeBacklog</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PathwayRouting</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_BuyVsBuild</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_MergeBuyBuild</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_ParallelSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TechArchReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SecurityAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RiskCompliance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FinancialAnalysis</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_ParallelJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DefineBuildReqs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_TriageSLAEscalation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RefineRequirements</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PerformPoC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TechRiskEval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_EvalApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_EvalRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_PathwayExec</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OnboardSoftware</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_MergeExec</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PerformUAT</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FinalApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CloseRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_FinalDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_FinalRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SP_PDLC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Timer_TriageSLA</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Requester" name="Software Requester">
        <bpmn:flowNodeRef>Start_SoftwareNeed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReviewExisting</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_BypassProcess</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GatherDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SubmitRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LeverageExisting</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Leveraged</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_0zf4l0g</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_SoftwareOnboarded</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:userTask id="Task_InitialTriage" name="Initial Triage&#10;and Evaluation" camunda:formKey="forms/vendor-intake-form.html?readonly=true" camunda:candidateGroups="governance-lane">
      <bpmn:documentation>Form: vendor-intake-form.html (read-only view of submitted data). Perform initial triage of the incoming software request to evaluate feasibility, strategic alignment, duplicate detection, and resource availability. Includes automated pre-screening for known vendor matches and existing capability overlap. Assign preliminary priority and determine whether the request should proceed, be rejected, or be returned for additional information. This is the first governance gate in the onboarding lifecycle.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 25-30: Initial risk screening — determine whether the proposed software/vendor relationship would create concentration risk, introduce critical dependency, or fall within a high-risk category requiring enhanced due diligence. Early identification of critical/significant third-party relationships. (2) NIST CSF 2.0 GV.RM-01: Risk management strategy alignment — verify the request aligns with the organization&#39;s risk appetite and technology strategy. (3) SOX Section 404: Ensure the triage decision is documented with rationale, supporting the auditability of the intake process. Delegated authority verified for the approval to proceed. EVIDENCE COLLECTION: (a) Triage evaluation form with scoring across feasibility, strategic alignment, duplicate detection, and resource availability. (b) Duplicate detection results from software catalog and vendor registry search. (c) Preliminary risk screening result (concentration risk, criticality assessment). (d) Triage decision with documented rationale (approve/reject/return for info). (e) Priority assignment with justification. (f) Assigned governance analyst name and date. DATA POINTS: Request tracking number, triage score (composite), strategic alignment rating (1-5), duplicate match results (existing solutions found), preliminary risk indicators, resource availability assessment, triage decision (approve/reject/return), decision rationale, assigned analyst, triage completion timestamp, SLA compliance (within 2-day target)." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_R_ToTriage</bpmn:incoming>
      <bpmn:outgoing>Flow_PM2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_TriageDecision" name="Approved ?">
      <bpmn:incoming>Flow_PM2</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_Reject</bpmn:outgoing>
      <bpmn:outgoing>Flow_PM_Approve</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_PrelimAnalysis" name="Preliminary&#10;Analysis" camunda:candidateGroups="governance-lane">
      <bpmn:documentation>Conduct preliminary analysis of the approved request to assess scope, complexity, estimated effort, and determine whether backlog prioritization is needed. Analyze business requirements against available solutions, estimate total cost of ownership, and identify key risk factors. This analysis feeds the pathway routing decision (Buy vs. Build) and determines whether the request needs further assessment through backlog prioritization.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 30: Pre-engagement planning — document the preliminary assessment of the vendor/software relationship complexity, data sensitivity, and operational criticality to inform the depth of subsequent due diligence. (2) NIST CSF 2.0 ID.RA (Risk Assessment): Conduct initial risk identification including data classification, integration complexity, and business continuity impact to feed into the risk tier classification downstream. (3) GDPR Article 35: If personal data processing is involved, confirm whether a full DPIA is required based on the data types, volume, and processing purposes identified. EVIDENCE COLLECTION: (a) Preliminary analysis report with scope assessment, complexity rating, and effort estimate. (b) Total cost of ownership (TCO) preliminary estimate (3-year and 5-year projections). (c) Risk factor identification matrix (data sensitivity, integration complexity, vendor dependency, regulatory exposure). (d) Build vs. buy preliminary recommendation with supporting rationale. (e) Backlog prioritization recommendation (if further assessment needed). DATA POINTS: Scope complexity rating (low/medium/high), estimated TCO range, risk factors identified (count and severity), data classification level, DPIA required (yes/no), build vs. buy preliminary leaning, backlog priority score, estimated timeline to deployment, number of integrations required, user population size." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM_Approve</bpmn:incoming>
      <bpmn:outgoing>Flow_PM3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_NeedsAssessment" name="Needs further&#10;assessment?">
      <bpmn:incoming>Flow_PM3</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_ToBacklog</bpmn:outgoing>
      <bpmn:outgoing>Flow_PM_ToPathway</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_Backlog" name="Backlog&#10;Prioritization" camunda:candidateGroups="governance-lane">
      <bpmn:documentation>Prioritize the request within the software onboarding backlog based on strategic value, urgency, resource availability, risk profile, and organizational capacity. Rank against competing requests using a weighted scoring model. Determine the scheduling window for when the request can proceed through the full evaluation process. Communicate priority and timeline expectations to the requesting business unit.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 25: Governance oversight — backlog prioritization must be transparent, documented, and follow a consistent methodology to ensure regulatory-critical requests (e.g., compliance remediation software) are not deprioritized without documented justification. (2) NIST CSF 2.0 GV.OC-04: Governance processes must ensure that risk-critical technology needs are addressed within acceptable timeframes. (3) SOX Section 404: Prioritization decisions affecting financial systems or controls must be documented with delegated authority sign-off. EVIDENCE COLLECTION: (a) Backlog prioritization scorecard with weighted criteria and scores. (b) Prioritized backlog list showing position relative to other requests. (c) Scheduling window assignment with estimated start and completion dates. (d) Communication to requesting business unit confirming priority and timeline. (e) Escalation documentation if the request was expedited due to regulatory or compliance urgency. DATA POINTS: Priority score (weighted composite), backlog position (rank), strategic value score, urgency rating, resource availability status, estimated scheduling window (start/end), competing requests assessed against, escalation flag (yes/no), stakeholder notification date." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM_ToBacklog</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_BacklogOut</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_MergeBacklog">
      <bpmn:incoming>Flow_PM_ToPathway</bpmn:incoming>
      <bpmn:incoming>Flow_PM_BacklogOut</bpmn:incoming>
      <bpmn:outgoing>Flow_PM4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:businessRuleTask id="Task_PathwayRouting" name="Pathway&#10;Routing" camunda:resultVariable="selectedPathway" camunda:decisionRef="OB_DMN_PathwayRouting" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>Flow_PM4</bpmn:incoming>
      <bpmn:outgoing>Flow_PM5</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="GW_BuyVsBuild" name="Do we Build ?">
      <bpmn:incoming>Flow_PM5</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_Buy</bpmn:outgoing>
      <bpmn:outgoing>Flow_PM_Build</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_AssessVendorLandscape" name="Assess Vendor&#10;Landscape" camunda:candidateGroups="procurement-lane">
      <bpmn:documentation>Conduct a comprehensive assessment of the vendor landscape for the Buy pathway. Identify potential vendors through market research, analyst reports, peer benchmarking, and the organization's approved vendor registry. Evaluate vendor capabilities against requirements, assess market positioning, and develop a shortlist of qualified vendors to invite for formal proposal. Consider concentration risk with existing vendor portfolio.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 35: Vendor selection process — the landscape assessment must demonstrate a fair, documented evaluation of multiple vendors to avoid sole-source engagements without justification. Concentration risk analysis required against existing vendor portfolio. (2) NIST CSF 2.0 GV.SC-04: Supply chain risk assessment — evaluate vendor market stability, financial health, and geographic concentration. (3) DORA Article 28: ICT third-party concentration risk — assess whether shortlisted vendors would create or exacerbate concentration of critical ICT services with a single provider or within a single jurisdiction. EVIDENCE COLLECTION: (a) Market research report identifying candidate vendors (minimum 3 for competitive evaluation unless sole-source justified). (b) Vendor capability comparison matrix against requirements. (c) Concentration risk analysis against existing vendor portfolio. (d) Shortlist recommendation with selection rationale. (e) Sole-source justification document (if fewer than 3 candidates). (f) Analyst report references (Gartner, Forrester, etc. if used). DATA POINTS: Number of vendors identified, number shortlisted, selection criteria and weights, concentration risk assessment result, vendor market positions (leader/challenger/niche), geographic distribution of candidates, existing relationships with any candidates, estimated competitive savings opportunity." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM_Par5</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_Par5J</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_MergeBuyBuild">
      <bpmn:incoming>Flow_PM_Buy</bpmn:incoming>
      <bpmn:incoming>Flow_PM_BuildMerge</bpmn:incoming>
      <bpmn:outgoing>Flow_PM6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:parallelGateway id="GW_ParallelSplit">
      <bpmn:incoming>Flow_PM6</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_Par1</bpmn:outgoing>
      <bpmn:outgoing>Flow_PM_Par2</bpmn:outgoing>
      <bpmn:outgoing>Flow_PM_Par3</bpmn:outgoing>
      <bpmn:outgoing>Flow_PM_Par4</bpmn:outgoing>
      <bpmn:outgoing>Flow_PM_Par5</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="Task_TechArchReview" name="Technical&#10;Architecture Review" camunda:candidateGroups="technical-assessment">
      <bpmn:documentation>Evaluate the proposed solution's technical architecture for scalability, reliability, maintainability, integration compatibility, and alignment with enterprise architecture standards. Assess API design, data flow architecture, infrastructure requirements, technology stack maturity, and technical debt risk. Verify the solution can integrate with existing enterprise systems without introducing architectural anti-patterns.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) NIST CSF 2.0 PR.PS (Platform Security): Evaluate platform hardening, secure configuration baselines, and change management controls in the proposed architecture. (2) DORA Article 9: ICT system resilience — assess high availability design, failover mechanisms, disaster recovery architecture, and recovery time/point objectives. (3) OCC 2023-17 Section 50: Technology risk assessment — evaluate whether the vendor&#39;s architecture introduces systemic risk through single points of failure, deprecated technologies, or unsupported platforms. EVIDENCE COLLECTION: (a) Architecture review assessment report with findings and recommendations. (b) Integration compatibility matrix against enterprise systems. (c) Scalability assessment with projected capacity requirements. (d) Technology stack maturity evaluation (vendor support lifecycle, community health). (e) Architecture diagram review with annotated risk areas. DATA POINTS: Architecture pattern (microservices/monolith/hybrid), API standards compliance, integration points count, scalability ceiling estimate, technology stack age and support status, single points of failure identified, DR architecture rating, enterprise standards compliance score." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM_Par1</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_Par1J</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_SecurityAssessment" name="Security&#10;Assessment" camunda:candidateGroups="technical-assessment">
      <bpmn:documentation>Conduct a comprehensive security assessment of the proposed solution covering vulnerability posture, threat modeling, access control design, encryption standards, network security, application security, and incident response readiness. For Buy pathway, evaluate vendor security controls; for Build pathway, evaluate the security architecture of the proposed design. Identify security risks and required mitigations before proceeding.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Sections 50-55: Information security assessment — evaluate access controls, data encryption (at rest and in transit), vulnerability management, patch management cadence, and security monitoring capabilities. (2) NIST CSF 2.0: PR.AA (Access Control), PR.DS (Data Security), DE.CM (Continuous Monitoring), DE.AE (Adverse Event Analysis) — structured assessment across all NIST security domains. (3) ISO 27001 Annex A: Map assessment findings to relevant Annex A controls — A.8 Asset Management, A.9 Access Control, A.10 Cryptography, A.12 Operations Security, A.14 System Acquisition. (4) DORA Articles 9-11: ICT security requirements — assess digital operational resilience, ICT-related incident management, and testing capabilities. EVIDENCE COLLECTION: (a) Security assessment report with risk-rated findings (critical/high/medium/low). (b) Threat model document identifying attack vectors and mitigations. (c) Vulnerability scan results or vendor-provided scan summary. (d) Encryption standards verification (algorithms, key lengths, key management). (e) Access control architecture review (RBAC/ABAC design, MFA, privileged access). (f) Security risk register entries for identified risks with mitigations and owners. DATA POINTS: Total findings by severity, open critical/high findings count, encryption standard compliance, MFA coverage, vulnerability scan score, penetration test date (if available), security certifications verified, mean time to patch for critical vulnerabilities, security monitoring coverage percentage." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM_Par2</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_Par2J</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_RiskCompliance" name="Risk, Compliance,&#10;and Legal" camunda:candidateGroups="compliance-lane">
      <bpmn:documentation>Evaluate regulatory and compliance risks associated with the proposed solution. Assess data protection compliance (GDPR, CCPA), financial controls adequacy (SOX), third-party risk management alignment (OCC 2023-17), and operational resilience requirements (DORA). Determine applicable regulatory frameworks based on data types, geographic scope, and industry requirements. Identify compliance gaps and required remediation actions.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Sections 35-40: Third-party risk assessment — comprehensive evaluation of vendor compliance posture, regulatory examination readiness, and willingness to provide audit access. Risk tier classification input for DMN_RiskTierClassification. (2) GDPR Articles 28, 35, 44-49: Data protection compliance — DPA adequacy, cross-border transfer mechanisms (SCCs, adequacy decisions), DPIA completion for high-risk processing, data subject rights support. (3) SOX Sections 302, 404: Financial controls compliance — evaluate whether the solution introduces, modifies, or removes any internal controls over financial reporting. Segregation of duties assessment. (4) DORA Articles 5-7: ICT risk management framework alignment — verify the solution fits within the organization&#39;s digital operational resilience strategy. (5) CCPA: Service provider classification, data sale restrictions, consumer rights support. EVIDENCE COLLECTION: (a) Regulatory applicability matrix (which regulations apply and why). (b) Compliance gap analysis with required remediation actions and owners. (c) DPIA report (if high-risk personal data processing). (d) Cross-border data transfer assessment (if data leaves jurisdiction). (e) Risk tier classification recommendation (input to DMN). (f) Compliance sign-off or conditional approval with required mitigations. DATA POINTS: Applicable regulations count, compliance gaps identified (by severity), DPIA required and status, cross-border transfer required (yes/no), risk tier recommendation (Critical/High/Medium/Low), remediation actions required (count), estimated remediation effort, compliance approval status (approved/conditional/rejected)." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM_Par3</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_Par3J</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_FinancialAnalysis" name="Financial&#10;Analysis" camunda:candidateGroups="governance-lane">
      <bpmn:documentation>Perform comprehensive financial analysis including total cost of ownership (TCO), return on investment (ROI), net present value (NPV), and payback period calculations. Evaluate licensing models, implementation costs, ongoing maintenance fees, infrastructure costs, training expenses, and exit costs. Compare against budget authorization and organizational spending thresholds. For Buy pathway, analyze vendor pricing competitiveness; for Build pathway, estimate development and maintenance costs.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) SOX Sections 302, 404: Financial analysis must follow the organization&#39;s capital expenditure and operating expenditure classification rules. All cost estimates must be verifiable and align with the delegated authority matrix. Cost projections affecting financial statements require controller sign-off. (2) OCC 2023-17 Section 40: Contract cost reasonableness — financial analysis must demonstrate the proposed pricing is reasonable relative to market benchmarks and the services provided. Exit cost analysis required to avoid vendor lock-in. (3) NIST CSF 2.0 GV.OC-03: Financial resource allocation must be aligned with the organization&#39;s cybersecurity and risk management strategy — ensure adequate budget for security controls. EVIDENCE COLLECTION: (a) TCO analysis (3-year and 5-year projections) with itemized cost categories. (b) ROI calculation with assumptions documented. (c) NPV and payback period analysis. (d) Budget authorization verification against delegated authority matrix. (e) Market pricing benchmark comparison (for Buy pathway). (f) Build vs. Buy cost comparison (if both pathways were evaluated). (g) Exit cost analysis including data migration, transition, and decommissioning costs. DATA POINTS: Total 3-year TCO, total 5-year TCO, annual recurring cost, one-time implementation cost, ROI percentage, payback period (months), NPV at organizational discount rate, licensing model type, exit cost estimate, budget variance (over/under authorized amount), cost per user, cost per transaction (if applicable)." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM_Par4</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_Par4J</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="GW_ParallelJoin">
      <bpmn:incoming>Flow_PM_Par1J</bpmn:incoming>
      <bpmn:incoming>Flow_PM_Par2J</bpmn:incoming>
      <bpmn:incoming>Flow_PM_Par3J</bpmn:incoming>
      <bpmn:incoming>Flow_PM_Par4J</bpmn:incoming>
      <bpmn:incoming>Flow_PM_Par5J</bpmn:incoming>
      <bpmn:outgoing>Flow_PM7</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="Task_EvaluateVendorResponse" name="Evaluate Vendor&#10;Response" camunda:candidateGroups="procurement-lane">
      <bpmn:documentation>Consolidate and evaluate vendor proposal responses against the parallel evaluation results (Technical Architecture, Security, Risk and Compliance, Financial). Score vendor proposals using a weighted evaluation matrix. Identify the preferred vendor or top-ranked candidates. Document evaluation rationale, strengths, weaknesses, and conditions for selection. This is the decision point for vendor shortlisting before due diligence.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 40: Vendor selection must be based on documented, objective criteria applied consistently across all evaluated vendors. The evaluation must demonstrate that risk factors were weighted appropriately and that the selection was not based solely on cost. (2) NIST CSF 2.0 GV.SC-05: Supply chain risk evaluation — consolidated risk assessment across all evaluation dimensions must inform the selection decision. (3) SOX Section 404: Evaluation scoring methodology and results must be documented and retained for audit purposes. Conflicts of interest must be declared by all evaluators. EVIDENCE COLLECTION: (a) Consolidated evaluation scorecard with weighted scores across all dimensions (technical, security, compliance, financial). (b) Evaluator conflict-of-interest declarations. (c) Vendor ranking report with selection rationale. (d) Strengths/weaknesses/conditions matrix for each evaluated vendor. (e) Selection recommendation memo to governance committee. DATA POINTS: Number of vendors evaluated, weighted scores per vendor per dimension, overall ranking, preferred vendor recommendation, key differentiators identified, conditions or caveats noted, evaluator panel composition, evaluation completion date." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM8b</bpmn:incoming>
      <bpmn:outgoing>Flow_PM9</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_VendorDueDiligence" name="Vendor Due&#10;Diligence" camunda:candidateGroups="procurement-lane">
      <bpmn:documentation>Conduct formal vendor due diligence on the preferred vendor(s). This is a deep-dive investigation covering financial stability, operational resilience, legal standing, regulatory compliance history, security posture, business continuity capabilities, and fourth-party (sub-contractor) risk. Due diligence depth is calibrated to the vendor's risk tier. This task triggers the message flow to the Vendor pool for engagement initiation.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Sections 35-55: Comprehensive due diligence requirements — financial condition assessment, business experience evaluation, legal and regulatory compliance verification, information security program review, operational resilience assessment, incident management capability review, and business continuity/disaster recovery evaluation. Due diligence depth must be commensurate with the risk and complexity of the relationship. (2) NIST CSF 2.0 GV.SC-06: Due diligence on supply chain partners — validate vendor risk management practices, security controls, and ability to meet contractual obligations. (3) DORA Article 28: ICT third-party risk assessment — evaluate the vendor&#39;s ability to meet digital operational resilience requirements, including incident reporting, testing, and exit planning. (4) GDPR Article 28: Verify the vendor&#39;s ability to comply with data processor obligations, including technical and organizational measures, sub-processor management, and data subject rights support. EVIDENCE COLLECTION: (a) Due diligence report covering all OCC 2023-17 assessment dimensions. (b) Financial stability analysis (credit reports, audited financials, going-concern assessment). (c) Legal standing verification (litigation history, regulatory actions, sanctions screening). (d) Business continuity and disaster recovery plan review results. (e) Fourth-party (sub-contractor) risk assessment. (f) Regulatory compliance history check. (g) On-site or virtual assessment results (if conducted). DATA POINTS: Due diligence scope (dimensions assessed), risk tier confirmed, financial stability rating, litigation/regulatory action history, BCP/DR test results and dates, sub-contractor count and risk assessment, overall due diligence rating (pass/conditional/fail), conditions for proceeding (if any), due diligence completion date." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM7</bpmn:incoming>
      <bpmn:outgoing>Flow_PM8</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_DefineBuildReqs" name="Define Build&#10;Requirements" camunda:candidateGroups="governance-lane">
      <bpmn:documentation>Define comprehensive build requirements for the Build pathway including functional specifications, non-functional requirements (performance, scalability, security, availability), architecture constraints, integration specifications, data model requirements, and acceptance criteria. Establish the product backlog, define MVP scope, and document technology stack decisions. Requirements must address security, compliance, and data protection from inception.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 40: If the build involves third-party components, libraries, or cloud services, each must be evaluated under the third-party risk management framework. Open-source components require license compliance and vulnerability assessment. (2) NIST CSF 2.0 PR.PS (Platform Security): Security requirements must be defined as part of the build specification — secure coding standards, authentication requirements, encryption standards, and logging requirements. (3) GDPR Article 25: Data protection by design and by default — privacy requirements must be embedded in the build specifications from the outset, not retrofitted. Data minimization, purpose limitation, and retention policies must be defined. (4) SOX Section 404: If the build touches financial data or controls, segregation of duties, access controls, and audit logging requirements must be specified. EVIDENCE COLLECTION: (a) Functional requirements specification document with acceptance criteria. (b) Non-functional requirements document (performance targets, scalability requirements, availability SLA). (c) Security requirements checklist (authentication, authorization, encryption, logging, vulnerability management). (d) Architecture decision records (ADRs) for key technology choices. (e) Data protection requirements including DPIA results if applicable. (f) Third-party component inventory (libraries, frameworks, cloud services) with license types. DATA POINTS: Total requirements count (functional + non-functional), security requirements count, data types processed, technology stack selected, estimated development effort (story points or person-days), MVP scope definition, target deployment date, third-party component count, open-source license types, DPIA required (yes/no)." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM_Build</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_BuildMerge</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_TriageSLAEscalation" name="Triage SLA&#10;Escalation">
      <bpmn:incoming>Flow_PM_SLAEsc</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Task_RefineRequirements" name="Refine&#10;Requirements" camunda:candidateGroups="governance-lane">
      <bpmn:documentation>Refine and finalize requirements based on insights from the parallel evaluations and vendor due diligence. Incorporate feedback from Technical Architecture, Security, Risk and Compliance, and Financial analysis streams. Update requirements to address identified gaps, risks, and conditions. Produce the final requirements specification that will guide the Proof of Concept and subsequent contracting or build activities.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 40: Requirements refinement must incorporate all risk and compliance findings from the evaluation streams — security requirements, data protection requirements, audit rights, and regulatory compliance requirements must be explicitly captured in the final specification. (2) NIST CSF 2.0 PR (Protect): Refined requirements must include all identified security and privacy controls as mandatory requirements, not optional. (3) GDPR Article 25: Data protection by design — refined requirements must embed privacy requirements identified during the compliance evaluation. EVIDENCE COLLECTION: (a) Requirements change log documenting what was added, modified, or removed based on evaluation findings. (b) Traceability matrix linking evaluation findings to updated requirements. (c) Final requirements specification document (versioned and approved). (d) Sign-off from evaluation stream leads confirming their findings are reflected. DATA POINTS: Original requirements count, refined requirements count, requirements added from security stream, requirements added from compliance stream, requirements added from technical stream, critical requirements identified, requirements approval date, version number." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM_SelYes</bpmn:incoming>
      <bpmn:outgoing>Flow_PM10</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_PerformPoC" name="Perform Proof&#10;of Concept (PoC)" camunda:candidateGroups="technical-assessment">
      <bpmn:documentation>Execute a structured Proof of Concept to validate the proposed solution against refined requirements in a controlled environment. Define PoC success criteria, test scenarios, evaluation metrics, and timeline. For Buy pathway, conduct a guided evaluation with the vendor's solution; for Build pathway, develop a prototype demonstrating key architectural decisions. Document results against predefined acceptance criteria.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 45: PoC environments must not use production data unless properly anonymized or pseudonymized. If vendor access is required, PoC-specific access controls and NDAs must be in place. (2) GDPR Article 5: Data minimization — PoC must use synthetic or anonymized data. If real data is necessary, a data protection assessment must be completed and documented. (3) NIST CSF 2.0 PR.DS: Data security controls must be applied to the PoC environment, including encryption, access controls, and audit logging. PoC environments must be decommissioned after evaluation. (4) DORA Article 9: ICT testing — PoC should validate resilience characteristics (failover, recovery) where feasible. EVIDENCE COLLECTION: (a) PoC plan with defined success criteria, test scenarios, and evaluation metrics. (b) PoC results report with pass/fail against each success criterion. (c) Performance test results (response times, throughput, resource utilization). (d) Integration test results with existing enterprise systems. (e) Data handling confirmation (synthetic data used or DPIA completed). (f) PoC environment decommission confirmation. DATA POINTS: PoC duration (days), success criteria count, criteria met/not met, performance benchmarks achieved, integration tests passed/failed, key findings and limitations discovered, go/no-go recommendation, evaluator sign-offs, PoC environment decommission date." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM10</bpmn:incoming>
      <bpmn:outgoing>Flow_PM11</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_TechRiskEval" name="Technology and&#10;Risk Evaluation" camunda:candidateGroups="technical-assessment">
      <bpmn:documentation>Conduct a consolidated technology and risk evaluation synthesizing results from all prior assessment activities — PoC findings, parallel evaluations, and due diligence results. Produce a final risk-rated assessment determining whether the solution meets the organization's risk appetite and technology standards. This is the final technical gate before the Evaluation Approved decision point.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 55: Consolidated risk assessment — all evaluation dimensions must be synthesized into a single risk-rated view. Residual risks must be documented with accepted risk levels and compensating controls. (2) NIST CSF 2.0 ID.RA (Risk Assessment): Formal risk assessment following a structured methodology — identify threats, vulnerabilities, likelihood, and impact. Risk ratings must use the organization&#39;s standard risk taxonomy. (3) DORA Article 5: ICT risk management — the evaluation must assess the solution&#39;s impact on the organization&#39;s overall digital operational resilience posture. (4) SOX Section 404: If the solution affects financial controls, the risk evaluation must specifically address control effectiveness, segregation of duties, and audit trail adequacy. EVIDENCE COLLECTION: (a) Consolidated technology and risk evaluation report with overall risk rating. (b) Risk register entries for all identified residual risks with owners, mitigations, and accepted risk levels. (c) PoC results summary incorporated into the evaluation. (d) Compensating controls matrix for accepted risks. (e) Go/no-go recommendation with supporting rationale. (f) Evaluation committee sign-off. DATA POINTS: Overall risk rating (Critical/High/Medium/Low), residual risks count by severity, compensating controls count, PoC success rate, evaluation committee vote (approve/reject), conditions attached (if any), risk acceptance authority (who approved residual risks), evaluation completion date." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM11</bpmn:incoming>
      <bpmn:outgoing>Flow_PM12</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_EvalApproved" name="Evaluation&#10;Approved?">
      <bpmn:incoming>Flow_PM12</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_EvalYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_PM_EvalNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_VendorSelected" name="Vendor&#10;Selected?">
      <bpmn:incoming>Flow_PM9</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_SelYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_PM_SelNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:startEvent id="Start_SoftwareNeed" name="Software need&#10;defined">
      <bpmn:outgoing>Flow_R1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_ReviewExisting" name="Review existing&#10;solutions" camunda:candidateGroups="business-lane">
      <bpmn:documentation>Review the organization's existing software portfolio and backlog to determine whether current solutions can fulfill the identified business need. Search the enterprise software catalog, asset management system, and approved vendor registry for existing capabilities that overlap with the request. Assess whether existing licenses, modules, or configurations can be leveraged before initiating a new procurement or build effort.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 20: Inventory management — the organization must maintain an accurate inventory of all third-party relationships; this review ensures new requests are checked against the existing portfolio to avoid duplicate vendor relationships and unmanaged concentration risk. (2) NIST CSF 2.0 ID.AM (Asset Management): Verify existing software assets are cataloged, classified, and their capabilities documented to enable effective reuse analysis. (3) SOX Section 404: Ensure any software reuse decision is documented with rationale to maintain an auditable trail of technology decisions impacting financial controls. EVIDENCE COLLECTION: (a) Search results from enterprise software catalog showing existing solutions evaluated. (b) Portfolio overlap analysis documenting how existing tools were assessed against the new requirement. (c) Decision rationale document if existing solution is deemed sufficient (bypass path) or insufficient (proceed to formal process). (d) Asset management system query log showing search criteria used. DATA POINTS: Request description, business unit, existing software matches found (name, version, license status, utilization rate), gap analysis summary (what the existing solution covers vs. what is missing), requester assessment of fit (sufficient/insufficient), estimated cost avoidance if existing solution is leveraged." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_R1</bpmn:incoming>
      <bpmn:outgoing>Flow_R2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_BypassProcess" name="Bypass formal&#10;process?">
      <bpmn:incoming>Flow_R2</bpmn:incoming>
      <bpmn:outgoing>Flow_R_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_R_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_GatherDocs" name="Gather&#10;documentation" camunda:formKey="forms/vendor-intake-form.html#section-1,section-2" camunda:candidateGroups="business-lane">
      <bpmn:documentation>Form: vendor-intake-form.html Sections 1-2 (Request Basics + Governance) — business persona view. Assemble all documentation required to support a formal software request submission. Gather business requirements, use cases, stakeholder sign-offs, budget authorization, data classification assessment, and any preliminary market research. Ensure the request package is complete per the standardized intake template to prevent delays during triage. Information collected here is centralized and reused throughout the lifecycle.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 25: Needs assessment documentation — the business case must articulate the need, alternatives considered, and alignment with the organization&#39;s strategic plan. This documentation becomes part of the regulatory examination file for third-party risk management. (2) GDPR Article 35/CCPA: If the software will process personal data, a preliminary Data Protection Impact Assessment (DPIA) screening should be initiated at this stage to identify high-risk processing activities early. (3) SOX Section 404: Budget authorization and financial justification must follow the organization&#39;s delegated authority matrix and be documented for audit trail purposes. (4) NIST CSF 2.0 GV.RM (Risk Management Strategy): Preliminary risk indicators should be captured to enable early risk tier estimation. EVIDENCE COLLECTION: (a) Completed software request intake form per standardized template. (b) Business requirements document with use cases and success criteria. (c) Stakeholder sign-off confirming business need and sponsorship. (d) Budget authorization or funding source identification. (e) Preliminary data classification assessment (what data types will the software process). (f) Market research or preliminary vendor identification (if available). (g) DPIA screening questionnaire (if personal data processing is involved). DATA POINTS: Business unit, cost center, budget amount authorized, expected user count, data types to be processed (PII, PHI, financial, public), deployment model preference (cloud/on-premise/hybrid), integration requirements with existing systems, urgency level, strategic alignment score, compliance requirements identified." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_R_No</bpmn:incoming>
      <bpmn:outgoing>Flow_R3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_SubmitRequest" name="Submit software&#10;request" camunda:formKey="forms/vendor-intake-form.html#section-5" camunda:candidateGroups="business-lane">
      <bpmn:documentation>Form: vendor-intake-form.html Section 5 (Review and Submit). Submit the completed software request package to the Product Management team for formal triage and evaluation. The submission must include all required documentation per the intake template. Upon submission, the request is assigned a tracking number and enters the governance workflow with full audit trail from this point forward.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 25: Formal submission creates the official record of the third-party engagement request — this is the point at which the governance audit trail formally begins. The submission must be timestamped and immutable once submitted. (2) NIST CSF 2.0 GV.OC (Organizational Context): The request must capture sufficient context about the business need, data sensitivity, and operational criticality to enable accurate downstream risk assessment and pathway routing. (3) SOX Section 302: The submitting business owner certifies the accuracy and completeness of the request documentation, creating accountability for the information provided. EVIDENCE COLLECTION: (a) Submitted request package with timestamp, submitter identity, and completeness validation result. (b) Tracking number assignment confirmation. (c) Acknowledgment receipt from Product Management confirming request received. (d) Completeness check result (all required fields populated per intake template). (e) Submitter certification that information is accurate and complete. DATA POINTS: Request tracking number, submission timestamp, submitter name and role, business unit, completeness score (percentage of template fields populated), attachments list, priority requested by business, estimated annual cost, data classification summary." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_R3</bpmn:incoming>
      <bpmn:outgoing>Flow_R_ToTriage</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_LeverageExisting" name="Leverage existing&#10;software" camunda:candidateGroups="business-lane">
      <bpmn:documentation>Configure, extend, or activate existing software capabilities to meet the identified business need without initiating a new procurement. This may involve enabling dormant modules, adjusting configurations, requesting additional user licenses, or integrating existing tools in a new workflow. Document the reuse decision and update the software asset register to reflect the expanded usage scope.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 20: Even when leveraging existing software, the expanded scope of use must be evaluated for any change in risk profile — if the existing vendor relationship is being extended to new data types, business functions, or user populations, the third-party risk assessment may need updating. (2) NIST CSF 2.0 PR.DS (Data Security): Ensure data protection controls remain adequate for the expanded use case — new data flows or user populations may require additional access controls or encryption. (3) SOX Section 404: Document the decision to reuse existing software with clear rationale, cost avoidance calculation, and any changes to financial control configurations. EVIDENCE COLLECTION: (a) Reuse decision document with business justification and cost avoidance estimate. (b) Updated software asset register entry reflecting expanded scope. (c) License compliance verification confirming sufficient licenses for expanded use. (d) Configuration change request (if applicable) with approval chain. (e) Risk assessment delta — confirmation that expanded use does not change the vendor&#39;s risk tier. DATA POINTS: Existing software name and version, current license count vs. required, configuration changes needed, estimated cost avoidance vs. new procurement, risk tier impact assessment (no change/escalation needed), expanded user population scope, new data types introduced (if any)." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_R_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_R_EndLeverage</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_Leveraged" name="Software&#10;Leveraged">
      <bpmn:incoming>Flow_R_EndLeverage</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Rejected" name="Request&#10;Rejected">
      <bpmn:incoming>Flow_PM_Reject</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_EvalRejected" name="Evaluation&#10;Failed">
      <bpmn:incoming>Flow_PM_EvalNo</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_PathwayExec" name="Pathway&#10;Execution">
      <bpmn:incoming>Flow_PM_EvalYes</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_ToBuyExec</bpmn:outgoing>
      <bpmn:outgoing>Flow_PM_ToBuildExec</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_NegotiateContract" name="Negotiate&#10;Contract" camunda:candidateGroups="contracting-lane">
      <bpmn:documentation>Lead contract negotiation with the selected vendor, incorporating all requirements, risk mitigations, and compliance conditions identified during the evaluation process. Negotiate commercial terms, SLAs, data protection provisions, audit rights, termination clauses, liability caps, indemnification, intellectual property rights, and exit/transition assistance. Ensure all OCC 2023-17 required contractual provisions are included. This task triggers the message flow sending the contract draft to the Vendor pool.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Sections 60-70: Mandatory contractual provisions — audit rights (for institution and regulators), subcontracting restrictions, data ownership and return/destruction, business continuity requirements, default and termination provisions, indemnification, insurance requirements, dispute resolution, regulatory compliance representations. All provisions must be present or a documented exception approved by appropriate authority. (2) GDPR Article 28(3): DPA mandatory provisions — processing only on documented instructions, confidentiality obligations, security measures, sub-processor management, data subject rights assistance, breach notification (within 72 hours), deletion/return on termination, audit cooperation. (3) DORA Article 30: ICT contractual provisions — SLA definitions, availability targets, incident notification timelines, audit and access rights, exit strategy and transition assistance, sub-outsourcing governance. (4) SOX Sections 302, 404: Financial controls provisions — audit access, financial reporting cooperation, internal control representations. EVIDENCE COLLECTION: (a) Contract negotiation log documenting positions, counteroffers, and resolutions for each material term. (b) Legal review checklist cross-referenced against OCC 2023-17 Section 60 required provisions. (c) DPA checklist against GDPR Article 28(3) mandatory terms. (d) SLA schedule with measurable targets and remedies. (e) Risk mitigation conditions incorporated from evaluation findings. (f) Approved exceptions with authority sign-off (if any required provisions are modified or waived). DATA POINTS: Negotiation rounds count, material terms negotiated, SLA targets agreed, liability cap amount, indemnification scope, insurance minimums, termination notice period, data return/deletion timeline, audit rights frequency, contract value, contract term." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM_ToBuyExec</bpmn:incoming>
      <bpmn:outgoing>Flow_PM13</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_FinalizeContract" name="Finalize&#10;Contract" camunda:candidateGroups="contracting-lane">
      <bpmn:documentation>Finalize the contract after receiving the vendor's signed counterpart and verifying all negotiated terms are reflected accurately. Confirm all schedules (MSA, SLA, DPA, SOW) are complete and internally consistent. Obtain internal approvals per the delegated authority matrix. Register the executed contract in the contract management system and initiate the vendor onboarding process. This task receives the signed contract message flow from the Vendor pool.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 60: Pre-execution verification — confirm all mandatory provisions are present in the final executed version. No material terms should differ from the negotiated and approved version. (2) SOX Section 302: Internal approval chain completed per delegated authority matrix — contract value determines required approval level (department head, VP, C-suite, board). (3) SEC 17a-4: Executed contract must be stored in a tamper-evident, compliant records retention system with appropriate retention period (7+ years for financial services). (4) GDPR Article 28: Confirm DPA is fully executed before any data processing commences. EVIDENCE COLLECTION: (a) Final executed contract comparison against negotiated terms (no unauthorized changes). (b) Internal approval chain documentation (all required approvals obtained). (c) Contract registration confirmation in contract management system with reference number. (d) Insurance certificate verification (current and meeting contractual minimums). (e) Contract summary memo for governance records. (f) Vendor onboarding trigger confirmation. DATA POINTS: Contract reference number, execution date, effective date, term length, total contract value, approval chain completed (names, dates, authorities), DPA execution confirmed, insurance verified, contract management system registration date, next review date." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM13b</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_BuyExecMerge</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_OnboardSoftware" name="Onboard&#10;Software" camunda:candidateGroups="automation-lane">
      <bpmn:documentation>Execute the technical onboarding of the approved software into the production environment. Provision user accounts, configure access controls, establish monitoring and alerting, update the CMDB and software asset register, deploy to production (for Buy pathway — activate licenses and configure; for Build pathway — promote from staging). Complete the go-live checklist including operational runbook, support handoff, and monitoring baseline establishment.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 80: Ongoing monitoring setup — establish the monitoring framework at onboarding including KRIs, performance metrics, SLA tracking, and escalation thresholds. Add the software/vendor to the third-party inventory with complete metadata. (2) NIST CSF 2.0 PR.AA: Identity and access management — provision user access following least-privilege principle, enforce MFA, configure RBAC per the approved access control design. Schedule periodic access reviews. (3) DORA Article 28: ICT register — add the solution to the organization&#39;s ICT asset register with all mandatory metadata (provider, services, criticality, dependencies). (4) ISO 27001 A.8: Asset management — register the software in the asset management system with owner, classification, and retention requirements. EVIDENCE COLLECTION: (a) Go-live checklist signed off by technical operations, security, and business owner. (b) User provisioning records with access levels documented. (c) CMDB/asset register update confirmation. (d) Monitoring and alerting configuration documentation. (e) Operational runbook and support handoff documentation. (f) Production deployment verification results. (g) Backup and recovery configuration confirmation. DATA POINTS: Go-live date, users provisioned (count), access levels configured, monitoring KRIs established (count), CMDB entry created, operational runbook completed, support team assigned, backup configuration verified, first monitoring baseline captured date." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM_FinalYes</bpmn:incoming>
      <bpmn:outgoing>Flow_PM17</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_MergeExec">
      <bpmn:incoming>Flow_PM_BuyExecMerge</bpmn:incoming>
      <bpmn:incoming>Flow_PM_BuildExecMerge</bpmn:incoming>
      <bpmn:outgoing>Flow_PM14</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_PerformUAT" name="Perform&#10;Pilot / UAT" camunda:candidateGroups="business-lane">
      <bpmn:documentation>Conduct User Acceptance Testing (UAT) or a controlled pilot with representative business users to validate the solution meets business requirements in a production-like environment. Execute predefined UAT test scenarios covering all critical business workflows. Collect user feedback on usability, performance, and completeness. Document defects, change requests, and acceptance decision. UAT sign-off is a prerequisite for final governance approval.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 55: Business validation — the requesting business unit must confirm the solution meets the stated needs and operates as expected before governance approval. This creates accountability at the first line of defense. (2) SOX Section 404: For systems affecting financial controls, UAT must specifically validate control effectiveness — transaction accuracy, access controls, audit trail completeness, and segregation of duties. UAT evidence becomes part of the SOX compliance documentation. (3) GDPR Article 25: Validate privacy controls function as designed — data minimization, consent management, data subject rights (access, deletion, portability), and privacy notice accuracy. (4) NIST CSF 2.0 PR.AT: User training validation — confirm users can operate the system securely and understand their responsibilities. EVIDENCE COLLECTION: (a) UAT plan with test scenarios mapped to business requirements. (b) UAT execution results with pass/fail per scenario. (c) User feedback survey results. (d) Defect log with severity and resolution status. (e) UAT sign-off from business owner and key stakeholders. (f) Training completion records for UAT participants. (g) Change request log (if UAT identified needed modifications). DATA POINTS: UAT scenarios total, pass rate percentage, critical defects found, defects resolved before sign-off, defects deferred (with risk acceptance), user satisfaction score, pilot user count, pilot duration (days), business owner sign-off date, training completion rate." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM14</bpmn:incoming>
      <bpmn:outgoing>Flow_PM15</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_FinalApproval" name="Provide Final&#10;Approval" camunda:candidateGroups="oversight-lane">
      <bpmn:documentation>Third line of defense (Internal Audit/Oversight) provides final governance approval based on the complete evidence package — evaluation results, risk assessment, UAT sign-off, contract execution (for Buy), and compliance verification. This is the last governance gate before software onboarding. The oversight committee reviews the consolidated evidence and either approves, approves with conditions, or rejects the request. Approval authority is commensurate with the risk tier and contract value.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 70: Board or senior management oversight — approval authority for third-party relationships must be commensurate with the risk and complexity. Critical and significant relationships require senior management or board-level approval. (2) NIST CSF 2.0 GV.OV (Oversight): Governance oversight must verify that all risk management activities have been completed satisfactorily. Third line of defense provides independent assurance. (3) SOX Section 302: Management certification — the approving authority certifies that all required due diligence, risk assessment, and compliance activities have been completed and the residual risk is within acceptable limits. (4) DORA Article 5: Management body responsibility — senior management must approve ICT third-party arrangements with appropriate oversight documentation. EVIDENCE COLLECTION: (a) Consolidated approval package including: evaluation results, risk assessment, UAT sign-off, contract summary, compliance verification. (b) Approval decision document with rationale and any conditions. (c) Delegated authority verification (approver has sufficient authority for this risk tier/contract value). (d) Conditions tracker (if approved with conditions — conditions, owners, deadlines). (e) Committee meeting minutes (if committee approval required). DATA POINTS: Approval decision (approve/conditional/reject), approver name and authority level, risk tier confirmed, conditions attached (count and descriptions), committee vote result (if applicable), approval date, conditions deadline dates, evidence package completeness score." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM15</bpmn:incoming>
      <bpmn:outgoing>Flow_PM16</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_CloseRequest" name="Close Request" camunda:candidateGroups="governance-lane">
      <bpmn:documentation>Close the software onboarding request by archiving all decisions, evidence, and artifacts for audit trail and regulatory examination purposes. Confirm the transition to ongoing monitoring and vendor management (for Buy pathway) or operational support (for Build pathway). Update the portfolio and tracking systems. Conduct a brief lessons-learned retrospective to capture process improvement opportunities for future onboarding requests.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 80: Transition to ongoing monitoring — confirm the monitoring cadence is established (references DMN_MonitoringCadenceAssignment), the vendor/software is in the third-party inventory, and the ongoing oversight responsibilities are assigned. (2) SEC 17a-4: Records retention — all onboarding artifacts must be archived in a compliant retention system. The complete audit trail from intake through deployment must be preserved, indexed, and retrievable for regulatory examination. Retention period per organizational policy (typically 7+ years). (3) NIST CSF 2.0 GV.SC-09: Lessons learned — document process improvement opportunities, track recurring issues, and feed improvements back into the onboarding process. (4) SOX Section 404: Confirm audit trail completeness — all decisions, approvals, and evidence must be traceable from request through go-live. EVIDENCE COLLECTION: (a) Request closure confirmation with summary of the complete onboarding journey. (b) Complete evidence archive index (all artifacts cataloged with retention dates). (c) Monitoring transition confirmation (cadence, KRIs, assigned reviewer). (d) Lessons-learned document from the onboarding process. (e) Portfolio and tracking system updates confirmed. (f) Stakeholder notification of successful onboarding completion. DATA POINTS: Total onboarding duration (days), total cost of onboarding process, pathway taken (Buy/Build), risk tier final, monitoring cadence assigned, next scheduled review date, lessons-learned recommendations count, evidence artifacts archived count, request closure date, stakeholders notified." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PM17</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_FinalDecision" name="Approved?">
      <bpmn:incoming>Flow_PM16</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_FinalYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_PM_FinalNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_FinalRejected" name="Request&#10;Denied">
      <bpmn:incoming>Flow_PM_FinalNo</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sendTask id="Activity_0zf4l0g" name="Notify Requester">
      <bpmn:incoming>Flow_PM_End</bpmn:incoming>
      <bpmn:outgoing>Flow_0033t8v</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="End_SoftwareOnboarded" name="Software&#10;Onboarded">
      <bpmn:incoming>Flow_0033t8v</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_VendorNotSelected" name="Vendor&#10;Not Selected">
      <bpmn:incoming>Flow_PM_SelNo</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:subProcess id="SP_PDLC" name="Product Development&#10;Life Cycle">
      <bpmn:incoming>Flow_PM_ToBuildExec</bpmn:incoming>
      <bpmn:outgoing>Flow_PM_BuildExecMerge</bpmn:outgoing>
      <bpmn:startEvent id="PDLC_Start" name="Start">
        <bpmn:outgoing>Flow_PDLC1</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:userTask id="PDLC_ArchReview" name="Architecture&#10;Review" camunda:candidateGroups="technical-assessment">
        <bpmn:documentation>Conduct formal architecture review of the build design before development begins. Validate the proposed architecture against enterprise standards, security requirements, scalability targets, and integration specifications. Review technology stack selections, data model design, API contracts, and infrastructure requirements. Produce an Architecture Decision Record (ADR) for each significant design choice.</bpmn:documentation>
        <bpmn:extensionElements>
          <camunda:properties>
            <camunda:property name="comments" value="REGULATORY CONTROLS: (1) NIST CSF 2.0 PR.PS: Platform security review — validate secure architecture patterns, defense-in-depth design, and secure defaults. (2) GDPR Article 25: Data protection by design — verify privacy-preserving architecture (data minimization, purpose limitation enforced architecturally, encryption at rest and in transit). (3) SOX Section 404: If the build processes financial data, architecture must enforce segregation of duties, audit logging, and data integrity controls. (4) DORA Article 9: ICT resilience by design — verify high availability, failover, and recovery mechanisms are architecturally embedded. EVIDENCE COLLECTION: (a) Architecture review report with findings rated by severity. (b) Architecture Decision Records (ADRs) for key technology and design choices. (c) Security architecture review checklist. (d) Data flow diagram with encryption and access control annotations. (e) Enterprise standards compliance matrix. DATA POINTS: Architecture review findings count (by severity), ADRs produced, enterprise standards compliance percentage, security patterns implemented, data protection mechanisms confirmed, review board approval status." />
          </camunda:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_PDLC1</bpmn:incoming>
        <bpmn:outgoing>Flow_PDLC2</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:userTask id="PDLC_Development" name="Development&#10;and Build" camunda:candidateGroups="technical-assessment">
        <bpmn:documentation>Execute the development and build phase following the approved architecture and refined requirements. Implement using secure coding standards, conduct peer code reviews, maintain automated CI/CD pipelines with quality gates, and track development progress against the product backlog. All third-party libraries and dependencies must be scanned for vulnerabilities and license compliance. Development must follow the organization's SDLC methodology.</bpmn:documentation>
        <bpmn:extensionElements>
          <camunda:properties>
            <camunda:property name="comments" value="REGULATORY CONTROLS: (1) NIST CSF 2.0 PR.PS-01: Secure coding practices — OWASP Top 10 mitigation, input validation, output encoding, parameterized queries, secure authentication/authorization implementation. (2) OCC 2023-17 Section 50: If using open-source or third-party components, each must be assessed for security vulnerabilities (CVE scanning) and license compliance. Software composition analysis (SCA) required. (3) SOX Section 404: Change management controls — all code changes must go through peer review, approval, and be logged with audit trail. Segregation of duties between developer and approver. (4) GDPR Article 25: Privacy by design implementation — data minimization, pseudonymization, encryption, and access controls implemented per the architecture review. EVIDENCE COLLECTION: (a) Code review records (all PRs with reviewer approvals). (b) CI/CD pipeline execution logs with quality gate results. (c) Software composition analysis (SCA) report — third-party dependencies, vulnerabilities, licenses. (d) Static application security testing (SAST) results. (e) Code coverage metrics. (f) Development progress reports against backlog. DATA POINTS: Story points completed, code review approval rate, SAST findings by severity, SCA vulnerabilities found and remediated, code coverage percentage, CI/CD pipeline pass rate, third-party dependency count, open-source license types used, build artifacts versioned and stored." />
          </camunda:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_PDLC2</bpmn:incoming>
        <bpmn:outgoing>Flow_PDLC3</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:userTask id="PDLC_Testing" name="Testing and&#10;Quality Assurance" camunda:candidateGroups="technical-assessment">
        <bpmn:documentation>Execute comprehensive testing and quality assurance activities including functional testing, integration testing, security testing (DAST, penetration testing), performance testing, accessibility testing, and regression testing. Validate all requirements are met per the acceptance criteria. Conduct dynamic application security testing (DAST) and, for high-risk applications, penetration testing. Test results determine whether the build proceeds to integration or loops back for remediation.</bpmn:documentation>
        <bpmn:extensionElements>
          <camunda:properties>
            <camunda:property name="comments" value="REGULATORY CONTROLS: (1) NIST CSF 2.0 DE.CM: Security testing — DAST scanning, penetration testing (for high-risk applications), and vulnerability assessment must be completed before production deployment. All findings must be remediated or accepted with documented risk acceptance. (2) DORA Article 24-27: Digital operational resilience testing — ICT systems must be tested for resilience, including threat-led penetration testing (TLPT) for critical systems. (3) SOX Section 404: Test evidence for systems affecting financial controls must be retained — functional test results demonstrating control effectiveness, access control testing, and data integrity validation. (4) ISO 27001 A.14.2: Security testing in development — verify secure development lifecycle testing requirements are met. EVIDENCE COLLECTION: (a) Test execution report with pass/fail rates across all test types. (b) DAST scan results with remediated findings. (c) Penetration test report (if applicable — required for high-risk applications). (d) Performance test results against defined SLA targets. (e) Accessibility audit results (WCAG 2.1 AA compliance). (f) Regression test suite results. (g) Test coverage metrics (requirements coverage, code coverage). DATA POINTS: Total test cases, pass rate percentage, DAST findings by severity, penetration test findings (if conducted), performance benchmarks met/missed, accessibility compliance score, regression test pass rate, test coverage percentage, defects found by severity, defects resolved vs. deferred." />
          </camunda:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_PDLC3</bpmn:incoming>
        <bpmn:outgoing>Flow_PDLC4</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:exclusiveGateway id="PDLC_GW_TestResult" name="Tests&#10;Passed?">
        <bpmn:incoming>Flow_PDLC4</bpmn:incoming>
        <bpmn:outgoing>Flow_PDLC_Yes</bpmn:outgoing>
        <bpmn:outgoing>Flow_PDLC_No</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:userTask id="PDLC_Integration" name="Integration&#10;and Deployment" camunda:candidateGroups="technical-assessment">
        <bpmn:documentation>Execute integration testing with enterprise systems and deploy the build artifact to the target environment. Validate all integration points function correctly with production-like data. Follow the organization's change management process for deployment — change request, impact assessment, approval, implementation, and post-implementation review. Establish configuration baselines and verify rollback procedures before go-live.</bpmn:documentation>
        <bpmn:extensionElements>
          <camunda:properties>
            <camunda:property name="comments" value="REGULATORY CONTROLS: (1) NIST CSF 2.0 PR.PS-04: Configuration management — establish and document configuration baselines for all deployed components. Enable configuration drift detection. (2) DORA Article 12: ICT change management — all deployment activities must follow formal change management with approval, testing, and rollback capability. Changes must be logged and auditable. (3) ISO 27001 A.12.1.2: Change management controls — formal change request with impact assessment, approval from change advisory board (for significant changes), implementation plan, and post-implementation verification. (4) SOX Section 404: Deployment of systems affecting financial controls requires segregation of duties between development and operations (developer cannot deploy to production). EVIDENCE COLLECTION: (a) Integration test results confirming all enterprise system connections function correctly. (b) Change management request with approvals. (c) Deployment plan and execution log. (d) Configuration baseline snapshot post-deployment. (e) Rollback plan tested and confirmed. (f) Post-implementation verification results. DATA POINTS: Integration points tested (count and pass/fail), change request number, deployment date and duration, deployment method, configuration items deployed, rollback test result, post-implementation verification status, environments deployed to, deployment approval chain." />
          </camunda:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_PDLC_Yes</bpmn:incoming>
        <bpmn:outgoing>Flow_PDLC5</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:endEvent id="PDLC_End" name="PDLC&#10;Complete">
        <bpmn:incoming>Flow_PDLC5</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_PDLC1" sourceRef="PDLC_Start" targetRef="PDLC_ArchReview" />
      <bpmn:sequenceFlow id="Flow_PDLC2" sourceRef="PDLC_ArchReview" targetRef="PDLC_Development" />
      <bpmn:sequenceFlow id="Flow_PDLC3" sourceRef="PDLC_Development" targetRef="PDLC_Testing" />
      <bpmn:sequenceFlow id="Flow_PDLC4" sourceRef="PDLC_Testing" targetRef="PDLC_GW_TestResult" />
      <bpmn:sequenceFlow id="Flow_PDLC_Yes" name="Yes" sourceRef="PDLC_GW_TestResult" targetRef="PDLC_Integration" />
      <bpmn:sequenceFlow id="Flow_PDLC_No" name="No" sourceRef="PDLC_GW_TestResult" targetRef="PDLC_Development" />
      <bpmn:sequenceFlow id="Flow_PDLC5" sourceRef="PDLC_Integration" targetRef="PDLC_End" />
    </bpmn:subProcess>
    <bpmn:receiveTask id="Receive_VendorResponse" name="Await Vendor&#10;Response">
      <bpmn:incoming>Flow_PM8</bpmn:incoming>
      <bpmn:outgoing>Flow_PM8b</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:boundaryEvent id="Timer_VendorResponseSLA" name="5 Day&#10;SLA" cancelActivity="false" attachedToRef="Receive_VendorResponse">
      <bpmn:outgoing>Flow_VendorResponseSLA</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_VendorResponse">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="End_VendorResponseSLABreach" name="Vendor Response&#10;SLA Breach">
      <bpmn:incoming>Flow_VendorResponseSLA</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_VendorResponseSLA" sourceRef="Timer_VendorResponseSLA" targetRef="End_VendorResponseSLABreach" />
    <bpmn:receiveTask id="Receive_SignedContract" name="Await Signed&#10;Contract">
      <bpmn:incoming>Flow_PM13</bpmn:incoming>
      <bpmn:outgoing>Flow_PM13b</bpmn:outgoing>
    </bpmn:receiveTask>
    <bpmn:boundaryEvent id="Timer_ContractSLA" name="7 Day&#10;SLA" cancelActivity="false" attachedToRef="Receive_SignedContract">
      <bpmn:outgoing>Flow_ContractSLA</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_ContractSLA">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P7D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="End_ContractSLABreach" name="Contract&#10;SLA Breach">
      <bpmn:incoming>Flow_ContractSLA</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ContractSLA" sourceRef="Timer_ContractSLA" targetRef="End_ContractSLABreach" />
    <bpmn:boundaryEvent id="Timer_TriageSLA" name="2 Day&#10;SLA" cancelActivity="false" attachedToRef="Task_InitialTriage">
      <bpmn:outgoing>Flow_PM_SLAEsc</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Triage">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P2D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_R_ToTriage" sourceRef="Task_SubmitRequest" targetRef="Task_InitialTriage" />
    <bpmn:sequenceFlow id="Flow_PM2" sourceRef="Task_InitialTriage" targetRef="GW_TriageDecision" />
    <bpmn:sequenceFlow id="Flow_PM_Reject" name="No" sourceRef="GW_TriageDecision" targetRef="End_Rejected" />
    <bpmn:sequenceFlow id="Flow_PM_Approve" name="Yes" sourceRef="GW_TriageDecision" targetRef="Task_PrelimAnalysis" />
    <bpmn:sequenceFlow id="Flow_PM3" sourceRef="Task_PrelimAnalysis" targetRef="GW_NeedsAssessment" />
    <bpmn:sequenceFlow id="Flow_PM_ToBacklog" name="Yes" sourceRef="GW_NeedsAssessment" targetRef="Task_Backlog" />
    <bpmn:sequenceFlow id="Flow_PM_ToPathway" name="No" sourceRef="GW_NeedsAssessment" targetRef="GW_MergeBacklog" />
    <bpmn:sequenceFlow id="Flow_PM_BacklogOut" sourceRef="Task_Backlog" targetRef="GW_MergeBacklog" />
    <bpmn:sequenceFlow id="Flow_PM4" sourceRef="GW_MergeBacklog" targetRef="Task_PathwayRouting" />
    <bpmn:sequenceFlow id="Flow_PM5" sourceRef="Task_PathwayRouting" targetRef="GW_BuyVsBuild" />
    <bpmn:sequenceFlow id="Flow_PM_Buy" name="No" sourceRef="GW_BuyVsBuild" targetRef="GW_MergeBuyBuild" />
    <bpmn:sequenceFlow id="Flow_PM_Build" name="Yes" sourceRef="GW_BuyVsBuild" targetRef="Task_DefineBuildReqs" />
    <bpmn:sequenceFlow id="Flow_PM_Par5" sourceRef="GW_ParallelSplit" targetRef="Task_AssessVendorLandscape" />
    <bpmn:sequenceFlow id="Flow_PM_Par5J" sourceRef="Task_AssessVendorLandscape" targetRef="GW_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_PM_BuildMerge" sourceRef="Task_DefineBuildReqs" targetRef="GW_MergeBuyBuild" />
    <bpmn:sequenceFlow id="Flow_PM6" sourceRef="GW_MergeBuyBuild" targetRef="GW_ParallelSplit" />
    <bpmn:sequenceFlow id="Flow_PM_Par1" sourceRef="GW_ParallelSplit" targetRef="Task_TechArchReview" />
    <bpmn:sequenceFlow id="Flow_PM_Par2" sourceRef="GW_ParallelSplit" targetRef="Task_SecurityAssessment" />
    <bpmn:sequenceFlow id="Flow_PM_Par3" sourceRef="GW_ParallelSplit" targetRef="Task_RiskCompliance" />
    <bpmn:sequenceFlow id="Flow_PM_Par4" sourceRef="GW_ParallelSplit" targetRef="Task_FinancialAnalysis" />
    <bpmn:sequenceFlow id="Flow_PM_Par1J" sourceRef="Task_TechArchReview" targetRef="GW_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_PM_Par2J" sourceRef="Task_SecurityAssessment" targetRef="GW_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_PM_Par3J" sourceRef="Task_RiskCompliance" targetRef="GW_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_PM_Par4J" sourceRef="Task_FinancialAnalysis" targetRef="GW_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_PM7" sourceRef="GW_ParallelJoin" targetRef="Task_VendorDueDiligence" />
    <bpmn:sequenceFlow id="Flow_PM8" sourceRef="Task_VendorDueDiligence" targetRef="Receive_VendorResponse" />
    <bpmn:sequenceFlow id="Flow_PM9" sourceRef="Task_EvaluateVendorResponse" targetRef="GW_VendorSelected" />
    <bpmn:sequenceFlow id="Flow_PM8b" sourceRef="Receive_VendorResponse" targetRef="Task_EvaluateVendorResponse" />
    <bpmn:sequenceFlow id="Flow_PM_SLAEsc" sourceRef="Timer_TriageSLA" targetRef="End_TriageSLAEscalation" />
    <bpmn:sequenceFlow id="Flow_PM_SelYes" name="Yes" sourceRef="GW_VendorSelected" targetRef="Task_RefineRequirements" />
    <bpmn:sequenceFlow id="Flow_PM10" sourceRef="Task_RefineRequirements" targetRef="Task_PerformPoC" />
    <bpmn:sequenceFlow id="Flow_PM11" sourceRef="Task_PerformPoC" targetRef="Task_TechRiskEval" />
    <bpmn:sequenceFlow id="Flow_PM12" sourceRef="Task_TechRiskEval" targetRef="GW_EvalApproved" />
    <bpmn:sequenceFlow id="Flow_PM_EvalYes" name="Yes" sourceRef="GW_EvalApproved" targetRef="GW_PathwayExec" />
    <bpmn:sequenceFlow id="Flow_PM_EvalNo" name="No" sourceRef="GW_EvalApproved" targetRef="End_EvalRejected" />
    <bpmn:sequenceFlow id="Flow_PM_SelNo" name="No" sourceRef="GW_VendorSelected" targetRef="End_VendorNotSelected" />
    <bpmn:sequenceFlow id="Flow_R1" sourceRef="Start_SoftwareNeed" targetRef="Task_ReviewExisting" />
    <bpmn:sequenceFlow id="Flow_R2" sourceRef="Task_ReviewExisting" targetRef="GW_BypassProcess" />
    <bpmn:sequenceFlow id="Flow_R_Yes" name="Yes" sourceRef="GW_BypassProcess" targetRef="Task_LeverageExisting" />
    <bpmn:sequenceFlow id="Flow_R_No" name="No" sourceRef="GW_BypassProcess" targetRef="Task_GatherDocs" />
    <bpmn:sequenceFlow id="Flow_R3" sourceRef="Task_GatherDocs" targetRef="Task_SubmitRequest" />
    <bpmn:sequenceFlow id="Flow_R_EndLeverage" sourceRef="Task_LeverageExisting" targetRef="End_Leveraged" />
    <bpmn:sequenceFlow id="Flow_PM_ToBuyExec" name="Buy" sourceRef="GW_PathwayExec" targetRef="Task_NegotiateContract" />
    <bpmn:sequenceFlow id="Flow_PM_ToBuildExec" name="Build" sourceRef="GW_PathwayExec" targetRef="SP_PDLC" />
    <bpmn:sequenceFlow id="Flow_PM13" sourceRef="Task_NegotiateContract" targetRef="Receive_SignedContract" />
    <bpmn:sequenceFlow id="Flow_PM13b" sourceRef="Receive_SignedContract" targetRef="Task_FinalizeContract" />
    <bpmn:sequenceFlow id="Flow_PM_BuyExecMerge" sourceRef="Task_FinalizeContract" targetRef="GW_MergeExec" />
    <bpmn:sequenceFlow id="Flow_PM_FinalYes" name="Yes" sourceRef="GW_FinalDecision" targetRef="Task_OnboardSoftware" />
    <bpmn:sequenceFlow id="Flow_PM17" sourceRef="Task_OnboardSoftware" targetRef="Task_CloseRequest" />
    <bpmn:sequenceFlow id="Flow_PM_BuildExecMerge" sourceRef="SP_PDLC" targetRef="GW_MergeExec" />
    <bpmn:sequenceFlow id="Flow_PM14" sourceRef="GW_MergeExec" targetRef="Task_PerformUAT" />
    <bpmn:sequenceFlow id="Flow_PM15" sourceRef="Task_PerformUAT" targetRef="Task_FinalApproval" />
    <bpmn:sequenceFlow id="Flow_PM16" sourceRef="Task_FinalApproval" targetRef="GW_FinalDecision" />
    <bpmn:sequenceFlow id="Flow_PM_End" sourceRef="Task_CloseRequest" targetRef="Activity_0zf4l0g" />
    <bpmn:sequenceFlow id="Flow_PM_FinalNo" name="No" sourceRef="GW_FinalDecision" targetRef="End_FinalRejected" />
    <bpmn:sequenceFlow id="Flow_0033t8v" sourceRef="Activity_0zf4l0g" targetRef="End_SoftwareOnboarded" />
  </bpmn:process>
  <bpmn:process id="Process_Vendor" name="Vendor / Third Party" isExecutable="false" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="Start_VendorEngagement" name="Vendor&#10;Engagement&#10;Initiated">
      <bpmn:outgoing>Flow_V1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_VendorEngagement" />
    </bpmn:startEvent>
    <bpmn:userTask id="Task_VendorIntake" name="Vendor&#10;Intake and&#10;Qualification" camunda:formKey="forms/vendor-questionnaire.html#section-1,section-2,section-3" camunda:candidateGroups="vendor-response">
      <bpmn:documentation>Form: vendor-questionnaire.html Sections 1-3 (Basics + Governance + Risk) — vendor persona view, pre-populated with company name and reference number. Screen vendor eligibility and establish baseline qualification before any substantive information exchange begins. Collect vendor legal entity details, ownership structure, financial stability indicators, geographic footprint, and existing certifications. Perform conflict-of-interest screening and preliminary risk tier classification. Verify the vendor is not on any sanctions or exclusion lists. Establish the lawful basis for data collection under applicable privacy regulations.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Sections 30-35: Pre-engagement due diligence requirements — verify vendor identity, assess concentration risk, determine if vendor is critical or significant. (2) NIST CSF 2.0 GV.OC-05: Supply chain risk identification at initial onboarding — document risk factors in the vendor risk register. (3) GDPR Article 6/CCPA: Establish lawful basis before collecting any personal data from or about the vendor; document the legal basis in the processing activities register. EVIDENCE COLLECTION: (a) Completed vendor qualification form with legal entity name, DUNS number, jurisdiction of incorporation. (b) Risk tier pre-assessment worksheet (feeds into DMN_RiskTierClassification). (c) Signed conflict-of-interest declaration from the requesting business unit. (d) Sanctions screening result (OFAC, EU consolidated list). (e) Vendor financial stability indicators (credit rating, annual revenue, years in operation). (f) Proof of insurance certificates (E&#38;O, cyber liability). DATA POINTS: Legal entity name, tax ID, DUNS, ownership structure (UBO disclosure for &#62;25% holders), primary contact, geographic presence, industry certifications held, number of employees, annual revenue range, existing client references in financial services." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_V1</bpmn:incoming>
      <bpmn:outgoing>Flow_V2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_VendorQualified" name="Vendor&#10;Qualified?">
      <bpmn:incoming>Flow_V2</bpmn:incoming>
      <bpmn:outgoing>Flow_V_QualYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_V_QualNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_VendorProposal" name="Vendor&#10;Proposal" camunda:candidateGroups="vendor-response">
      <bpmn:documentation>Vendor prepares and submits a formal commercial and technical proposal in response to the organization's requirements. The proposal must address functional requirements, technical architecture, SLA commitments, pricing model, implementation timeline, and support structure. Vendor should disclose financial stability information, sub-contractor dependencies, and data handling practices. This proposal triggers the parallel evaluation tracks (Security, Compliance, Technical Demo).</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 40: RFP/RFI requirements — vendor must demonstrate capability, financial stability, and willingness to comply with regulatory examination requirements. (2) SOX Section 404: Proposed financial controls and reporting capabilities must be documented in the proposal to ensure auditability of financial data flows. (3) DORA Article 28: ICT third-party provider must assert resilience capabilities, including recovery time objectives, availability targets, and incident notification commitments in the proposal. EVIDENCE COLLECTION: (a) Signed proposal document with commercial terms, technical specifications, and SLA commitments. (b) Vendor capability matrix mapping proposed features to stated requirements. (c) Financial stability disclosures (audited financials, credit references, or parent company guarantee if applicable). (d) Sub-contractor dependency disclosure listing all fourth parties involved in service delivery. (e) Data handling and residency commitments (where data will be processed, stored, and backed up). (f) Implementation timeline with milestones and resource commitments. DATA POINTS: Proposed pricing model (subscription, perpetual, consumption-based), total cost of ownership (TCO) estimate over 3-5 years, SLA targets (uptime, response time, resolution time), proposed technology stack, integration approach, data residency locations, sub-processor list, key personnel assigned, reference customers in regulated industries." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_V_QualYes</bpmn:incoming>
      <bpmn:outgoing>Flow_V3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="GW_VendorParSplit">
      <bpmn:incoming>Flow_V3</bpmn:incoming>
      <bpmn:outgoing>Flow_V_VP1</bpmn:outgoing>
      <bpmn:outgoing>Flow_V_VP2</bpmn:outgoing>
      <bpmn:outgoing>Flow_V_VP3</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="Task_VendorSecurityReview" name="Security&#10;Questionnaire" camunda:formKey="forms/vendor-questionnaire.html#section-4" camunda:candidateGroups="vendor-response">
      <bpmn:documentation>Form: vendor-questionnaire.html Section 4 (Technical and Security) — model security questions. Vendor completes a standardized security questionnaire (HECVAT, SIG, or equivalent) covering information security program maturity, access controls, encryption practices, incident response capabilities, vulnerability management, and business continuity planning. Vendor provides supporting evidence including SOC 2 Type II reports, penetration test summaries, and vulnerability disclosure policies. This runs in parallel with Compliance Documentation and Technical Demonstration.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Sections 50-55: Information security program assessment — evaluate vendor access controls, data handling procedures, encryption at rest and in transit, and incident response readiness. (2) NIST CSF 2.0 PR.AA (Identity Management and Access Control): Assess vendor authentication mechanisms, privileged access management, MFA enforcement. NIST PR.DS (Data Security): Evaluate encryption standards, key management, data classification practices. NIST DE.CM (Continuous Monitoring): Assess vendor logging, monitoring, and alerting capabilities. (3) ISO 27001 Annex A: Map vendor controls to relevant Annex A domains — A.9 Access Control, A.10 Cryptography, A.12 Operations Security, A.16 Incident Management, A.17 Business Continuity. (4) DORA Articles 9, 28: ICT security requirements assessment — verify vendor incident reporting capability within 24-hour notification windows, test resilience measures. EVIDENCE COLLECTION: (a) Completed HECVAT or SIG security questionnaire with all sections addressed. (b) SOC 2 Type II report (current year) or SOC 1 if financial data processing. (c) Most recent penetration test executive summary (within 12 months). (d) Vulnerability disclosure and patch management policy. (e) Business continuity and disaster recovery plan summary with RTO/RPO commitments. (f) Data encryption standards documentation (at rest, in transit, key management). (g) Security incident history disclosure (breaches in past 3 years). DATA POINTS: Security certifications held (ISO 27001, SOC 2, PCI DSS, FedRAMP), encryption algorithms and key lengths, MFA enforcement percentage, mean time to patch critical vulnerabilities, incident response SLA, backup frequency and retention, DR test frequency, security awareness training completion rate." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_V_VP1</bpmn:incoming>
      <bpmn:outgoing>Flow_V_VP1J</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_VendorComplianceReview" name="Compliance&#10;Documentation" camunda:formKey="forms/vendor-questionnaire.html#section-2,section-4" camunda:candidateGroups="vendor-response">
      <bpmn:documentation>Form: vendor-questionnaire.html Section 2 (regulatory questions) + Section 4 (audit readiness). Vendor submits regulatory certifications, compliance attestations, and data protection documentation. This includes proof of regulatory compliance relevant to the services being provided, audit rights confirmation, Data Processing Agreement (DPA) terms, sub-processor disclosures, and data residency documentation. Vendor must demonstrate compliance posture across all applicable regulatory frameworks for the engagement scope.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 55: Regulatory compliance certifications — vendor must confirm willingness to submit to regulatory examination, provide audit rights, and maintain compliance with applicable banking regulations. (2) GDPR Article 28: Data Processing Agreement requirements — vendor must provide draft or executed DPA covering processing purpose limitation, data minimization, security measures, sub-processor authorization, data subject rights support, breach notification obligations, and data return/deletion on termination. CCPA: Vendor must confirm service provider status and data handling restrictions. (3) SOX: External audit independence confirmation if vendor touches financial reporting data; financial controls attestation documenting how vendor safeguards data integrity in financial workflows. (4) DORA Article 30: Contractual arrangements documentation — vendor must disclose full sub-contracting chain, confirm exit strategy feasibility, and demonstrate ability to support regulatory reporting. (5) NIST CSF 2.0 GV.SC-07: Supplier compliance posture documentation — vendor provides evidence of supply chain risk management practices. EVIDENCE COLLECTION: (a) Regulatory certifications (ISO 27001 certificate, SOC 2 Type II report, PCI DSS AOC, FedRAMP authorization as applicable). (b) Signed or draft Data Processing Agreement with all GDPR Article 28(3) provisions addressed. (c) Complete sub-processor list with names, locations, and services provided. (d) Audit rights confirmation letter allowing organization and regulators to examine vendor operations. (e) Data residency documentation confirming where data will be stored, processed, and backed up. (f) Privacy impact assessment or DPIA if high-risk processing is involved. (g) Regulatory examination history disclosure (any enforcement actions, consent orders, or material findings in past 5 years). DATA POINTS: Certifications held and expiry dates, DPA execution status, sub-processor count and jurisdictions, data residency countries, audit rights scope (on-site, remote, frequency), regulatory examination history, privacy officer contact details, data breach notification timeline commitment, data retention and deletion policies." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_V_VP2</bpmn:incoming>
      <bpmn:outgoing>Flow_V_VP2J</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_VendorTechDemo" name="Technical&#10;Demonstration" camunda:formKey="forms/vendor-questionnaire.html#section-4" camunda:candidateGroups="vendor-response">
      <bpmn:documentation>Form: vendor-questionnaire.html Section 4 (integration and MCP questions). Vendor conducts a structured technical demonstration of the proposed solution against predefined evaluation criteria. The demo must cover functional capabilities, integration points, security controls in action, performance under load, failover and recovery mechanisms, and administrative workflows. Evaluators score the demonstration using a standardized scorecard aligned with the requirements from the vendor proposal.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 40: Technology capability validation — demonstration must verify that the vendor&#39;s solution meets the stated technical requirements and can operate within the organization&#39;s technology environment without introducing unacceptable risk. (2) NIST CSF 2.0 PR.PS (Platform Security): Demonstrate secure configuration management, hardening practices, and change management controls during the live demonstration. (3) DORA Article 9: ICT resilience capabilities — vendor must demonstrate failover mechanisms, recovery procedures, and availability targets during the technical demonstration, including simulated failure scenarios where feasible. EVIDENCE COLLECTION: (a) Pre-defined demo script with evaluation criteria mapped to requirements. (b) Completed evaluation scorecard signed by all assessors (Technical Architecture, Security, Business). (c) Architecture diagram reviewed and annotated during the demonstration. (d) Availability and recovery time objective (RTO/RPO) verification results from demonstrated failover. (e) Integration compatibility assessment documenting API standards, authentication methods, and data format compatibility. (f) Performance benchmark results (response times, throughput, concurrent user capacity). (g) Screenshots or recording of key demo scenarios (with vendor consent). DATA POINTS: Demo completion percentage against script, evaluator scores by category (functionality, security, performance, usability, integration), identified gaps or limitations, questions raised and vendor responses, integration complexity assessment (low/medium/high), estimated customization effort, accessibility compliance status (WCAG 2.1 AA if applicable)." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_V_VP3</bpmn:incoming>
      <bpmn:outgoing>Flow_V_VP3J</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="GW_VendorParJoin">
      <bpmn:incoming>Flow_V_VP1J</bpmn:incoming>
      <bpmn:incoming>Flow_V_VP2J</bpmn:incoming>
      <bpmn:incoming>Flow_V_VP3J</bpmn:incoming>
      <bpmn:outgoing>Flow_V4</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="Task_VendorContractReview" name="Vendor Contract&#10;Review" camunda:candidateGroups="vendor-response">
      <bpmn:documentation>Vendor receives the draft contract from the organization's legal/contracting team and performs a thorough review of all terms, conditions, and obligations. The vendor reviews service level commitments, liability provisions, indemnification clauses, audit rights, data protection obligations, termination and exit provisions, intellectual property rights, and regulatory compliance requirements. Vendor provides redlined comments and negotiation positions on any terms requiring modification.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Sections 60-70: Required contractual provisions that must be present and accepted — includes audit rights for the institution and its regulators, subcontracting restrictions and approval requirements, data ownership and return provisions, business continuity and disaster recovery commitments, termination rights (for cause and for convenience), confidentiality obligations, and regulatory compliance representations. (2) SOX Section 302/404: Audit rights and financial controls provisions must be explicitly stated in the contract — vendor must agree to provide access to financial records and cooperate with external auditors as needed. (3) GDPR Article 28(3): Mandatory Data Processing Agreement provisions must be reviewed and confirmed — including processing only on documented instructions, confidentiality obligations, security measures, sub-processor management, data subject rights assistance, breach notification within 72 hours, and data deletion on termination. CCPA service provider contractual requirements. (4) DORA Article 30: Mandatory ICT contractual provisions — SLA definitions with measurable targets, availability guarantees, audit and access rights, exit strategy and transition assistance, incident notification within contractual timeframes, and sub-outsourcing governance. EVIDENCE COLLECTION: (a) Redlined contract document with vendor comments and negotiation positions. (b) Legal review checklist cross-referenced against OCC 2023-17 Section 60 required provisions (all provisions must be present or explicitly waived with justification). (c) DPA review sign-off confirming all GDPR Article 28(3) requirements are addressed. (d) SLA schedule review confirming measurable targets with defined remedies for non-performance. (e) Insurance requirements confirmation (vendor confirms ability to maintain required coverage levels). (f) Escalation matrix and governance structure for contract management. DATA POINTS: Number of redlined clauses, categories of requested changes (commercial, legal, operational, technical), negotiation risk assessment (high/medium/low impact items), estimated time to resolution, vendor authorized negotiator identity and authority level." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_V4</bpmn:incoming>
      <bpmn:outgoing>Flow_V5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_VendorContractSign" name="Contract&#10;Execution" camunda:candidateGroups="vendor-response">
      <bpmn:documentation>Vendor executes (counter-signs) the final negotiated contract, including the master services agreement, all schedules (SLA, DPA, SOW), and any side letters. The authorized signatory must be verified against the vendor's corporate authorization records. Execution must occur before any data processing, system access provisioning, or service delivery begins. The executed contract is the legal prerequisite for all subsequent onboarding activities.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 60: Executed contract must contain all required provisions — no services may commence until the contract is fully executed with all mandatory OCC provisions present. The executed contract becomes part of the regulatory examination file. (2) SOX Section 302: Authorized signatory confirmation — verify the person signing has corporate authority to bind the vendor. Financial controls terms become legally binding upon execution. (3) GDPR Article 28: Executed DPA is a legal prerequisite before any personal data processing begins — the DPA must be in force before data flows are established. CCPA service provider agreement must be executed. (4) DORA Article 30: Fully executed ICT contract with all mandatory DORA provisions — contract must be registered in the ICT third-party provider register upon execution. (5) SEC 17a-4: Records retention — the executed contract must be stored in a compliant, tamper-evident repository with guaranteed retention period (typically 7+ years for financial services). EVIDENCE COLLECTION: (a) Fully executed contract (wet signature or qualified e-signature with timestamp and audit trail). (b) Executed Data Processing Agreement as a separate schedule or standalone document. (c) Authorized signatory verification (corporate resolution, power of attorney, or certificate of authority). (d) Contract reference number assigned and logged in the contract management system. (e) Insurance certificates confirmed as current and meeting contractual minimums. (f) Executed NDA if not already covered by the master agreement. (g) Board or committee approval documentation if the contract exceeds delegated authority thresholds. DATA POINTS: Execution date, contract effective date, contract term (initial + renewal periods), total contract value, authorized signatories (both parties), contract reference number, DPA execution confirmation, insurance coverage verification date, repository location for original documents." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_V5</bpmn:incoming>
      <bpmn:outgoing>Flow_V6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_VendorOnboarding" name="Vendor&#10;Onboarding" camunda:candidateGroups="vendor-response">
      <bpmn:documentation>Vendor is formally onboarded into the organization's ecosystem. This includes provisioning system access on a least-privilege basis, establishing data flows per the DPA, adding the vendor to the third-party risk register and ICT provider inventory, configuring monitoring baselines, and completing knowledge transfer. Vendor completes onboarding checklist items including security awareness acknowledgment, acceptable use policy acceptance, and emergency contact registration.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 80: Ongoing monitoring baseline established — vendor must be added to the third-party inventory with risk tier, criticality designation, and monitoring cadence assigned (references DMN_MonitoringCadenceAssignment). Concentration risk assessment updated. (2) NIST CSF 2.0 PR.AA-05: Vendor access provisioned on least-privilege principle — access scoped strictly to what is required by the contract. Multi-factor authentication enforced for all vendor access. Access reviews scheduled per the monitoring cadence. (3) DORA Article 28: Vendor added to the ICT third-party provider register with all mandatory fields populated (provider name, services, criticality, contract reference, risk assessment date). (4) GDPR/CCPA: Data flows documented in the Record of Processing Activities (ROPA). Processing activities register updated to reflect the new vendor relationship. DPA controls activated and verified (encryption, access controls, breach notification procedures tested). (5) ISO 27001 A.15.1: Information security in supplier relationships — vendor formally enrolled in the supplier management program with defined security requirements, communication channels, and review schedule. EVIDENCE COLLECTION: (a) Vendor entry in the third-party risk register with complete metadata. (b) Access provisioning record documenting specific systems, roles, and permissions granted (least-privilege verification). (c) Updated data flow diagram showing vendor data ingress/egress points. (d) Supplier onboarding checklist signed off by Risk and Governance team. (e) Vendor security awareness acknowledgment and acceptable use policy acceptance. (f) Emergency contact and escalation path registration. (g) Monitoring baseline configuration (KRIs, thresholds, alert recipients). (h) Initial performance baseline metrics captured. DATA POINTS: Systems accessed (list), access level per system, data categories processed, data flow endpoints, monitoring cadence assigned, KRI thresholds configured, onboarding completion date, first scheduled review date, vendor relationship manager assigned, backup contact designated." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_V6</bpmn:incoming>
      <bpmn:outgoing>Flow_V7</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_VendorDeploySupport" name="Deployment&#10;Support" camunda:candidateGroups="vendor-response">
      <bpmn:documentation>Vendor actively supports the deployment and go-live of their product or service within the organization's environment. This includes executing the deployment runbook, configuring production environments, performing data migration (if applicable), conducting smoke testing, establishing configuration baselines, verifying rollback procedures, and providing on-call support during the stabilization period. Vendor must document all deployment activities and configuration changes for audit purposes.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 80: Change management oversight for vendor-involved deployments — all deployment activities must follow the organization&#39;s change management process. Vendor changes are subject to the same approval and documentation requirements as internal changes. (2) NIST CSF 2.0 PR.PS-04: Audit logs generated during deployment — all configuration changes, access events, and deployment actions must be logged with timestamps, actor identification, and before/after state. Configuration baseline established post-deployment for drift detection. (3) DORA Article 12: ICT change management — vendor-supported changes must be covered under resilience testing requirements. Deployment must not compromise operational resilience. Rollback capability must be verified before go-live. (4) ISO 27001 A.12.1.2: Change management controls applied to vendor-assisted deployments — formal change request, impact assessment, approval, implementation, and post-implementation review. EVIDENCE COLLECTION: (a) Vendor-provided deployment runbook with step-by-step procedures. (b) Go-live sign-off record signed by Technical Assessment, Business Owner, and Vendor. (c) Configuration baseline snapshot captured immediately post-deployment. (d) Rollback plan confirmation — tested and verified before production deployment. (e) Deployment log artifact with timestamps, actions taken, personnel involved, and issues encountered. (f) Smoke test results confirming core functionality in production environment. (g) Data migration validation report (if applicable) confirming data integrity and completeness. (h) Post-deployment monitoring dashboard showing system health metrics. DATA POINTS: Deployment date and duration, deployment method (blue-green, rolling, big-bang), environments deployed to, configuration items changed, data migration volume and validation result, smoke test pass/fail results, issues encountered and resolution, rollback test result, stabilization period duration, on-call support contact and schedule." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_V7</bpmn:incoming>
      <bpmn:outgoing>Flow_V8</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_VendorCloseRequest" name="Close Request" camunda:candidateGroups="vendor-response">
      <bpmn:documentation>Vendor confirms engagement completion and provides final deliverables for handoff to ongoing operations and monitoring. This includes archiving all security and compliance evidence, establishing vendor performance baselines for ongoing measurement, completing final documentation, confirming data handling obligations are met, and transitioning to the ongoing monitoring cadence. The vendor engagement moves from active onboarding to steady-state vendor management.</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="comments" value="REGULATORY CONTROLS: (1) OCC 2023-17 Section 80: Transition to ongoing monitoring — vendor performance baseline must be documented and the monitoring cadence formally established (references DMN_MonitoringCadenceAssignment output). The vendor relationship transitions from onboarding oversight to continuous monitoring with defined KRIs, review frequency, and escalation thresholds. (2) NIST CSF 2.0 GV.SC-09: Supplier performance debrief — conduct a lessons-learned review of the onboarding process. Document what worked well, what required remediation, and process improvement recommendations for future vendor onboardings. (3) GDPR/CCPA: Confirm all data processing activities are within contracted scope. Verify no unauthorized residual data is retained by the vendor beyond what is contractually permitted. Processing activities register reflects accurate current state. (4) SEC 17a-4: Engagement records must be closed and archived in a compliant retention system with tamper-evident storage. All onboarding artifacts (contract, assessments, approvals, evidence) must be indexed and retrievable for regulatory examination. Complete audit trail from intake through deployment must be preserved. EVIDENCE COLLECTION: (a) Vendor closure confirmation signed by both parties acknowledging successful onboarding completion. (b) Performance baseline scorecard with initial KRI values and targets. (c) Data handling confirmation letter from vendor attesting compliance with DPA obligations. (d) Complete engagement summary filed to the audit record (includes all artifacts from intake through deployment). (e) Transition to monitoring cadence documented with assigned reviewer, schedule, and escalation path. (f) Lessons learned document from the onboarding process. (g) Updated third-party risk register reflecting steady-state risk tier and monitoring assignment. (h) Contract governance handoff to the ongoing vendor management team. DATA POINTS: Onboarding completion date, total onboarding duration (days), onboarding cost, initial vendor performance score, assigned monitoring cadence (quarterly, semi-annual, annual per DMN output), next scheduled review date, vendor relationship manager for ongoing management, open action items (if any) with owners and due dates, process improvement recommendations count." />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_V8</bpmn:incoming>
      <bpmn:outgoing>Flow_V_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_VendorComplete" name="Vendor&#10;Software&#10;Deployed">
      <bpmn:incoming>Flow_V_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_VendorDisqualified" name="Vendor&#10;Disqualified">
      <bpmn:incoming>Flow_V_QualNo</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_V1" sourceRef="Start_VendorEngagement" targetRef="Task_VendorIntake" />
    <bpmn:sequenceFlow id="Flow_V2" sourceRef="Task_VendorIntake" targetRef="GW_VendorQualified" />
    <bpmn:sequenceFlow id="Flow_V_QualYes" name="Yes" sourceRef="GW_VendorQualified" targetRef="Task_VendorProposal" />
    <bpmn:sequenceFlow id="Flow_V_QualNo" name="No" sourceRef="GW_VendorQualified" targetRef="End_VendorDisqualified" />
    <bpmn:sequenceFlow id="Flow_V3" sourceRef="Task_VendorProposal" targetRef="GW_VendorParSplit" />
    <bpmn:sequenceFlow id="Flow_V_VP1" sourceRef="GW_VendorParSplit" targetRef="Task_VendorSecurityReview" />
    <bpmn:sequenceFlow id="Flow_V_VP2" sourceRef="GW_VendorParSplit" targetRef="Task_VendorComplianceReview" />
    <bpmn:sequenceFlow id="Flow_V_VP3" sourceRef="GW_VendorParSplit" targetRef="Task_VendorTechDemo" />
    <bpmn:sequenceFlow id="Flow_V_VP1J" sourceRef="Task_VendorSecurityReview" targetRef="GW_VendorParJoin" />
    <bpmn:sequenceFlow id="Flow_V_VP2J" sourceRef="Task_VendorComplianceReview" targetRef="GW_VendorParJoin" />
    <bpmn:sequenceFlow id="Flow_V_VP3J" sourceRef="Task_VendorTechDemo" targetRef="GW_VendorParJoin" />
    <bpmn:sequenceFlow id="Flow_V4" sourceRef="GW_VendorParJoin" targetRef="Task_VendorContractReview" />
    <bpmn:sequenceFlow id="Flow_V5" sourceRef="Task_VendorContractReview" targetRef="Task_VendorContractSign" />
    <bpmn:sequenceFlow id="Flow_V6" sourceRef="Task_VendorContractSign" targetRef="Task_VendorOnboarding" />
    <bpmn:sequenceFlow id="Flow_V7" sourceRef="Task_VendorOnboarding" targetRef="Task_VendorDeploySupport" />
    <bpmn:sequenceFlow id="Flow_V8" sourceRef="Task_VendorDeploySupport" targetRef="Task_VendorCloseRequest" />
    <bpmn:sequenceFlow id="Flow_V_End" sourceRef="Task_VendorCloseRequest" targetRef="End_VendorComplete" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_IdealState">
      <bpmndi:BPMNShape id="Participant_ProductMgmt_di" bpmnElement="Participant_ProductMgmt" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="4940" height="1041" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Procurement_di" bpmnElement="Lane_Procurement" isHorizontal="true">
        <dc:Bounds x="190" y="950" width="4910" height="171" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_ProductMgmt_di" bpmnElement="Lane_ProductMgmt" isHorizontal="true">
        <dc:Bounds x="190" y="430" width="4910" height="520" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Requester_di" bpmnElement="Lane_Requester" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="4910" height="350" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_InitialTriage_di" bpmnElement="Task_InitialTriage">
        <dc:Bounds x="890" y="690" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_TriageDecision_di" bpmnElement="GW_TriageDecision" isMarkerVisible="true">
        <dc:Bounds x="1045" y="705" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1042" y="683" width="57" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PrelimAnalysis_di" bpmnElement="Task_PrelimAnalysis">
        <dc:Bounds x="1150" y="690" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_NeedsAssessment_di" bpmnElement="GW_NeedsAssessment" isMarkerVisible="true">
        <dc:Bounds x="1305" y="705" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1297" y="676" width="67" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Backlog_di" bpmnElement="Task_Backlog">
        <dc:Bounds x="1280" y="840" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_MergeBacklog_di" bpmnElement="GW_MergeBacklog" isMarkerVisible="true">
        <dc:Bounds x="1415" y="705" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PathwayRouting_di" bpmnElement="Task_PathwayRouting">
        <dc:Bounds x="1520" y="690" width="100" height="80" />
