        <dc:Bounds x="600" y="90" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Leveraged_di" bpmnElement="EndEvent_Leveraged">
        <dc:Bounds x="762" y="112" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="745" y="155" width="70" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GatherDocumentation_di" bpmnElement="Task_GatherDocumentation">
        <dc:Bounds x="600" y="230" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SubmitSoftwareRequest_di" bpmnElement="Task_SubmitSoftwareRequest">
        <dc:Bounds x="760" y="230" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_RequestClosed_Requester_di" bpmnElement="EndEvent_RequestClosed_Requester">
        <dc:Bounds x="922" y="252" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="910" y="295" width="60" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Participant_ProductManagement_di" bpmnElement="Participant_ProductManagement" isHorizontal="true">
        <dc:Bounds x="160" y="380" width="1900" height="350" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_RequestReceived_di" bpmnElement="StartEvent_RequestReceived">
        <dc:Bounds x="222" y="542" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="210" y="585" width="60" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReviewAndEvaluateRequest_di" bpmnElement="Task_ReviewAndEvaluateRequest">
        <dc:Bounds x="320" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_EvaluateRequest_di" bpmnElement="Gateway_EvaluateRequest" isMarkerVisible="true">
        <dc:Bounds x="485" y="535" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="480" y="498" width="60" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_RequestRejected_di" bpmnElement="EndEvent_RequestRejected">
        <dc:Bounds x="632" y="622" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="620" y="665" width="60" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_BuyVsBuild_di" bpmnElement="Gateway_BuyVsBuild" isMarkerVisible="true">
        <dc:Bounds x="625" y="535" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="618" y="592" width="64" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_BuyPath_di" bpmnElement="Task_BuyPath">
        <dc:Bounds x="740" y="440" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_BuildPath_di" bpmnElement="Task_BuildPath">
        <dc:Bounds x="740" y="620" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_MergePaths_di" bpmnElement="Gateway_MergePaths" isMarkerVisible="true">
        <dc:Bounds x="905" y="535" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PerformPoc_di" bpmnElement="Task_PerformPoc">
        <dc:Bounds x="1020" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RefineRequirements_di" bpmnElement="Task_RefineRequirements">
        <dc:Bounds x="1180" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_TechRiskEval_di" bpmnElement="Task_TechRiskEval">
        <dc:Bounds x="1340" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PerformUAT_di" bpmnElement="Task_PerformUAT">
        <dc:Bounds x="1500" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_OnboardSoftware_di" bpmnElement="Task_OnboardSoftware">
        <dc:Bounds x="1660" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProvideFinalApproval_di" bpmnElement="Task_ProvideFinalApproval">
        <dc:Bounds x="1820" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_SoftwareOnboarded_di" bpmnElement="EndEvent_SoftwareOnboarded">
        <dc:Bounds x="1982" y="542" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1966" y="585" width="68" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="258" y="200" />
        <di:waypoint x="320" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="420" y="200" />
        <di:waypoint x="485" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_LeverageExisting_di" bpmnElement="Flow_LeverageExisting">
        <di:waypoint x="510" y="175" />
        <di:waypoint x="510" y="130" />
        <di:waypoint x="600" y="130" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="518" y="150" width="19" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_NewSoftwareNeeded_di" bpmnElement="Flow_NewSoftwareNeeded">
        <di:waypoint x="510" y="225" />
        <di:waypoint x="510" y="270" />
        <di:waypoint x="600" y="270" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="519" y="245" width="17" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EndLeverage_di" bpmnElement="Flow_EndLeverage">
        <di:waypoint x="700" y="130" />
        <di:waypoint x="762" y="130" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="700" y="270" />
        <di:waypoint x="760" y="270" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToRequesterEnd_di" bpmnElement="Flow_ToRequesterEnd">
        <di:waypoint x="860" y="270" />
        <di:waypoint x="922" y="270" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="258" y="560" />
        <di:waypoint x="320" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="420" y="560" />
        <di:waypoint x="485" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_RejectRequest_di" bpmnElement="Flow_RejectRequest">
        <di:waypoint x="510" y="585" />
        <di:waypoint x="510" y="640" />
        <di:waypoint x="632" y="640" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="518" y="610" width="34" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Continue_di" bpmnElement="Flow_Continue">
        <di:waypoint x="535" y="560" />
        <di:waypoint x="625" y="560" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="557" y="542" width="43" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_BuyPath_di" bpmnElement="Flow_BuyPath">
        <di:waypoint x="650" y="535" />
        <di:waypoint x="650" y="480" />
        <di:waypoint x="740" y="480" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="660" y="505" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_BuildPath_di" bpmnElement="Flow_BuildPath">
        <di:waypoint x="650" y="585" />
        <di:waypoint x="650" y="660" />
        <di:waypoint x="740" y="660" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="659" y="620" width="25" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_BuyConverge_di" bpmnElement="Flow_BuyConverge">
        <di:waypoint x="840" y="480" />
        <di:waypoint x="930" y="480" />
        <di:waypoint x="930" y="535" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_BuildConverge_di" bpmnElement="Flow_BuildConverge">
        <di:waypoint x="840" y="660" />
        <di:waypoint x="930" y="660" />
        <di:waypoint x="930" y="585" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToPoc_di" bpmnElement="Flow_ToPoc">
        <di:waypoint x="955" y="560" />
        <di:waypoint x="1020" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToRefineReq_di" bpmnElement="Flow_ToRefineReq">
        <di:waypoint x="1120" y="560" />
        <di:waypoint x="1180" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToTechRiskEval_di" bpmnElement="Flow_ToTechRiskEval">
        <di:waypoint x="1280" y="560" />
        <di:waypoint x="1340" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToUat_di" bpmnElement="Flow_ToUat">
        <di:waypoint x="1440" y="560" />
        <di:waypoint x="1500" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToOnboard_di" bpmnElement="Flow_ToOnboard">
        <di:waypoint x="1600" y="560" />
        <di:waypoint x="1660" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToFinalApproval_di" bpmnElement="Flow_ToFinalApproval">
        <di:waypoint x="1760" y="560" />
        <di:waypoint x="1820" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToEnd_di" bpmnElement="Flow_ToEnd">
        <di:waypoint x="1920" y="560" />
        <di:waypoint x="1982" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Message_SubmitRequest_di" bpmnElement="Flow_Message_SubmitRequest">
        <di:waypoint x="810" y="310" />
        <di:waypoint x="810" y="430" />
        <di:waypoint x="240" y="430" />
        <di:waypoint x="240" y="542" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
