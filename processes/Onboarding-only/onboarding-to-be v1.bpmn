<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_1"
  targetNamespace="http://bpmn.io/schema/bpmn"
  exporter="Camunda Modeler"
  exporterVersion="5.25.0">

  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_SoftwareRequester" name="Software Requester" processRef="Process_SoftwareRequester" />
    <bpmn:participant id="Participant_ProductManagement" name="Product Management" processRef="Process_ProductManagement" />
    <bpmn:messageFlow id="Flow_Message_SubmitRequest" sourceRef="Task_SubmitSoftwareRequest" targetRef="StartEvent_RequestReceived" />
  </bpmn:collaboration>

  <bpmn:process id="Process_SoftwareRequester" isExecutable="false">
    <bpmn:startEvent id="StartEvent_SoftwareDefined" name="Software need&#10;defined">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_ReviewExistingSolutions" name="Review existing&#10;solutions">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_BypassProcess" name="Bypass formal&#10;process?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_LeverageExisting</bpmn:outgoing>
      <bpmn:outgoing>Flow_NewSoftwareNeeded</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_LeverageExistingSoftware" name="Leverage existing&#10;software">
      <bpmn:incoming>Flow_LeverageExisting</bpmn:incoming>
      <bpmn:outgoing>Flow_EndLeverage</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_Leveraged" name="Software&#10;Leveraged">
      <bpmn:incoming>Flow_EndLeverage</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Task_GatherDocumentation" name="Gather&#10;documentation">
      <bpmn:incoming>Flow_NewSoftwareNeeded</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_SubmitSoftwareRequest" name="Submit software&#10;request">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_ToRequesterEnd</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_RequestClosed_Requester" name="Request&#10;Submitted">
      <bpmn:incoming>Flow_ToRequesterEnd</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_SoftwareDefined" targetRef="Task_ReviewExistingSolutions" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_ReviewExistingSolutions" targetRef="Gateway_BypassProcess" />
    <bpmn:sequenceFlow id="Flow_LeverageExisting" name="Yes" sourceRef="Gateway_BypassProcess" targetRef="Task_LeverageExistingSoftware" />
    <bpmn:sequenceFlow id="Flow_NewSoftwareNeeded" name="No" sourceRef="Gateway_BypassProcess" targetRef="Task_GatherDocumentation" />
    <bpmn:sequenceFlow id="Flow_EndLeverage" sourceRef="Task_LeverageExistingSoftware" targetRef="EndEvent_Leveraged" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_GatherDocumentation" targetRef="Task_SubmitSoftwareRequest" />
    <bpmn:sequenceFlow id="Flow_ToRequesterEnd" sourceRef="Task_SubmitSoftwareRequest" targetRef="EndEvent_RequestClosed_Requester" />
  </bpmn:process>

  <bpmn:process id="Process_ProductManagement" isExecutable="true">
    <bpmn:startEvent id="StartEvent_RequestReceived" name="Request&#10;Received">
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_ReviewAndEvaluateRequest" name="Initial Triage&#10;and Evaluation">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_EvaluateRequest" name="Triage&#10;Decision">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_RejectRequest</bpmn:outgoing>
      <bpmn:outgoing>Flow_Continue</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_RequestRejected" name="Request&#10;Rejected">
      <bpmn:incoming>Flow_RejectRequest</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_BuyVsBuild" name="Buy vs.&#10;Build">
      <bpmn:incoming>Flow_Continue</bpmn:incoming>
      <bpmn:outgoing>Flow_BuyPath</bpmn:outgoing>
      <bpmn:outgoing>Flow_BuildPath</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_BuyPath" name="Assess Vendor&#10;Landscape (Buy)">
      <bpmn:incoming>Flow_BuyPath</bpmn:incoming>
      <bpmn:outgoing>Flow_BuyConverge</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_BuildPath" name="Integrate into&#10;Production Plan (Build)">
      <bpmn:incoming>Flow_BuildPath</bpmn:incoming>
      <bpmn:outgoing>Flow_BuildConverge</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_MergePaths">
      <bpmn:incoming>Flow_BuyConverge</bpmn:incoming>
      <bpmn:incoming>Flow_BuildConverge</bpmn:incoming>
      <bpmn:outgoing>Flow_ToPoc</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_PerformPoc" name="Perform Proof&#10;of Concept (PoC)">
      <bpmn:incoming>Flow_ToPoc</bpmn:incoming>
      <bpmn:outgoing>Flow_ToRefineReq</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_RefineRequirements" name="Refine&#10;Requirements">
      <bpmn:incoming>Flow_ToRefineReq</bpmn:incoming>
      <bpmn:outgoing>Flow_ToTechRiskEval</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:task id="Task_TechRiskEval" name="Technology and&#10;Risk Evaluation">
      <bpmn:incoming>Flow_ToTechRiskEval</bpmn:incoming>
      <bpmn:outgoing>Flow_ToUat</bpmn:outgoing>
    </bpmn:task>
    <bpmn:userTask id="Task_PerformUAT" name="Perform&#10;Pilot / UAT">
      <bpmn:incoming>Flow_ToUat</bpmn:incoming>
      <bpmn:outgoing>Flow_ToOnboard</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:task id="Task_OnboardSoftware" name="Onboard Software&#10;and Negotiate">
      <bpmn:incoming>Flow_ToOnboard</bpmn:incoming>
      <bpmn:outgoing>Flow_ToFinalApproval</bpmn:outgoing>
    </bpmn:task>
    <bpmn:userTask id="Task_ProvideFinalApproval" name="Provide Final&#10;Approval">
      <bpmn:incoming>Flow_ToFinalApproval</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEnd</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_SoftwareOnboarded" name="Software&#10;Onboarded">
      <bpmn:incoming>Flow_ToEnd</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_4" sourceRef="StartEvent_RequestReceived" targetRef="Task_ReviewAndEvaluateRequest" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_ReviewAndEvaluateRequest" targetRef="Gateway_EvaluateRequest" />
    <bpmn:sequenceFlow id="Flow_RejectRequest" name="Reject" sourceRef="Gateway_EvaluateRequest" targetRef="EndEvent_RequestRejected" />
    <bpmn:sequenceFlow id="Flow_Continue" name="Approve" sourceRef="Gateway_EvaluateRequest" targetRef="Gateway_BuyVsBuild" />
    <bpmn:sequenceFlow id="Flow_BuyPath" name="Buy" sourceRef="Gateway_BuyVsBuild" targetRef="Task_BuyPath" />
    <bpmn:sequenceFlow id="Flow_BuildPath" name="Build" sourceRef="Gateway_BuyVsBuild" targetRef="Task_BuildPath" />
    <bpmn:sequenceFlow id="Flow_BuyConverge" sourceRef="Task_BuyPath" targetRef="Gateway_MergePaths" />
    <bpmn:sequenceFlow id="Flow_BuildConverge" sourceRef="Task_BuildPath" targetRef="Gateway_MergePaths" />
    <bpmn:sequenceFlow id="Flow_ToPoc" sourceRef="Gateway_MergePaths" targetRef="Task_PerformPoc" />
    <bpmn:sequenceFlow id="Flow_ToRefineReq" sourceRef="Task_PerformPoc" targetRef="Task_RefineRequirements" />
    <bpmn:sequenceFlow id="Flow_ToTechRiskEval" sourceRef="Task_RefineRequirements" targetRef="Task_TechRiskEval" />
    <bpmn:sequenceFlow id="Flow_ToUat" sourceRef="Task_TechRiskEval" targetRef="Task_PerformUAT" />
    <bpmn:sequenceFlow id="Flow_ToOnboard" sourceRef="Task_PerformUAT" targetRef="Task_OnboardSoftware" />
    <bpmn:sequenceFlow id="Flow_ToFinalApproval" sourceRef="Task_OnboardSoftware" targetRef="Task_ProvideFinalApproval" />
    <bpmn:sequenceFlow id="Flow_ToEnd" sourceRef="Task_ProvideFinalApproval" targetRef="EndEvent_SoftwareOnboarded" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="Participant_SoftwareRequester_di" bpmnElement="Participant_SoftwareRequester" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1050" height="250" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_SoftwareDefined_di" bpmnElement="StartEvent_SoftwareDefined">
        <dc:Bounds x="222" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="202" y="225" width="77" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReviewExistingSolutions_di" bpmnElement="Task_ReviewExistingSolutions">
        <dc:Bounds x="320" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_BypassProcess_di" bpmnElement="Gateway_BypassProcess" isMarkerVisible="true">
        <dc:Bounds x="485" y="175" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="468" y="138" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
