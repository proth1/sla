        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_SP3_Complete_di" bpmnElement="EndEvent_SP3_Complete">
        <dc:Bounds x="620" y="389" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="604" y="432" width="68" height="27" />
