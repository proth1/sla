      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="SubProcess_SP4_RegulatoryChange_di" bpmnElement="SubProcess_SP4_RegulatoryChange" isExpanded="false">
        <dc:Bounds x="450" y="497" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_SP4_Complete_di" bpmnElement="EndEvent_SP4_Complete">
        <dc:Bounds x="620" y="519" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="604" y="562" width="68" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="SubProcess_SP5_ContinuousImprovement_di" bpmnElement="SubProcess_SP5_ContinuousImprovement" isExpanded="false">
        <dc:Bounds x="450" y="614" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_SP5_Complete_di" bpmnElement="EndEvent_SP5_Complete">
        <dc:Bounds x="620" y="636" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="604" y="679" width="68" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_Fork_di" bpmnElement="Flow_Start_Fork">
        <di:waypoint x="284" y="654" />
