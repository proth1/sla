<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_Phase4"
                  targetNamespace="http://sla.governance/bpmn"
                  exporter="Camunda Modeler"
                  exporterVersion="5.42.0">

  <bpmn:collaboration id="Collaboration_Phase4">
    <bpmn:participant id="Participant_Phase4" name="Phase 4: Portfolio Prioritization, Go/No-Go &amp; Buy vs Build" processRef="Process_PortfolioPrioritization" />
  </bpmn:collaboration>

  <bpmn:process id="Process_PortfolioPrioritization" name="Phase 4: Portfolio Prioritization, Go/No-Go, and Buy vs Build" isExecutable="false" camunda:historyTimeToLive="180">

    <bpmn:laneSet id="LaneSet_Phase4">
      <bpmn:lane id="Lane_GB_P4" name="Governance Board">
        <bpmn:flowNodeRef>Task_PortfolioCouncilReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DMN04_GoNoGo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_GoNoGo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ExecutiveSponsorSignOff</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PhaseTransitionP4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Phase4Complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_GoNoGoRejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_BO_P4" name="Business Owner">
        <bpmn:flowNodeRef>StartEvent_Phase4Initiated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GovernancePackageAssembly</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DecisionDocumentation</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ITA_P4" name="IT Architecture">
        <bpmn:flowNodeRef>Task_StrategicAlignmentScoring</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CapacityPlanningReview</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Proc_P4" name="Procurement">
        <bpmn:flowNodeRef>Task_DMN05_BuyVsBuild</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_BuyOrBuild</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VendorSourceStrategy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_BuildPlanInit</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_LC_P4" name="Legal &amp; Compliance">
        <bpmn:flowNodeRef>Task_ComplianceGateP4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ComplianceGate</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_IS_P4" name="Information Security">
        <bpmn:flowNodeRef>Task_FinancialImpactModel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RiskAcceptanceDecision</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_VM_P4" name="Vendor Management">
        <bpmn:flowNodeRef>Task_PortfolioPrioritizationScore</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SequencingDecision</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Phase4Initiated" name="Phase 3 Complete&#10;(Portfolio Entry)">
      <bpmn:outgoing>Flow_Start_GovPackage</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_GovernancePackageAssembly" name="Governance Package&#10;Assembly (DMN Outputs,&#10;Risk Scores, ADR)" camunda:type="external" camunda:topic="governance-package">
      <bpmn:incoming>Flow_Start_GovPackage</bpmn:incoming>
      <bpmn:outgoing>Flow_GovPackage_StrategicAlign</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_StrategicAlignmentScoring" name="Strategic Alignment&#10;Scoring (Enterprise&#10;Strategy Pillars)" camunda:type="external" camunda:topic="strategic-scoring">
      <bpmn:incoming>Flow_GovPackage_StrategicAlign</bpmn:incoming>
      <bpmn:outgoing>Flow_StrategicAlign_FinancialModel</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_FinancialImpactModel" name="Financial Impact&#10;Modeling (TCO, ROI,&#10;Payback Period)" camunda:type="external" camunda:topic="financial-modeling">
      <bpmn:incoming>Flow_StrategicAlign_FinancialModel</bpmn:incoming>
      <bpmn:outgoing>Flow_FinancialModel_PortfolioScore</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_PortfolioPrioritizationScore" name="Portfolio Prioritization&#10;Score (Weighted Matrix)" camunda:type="external" camunda:topic="portfolio-scoring">
      <bpmn:incoming>Flow_FinancialModel_PortfolioScore</bpmn:incoming>
      <bpmn:outgoing>Flow_PortfolioScore_CouncilReview</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_PortfolioCouncilReview" name="Portfolio Governance&#10;Council Review (Cross-Functional)" camunda:candidateGroups="sla-governance-board">
      <bpmn:incoming>Flow_PortfolioScore_CouncilReview</bpmn:incoming>
      <bpmn:outgoing>Flow_CouncilReview_DMN04</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Timer_CouncilReviewSLA" attachedToRef="Task_PortfolioCouncilReview" cancelActivity="false">
      <bpmn:outgoing>Flow_CouncilSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_CouncilReview">
        <bpmn:timeDuration>P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:businessRuleTask id="Task_DMN04_GoNoGo" name="DMN-04: Go/No-Go&#10;Viability Decision" camunda:decisionRef="DMN_04_GoNoGoViability" camunda:resultVariable="goNoGoDecision" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>Flow_CouncilReview_DMN04</bpmn:incoming>
      <bpmn:outgoing>Flow_DMN04_Gateway</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_GoNoGo" name="Go / No-Go?" default="Flow_GoDecision">
      <bpmn:incoming>Flow_DMN04_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_NoGoDecision</bpmn:outgoing>
      <bpmn:outgoing>Flow_GoDecision</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_GoNoGoRejected" name="Go/No-Go Rejected&#10;(Initiative Closed)">
      <bpmn:incoming>Flow_NoGoDecision</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_ComplianceGateP4" name="Compliance Gate&#10;(Regulatory Requirements&#10;Validation)" camunda:type="external" camunda:topic="compliance-gate">
      <bpmn:incoming>Flow_GoDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_ComplianceGate_Gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_ComplianceGate" name="Compliance&#10;Gate Passed?" default="Flow_CompliancePass">
      <bpmn:incoming>Flow_ComplianceGate_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_ComplianceFail</bpmn:outgoing>
      <bpmn:outgoing>Flow_CompliancePass</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_RiskAcceptanceDecision" name="Risk Acceptance&#10;Decision (Override with&#10;Documented Rationale)" camunda:candidateGroups="information-security">
      <bpmn:incoming>Flow_ComplianceFail</bpmn:incoming>
      <bpmn:outgoing>Flow_RiskAccept_DMN05</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:businessRuleTask id="Task_DMN05_BuyVsBuild" name="DMN-05: Buy vs Build&#10;Decision" camunda:decisionRef="DMN_05_BuyVsBuild" camunda:resultVariable="buyOrBuildDecision" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>Flow_CompliancePass</bpmn:incoming>
      <bpmn:incoming>Flow_RiskAccept_DMN05</bpmn:incoming>
      <bpmn:outgoing>Flow_DMN05_Gateway</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_BuyOrBuild" name="Buy or Build?" default="Flow_BuyPath">
      <bpmn:incoming>Flow_DMN05_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_BuyPath</bpmn:outgoing>
      <bpmn:outgoing>Flow_BuildPath</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_VendorSourceStrategy" name="Vendor Sourcing&#10;Strategy (RFP or Direct)" camunda:candidateGroups="procurement">
      <bpmn:incoming>Flow_BuyPath</bpmn:incoming>
      <bpmn:outgoing>Flow_VendorSource_Executive</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_BuildPlanInit" name="Build Plan Initialization&#10;(Resource + Sprint Planning)" camunda:candidateGroups="procurement">
      <bpmn:incoming>Flow_BuildPath</bpmn:incoming>
      <bpmn:outgoing>Flow_BuildPlan_Executive</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_CapacityPlanningReview" name="Capacity Planning&#10;+ Roadmap Integration" camunda:candidateGroups="it-architecture">
      <bpmn:incoming>Flow_VendorSource_Executive</bpmn:incoming>
      <bpmn:incoming>Flow_BuildPlan_Executive</bpmn:incoming>
      <bpmn:outgoing>Flow_Capacity_ExecutiveSignOff</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ExecutiveSponsorSignOff" name="Executive Sponsor&#10;Sign-Off (Tier 1 AI/Critical&#10;Vendor per OCC)" camunda:candidateGroups="sla-governance-board">
      <bpmn:incoming>Flow_Capacity_ExecutiveSignOff</bpmn:incoming>
      <bpmn:outgoing>Flow_ExecutiveSignOff_Sequencing</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Timer_ExecutiveSignOffSLA" attachedToRef="Task_ExecutiveSponsorSignOff" cancelActivity="false">
      <bpmn:outgoing>Flow_ExecSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_ExecutiveSignOff">
        <bpmn:timeDuration>P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:userTask id="Task_SequencingDecision" name="Portfolio Sequencing&#10;Decision (Prioritization)" camunda:candidateGroups="vendor-management">
      <bpmn:incoming>Flow_ExecutiveSignOff_Sequencing</bpmn:incoming>
      <bpmn:outgoing>Flow_Sequencing_DecisionDoc</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_DecisionDocumentation" name="Decision Documentation&#10;(Audit Trail, Override&#10;Rationale)" camunda:type="external" camunda:topic="decision-documentation">
      <bpmn:incoming>Flow_Sequencing_DecisionDoc</bpmn:incoming>
      <bpmn:outgoing>Flow_DecisionDoc_PhaseTransition</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_PhaseTransitionP4" name="Phase 4 Quality Gate&#10;+ Budget Release" camunda:candidateGroups="sla-governance-board">
      <bpmn:incoming>Flow_DecisionDoc_PhaseTransition</bpmn:incoming>
      <bpmn:outgoing>Flow_PhaseTransition_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Timer_Phase4QualityGate" attachedToRef="Task_PhaseTransitionP4" cancelActivity="false">
      <bpmn:outgoing>Flow_P4QGEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_P4QualityGate">
        <bpmn:timeDuration>P2D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="EndEvent_Phase4Complete" name="Phase 4 Complete&#10;(Budget Released)">
      <bpmn:incoming>Flow_PhaseTransition_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_CouncilSLAEscalated" name="Council Review&#10;SLA Escalated">
      <bpmn:incoming>Flow_CouncilSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_ExecSLAEscalated" name="Executive Sign-Off&#10;SLA Escalated">
      <bpmn:incoming>Flow_ExecSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_P4QGEscalated" name="Phase 4 QG SLA&#10;Escalated">
      <bpmn:incoming>Flow_P4QGEscalate</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:textAnnotation id="Annotation_P4_DMN">
      <bpmn:text>DMN-04 (GoNoGoViability): Portfolio Council retains human override authority. DMN-05 (BuyVsBuild): Deterministic routing with logged rationale. OCC 2023-17: Executive sign-off required for Tier 1 critical activities.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_P4_DMN" sourceRef="Task_DMN04_GoNoGo" targetRef="Annotation_P4_DMN" />

    <bpmn:textAnnotation id="Annotation_P4_SOX">
      <bpmn:text>SOX: Budget release requires documented approval trail. FINRA 4511: All governance decisions logged. EU AI Act: Tier 1 AI systems require executive sponsor. DORA: Capacity planning includes operational resilience assessment.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_P4_SOX" sourceRef="Task_DecisionDocumentation" targetRef="Annotation_P4_SOX" />
    <bpmn:sequenceFlow id="Flow_Start_GovPackage" sourceRef="StartEvent_Phase4Initiated" targetRef="Task_GovernancePackageAssembly" />
    <bpmn:sequenceFlow id="Flow_GovPackage_StrategicAlign" sourceRef="Task_GovernancePackageAssembly" targetRef="Task_StrategicAlignmentScoring" />
    <bpmn:sequenceFlow id="Flow_StrategicAlign_FinancialModel" sourceRef="Task_StrategicAlignmentScoring" targetRef="Task_FinancialImpactModel" />
    <bpmn:sequenceFlow id="Flow_FinancialModel_PortfolioScore" sourceRef="Task_FinancialImpactModel" targetRef="Task_PortfolioPrioritizationScore" />
    <bpmn:sequenceFlow id="Flow_PortfolioScore_CouncilReview" sourceRef="Task_PortfolioPrioritizationScore" targetRef="Task_PortfolioCouncilReview" />
    <bpmn:sequenceFlow id="Flow_CouncilReview_DMN04" sourceRef="Task_PortfolioCouncilReview" targetRef="Task_DMN04_GoNoGo" />
    <bpmn:sequenceFlow id="Flow_DMN04_Gateway" sourceRef="Task_DMN04_GoNoGo" targetRef="Gateway_GoNoGo" />
    <bpmn:sequenceFlow id="Flow_NoGoDecision" name="No-Go" sourceRef="Gateway_GoNoGo" targetRef="EndEvent_GoNoGoRejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${goNoGoDecision == 'NO_GO'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_GoDecision" name="Go" sourceRef="Gateway_GoNoGo" targetRef="Task_ComplianceGateP4" />
    <bpmn:sequenceFlow id="Flow_ComplianceGate_Gateway" sourceRef="Task_ComplianceGateP4" targetRef="Gateway_ComplianceGate" />
    <bpmn:sequenceFlow id="Flow_ComplianceFail" name="Fail" sourceRef="Gateway_ComplianceGate" targetRef="Task_RiskAcceptanceDecision">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${complianceGateFailed == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_CompliancePass" name="Pass" sourceRef="Gateway_ComplianceGate" targetRef="Task_DMN05_BuyVsBuild" />
    <bpmn:sequenceFlow id="Flow_RiskAccept_DMN05" sourceRef="Task_RiskAcceptanceDecision" targetRef="Task_DMN05_BuyVsBuild" />
    <bpmn:sequenceFlow id="Flow_DMN05_Gateway" sourceRef="Task_DMN05_BuyVsBuild" targetRef="Gateway_BuyOrBuild" />
    <bpmn:sequenceFlow id="Flow_BuyPath" name="Buy" sourceRef="Gateway_BuyOrBuild" targetRef="Task_VendorSourceStrategy" />
    <bpmn:sequenceFlow id="Flow_BuildPath" name="Build" sourceRef="Gateway_BuyOrBuild" targetRef="Task_BuildPlanInit">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${buyOrBuildDecision == 'BUILD'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_VendorSource_Executive" sourceRef="Task_VendorSourceStrategy" targetRef="Task_CapacityPlanningReview" />
    <bpmn:sequenceFlow id="Flow_BuildPlan_Executive" sourceRef="Task_BuildPlanInit" targetRef="Task_CapacityPlanningReview" />
    <bpmn:sequenceFlow id="Flow_Capacity_ExecutiveSignOff" sourceRef="Task_CapacityPlanningReview" targetRef="Task_ExecutiveSponsorSignOff" />
    <bpmn:sequenceFlow id="Flow_ExecutiveSignOff_Sequencing" sourceRef="Task_ExecutiveSponsorSignOff" targetRef="Task_SequencingDecision" />
    <bpmn:sequenceFlow id="Flow_Sequencing_DecisionDoc" sourceRef="Task_SequencingDecision" targetRef="Task_DecisionDocumentation" />
    <bpmn:sequenceFlow id="Flow_DecisionDoc_PhaseTransition" sourceRef="Task_DecisionDocumentation" targetRef="Task_PhaseTransitionP4" />
    <bpmn:sequenceFlow id="Flow_PhaseTransition_End" sourceRef="Task_PhaseTransitionP4" targetRef="EndEvent_Phase4Complete" />
    <bpmn:sequenceFlow id="Flow_CouncilSLAEscalate" sourceRef="Timer_CouncilReviewSLA" targetRef="EndEvent_CouncilSLAEscalated" />
    <bpmn:sequenceFlow id="Flow_ExecSLAEscalate" sourceRef="Timer_ExecutiveSignOffSLA" targetRef="EndEvent_ExecSLAEscalated" />
    <bpmn:sequenceFlow id="Flow_P4QGEscalate" sourceRef="Timer_Phase4QualityGate" targetRef="EndEvent_P4QGEscalated" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Phase4">
    <bpmndi:BPMNPlane id="BPMNPlane_Phase4" bpmnElement="Collaboration_Phase4">

      <bpmndi:BPMNShape id="Participant_Phase4_di" bpmnElement="Participant_Phase4" isHorizontal="true">
        <dc:Bounds x="155" y="47" width="2800" height="1240" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_GB_P4_di" bpmnElement="Lane_GB_P4" isHorizontal="true">
        <dc:Bounds x="185" y="47" width="2770" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_BO_P4_di" bpmnElement="Lane_BO_P4" isHorizontal="true">
        <dc:Bounds x="185" y="207" width="2770" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_ITA_P4_di" bpmnElement="Lane_ITA_P4" isHorizontal="true">
        <dc:Bounds x="185" y="367" width="2770" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Proc_P4_di" bpmnElement="Lane_Proc_P4" isHorizontal="true">
        <dc:Bounds x="185" y="527" width="2770" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_LC_P4_di" bpmnElement="Lane_LC_P4" isHorizontal="true">
        <dc:Bounds x="185" y="687" width="2770" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_IS_P4_di" bpmnElement="Lane_IS_P4" isHorizontal="true">
        <dc:Bounds x="185" y="847" width="2770" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_VM_P4_di" bpmnElement="Lane_VM_P4" isHorizontal="true">
        <dc:Bounds x="185" y="1007" width="2770" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_Phase4Initiated_di" bpmnElement="StartEvent_Phase4Initiated">
        <dc:Bounds x="247" y="269" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="225" y="312" width="80" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GovernancePackageAssembly_di" bpmnElement="Task_GovernancePackageAssembly">
        <dc:Bounds x="330" y="247" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_StrategicAlignmentScoring_di" bpmnElement="Task_StrategicAlignmentScoring">
        <dc:Bounds x="520" y="387" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_FinancialImpactModel_di" bpmnElement="Task_FinancialImpactModel">
        <dc:Bounds x="710" y="867" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PortfolioPrioritizationScore_di" bpmnElement="Task_PortfolioPrioritizationScore">
        <dc:Bounds x="900" y="1027" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PortfolioCouncilReview_di" bpmnElement="Task_PortfolioCouncilReview">
        <dc:Bounds x="1090" y="87" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Timer_CouncilReviewSLA_di" bpmnElement="Timer_CouncilReviewSLA">
        <dc:Bounds x="1142" y="149" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_CouncilSLAEscalated_di" bpmnElement="EndEvent_CouncilSLAEscalated">
        <dc:Bounds x="1142" y="52" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1118" y="20" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DMN04_GoNoGo_di" bpmnElement="Task_DMN04_GoNoGo">
        <dc:Bounds x="1280" y="87" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_GoNoGo_di" bpmnElement="Gateway_GoNoGo" isMarkerVisible="true">
        <dc:Bounds x="1465" y="102" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1452" y="159" width="76" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_GoNoGoRejected_di" bpmnElement="EndEvent_GoNoGoRejected">
        <dc:Bounds x="1572" y="52" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1548" y="20" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ComplianceGateP4_di" bpmnElement="Task_ComplianceGateP4">
        <dc:Bounds x="1570" y="707" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ComplianceGate_di" bpmnElement="Gateway_ComplianceGate" isMarkerVisible="true">
        <dc:Bounds x="1755" y="722" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1738" y="779" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RiskAcceptanceDecision_di" bpmnElement="Task_RiskAcceptanceDecision">
        <dc:Bounds x="1850" y="867" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DMN05_BuyVsBuild_di" bpmnElement="Task_DMN05_BuyVsBuild">
