<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_Phase6SDLC"
                  targetNamespace="http://sla.governance/bpmn"
                  exporter="Camunda Modeler"
                  exporterVersion="5.25.0">

  <bpmn:collaboration id="Collaboration_Phase6SDLC">
    <bpmn:participant id="Participant_EnterpriseGovernance" name="Enterprise Governance" processRef="Process_Phase6SDLC" />
    <bpmn:participant id="Participant_VendorThirdParty" name="Vendor / Third Party" processRef="Process_VendorPhase6" />
    <bpmn:messageFlow id="MsgFlow_VendorFeedback" sourceRef="Participant_VendorThirdParty" targetRef="Participant_EnterpriseGovernance" name="Vendor Build Artifacts" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Phase6SDLC" name="Phase 6: SDLC Development and Testing" isExecutable="false" camunda:historyTimeToLive="180">

    <bpmn:laneSet id="LaneSet_Phase6SDLC">
      <bpmn:lane id="Lane_Business" name="Business Lane" camunda:candidateGroups="business-lane">
        <bpmn:flowNodeRef>StartEvent_Phase6Initiated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SubProcess_6A_SprintLifecycle</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryEvent_SP6A_SLA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SP6A_SLAEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryEvent_Phase6_Timer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Phase6TimerEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SubProcess_6F_SprintReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryEvent_SP6F_SLA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SP6F_SLAEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_QualityGate_Merge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Phase6Complete</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Governance" name="Governance Lane" camunda:candidateGroups="governance-lane">
        <bpmn:flowNodeRef>Gateway_QualityGate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_QualityGateRejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Contracting" name="Contracting Lane" camunda:candidateGroups="contracting-lane">
      </bpmn:lane>
      <bpmn:lane id="Lane_TechnicalAssessment" name="Technical Assessment" camunda:candidateGroups="technical-assessment">
        <bpmn:flowNodeRef>SubProcess_6B_DevPipeline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryEvent_SP6B_SLA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SP6B_SLAEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Parallel_Split_TC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>SubProcess_6C_TestingPipeline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryEvent_SP6C_SLA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SP6C_SLAEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Parallel_Join_TC</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_AIReview" name="AI Review Lane" camunda:candidateGroups="ai-review">
      </bpmn:lane>
      <bpmn:lane id="Lane_Compliance" name="Compliance Lane" camunda:candidateGroups="compliance-lane">
        <bpmn:flowNodeRef>SubProcess_6E_ComplianceGates</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryEvent_SP6E_SLA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SP6E_SLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Oversight" name="Oversight Lane" camunda:candidateGroups="oversight-lane">
      </bpmn:lane>
      <bpmn:lane id="Lane_Automation" name="Automation Lane" camunda:candidateGroups="automation-lane">
        <bpmn:flowNodeRef>SubProcess_6D_DevSecOps</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryEvent_SP6D_SLA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SP6D_SLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_Phase6Initiated" name="Phase 6&#10;SDLC Initiated">
      <bpmn:outgoing>Flow_Start_SP6A</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:subProcess id="SubProcess_6A_SprintLifecycle" name="SP-6A: Sprint&#10;Lifecycle">
      <bpmn:incoming>Flow_Start_SP6A</bpmn:incoming>
      <bpmn:outgoing>Flow_SP6A_SP6B</bpmn:outgoing>
    </bpmn:subProcess>

    <bpmn:boundaryEvent id="BoundaryEvent_SP6A_SLA" name="2 Day&#10;SLA" attachedToRef="SubProcess_6A_SprintLifecycle" cancelActivity="false">
      <bpmn:outgoing>Flow_SP6A_SLA_End</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_SP6A">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P2D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:endEvent id="EndEvent_SP6A_SLAEscalated" name="Sprint Lifecycle&#10;SLA Escalated">
      <bpmn:incoming>Flow_SP6A_SLA_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:boundaryEvent id="BoundaryEvent_Phase6_Timer" name="15 Day&#10;Phase SLA" attachedToRef="SubProcess_6A_SprintLifecycle" cancelActivity="false">
      <bpmn:outgoing>Flow_Phase6_Timer_End</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Phase6">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P15D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:endEvent id="EndEvent_Phase6TimerEscalated" name="Phase 6&#10;Timer Escalated">
      <bpmn:incoming>Flow_Phase6_Timer_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:subProcess id="SubProcess_6B_DevPipeline" name="SP-6B: Development&#10;Pipeline">
      <bpmn:incoming>Flow_SP6A_SP6B</bpmn:incoming>
      <bpmn:outgoing>Flow_SP6B_Split</bpmn:outgoing>
    </bpmn:subProcess>

    <bpmn:boundaryEvent id="BoundaryEvent_SP6B_SLA" name="5 Day&#10;SLA" attachedToRef="SubProcess_6B_DevPipeline" cancelActivity="false">
      <bpmn:outgoing>Flow_SP6B_SLA_End</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_SP6B">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:endEvent id="EndEvent_SP6B_SLAEscalated" name="Dev Pipeline&#10;SLA Escalated">
      <bpmn:incoming>Flow_SP6B_SLA_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:parallelGateway id="Gateway_Parallel_Split_TC" name="">
      <bpmn:incoming>Flow_SP6B_Split</bpmn:incoming>
      <bpmn:outgoing>Flow_Split_SP6C</bpmn:outgoing>
      <bpmn:outgoing>Flow_Split_SP6D</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:subProcess id="SubProcess_6C_TestingPipeline" name="SP-6C: Testing&#10;Pipeline">
      <bpmn:incoming>Flow_Split_SP6C</bpmn:incoming>
      <bpmn:outgoing>Flow_SP6C_Join</bpmn:outgoing>
    </bpmn:subProcess>

    <bpmn:boundaryEvent id="BoundaryEvent_SP6C_SLA" name="3 Day&#10;SLA" attachedToRef="SubProcess_6C_TestingPipeline" cancelActivity="false">
      <bpmn:outgoing>Flow_SP6C_SLA_End</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_SP6C">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:endEvent id="EndEvent_SP6C_SLAEscalated" name="Testing Pipeline&#10;SLA Escalated">
      <bpmn:incoming>Flow_SP6C_SLA_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:subProcess id="SubProcess_6D_DevSecOps" name="SP-6D: DevSecOps&#10;Security Pipeline">
      <bpmn:incoming>Flow_Split_SP6D</bpmn:incoming>
      <bpmn:outgoing>Flow_SP6D_Join</bpmn:outgoing>
    </bpmn:subProcess>

    <bpmn:boundaryEvent id="BoundaryEvent_SP6D_SLA" name="3 Day&#10;SLA" attachedToRef="SubProcess_6D_DevSecOps" cancelActivity="false">
      <bpmn:outgoing>Flow_SP6D_SLA_End</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_SP6D">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:endEvent id="EndEvent_SP6D_SLAEscalated" name="DevSecOps&#10;SLA Escalated">
      <bpmn:incoming>Flow_SP6D_SLA_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:parallelGateway id="Gateway_Parallel_Join_TC" name="">
      <bpmn:incoming>Flow_SP6C_Join</bpmn:incoming>
      <bpmn:incoming>Flow_SP6D_Join</bpmn:incoming>
      <bpmn:outgoing>Flow_Join_SP6E</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:subProcess id="SubProcess_6E_ComplianceGates" name="SP-6E: Compliance&#10;Validation Gates">
      <bpmn:incoming>Flow_Join_SP6E</bpmn:incoming>
      <bpmn:outgoing>Flow_SP6E_SP6F</bpmn:outgoing>
    </bpmn:subProcess>

    <bpmn:boundaryEvent id="BoundaryEvent_SP6E_SLA" name="2 Day&#10;SLA" attachedToRef="SubProcess_6E_ComplianceGates" cancelActivity="false">
      <bpmn:outgoing>Flow_SP6E_SLA_End</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_SP6E">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P2D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:endEvent id="EndEvent_SP6E_SLAEscalated" name="Compliance Gates&#10;SLA Escalated">
      <bpmn:incoming>Flow_SP6E_SLA_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:subProcess id="SubProcess_6F_SprintReview" name="SP-6F: Sprint&#10;Review">
      <bpmn:incoming>Flow_SP6E_SP6F</bpmn:incoming>
      <bpmn:outgoing>Flow_SP6F_QGMerge</bpmn:outgoing>
    </bpmn:subProcess>

    <bpmn:boundaryEvent id="BoundaryEvent_SP6F_SLA" name="1 Day&#10;SLA" attachedToRef="SubProcess_6F_SprintReview" cancelActivity="false">
      <bpmn:outgoing>Flow_SP6F_SLA_End</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_SP6F">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:endEvent id="EndEvent_SP6F_SLAEscalated" name="Sprint Review&#10;SLA Escalated">
      <bpmn:incoming>Flow_SP6F_SLA_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:exclusiveGateway id="Gateway_QualityGate_Merge" name="">
      <bpmn:incoming>Flow_SP6F_QGMerge</bpmn:incoming>
      <bpmn:incoming>Flow_QGRejected_Merge</bpmn:incoming>
      <bpmn:outgoing>Flow_QGMerge_QG</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="Gateway_QualityGate" name="Quality&#10;Gate?" default="Flow_QGPassed">
      <bpmn:incoming>Flow_QGMerge_QG</bpmn:incoming>
      <bpmn:outgoing>Flow_QGPassed</bpmn:outgoing>
      <bpmn:outgoing>Flow_QGRejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_QualityGateRejected" name="Quality Gate&#10;Rejected&#10;(Return to SP-6A)">
      <bpmn:incoming>Flow_QGRejected</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Phase6Complete" name="Phase 6 Complete&#10;(SDLC Ready for&#10;Deployment)">
      <bpmn:incoming>Flow_QGPassed</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:textAnnotation id="Annotation_OCC_DORA">
      <bpmn:text>OCC 2023-17: SDLC controls embedded in development pipeline. DORA: Resilience testing via DevSecOps pipeline. SR 11-7: AI Model Validation conditional on AI initiative type.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_OCC_DORA" sourceRef="SubProcess_6D_DevSecOps" targetRef="Annotation_OCC_DORA" />

    <bpmn:textAnnotation id="Annotation_SOX_Compliance">
      <bpmn:text>SOX: Compliance validation gates mandatory for financial application changes. GDPR/CCPA: Privacy controls validated at Post-Code Gate. EU AI Act: AI model validation at SP-6C testing phase.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_SOX_Compliance" sourceRef="SubProcess_6E_ComplianceGates" targetRef="Annotation_SOX_Compliance" />

    <bpmn:sequenceFlow id="Flow_Start_SP6A" sourceRef="StartEvent_Phase6Initiated" targetRef="SubProcess_6A_SprintLifecycle" />
    <bpmn:sequenceFlow id="Flow_SP6A_SLA_End" sourceRef="BoundaryEvent_SP6A_SLA" targetRef="EndEvent_SP6A_SLAEscalated" />
    <bpmn:sequenceFlow id="Flow_Phase6_Timer_End" sourceRef="BoundaryEvent_Phase6_Timer" targetRef="EndEvent_Phase6TimerEscalated" />
    <bpmn:sequenceFlow id="Flow_SP6A_SP6B" sourceRef="SubProcess_6A_SprintLifecycle" targetRef="SubProcess_6B_DevPipeline" />
    <bpmn:sequenceFlow id="Flow_SP6B_SLA_End" sourceRef="BoundaryEvent_SP6B_SLA" targetRef="EndEvent_SP6B_SLAEscalated" />
    <bpmn:sequenceFlow id="Flow_SP6B_Split" sourceRef="SubProcess_6B_DevPipeline" targetRef="Gateway_Parallel_Split_TC" />
    <bpmn:sequenceFlow id="Flow_Split_SP6C" sourceRef="Gateway_Parallel_Split_TC" targetRef="SubProcess_6C_TestingPipeline" />
    <bpmn:sequenceFlow id="Flow_Split_SP6D" sourceRef="Gateway_Parallel_Split_TC" targetRef="SubProcess_6D_DevSecOps" />
    <bpmn:sequenceFlow id="Flow_SP6C_SLA_End" sourceRef="BoundaryEvent_SP6C_SLA" targetRef="EndEvent_SP6C_SLAEscalated" />
    <bpmn:sequenceFlow id="Flow_SP6D_SLA_End" sourceRef="BoundaryEvent_SP6D_SLA" targetRef="EndEvent_SP6D_SLAEscalated" />
    <bpmn:sequenceFlow id="Flow_SP6C_Join" sourceRef="SubProcess_6C_TestingPipeline" targetRef="Gateway_Parallel_Join_TC" />
    <bpmn:sequenceFlow id="Flow_SP6D_Join" sourceRef="SubProcess_6D_DevSecOps" targetRef="Gateway_Parallel_Join_TC" />
    <bpmn:sequenceFlow id="Flow_Join_SP6E" sourceRef="Gateway_Parallel_Join_TC" targetRef="SubProcess_6E_ComplianceGates" />
    <bpmn:sequenceFlow id="Flow_SP6E_SLA_End" sourceRef="BoundaryEvent_SP6E_SLA" targetRef="EndEvent_SP6E_SLAEscalated" />
    <bpmn:sequenceFlow id="Flow_SP6E_SP6F" sourceRef="SubProcess_6E_ComplianceGates" targetRef="SubProcess_6F_SprintReview" />
    <bpmn:sequenceFlow id="Flow_SP6F_SLA_End" sourceRef="BoundaryEvent_SP6F_SLA" targetRef="EndEvent_SP6F_SLAEscalated" />
    <bpmn:sequenceFlow id="Flow_SP6F_QGMerge" sourceRef="SubProcess_6F_SprintReview" targetRef="Gateway_QualityGate_Merge" />
    <bpmn:sequenceFlow id="Flow_QGRejected_Merge" sourceRef="EndEvent_QualityGateRejected" targetRef="Gateway_QualityGate_Merge">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_QGMerge_QG" sourceRef="Gateway_QualityGate_Merge" targetRef="Gateway_QualityGate" />
    <bpmn:sequenceFlow id="Flow_QGPassed" name="Yes" sourceRef="Gateway_QualityGate" targetRef="EndEvent_Phase6Complete" />
    <bpmn:sequenceFlow id="Flow_QGRejected" name="No" sourceRef="Gateway_QualityGate" targetRef="EndEvent_QualityGateRejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${qualityGatePassed == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

  </bpmn:process>

  <bpmn:process id="Process_VendorPhase6" name="Vendor / Third Party" isExecutable="false">
    <bpmn:laneSet id="LaneSet_VendorPhase6">
      <bpmn:lane id="Lane_VendorResponse" name="Vendor Response" camunda:candidateGroups="vendor-management">
        <bpmn:flowNodeRef>StartEvent_Vendor_Phase6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Vendor_ProvideBuildArtifacts</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Vendor_Phase6</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Vendor_Phase6" name="Vendor&#10;Engaged">
      <bpmn:outgoing>Flow_Vendor_Start_Task</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_Vendor_ProvideBuildArtifacts" name="Provide Build&#10;Artifacts &amp; Evidence" camunda:candidateGroups="vendor-management">
      <bpmn:incoming>Flow_Vendor_Start_Task</bpmn:incoming>
      <bpmn:outgoing>Flow_Vendor_Task_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_Vendor_Phase6" name="Vendor&#10;Contribution Complete">
      <bpmn:incoming>Flow_Vendor_Task_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Vendor_Start_Task" sourceRef="StartEvent_Vendor_Phase6" targetRef="Task_Vendor_ProvideBuildArtifacts" />
    <bpmn:sequenceFlow id="Flow_Vendor_Task_End" sourceRef="Task_Vendor_ProvideBuildArtifacts" targetRef="EndEvent_Vendor_Phase6" />
  </bpmn:process>

  <bpmn:process id="SubProcess_6A_SprintLifecycle_Proc" name="SP-6A Sprint Lifecycle" isExecutable="false">
    <bpmn:startEvent id="SP6A_Start" name="Sprint&#10;Initiated">
      <bpmn:outgoing>Flow_6A_Start_Plan</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="SP6A_Task_SprintPlanning" name="Sprint Planning&#10;(Business + Technical)" camunda:candidateGroups="business-lane">
      <bpmn:incoming>Flow_6A_Start_Plan</bpmn:incoming>
      <bpmn:outgoing>Flow_6A_Plan_Backlog</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="SP6A_Task_BacklogPrioritization" name="Backlog&#10;Prioritization" camunda:candidateGroups="business-lane">
      <bpmn:incoming>Flow_6A_Plan_Backlog</bpmn:incoming>
      <bpmn:outgoing>Flow_6A_Backlog_Goal</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="SP6A_Task_SprintGoalDefinition" name="Sprint Goal&#10;Definition" camunda:candidateGroups="business-lane">
      <bpmn:incoming>Flow_6A_Backlog_Goal</bpmn:incoming>
      <bpmn:outgoing>Flow_6A_Goal_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="SP6A_End" name="Sprint&#10;Lifecycle Complete">
      <bpmn:incoming>Flow_6A_Goal_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_6A_Start_Plan" sourceRef="SP6A_Start" targetRef="SP6A_Task_SprintPlanning" />
    <bpmn:sequenceFlow id="Flow_6A_Plan_Backlog" sourceRef="SP6A_Task_SprintPlanning" targetRef="SP6A_Task_BacklogPrioritization" />
    <bpmn:sequenceFlow id="Flow_6A_Backlog_Goal" sourceRef="SP6A_Task_BacklogPrioritization" targetRef="SP6A_Task_SprintGoalDefinition" />
    <bpmn:sequenceFlow id="Flow_6A_Goal_End" sourceRef="SP6A_Task_SprintGoalDefinition" targetRef="SP6A_End" />
  </bpmn:process>

  <bpmn:process id="SubProcess_6B_DevPipeline_Proc" name="SP-6B Development Pipeline" isExecutable="false">
    <bpmn:startEvent id="SP6B_Start" name="Dev Pipeline&#10;Initiated">
      <bpmn:outgoing>Flow_6B_Start_Code</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="SP6B_Task_CodeDevelopment" name="Code Development" camunda:candidateGroups="technical-assessment">
      <bpmn:incoming>Flow_6B_Start_Code</bpmn:incoming>
      <bpmn:incoming>Flow_6B_SelfHeal_Code</bpmn:incoming>
      <bpmn:outgoing>Flow_6B_Code_AIReview</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="SP6B_Task_AICodeReview" name="AI-Assisted&#10;Code Review" camunda:type="external" camunda:topic="ai-code-review">
      <bpmn:incoming>Flow_6B_Code_AIReview</bpmn:incoming>
      <bpmn:outgoing>Flow_6B_AIReview_Gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="SP6B_Gateway_QualityCheck" name="Quality&#10;Acceptable?" default="Flow_6B_QualityOK">
      <bpmn:incoming>Flow_6B_AIReview_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_6B_QualityOK</bpmn:outgoing>
      <bpmn:outgoing>Flow_6B_QualityIssues</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="SP6B_Task_SelfHealingLoop" name="Self-Healing Loop&#10;(Quality Issues)" camunda:candidateGroups="technical-assessment">
      <bpmn:incoming>Flow_6B_QualityIssues</bpmn:incoming>
      <bpmn:outgoing>Flow_6B_SelfHeal_Code</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="SP6B_Task_CodeIntegration" name="Code Integration" camunda:candidateGroups="technical-assessment">
      <bpmn:incoming>Flow_6B_QualityOK</bpmn:incoming>
      <bpmn:outgoing>Flow_6B_Integration_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="SP6B_End" name="Dev Pipeline&#10;Complete">
      <bpmn:incoming>Flow_6B_Integration_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_6B_Start_Code" sourceRef="SP6B_Start" targetRef="SP6B_Task_CodeDevelopment" />
    <bpmn:sequenceFlow id="Flow_6B_Code_AIReview" sourceRef="SP6B_Task_CodeDevelopment" targetRef="SP6B_Task_AICodeReview" />
    <bpmn:sequenceFlow id="Flow_6B_AIReview_Gateway" sourceRef="SP6B_Task_AICodeReview" targetRef="SP6B_Gateway_QualityCheck" />
    <bpmn:sequenceFlow id="Flow_6B_QualityOK" name="Yes" sourceRef="SP6B_Gateway_QualityCheck" targetRef="SP6B_Task_CodeIntegration" />
    <bpmn:sequenceFlow id="Flow_6B_QualityIssues" name="No" sourceRef="SP6B_Gateway_QualityCheck" targetRef="SP6B_Task_SelfHealingLoop">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${codeQualityAcceptable == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_6B_SelfHeal_Code" sourceRef="SP6B_Task_SelfHealingLoop" targetRef="SP6B_Task_CodeDevelopment" />
    <bpmn:sequenceFlow id="Flow_6B_Integration_End" sourceRef="SP6B_Task_CodeIntegration" targetRef="SP6B_End" />
  </bpmn:process>

  <bpmn:process id="SubProcess_6C_TestingPipeline_Proc" name="SP-6C Testing Pipeline" isExecutable="false">
    <bpmn:startEvent id="SP6C_Start" name="Testing&#10;Initiated">
      <bpmn:outgoing>Flow_6C_Start_Unit</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="SP6C_Task_UnitTesting" name="Unit Testing" camunda:type="external" camunda:topic="unit-testing">
      <bpmn:incoming>Flow_6C_Start_Unit</bpmn:incoming>
      <bpmn:outgoing>Flow_6C_Unit_Integration</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="SP6C_Task_IntegrationTesting" name="Integration Testing" camunda:candidateGroups="technical-assessment">
      <bpmn:incoming>Flow_6C_Unit_Integration</bpmn:incoming>
      <bpmn:outgoing>Flow_6C_Integration_Perf</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="SP6C_Task_PerformanceTesting" name="Performance Testing" camunda:candidateGroups="technical-assessment">
      <bpmn:incoming>Flow_6C_Integration_Perf</bpmn:incoming>
      <bpmn:outgoing>Flow_6C_Perf_AIGateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="SP6C_Gateway_AIInitiative" name="AI&#10;Initiative?" default="Flow_6C_NotAI">
      <bpmn:incoming>Flow_6C_Perf_AIGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_6C_IsAI</bpmn:outgoing>
      <bpmn:outgoing>Flow_6C_NotAI</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="SP6C_Task_AIModelValidation" name="AI Model Validation&#10;(SR 11-7)" camunda:candidateGroups="ai-review">
      <bpmn:incoming>Flow_6C_IsAI</bpmn:incoming>
      <bpmn:outgoing>Flow_6C_AIVal_Merge</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="SP6C_Gateway_AIMerge" name="">
      <bpmn:incoming>Flow_6C_AIVal_Merge</bpmn:incoming>
      <bpmn:incoming>Flow_6C_NotAI</bpmn:incoming>
      <bpmn:outgoing>Flow_6C_AIMerge_UAT</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="SP6C_Task_UATSignOff" name="UAT Sign-off" camunda:candidateGroups="business-lane">
      <bpmn:incoming>Flow_6C_AIMerge_UAT</bpmn:incoming>
      <bpmn:outgoing>Flow_6C_UAT_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="SP6C_End" name="Testing Pipeline&#10;Complete">
      <bpmn:incoming>Flow_6C_UAT_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_6C_Start_Unit" sourceRef="SP6C_Start" targetRef="SP6C_Task_UnitTesting" />
    <bpmn:sequenceFlow id="Flow_6C_Unit_Integration" sourceRef="SP6C_Task_UnitTesting" targetRef="SP6C_Task_IntegrationTesting" />
    <bpmn:sequenceFlow id="Flow_6C_Integration_Perf" sourceRef="SP6C_Task_IntegrationTesting" targetRef="SP6C_Task_PerformanceTesting" />
    <bpmn:sequenceFlow id="Flow_6C_Perf_AIGateway" sourceRef="SP6C_Task_PerformanceTesting" targetRef="SP6C_Gateway_AIInitiative" />
    <bpmn:sequenceFlow id="Flow_6C_IsAI" name="Yes" sourceRef="SP6C_Gateway_AIInitiative" targetRef="SP6C_Task_AIModelValidation">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isAIInitiative == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_6C_NotAI" name="No" sourceRef="SP6C_Gateway_AIInitiative" targetRef="SP6C_Gateway_AIMerge" />
    <bpmn:sequenceFlow id="Flow_6C_AIVal_Merge" sourceRef="SP6C_Task_AIModelValidation" targetRef="SP6C_Gateway_AIMerge" />
    <bpmn:sequenceFlow id="Flow_6C_AIMerge_UAT" sourceRef="SP6C_Gateway_AIMerge" targetRef="SP6C_Task_UATSignOff" />
    <bpmn:sequenceFlow id="Flow_6C_UAT_End" sourceRef="SP6C_Task_UATSignOff" targetRef="SP6C_End" />
  </bpmn:process>

  <bpmn:process id="SubProcess_6D_DevSecOps_Proc" name="SP-6D DevSecOps Security Pipeline" isExecutable="false">
    <bpmn:startEvent id="SP6D_Start" name="Security Pipeline&#10;Initiated">
      <bpmn:outgoing>Flow_6D_Start_Split</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:parallelGateway id="SP6D_Gateway_Split" name="">
      <bpmn:incoming>Flow_6D_Start_Split</bpmn:incoming>
      <bpmn:outgoing>Flow_6D_Split_PreCommit</bpmn:outgoing>
      <bpmn:outgoing>Flow_6D_Split_SAST</bpmn:outgoing>
      <bpmn:outgoing>Flow_6D_Split_SCA</bpmn:outgoing>
      <bpmn:outgoing>Flow_6D_Split_DAST</bpmn:outgoing>
      <bpmn:outgoing>Flow_6D_Split_Container</bpmn:outgoing>
      <bpmn:outgoing>Flow_6D_Split_IaC</bpmn:outgoing>
      <bpmn:outgoing>Flow_6D_Split_ProdMon</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="SP6D_Task_PreCommitScan" name="Pre-Commit&#10;Security Scan" camunda:type="external" camunda:topic="pre-commit-security-scan">
      <bpmn:incoming>Flow_6D_Split_PreCommit</bpmn:incoming>
      <bpmn:outgoing>Flow_6D_PreCommit_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="SP6D_Task_SAST" name="SAST&#10;(Static Analysis)" camunda:type="external" camunda:topic="sast-analysis">
      <bpmn:incoming>Flow_6D_Split_SAST</bpmn:incoming>
      <bpmn:outgoing>Flow_6D_SAST_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="SP6D_Task_SCA" name="SCA (Software&#10;Composition Analysis)" camunda:type="external" camunda:topic="sca-analysis">
      <bpmn:incoming>Flow_6D_Split_SCA</bpmn:incoming>
      <bpmn:outgoing>Flow_6D_SCA_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="SP6D_Task_DAST" name="DAST&#10;(Dynamic Analysis)" camunda:type="external" camunda:topic="dast-analysis">
      <bpmn:incoming>Flow_6D_Split_DAST</bpmn:incoming>
      <bpmn:outgoing>Flow_6D_DAST_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="SP6D_Task_ContainerSecurity" name="Container&#10;Security Scan" camunda:type="external" camunda:topic="container-security-scan">
      <bpmn:incoming>Flow_6D_Split_Container</bpmn:incoming>
      <bpmn:outgoing>Flow_6D_Container_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="SP6D_Task_IaCsecurity" name="Infrastructure as Code&#10;Security" camunda:type="external" camunda:topic="iac-security-scan">
      <bpmn:incoming>Flow_6D_Split_IaC</bpmn:incoming>
      <bpmn:outgoing>Flow_6D_IaC_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="SP6D_Task_ProdSecMonitoring" name="Production Security&#10;Monitoring" camunda:type="external" camunda:topic="production-security-monitoring">
      <bpmn:incoming>Flow_6D_Split_ProdMon</bpmn:incoming>
      <bpmn:outgoing>Flow_6D_ProdMon_Join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="SP6D_Gateway_Join" name="">
      <bpmn:incoming>Flow_6D_PreCommit_Join</bpmn:incoming>
      <bpmn:incoming>Flow_6D_SAST_Join</bpmn:incoming>
      <bpmn:incoming>Flow_6D_SCA_Join</bpmn:incoming>
      <bpmn:incoming>Flow_6D_DAST_Join</bpmn:incoming>
      <bpmn:incoming>Flow_6D_Container_Join</bpmn:incoming>
      <bpmn:incoming>Flow_6D_IaC_Join</bpmn:incoming>
      <bpmn:incoming>Flow_6D_ProdMon_Join</bpmn:incoming>
      <bpmn:outgoing>Flow_6D_Join_End</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:endEvent id="SP6D_End" name="DevSecOps Pipeline&#10;Complete">
      <bpmn:incoming>Flow_6D_Join_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_6D_Start_Split" sourceRef="SP6D_Start" targetRef="SP6D_Gateway_Split" />
    <bpmn:sequenceFlow id="Flow_6D_Split_PreCommit" sourceRef="SP6D_Gateway_Split" targetRef="SP6D_Task_PreCommitScan" />
    <bpmn:sequenceFlow id="Flow_6D_Split_SAST" sourceRef="SP6D_Gateway_Split" targetRef="SP6D_Task_SAST" />
    <bpmn:sequenceFlow id="Flow_6D_Split_SCA" sourceRef="SP6D_Gateway_Split" targetRef="SP6D_Task_SCA" />
    <bpmn:sequenceFlow id="Flow_6D_Split_DAST" sourceRef="SP6D_Gateway_Split" targetRef="SP6D_Task_DAST" />
    <bpmn:sequenceFlow id="Flow_6D_Split_Container" sourceRef="SP6D_Gateway_Split" targetRef="SP6D_Task_ContainerSecurity" />
    <bpmn:sequenceFlow id="Flow_6D_Split_IaC" sourceRef="SP6D_Gateway_Split" targetRef="SP6D_Task_IaCsecurity" />
    <bpmn:sequenceFlow id="Flow_6D_Split_ProdMon" sourceRef="SP6D_Gateway_Split" targetRef="SP6D_Task_ProdSecMonitoring" />
    <bpmn:sequenceFlow id="Flow_6D_PreCommit_Join" sourceRef="SP6D_Task_PreCommitScan" targetRef="SP6D_Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_6D_SAST_Join" sourceRef="SP6D_Task_SAST" targetRef="SP6D_Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_6D_SCA_Join" sourceRef="SP6D_Task_SCA" targetRef="SP6D_Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_6D_DAST_Join" sourceRef="SP6D_Task_DAST" targetRef="SP6D_Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_6D_Container_Join" sourceRef="SP6D_Task_ContainerSecurity" targetRef="SP6D_Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_6D_IaC_Join" sourceRef="SP6D_Task_IaCsecurity" targetRef="SP6D_Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_6D_ProdMon_Join" sourceRef="SP6D_Task_ProdSecMonitoring" targetRef="SP6D_Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_6D_Join_End" sourceRef="SP6D_Gateway_Join" targetRef="SP6D_End" />
