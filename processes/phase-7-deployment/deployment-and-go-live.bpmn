<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_Phase7Deployment"
                  targetNamespace="http://sla.governance/bpmn"
                  exporter="Camunda Modeler"
                  exporterVersion="5.25.0">

  <bpmn:collaboration id="Collaboration_Phase7">
    <bpmn:participant id="Participant_EnterpriseGov" name="Phase 7: Deployment Decision and Go-Live — Enterprise Governance Pool" processRef="Process_Phase7Deployment" />
    <bpmn:participant id="Participant_VendorParty" name="Vendor / Third Party" processRef="Process_VendorResponse" />
    <bpmn:messageFlow id="MsgFlow_VendorDeployCoord" sourceRef="Task_VendorDeployCoordination" targetRef="Task_71_ReadinessAssessment" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Phase7Deployment" name="Phase 7: Deployment Decision and Go-Live" isExecutable="false" camunda:historyTimeToLive="180">

    <bpmn:laneSet id="LaneSet_Phase7">
      <bpmn:lane id="Lane_Business" name="Business Lane">
        <bpmn:flowNodeRef>StartEvent_Phase7Initiated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Phase8Complete</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Governance" name="Governance Lane">
        <bpmn:flowNodeRef>EndEvent_Rejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Contracting" name="Contracting Lane">
      </bpmn:lane>
      <bpmn:lane id="Lane_TechnicalAssessment" name="Technical Assessment">
        <bpmn:flowNodeRef>Task_71_ReadinessAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_DeploymentDecision</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_AIReview" name="AI Review Lane">
        <bpmn:flowNodeRef>EndEvent_ReadinessSLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Compliance" name="Compliance Lane">
        <bpmn:flowNodeRef>EndEvent_RollbackRequired</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Oversight" name="Oversight Lane">
      </bpmn:lane>
      <bpmn:lane id="Lane_Automation" name="Automation Lane">
        <bpmn:flowNodeRef>Task_72_ProgressiveDeployment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_HealthChecks</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_73_PostDeployVerification</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_74_MonitoringActivation</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_Phase7Initiated" name="Phase 6&#10;Complete">
      <bpmn:outgoing>Flow_Start_Readiness</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_71_ReadinessAssessment" name="7.1 Deployment Readiness&#10;Assessment (Review Phase 6&#10;Artifacts, Compliance Gates,&#10;Security Clearances)" camunda:candidateGroups="technical-assessment">
      <bpmn:incoming>Flow_Start_Readiness</bpmn:incoming>
      <bpmn:outgoing>Flow_Readiness_Decision</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="Timer_ReadinessSLA" name="P3D&#10;SLA" attachedToRef="Task_71_ReadinessAssessment" cancelActivity="false">
      <bpmn:outgoing>Flow_ReadinessSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_ReadinessSLA">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:businessRuleTask id="Task_71_ChangeRiskScoring" name="7.1a Change Risk Scoring&#10;(DMN-6 Change Risk&#10;Scoring)" camunda:decisionRef="DMN_ChangeRiskScoring" camunda:resultVariable="deploymentRiskLevel" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>Flow_Readiness_Decision</bpmn:incoming>
      <bpmn:outgoing>Flow_RiskScoring_Gate</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:exclusiveGateway id="Gateway_DeploymentDecision" name="Deployment&#10;Decision?" default="Flow_Decision_Rejected">
      <bpmn:incoming>Flow_RiskScoring_Gate</bpmn:incoming>
      <bpmn:outgoing>Flow_Decision_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_Decision_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_72_ProgressiveDeployment" name="7.2 Progressive Deployment&#10;(Canary → Blue-Green →&#10;Full Rollout, Automated&#10;Health Checks)" camunda:type="external" camunda:topic="progressive-deployment">
      <bpmn:incoming>Flow_Decision_Approved</bpmn:incoming>
      <bpmn:outgoing>Flow_Progressive_HealthCheck</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_HealthChecks" name="Health Checks&#10;Pass?" default="Flow_Health_Rollback">
      <bpmn:incoming>Flow_Progressive_HealthCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_Health_Pass</bpmn:outgoing>
      <bpmn:outgoing>Flow_Health_Rollback</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_73_PostDeployVerification" name="7.3 Post-Deployment&#10;Verification (Smoke Tests,&#10;Performance Baseline,&#10;SLA Metric Activation)" camunda:type="external" camunda:topic="post-deploy-verification">
      <bpmn:incoming>Flow_Health_Pass</bpmn:incoming>
      <bpmn:outgoing>Flow_Verification_Monitoring</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_74_MonitoringActivation" name="7.4 Monitoring Activation&#10;(Production Dashboards,&#10;Alerting Rules,&#10;Runbook Integration)" camunda:type="external" camunda:topic="monitoring-activation">
      <bpmn:incoming>Flow_Verification_Monitoring</bpmn:incoming>
      <bpmn:outgoing>Flow_Monitoring_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent_Phase8Complete" name="Phase 7 Complete —&#10;Proceed to Phase 8">
      <bpmn:incoming>Flow_Monitoring_End</bpmn:incoming>
      <bpmn:signalEventDefinition id="Signal_Phase7Complete_Def" signalRef="Signal_Phase7Complete" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_RollbackRequired" name="Rollback Required —&#10;Return to Phase 6">
      <bpmn:incoming>Flow_Health_Rollback</bpmn:incoming>
      <bpmn:signalEventDefinition id="Signal_Phase7Rollback_Def" signalRef="Signal_Phase7Rollback" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Rejected" name="Rejected —&#10;Rework Required&#10;in Phase 6">
      <bpmn:incoming>Flow_Decision_Rejected</bpmn:incoming>
      <bpmn:terminateEventDefinition id="TerminateDef_Rejected" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_ReadinessSLAEscalated" name="Readiness SLA&#10;Escalated">
      <bpmn:incoming>Flow_ReadinessSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:textAnnotation id="Annotation_DORA">
      <bpmn:text>DORA (Digital Operational Resilience Act): Deployment readiness assessment (7.1) must validate operational resilience testing outcomes and ICT risk management controls. Progressive deployment (7.2) implements DORA Article 25 change management requirements. Post-deployment verification (7.3) confirms resilience baselines meet DORA thresholds before full production activation.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_DORA" sourceRef="Task_71_ReadinessAssessment" targetRef="Annotation_DORA" />

    <bpmn:textAnnotation id="Annotation_NIST">
      <bpmn:text>NIST CSF 2.0 (Cybersecurity Framework): Monitoring Activation (7.4) implements NIST CSF Detect function — production monitoring dashboards, alerting rules, and runbook integration establish continuous detection capabilities. Progressive deployment pattern (7.2) aligns with NIST CSF Respond and Recover functions through automated rollback capability.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_NIST" sourceRef="Task_74_MonitoringActivation" targetRef="Annotation_NIST" />

    <bpmn:sequenceFlow id="Flow_Start_Readiness" sourceRef="StartEvent_Phase7Initiated" targetRef="Task_71_ReadinessAssessment" />
    <bpmn:sequenceFlow id="Flow_Readiness_Decision" sourceRef="Task_71_ReadinessAssessment" targetRef="Task_71_ChangeRiskScoring" />
    <bpmn:sequenceFlow id="Flow_RiskScoring_Gate" sourceRef="Task_71_ChangeRiskScoring" targetRef="Gateway_DeploymentDecision" />

    <bpmn:sequenceFlow id="Flow_Decision_Approved" name="Approved" sourceRef="Gateway_DeploymentDecision" targetRef="Task_72_ProgressiveDeployment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${deploymentRiskLevel != 'BLOCKED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Decision_Rejected" name="Rejected" sourceRef="Gateway_DeploymentDecision" targetRef="EndEvent_Rejected" />

    <bpmn:sequenceFlow id="Flow_Progressive_HealthCheck" sourceRef="Task_72_ProgressiveDeployment" targetRef="Gateway_HealthChecks" />

    <bpmn:sequenceFlow id="Flow_Health_Pass" name="Yes" sourceRef="Gateway_HealthChecks" targetRef="Task_73_PostDeployVerification">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${healthCheckResult == 'PASS'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Health_Rollback" name="No" sourceRef="Gateway_HealthChecks" targetRef="EndEvent_RollbackRequired" />

    <bpmn:sequenceFlow id="Flow_Verification_Monitoring" sourceRef="Task_73_PostDeployVerification" targetRef="Task_74_MonitoringActivation" />
    <bpmn:sequenceFlow id="Flow_Monitoring_End" sourceRef="Task_74_MonitoringActivation" targetRef="EndEvent_Phase8Complete" />

    <bpmn:sequenceFlow id="Flow_ReadinessSLAEscalate" sourceRef="Timer_ReadinessSLA" targetRef="EndEvent_ReadinessSLAEscalated" />

  </bpmn:process>

  <bpmn:process id="Process_VendorResponse" name="Vendor / Third Party Response" isExecutable="false" camunda:historyTimeToLive="180">
    <bpmn:laneSet id="LaneSet_Vendor">
      <bpmn:lane id="Lane_VendorResponse" name="Vendor Response Lane">
        <bpmn:flowNodeRef>StartEvent_VendorDeployRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VendorDeployCoordination</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_VendorResponseSent</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_VendorDeployRequest" name="Deployment&#10;Coordination&#10;Request Received">
      <bpmn:outgoing>Flow_VendorStart_Coord</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_VendorDeployCoordination" name="Vendor Deployment&#10;Coordination Package&#10;Submission" camunda:candidateGroups="vendor-response">
      <bpmn:incoming>Flow_VendorStart_Coord</bpmn:incoming>
      <bpmn:outgoing>Flow_VendorCoord_End</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndEvent_VendorResponseSent" name="Coordination Package&#10;Submitted">
      <bpmn:incoming>Flow_VendorCoord_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_VendorStart_Coord" sourceRef="StartEvent_VendorDeployRequest" targetRef="Task_VendorDeployCoordination" />
    <bpmn:sequenceFlow id="Flow_VendorCoord_End" sourceRef="Task_VendorDeployCoordination" targetRef="EndEvent_VendorResponseSent" />

  </bpmn:process>

  <bpmn:signal id="Signal_Phase7Complete" name="Phase7DeploymentComplete" />
  <bpmn:signal id="Signal_Phase7Rollback" name="Phase7RollbackToPhase6" />

  <bpmndi:BPMNDiagram id="BPMNDiagram_Phase7">
    <bpmndi:BPMNPlane id="BPMNPlane_Phase7" bpmnElement="Collaboration_Phase7">

      <bpmndi:BPMNShape id="Participant_EnterpriseGov_di" bpmnElement="Participant_EnterpriseGov" isHorizontal="true">
        <dc:Bounds x="155" y="47" width="2200" height="1290" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Lane_Business_di" bpmnElement="Lane_Business" isHorizontal="true">
        <dc:Bounds x="185" y="47" width="2170" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Governance_di" bpmnElement="Lane_Governance" isHorizontal="true">
        <dc:Bounds x="185" y="207" width="2170" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Contracting_di" bpmnElement="Lane_Contracting" isHorizontal="true">
        <dc:Bounds x="185" y="367" width="2170" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_TechnicalAssessment_di" bpmnElement="Lane_TechnicalAssessment" isHorizontal="true">
        <dc:Bounds x="185" y="527" width="2170" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_AIReview_di" bpmnElement="Lane_AIReview" isHorizontal="true">
        <dc:Bounds x="185" y="687" width="2170" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Compliance_di" bpmnElement="Lane_Compliance" isHorizontal="true">
        <dc:Bounds x="185" y="847" width="2170" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Oversight_di" bpmnElement="Lane_Oversight" isHorizontal="true">
        <dc:Bounds x="185" y="1007" width="2170" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Automation_di" bpmnElement="Lane_Automation" isHorizontal="true">
        <dc:Bounds x="185" y="1167" width="2170" height="170" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Participant_VendorParty_di" bpmnElement="Participant_VendorParty" isHorizontal="true">
        <dc:Bounds x="155" y="1367" width="2200" height="160" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Lane_VendorResponse_di" bpmnElement="Lane_VendorResponse" isHorizontal="true">
        <dc:Bounds x="185" y="1367" width="2170" height="160" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_Phase7Initiated_di" bpmnElement="StartEvent_Phase7Initiated">
        <dc:Bounds x="222" y="109" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="200" y="152" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_71_ReadinessAssessment_di" bpmnElement="Task_71_ReadinessAssessment">
        <dc:Bounds x="310" y="567" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Timer_ReadinessSLA_di" bpmnElement="Timer_ReadinessSLA">
        <dc:Bounds x="342" y="629" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="386" y="633" width="30" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_ReadinessSLAEscalated_di" bpmnElement="EndEvent_ReadinessSLAEscalated">
        <dc:Bounds x="344" y="710" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="320" y="753" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_71_ChangeRiskScoring_di" bpmnElement="Task_71_ChangeRiskScoring">
        <dc:Bounds x="460" y="567" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_DeploymentDecision_di" bpmnElement="Gateway_DeploymentDecision" isMarkerVisible="true">
        <dc:Bounds x="615" y="582" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="596" y="639" width="88" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_Rejected_di" bpmnElement="EndEvent_Rejected">
        <dc:Bounds x="612" y="267" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="588" y="310" width="84" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_72_ProgressiveDeployment_di" bpmnElement="Task_72_ProgressiveDeployment">
        <dc:Bounds x="730" y="1207" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_HealthChecks_di" bpmnElement="Gateway_HealthChecks" isMarkerVisible="true">
        <dc:Bounds x="895" y="1222" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="876" y="1279" width="88" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_RollbackRequired_di" bpmnElement="EndEvent_RollbackRequired">
        <dc:Bounds x="1002" y="907" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="978" y="950" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_73_PostDeployVerification_di" bpmnElement="Task_73_PostDeployVerification">
        <dc:Bounds x="1010" y="1207" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_74_MonitoringActivation_di" bpmnElement="Task_74_MonitoringActivation">
        <dc:Bounds x="1170" y="1207" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_Phase8Complete_di" bpmnElement="EndEvent_Phase8Complete">
        <dc:Bounds x="1332" y="109" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1308" y="152" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Annotation_DORA_di" bpmnElement="Annotation_DORA">
        <dc:Bounds x="200" y="1575" width="900" height="70" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Annotation_NIST_di" bpmnElement="Annotation_NIST">
        <dc:Bounds x="1150" y="1575" width="900" height="70" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_VendorDeployRequest_di" bpmnElement="StartEvent_VendorDeployRequest">
        <dc:Bounds x="222" y="1429" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="200" y="1472" width="80" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_VendorDeployCoordination_di" bpmnElement="Task_VendorDeployCoordination">
        <dc:Bounds x="310" y="1407" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_VendorResponseSent_di" bpmnElement="EndEvent_VendorResponseSent">
        <dc:Bounds x="462" y="1429" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="440" y="1472" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Start_Readiness_di" bpmnElement="Flow_Start_Readiness">
        <di:waypoint x="258" y="127" />
        <di:waypoint x="284" y="127" />
        <di:waypoint x="284" y="607" />
        <di:waypoint x="310" y="607" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Readiness_Decision_di" bpmnElement="Flow_Readiness_Decision">
        <di:waypoint x="410" y="607" />
        <di:waypoint x="460" y="607" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_RiskScoring_Gate_di" bpmnElement="Flow_RiskScoring_Gate">
        <di:waypoint x="560" y="607" />
        <di:waypoint x="615" y="607" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Decision_Approved_di" bpmnElement="Flow_Decision_Approved">
        <di:waypoint x="640" y="632" />
        <di:waypoint x="640" y="1247" />
        <di:waypoint x="730" y="1247" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="648" y="935" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Decision_Rejected_di" bpmnElement="Flow_Decision_Rejected">
        <di:waypoint x="640" y="582" />
        <di:waypoint x="640" y="285" />
        <di:waypoint x="648" y="285" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="648" y="430" width="40" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Progressive_HealthCheck_di" bpmnElement="Flow_Progressive_HealthCheck">
        <di:waypoint x="830" y="1247" />
        <di:waypoint x="895" y="1247" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Health_Pass_di" bpmnElement="Flow_Health_Pass">
        <di:waypoint x="945" y="1247" />
        <di:waypoint x="1010" y="1247" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="971" y="1229" width="22" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Health_Rollback_di" bpmnElement="Flow_Health_Rollback">
        <di:waypoint x="920" y="1222" />
        <di:waypoint x="920" y="925" />
        <di:waypoint x="1002" y="925" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="928" y="1070" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Verification_Monitoring_di" bpmnElement="Flow_Verification_Monitoring">
        <di:waypoint x="1110" y="1247" />
        <di:waypoint x="1170" y="1247" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Monitoring_End_di" bpmnElement="Flow_Monitoring_End">
        <di:waypoint x="1270" y="1247" />
        <di:waypoint x="1350" y="1247" />
        <di:waypoint x="1350" y="145" />
        <di:waypoint x="1368" y="127" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_ReadinessSLAEscalate_di" bpmnElement="Flow_ReadinessSLAEscalate">
        <di:waypoint x="360" y="665" />
