<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_ClearingLifecycle" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.42.0">
  <bpmn:collaboration id="Collaboration_Clearing">
    <bpmn:participant id="Participant_Clearing" name="Clearing Lifecycle" processRef="Process_ClearingLifecycle" />
  </bpmn:collaboration>
  <bpmn:process id="Process_ClearingLifecycle" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Clearing">
      <bpmn:lane id="Lane_Trader" name="Trader">
        <bpmn:flowNodeRef>StartEvent_TradeInitiated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TradeCapture</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ClearingOps" name="Clearing Operations">
        <bpmn:flowNodeRef>Task_Validation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_TradeValid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_TradeRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RejectTrade</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Enrichment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Matching</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MatchFound</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ManualMatch</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MergeMatch</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Netting</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Settlement" name="Settlement">
        <bpmn:flowNodeRef>Task_SettlementInstruction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Settlement</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SettlementComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FailedSettlement</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SettlementFailed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Reconciliation</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Compliance" name="Compliance">
        <bpmn:flowNodeRef>Task_Reporting</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Complete</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_TradeInitiated" name="Trade&#10;Initiated">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_TradeCapture" name="Capture Trade Details">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="Task_Validation" name="Validate Trade">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_TradeValid" name="Trade Valid?">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_TradeNo</bpmn:outgoing>
      <bpmn:outgoing>Flow_TradeYes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_RejectTrade" name="Reject Trade">
      <bpmn:incoming>Flow_TradeNo</bpmn:incoming>
      <bpmn:outgoing>Flow_ToTradeRejected</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_TradeRejected" name="Trade&#10;Rejected">
      <bpmn:incoming>Flow_ToTradeRejected</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_Enrichment" name="Enrich Trade Data">
      <bpmn:incoming>Flow_TradeYes</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Matching" name="Match Counterparty">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_MatchFound" name="Match Found?">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_MatchNo</bpmn:outgoing>
      <bpmn:outgoing>Flow_MatchYes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ManualMatch" name="Manual Match Resolution" camunda:candidateGroups="clearing-ops">
      <bpmn:incoming>Flow_MatchNo</bpmn:incoming>
      <bpmn:outgoing>Flow_ManualMerge</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_MergeMatch">
      <bpmn:incoming>Flow_MatchYes</bpmn:incoming>
      <bpmn:incoming>Flow_ManualMerge</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_Netting" name="Calculate Net Positions">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_SettlementInstruction" name="Generate Settlement Instructions">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Settlement" name="Execute Settlement">
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_SettlementComplete" name="Settlement&#10;Complete?">
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:outgoing>Flow_SettleNo</bpmn:outgoing>
      <bpmn:outgoing>Flow_SettleYes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_FailedSettlement" name="Handle Failed Settlement">
      <bpmn:incoming>Flow_SettleNo</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSettleFailed</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_SettlementFailed" name="Settlement&#10;Failed">
      <bpmn:incoming>Flow_ToSettleFailed</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_Reconciliation" name="Perform Reconciliation">
      <bpmn:incoming>Flow_SettleYes</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_Reporting" name="Generate Regulatory Reporting">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Complete" name="Clearing&#10;Complete">
      <bpmn:incoming>Flow_11</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_TradeInitiated" targetRef="Task_TradeCapture" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_TradeCapture" targetRef="Task_Validation" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Task_Validation" targetRef="Gateway_TradeValid" />
    <bpmn:sequenceFlow id="Flow_TradeNo" name="No" sourceRef="Gateway_TradeValid" targetRef="Task_RejectTrade" />
    <bpmn:sequenceFlow id="Flow_TradeYes" name="Yes" sourceRef="Gateway_TradeValid" targetRef="Task_Enrichment" />
    <bpmn:sequenceFlow id="Flow_ToTradeRejected" sourceRef="Task_RejectTrade" targetRef="EndEvent_TradeRejected" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Task_Enrichment" targetRef="Task_Matching" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Task_Matching" targetRef="Gateway_MatchFound" />
    <bpmn:sequenceFlow id="Flow_MatchNo" name="No" sourceRef="Gateway_MatchFound" targetRef="Task_ManualMatch" />
    <bpmn:sequenceFlow id="Flow_MatchYes" name="Yes" sourceRef="Gateway_MatchFound" targetRef="Gateway_MergeMatch" />
    <bpmn:sequenceFlow id="Flow_ManualMerge" sourceRef="Task_ManualMatch" targetRef="Gateway_MergeMatch" />
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Gateway_MergeMatch" targetRef="Task_Netting" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="Task_Netting" targetRef="Task_SettlementInstruction" />
    <bpmn:sequenceFlow id="Flow_08" sourceRef="Task_SettlementInstruction" targetRef="Task_Settlement" />
    <bpmn:sequenceFlow id="Flow_09" sourceRef="Task_Settlement" targetRef="Gateway_SettlementComplete" />
    <bpmn:sequenceFlow id="Flow_SettleNo" name="No" sourceRef="Gateway_SettlementComplete" targetRef="Task_FailedSettlement" />
    <bpmn:sequenceFlow id="Flow_SettleYes" name="Yes" sourceRef="Gateway_SettlementComplete" targetRef="Task_Reconciliation" />
    <bpmn:sequenceFlow id="Flow_ToSettleFailed" sourceRef="Task_FailedSettlement" targetRef="EndEvent_SettlementFailed" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_Reconciliation" targetRef="Task_Reporting" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_Reporting" targetRef="EndEvent_Complete" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Clearing">
    <bpmndi:BPMNPlane id="BPMNPlane_Clearing" bpmnElement="Collaboration_Clearing">
      <bpmndi:BPMNShape id="Participant_Clearing_di" bpmnElement="Participant_Clearing" isHorizontal="true">
        <dc:Bounds x="155" y="47" width="1700" height="860" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Trader_di" bpmnElement="Lane_Trader" isHorizontal="true">
        <dc:Bounds x="185" y="47" width="1670" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_ClearingOps_di" bpmnElement="Lane_ClearingOps" isHorizontal="true">
