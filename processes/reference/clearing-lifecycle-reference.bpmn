      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Matching_di" bpmnElement="Task_Matching">
        <dc:Bounds x="943" y="322" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_MatchFound_di" bpmnElement="Gateway_MatchFound" isMarkerVisible="true">
        <dc:Bounds x="1095" y="337" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1089" y="313" width="62" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ManualMatch_di" bpmnElement="Task_ManualMatch">
        <dc:Bounds x="1095" y="417" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_MergeMatch_di" bpmnElement="Gateway_MergeMatch" isMarkerVisible="true">
        <dc:Bounds x="1247" y="337" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Netting_di" bpmnElement="Task_Netting">
        <dc:Bounds x="1349" y="322" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_SettlementInstruction_di" bpmnElement="Task_SettlementInstruction">
        <dc:Bounds x="1349" y="552" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Settlement_di" bpmnElement="Task_Settlement">
        <dc:Bounds x="1501" y="552" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SettlementComplete_di" bpmnElement="Gateway_SettlementComplete" isMarkerVisible="true">
        <dc:Bounds x="1603" y="567" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1597" y="543" width="62" height="27" />
