        <bpmndi:BPMNLabel>
          <dc:Bounds x="720" y="344" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToTradeRejected_di" bpmnElement="Flow_ToTradeRejected">
        <di:waypoint x="739" y="457" />
        <di:waypoint x="791" y="457" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_04_di" bpmnElement="Flow_04">
        <di:waypoint x="891" y="362" />
        <di:waypoint x="943" y="362" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_05_di" bpmnElement="Flow_05">
        <di:waypoint x="1043" y="362" />
        <di:waypoint x="1095" y="362" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_MatchNo_di" bpmnElement="Flow_MatchNo">
