        <dc:Bounds x="1603" y="640" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_SettlementFailed_di" bpmnElement="EndEvent_SettlementFailed">
        <dc:Bounds x="1705" y="662" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1690" y="705" width="66" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Reconciliation_di" bpmnElement="Task_Reconciliation">
        <dc:Bounds x="1655" y="552" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_Reporting_di" bpmnElement="Task_Reporting">
        <dc:Bounds x="1655" y="767" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Complete_di" bpmnElement="EndEvent_Complete">
        <dc:Bounds x="1757" y="789" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1742" y="832" width="66" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_01_di" bpmnElement="Flow_01">
        <di:waypoint x="283" y="147" />
        <di:waypoint x="335" y="147" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_02_di" bpmnElement="Flow_02">
        <di:waypoint x="537" y="187" />
        <di:waypoint x="537" y="322" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_03_di" bpmnElement="Flow_03">
        <di:waypoint x="587" y="362" />
        <di:waypoint x="639" y="362" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TradeNo_di" bpmnElement="Flow_TradeNo">
