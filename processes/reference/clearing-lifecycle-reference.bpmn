        <dc:Bounds x="335" y="107" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_Validation_di" bpmnElement="Task_Validation">
        <dc:Bounds x="487" y="322" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_TradeValid_di" bpmnElement="Gateway_TradeValid" isMarkerVisible="true">
