<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_Phase2Planning"
                  targetNamespace="http://sla.governance/bpmn"
                  exporter="Camunda Modeler"
                  exporterVersion="5.25.0">

  <bpmn:collaboration id="Collaboration_Phase2Planning">
    <bpmn:participant id="Participant_EnterpriseGov" name="Enterprise Governance" processRef="Process_Phase2Planning" />
    <bpmn:participant id="Participant_VendorThirdParty" name="Vendor / Third Party" processRef="Process_VendorPhase2" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Phase2Planning" name="Phase 2: Planning and Inherent Risk Scoping" isExecutable="false" camunda:historyTimeToLive="180">

    <bpmn:laneSet id="LaneSet_Phase2Planning">
      <bpmn:lane id="Lane_Business" name="Business">
        <bpmn:flowNodeRef>StartEvent_Phase2Initiated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_2_1_BusinessCaseValidation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_2_5_ScopeDefinitionBusiness</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Phase2Complete</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Governance" name="Governance">
        <bpmn:flowNodeRef>EndEvent_Rejected</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Contracting" name="Contracting">
      </bpmn:lane>
      <bpmn:lane id="Lane_Technical" name="Technical Assessment">
        <bpmn:flowNodeRef>Task_2_5_ScopeDefinitionTech</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_AIReview" name="AI Review">
        <bpmn:flowNodeRef>Task_2_4_AIRiskClassification</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Compliance" name="Compliance">
        <bpmn:flowNodeRef>Task_2_6_RegulatoryMapping</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Oversight" name="Oversight">
      </bpmn:lane>
      <bpmn:lane id="Lane_Automation" name="Automation">
        <bpmn:flowNodeRef>EndEvent_SLAEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_2_2_InherentRiskScoring</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>BoundaryEvent_Phase2SLATimer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_2_3_RiskTierAssignment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AIInitiative</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelSplitAI</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelSplitMain</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MainBranchJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_FinalJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_2_7_KnowledgeBasePrePopulation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RiskTierDecision</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_Phase2Initiated" name="Phase 2&#10;Initiated">
      <bpmn:outgoing>Flow_Start_BusinessCase</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_2_1_BusinessCaseValidation" name="2.1 Business Case&#10;Validation" camunda:candidateGroups="business-lane">
      <bpmn:incoming>Flow_Start_BusinessCase</bpmn:incoming>
      <bpmn:outgoing>Flow_BusinessCase_RiskScoring</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="Task_2_2_InherentRiskScoring" name="2.2 Inherent&#10;Risk Scoring" camunda:type="external" camunda:topic="inherent-risk-scoring">
      <bpmn:incoming>Flow_BusinessCase_RiskScoring</bpmn:incoming>
      <bpmn:outgoing>Flow_RiskScoring_TierAssignment</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:boundaryEvent id="BoundaryEvent_Phase2SLATimer" name="5 Day&#10;SLA" attachedToRef="Task_2_2_InherentRiskScoring" cancelActivity="false">
      <bpmn:outgoing>Flow_SLATimer_Escalated</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Phase2SLA">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:endEvent id="EndEvent_SLAEscalated" name="Phase 2 SLA&#10;Escalated">
      <bpmn:incoming>Flow_SLATimer_Escalated</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:businessRuleTask id="Task_2_3_RiskTierAssignment" name="2.3 Risk Tier&#10;Assignment" camunda:decisionRef="DMN_RiskTierClassification" camunda:resultVariable="riskTier" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>Flow_RiskScoring_TierAssignment</bpmn:incoming>
      <bpmn:outgoing>Flow_TierAssignment_AIGateway</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:exclusiveGateway id="Gateway_AIInitiative" name="AI Initiative?" default="Flow_NotAI_SplitMain">
      <bpmn:incoming>Flow_TierAssignment_AIGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_YesAI_SplitAI</bpmn:outgoing>
      <bpmn:outgoing>Flow_NotAI_SplitMain</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:parallelGateway id="Gateway_ParallelSplitAI">
      <bpmn:incoming>Flow_YesAI_SplitAI</bpmn:incoming>
      <bpmn:outgoing>Flow_SplitAI_Task24</bpmn:outgoing>
      <bpmn:outgoing>Flow_SplitAI_Task25Bus</bpmn:outgoing>
      <bpmn:outgoing>Flow_SplitAI_Task25Tech</bpmn:outgoing>
      <bpmn:outgoing>Flow_SplitAI_Task26</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:parallelGateway id="Gateway_ParallelSplitMain">
      <bpmn:incoming>Flow_NotAI_SplitMain</bpmn:incoming>
      <bpmn:outgoing>Flow_SplitMain_Task25Bus</bpmn:outgoing>
      <bpmn:outgoing>Flow_SplitMain_Task25Tech</bpmn:outgoing>
      <bpmn:outgoing>Flow_SplitMain_Task26</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:userTask id="Task_2_4_AIRiskClassification" name="2.4 AI Risk&#10;Classification" camunda:candidateGroups="ai-review">
      <bpmn:incoming>Flow_SplitAI_Task24</bpmn:incoming>
      <bpmn:outgoing>Flow_Task24_FinalJoin</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_2_5_ScopeDefinitionBusiness" name="2.5 Scope Definition&#10;(Business)" camunda:candidateGroups="business-lane">
      <bpmn:incoming>Flow_SplitAI_Task25Bus</bpmn:incoming>
      <bpmn:incoming>Flow_SplitMain_Task25Bus</bpmn:incoming>
      <bpmn:outgoing>Flow_Task25Bus_MainJoin</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_2_5_ScopeDefinitionTech" name="2.5 Scope Definition&#10;(Technical)" camunda:candidateGroups="technical-assessment">
      <bpmn:incoming>Flow_SplitAI_Task25Tech</bpmn:incoming>
      <bpmn:incoming>Flow_SplitMain_Task25Tech</bpmn:incoming>
      <bpmn:outgoing>Flow_Task25Tech_MainJoin</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="Task_2_6_RegulatoryMapping" name="2.6 Regulatory&#10;Mapping" camunda:type="external" camunda:topic="regulatory-mapping">
      <bpmn:incoming>Flow_SplitAI_Task26</bpmn:incoming>
      <bpmn:incoming>Flow_SplitMain_Task26</bpmn:incoming>
      <bpmn:outgoing>Flow_Task26_MainJoin</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:parallelGateway id="Gateway_MainBranchJoin">
      <bpmn:incoming>Flow_Task25Bus_MainJoin</bpmn:incoming>
      <bpmn:incoming>Flow_Task25Tech_MainJoin</bpmn:incoming>
      <bpmn:incoming>Flow_Task26_MainJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_MainJoin_FinalJoin</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:parallelGateway id="Gateway_FinalJoin">
      <bpmn:incoming>Flow_Task24_FinalJoin</bpmn:incoming>
      <bpmn:incoming>Flow_MainJoin_FinalJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_FinalJoin_KnowledgeBase</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:serviceTask id="Task_2_7_KnowledgeBasePrePopulation" name="2.7 Knowledge Base&#10;Pre-Population" camunda:type="external" camunda:topic="knowledge-base-population">
      <bpmn:incoming>Flow_FinalJoin_KnowledgeBase</bpmn:incoming>
      <bpmn:outgoing>Flow_KnowledgeBase_RiskTierDecision</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_RiskTierDecision" name="Risk Tier&#10;Decision?" default="Flow_StandardRisk">
      <bpmn:incoming>Flow_KnowledgeBase_RiskTierDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_UnacceptableRisk</bpmn:outgoing>
      <bpmn:outgoing>Flow_HighRisk</bpmn:outgoing>
      <bpmn:outgoing>Flow_StandardRisk</bpmn:outgoing>
      <bpmn:outgoing>Flow_MinimalRisk</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_Rejected" name="Rejected&#10;(Unacceptable Risk)">
      <bpmn:incoming>Flow_UnacceptableRisk</bpmn:incoming>
      <bpmn:terminateEventDefinition id="TerminateDef_Rejected" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Phase2Complete" name="Phase 2 Complete&#10;(Proceed to Phase 3)">
      <bpmn:incoming>Flow_HighRisk</bpmn:incoming>
      <bpmn:incoming>Flow_StandardRisk</bpmn:incoming>
      <bpmn:incoming>Flow_MinimalRisk</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:textAnnotation id="Annotation_OCC">
      <bpmn:text>OCC 2023-17: Third-party risk management — inherent risk scoring (2.2) and risk tier assignment (2.3) satisfy mandatory risk classification requirements for vendor engagement.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_OCC" sourceRef="Task_2_2_InherentRiskScoring" targetRef="Annotation_OCC" />

    <bpmn:textAnnotation id="Annotation_SR117">
      <bpmn:text>SR 11-7: Model risk management — AI Risk Classification (2.4) applies model risk tier (Tier 1/2/3) per Federal Reserve SR 11-7. Tier 1 AI models require independent validation and Board reporting.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_SR117" sourceRef="Task_2_4_AIRiskClassification" targetRef="Annotation_SR117" />

    <bpmn:textAnnotation id="Annotation_GDPR">
      <bpmn:text>GDPR/CCPA: Scope Definition (2.5) and Regulatory Mapping (2.6) identify data residency requirements, PII/NPI processing obligations, and cross-border transfer restrictions.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_GDPR" sourceRef="Task_2_6_RegulatoryMapping" targetRef="Annotation_GDPR" />

    <bpmn:textAnnotation id="Annotation_EUAI">
      <bpmn:text>EU AI Act: AI initiative flag (Gateway: AI Initiative?) triggers mandatory Article 6 risk classification. High-risk AI systems require conformity assessment before procurement.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_EUAI" sourceRef="Gateway_AIInitiative" targetRef="Annotation_EUAI" />

    <bpmn:sequenceFlow id="Flow_Start_BusinessCase" sourceRef="StartEvent_Phase2Initiated" targetRef="Task_2_1_BusinessCaseValidation" />
    <bpmn:sequenceFlow id="Flow_BusinessCase_RiskScoring" sourceRef="Task_2_1_BusinessCaseValidation" targetRef="Task_2_2_InherentRiskScoring" />
    <bpmn:sequenceFlow id="Flow_RiskScoring_TierAssignment" sourceRef="Task_2_2_InherentRiskScoring" targetRef="Task_2_3_RiskTierAssignment" />
    <bpmn:sequenceFlow id="Flow_TierAssignment_AIGateway" sourceRef="Task_2_3_RiskTierAssignment" targetRef="Gateway_AIInitiative" />

    <bpmn:sequenceFlow id="Flow_YesAI_SplitAI" name="Yes" sourceRef="Gateway_AIInitiative" targetRef="Gateway_ParallelSplitAI">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isAIInitiative == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NotAI_SplitMain" name="No" sourceRef="Gateway_AIInitiative" targetRef="Gateway_ParallelSplitMain" />

    <bpmn:sequenceFlow id="Flow_SplitAI_Task24" sourceRef="Gateway_ParallelSplitAI" targetRef="Task_2_4_AIRiskClassification" />
    <bpmn:sequenceFlow id="Flow_SplitAI_Task25Bus" sourceRef="Gateway_ParallelSplitAI" targetRef="Task_2_5_ScopeDefinitionBusiness" />
    <bpmn:sequenceFlow id="Flow_SplitAI_Task25Tech" sourceRef="Gateway_ParallelSplitAI" targetRef="Task_2_5_ScopeDefinitionTech" />
    <bpmn:sequenceFlow id="Flow_SplitAI_Task26" sourceRef="Gateway_ParallelSplitAI" targetRef="Task_2_6_RegulatoryMapping" />

    <bpmn:sequenceFlow id="Flow_SplitMain_Task25Bus" sourceRef="Gateway_ParallelSplitMain" targetRef="Task_2_5_ScopeDefinitionBusiness" />
    <bpmn:sequenceFlow id="Flow_SplitMain_Task25Tech" sourceRef="Gateway_ParallelSplitMain" targetRef="Task_2_5_ScopeDefinitionTech" />
    <bpmn:sequenceFlow id="Flow_SplitMain_Task26" sourceRef="Gateway_ParallelSplitMain" targetRef="Task_2_6_RegulatoryMapping" />

    <bpmn:sequenceFlow id="Flow_Task24_FinalJoin" sourceRef="Task_2_4_AIRiskClassification" targetRef="Gateway_FinalJoin" />
    <bpmn:sequenceFlow id="Flow_Task25Bus_MainJoin" sourceRef="Task_2_5_ScopeDefinitionBusiness" targetRef="Gateway_MainBranchJoin" />
    <bpmn:sequenceFlow id="Flow_Task25Tech_MainJoin" sourceRef="Task_2_5_ScopeDefinitionTech" targetRef="Gateway_MainBranchJoin" />
    <bpmn:sequenceFlow id="Flow_Task26_MainJoin" sourceRef="Task_2_6_RegulatoryMapping" targetRef="Gateway_MainBranchJoin" />

    <bpmn:sequenceFlow id="Flow_MainJoin_FinalJoin" sourceRef="Gateway_MainBranchJoin" targetRef="Gateway_FinalJoin" />

    <bpmn:sequenceFlow id="Flow_FinalJoin_KnowledgeBase" sourceRef="Gateway_FinalJoin" targetRef="Task_2_7_KnowledgeBasePrePopulation" />
    <bpmn:sequenceFlow id="Flow_KnowledgeBase_RiskTierDecision" sourceRef="Task_2_7_KnowledgeBasePrePopulation" targetRef="Gateway_RiskTierDecision" />

    <bpmn:sequenceFlow id="Flow_UnacceptableRisk" name="Unacceptable Risk" sourceRef="Gateway_RiskTierDecision" targetRef="EndEvent_Rejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${riskTier == 'UNACCEPTABLE'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_HighRisk" name="High Risk" sourceRef="Gateway_RiskTierDecision" targetRef="EndEvent_Phase2Complete">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${riskTier == 'HIGH'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_StandardRisk" name="Limited Risk" sourceRef="Gateway_RiskTierDecision" targetRef="EndEvent_Phase2Complete" />
    <bpmn:sequenceFlow id="Flow_MinimalRisk" name="Minimal Risk" sourceRef="Gateway_RiskTierDecision" targetRef="EndEvent_Phase2Complete">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${riskTier == 'MINIMAL'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_SLATimer_Escalated" sourceRef="BoundaryEvent_Phase2SLATimer" targetRef="EndEvent_SLAEscalated" />

  </bpmn:process>

  <bpmn:process id="Process_VendorPhase2" name="Vendor / Third Party — Phase 2" isExecutable="false" camunda:historyTimeToLive="180">
    <bpmn:laneSet id="LaneSet_Vendor">
      <bpmn:lane id="Lane_VendorResponse" name="Vendor Response">
        <bpmn:flowNodeRef>StartEvent_VendorPhase2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_VendorPhase2</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_VendorPhase2" name="Vendor Notified&#10;Phase 2 Open">
      <bpmn:outgoing>Flow_Vendor_Start_End</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:endEvent id="EndEvent_VendorPhase2" name="Vendor Awaiting&#10;Phase 3">
      <bpmn:incoming>Flow_Vendor_Start_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Vendor_Start_End" sourceRef="StartEvent_VendorPhase2" targetRef="EndEvent_VendorPhase2" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Phase2Planning">
    <bpmndi:BPMNPlane id="BPMNPlane_Phase2Planning" bpmnElement="Collaboration_Phase2Planning">

      <bpmndi:BPMNShape id="Participant_EnterpriseGov_di" bpmnElement="Participant_EnterpriseGov" isHorizontal="true">
        <dc:Bounds x="155" y="47" width="1850" height="1000" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Lane_Business_di" bpmnElement="Lane_Business" isHorizontal="true">
        <dc:Bounds x="185" y="47" width="1820" height="125" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Lane_Governance_di" bpmnElement="Lane_Governance" isHorizontal="true">
        <dc:Bounds x="185" y="172" width="1820" height="125" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Lane_Contracting_di" bpmnElement="Lane_Contracting" isHorizontal="true">
        <dc:Bounds x="185" y="297" width="1820" height="125" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Lane_Technical_di" bpmnElement="Lane_Technical" isHorizontal="true">
        <dc:Bounds x="185" y="422" width="1820" height="125" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Lane_AIReview_di" bpmnElement="Lane_AIReview" isHorizontal="true">
        <dc:Bounds x="185" y="547" width="1820" height="125" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Lane_Compliance_di" bpmnElement="Lane_Compliance" isHorizontal="true">
        <dc:Bounds x="185" y="672" width="1820" height="125" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Lane_Oversight_di" bpmnElement="Lane_Oversight" isHorizontal="true">
        <dc:Bounds x="185" y="797" width="1820" height="125" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Lane_Automation_di" bpmnElement="Lane_Automation" isHorizontal="true">
        <dc:Bounds x="185" y="922" width="1820" height="125" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_Phase2Initiated_di" bpmnElement="StartEvent_Phase2Initiated">
        <dc:Bounds x="247" y="91" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="232" y="134" width="66" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_2_1_BusinessCaseValidation_di" bpmnElement="Task_2_1_BusinessCaseValidation">
        <dc:Bounds x="330" y="69" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_2_2_InherentRiskScoring_di" bpmnElement="Task_2_2_InherentRiskScoring">
        <dc:Bounds x="500" y="944" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="BoundaryEvent_Phase2SLATimer_di" bpmnElement="BoundaryEvent_Phase2SLATimer">
        <dc:Bounds x="518" y="1006" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="562" y="1010" width="46" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_SLAEscalated_di" bpmnElement="EndEvent_SLAEscalated">
        <dc:Bounds x="622" y="1006" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="597" y="979" width="86" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_2_3_RiskTierAssignment_di" bpmnElement="Task_2_3_RiskTierAssignment">
        <dc:Bounds x="680" y="944" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_AIInitiative_di" bpmnElement="Gateway_AIInitiative" isMarkerVisible="true">
        <dc:Bounds x="840" y="959" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="825" y="1016" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_ParallelSplitAI_di" bpmnElement="Gateway_ParallelSplitAI">
        <dc:Bounds x="960" y="959" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_ParallelSplitMain_di" bpmnElement="Gateway_ParallelSplitMain">
        <dc:Bounds x="1050" y="959" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_2_4_AIRiskClassification_di" bpmnElement="Task_2_4_AIRiskClassification">
        <dc:Bounds x="1150" y="569" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_2_5_ScopeDefinitionBusiness_di" bpmnElement="Task_2_5_ScopeDefinitionBusiness">
        <dc:Bounds x="1150" y="69" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_2_5_ScopeDefinitionTech_di" bpmnElement="Task_2_5_ScopeDefinitionTech">
        <dc:Bounds x="1150" y="444" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_2_6_RegulatoryMapping_di" bpmnElement="Task_2_6_RegulatoryMapping">
        <dc:Bounds x="1150" y="694" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_MainBranchJoin_di" bpmnElement="Gateway_MainBranchJoin">
        <dc:Bounds x="1310" y="959" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_FinalJoin_di" bpmnElement="Gateway_FinalJoin">
        <dc:Bounds x="1410" y="959" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_2_7_KnowledgeBasePrePopulation_di" bpmnElement="Task_2_7_KnowledgeBasePrePopulation">
        <dc:Bounds x="1520" y="944" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_RiskTierDecision_di" bpmnElement="Gateway_RiskTierDecision" isMarkerVisible="true">
