<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_Phase3DueDiligence"
                  targetNamespace="http://sla.governance/bpmn"
                  exporter="Camunda Modeler"
                  exporterVersion="5.25.0">

  <bpmn:collaboration id="Collaboration_Phase3DD">
    <bpmn:participant id="Participant_EnterpriseGov" name="Enterprise Governance — Phase 3: Due Diligence and Swarm Evaluation" processRef="Process_Phase3DueDiligence" />
    <bpmn:participant id="Participant_VendorThirdParty" name="Vendor / Third Party" processRef="Process_VendorResponse" />
    <bpmn:messageFlow id="MsgFlow_VendorEvidence" name="Evidence Package" sourceRef="Task_VendorEvidenceSubmission" targetRef="Task_31_EvidenceCollection" />
    <bpmn:messageFlow id="MsgFlow_SecurityReq" name="Security Questionnaire" sourceRef="Task_33_SecurityAssessment" targetRef="Task_VendorSecurityQuestionnaire" />
    <bpmn:messageFlow id="MsgFlow_ComplianceReq" name="Compliance Attestation" sourceRef="Task_34_ComplianceAssessment" targetRef="Task_VendorComplianceAttestation" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Phase3DueDiligence" name="Phase 3: Due Diligence and Swarm Evaluation" isExecutable="false" camunda:historyTimeToLive="180">

    <bpmn:laneSet id="LaneSet_Phase3">

      <bpmn:lane id="Lane_Business" name="Business Lane">
        <bpmn:flowNodeRef>Task_36_FinancialStabilityReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_36SLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Governance" name="Governance Lane">
        <bpmn:flowNodeRef>Task_PhaseQualityGate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Phase3Complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_QGSLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Contracting" name="Contracting Lane">
        <bpmn:flowNodeRef>Task_ContractingReview</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_TechnicalAssessment" name="Technical Assessment">
        <bpmn:flowNodeRef>Task_33_SecurityAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_33SLAEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_37_OperationalResilienceVerification</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_37SLAEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_39_ArchitectureFeasibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_39SLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_AIReview" name="AI Review Lane">
        <bpmn:flowNodeRef>Gateway_AIMLCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_35_AIModelRiskAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_35SLAEscalated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AIBranchMerge</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Compliance" name="Compliance Lane">
        <bpmn:flowNodeRef>Task_34_ComplianceAssessment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_34SLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Oversight" name="Oversight Lane">
        <bpmn:flowNodeRef>Task_OversightReview</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Automation" name="Automation Lane">
        <bpmn:flowNodeRef>StartEvent_Phase3Initiated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_31_EvidenceCollection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_32_AgentSwarmDeployment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_38_SwarmResultsAggregation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_BuildPathway</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_310_TPRMBuildMapping</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PathwayMerge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ProcessSLAEscalated</bpmn:flowNodeRef>
      </bpmn:lane>

    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_Phase3Initiated" name="Phase 2 Complete&#10;(Pathway Assigned)">
      <bpmn:outgoing>Flow_Start_31</bpmn:outgoing>
      <bpmn:signalEventDefinition id="SignalDef_P2Catch" signalRef="Signal_Phase2Complete_P3" />
    </bpmn:startEvent>

    <bpmn:serviceTask id="Task_31_EvidenceCollection" name="3.1 Evidence Collection&#10;(API Auto-Ingestion)" camunda:type="external" camunda:topic="evidence-collection">
      <bpmn:incoming>Flow_Start_31</bpmn:incoming>
      <bpmn:outgoing>Flow_31_32</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_32_AgentSwarmDeployment" name="3.2 Agent Swarm&#10;Deployment (Orchestrator)" camunda:type="external" camunda:topic="swarm-deployment">
      <bpmn:incoming>Flow_31_32</bpmn:incoming>
      <bpmn:outgoing>Flow_32_ParallelSplit</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:boundaryEvent id="Timer_ProcessSLA" name="8 Day&#10;SLA" attachedToRef="Task_32_AgentSwarmDeployment" cancelActivity="false">
      <bpmn:outgoing>Flow_ProcessSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_ProcessSLA">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P8D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:parallelGateway id="Gateway_ParallelSplit" name="Parallel&#10;Assessment Split">
      <bpmn:incoming>Flow_32_ParallelSplit</bpmn:incoming>
      <bpmn:outgoing>Flow_Split_Security</bpmn:outgoing>
      <bpmn:outgoing>Flow_Split_Compliance</bpmn:outgoing>
      <bpmn:outgoing>Flow_Split_AICheck</bpmn:outgoing>
      <bpmn:outgoing>Flow_Split_Financial</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:serviceTask id="Task_33_SecurityAssessment" name="3.3 Security Assessment&#10;(Security Assessment Agent)" camunda:type="external" camunda:topic="security-assessment">
      <bpmn:incoming>Flow_Split_Security</bpmn:incoming>
      <bpmn:outgoing>Flow_33_37</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:boundaryEvent id="Timer_33_SLA" name="1 Day&#10;SLA" attachedToRef="Task_33_SecurityAssessment" cancelActivity="false">
      <bpmn:outgoing>Flow_33SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_33">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:userTask id="Task_37_OperationalResilienceVerification" name="3.7 Operational Resilience&#10;Verification (AI + Human)" camunda:candidateGroups="it-architecture">
      <bpmn:incoming>Flow_33_37</bpmn:incoming>
      <bpmn:outgoing>Flow_37_Join</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="Timer_37_SLA" name="1 Day&#10;SLA" attachedToRef="Task_37_OperationalResilienceVerification" cancelActivity="false">
      <bpmn:outgoing>Flow_37SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_37">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="Task_34_ComplianceAssessment" name="3.4 Compliance Assessment&#10;(Compliance Assessment Agent)" camunda:type="external" camunda:topic="compliance-assessment">
      <bpmn:incoming>Flow_Split_Compliance</bpmn:incoming>
      <bpmn:outgoing>Flow_34_Join</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:boundaryEvent id="Timer_34_SLA" name="1 Day&#10;SLA" attachedToRef="Task_34_ComplianceAssessment" cancelActivity="false">
      <bpmn:outgoing>Flow_34SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_34">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:exclusiveGateway id="Gateway_AIMLCheck" name="AI/ML&#10;Scope?" default="Flow_AICheck_NoAI">
      <bpmn:incoming>Flow_Split_AICheck</bpmn:incoming>
      <bpmn:outgoing>Flow_AICheck_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_AICheck_NoAI</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_35_AIModelRiskAssessment" name="3.5 AI Model Risk&#10;Assessment (SR 11-7 / EU AI Act)" camunda:candidateGroups="information-security">
      <bpmn:incoming>Flow_AICheck_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_35_AIBranchMerge</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="Timer_35_SLA" name="2 Day&#10;SLA" attachedToRef="Task_35_AIModelRiskAssessment" cancelActivity="false">
      <bpmn:outgoing>Flow_35SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_35">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P2D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:exclusiveGateway id="Gateway_AIBranchMerge">
      <bpmn:incoming>Flow_AICheck_NoAI</bpmn:incoming>
      <bpmn:incoming>Flow_35_AIBranchMerge</bpmn:incoming>
      <bpmn:outgoing>Flow_AIBranchMerge_Join</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_36_FinancialStabilityReview" name="3.6 Financial Stability&#10;Review (AI + Human)" camunda:candidateGroups="business-owner">
      <bpmn:incoming>Flow_Split_Financial</bpmn:incoming>
      <bpmn:outgoing>Flow_36_Join</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="Timer_36_SLA" name="1 Day&#10;SLA" attachedToRef="Task_36_FinancialStabilityReview" cancelActivity="false">
      <bpmn:outgoing>Flow_36SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_36">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:parallelGateway id="Gateway_ParallelJoin">
      <bpmn:incoming>Flow_37_Join</bpmn:incoming>
      <bpmn:incoming>Flow_34_Join</bpmn:incoming>
      <bpmn:incoming>Flow_AIBranchMerge_Join</bpmn:incoming>
      <bpmn:incoming>Flow_36_Join</bpmn:incoming>
      <bpmn:outgoing>Flow_Join_38</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:serviceTask id="Task_38_SwarmResultsAggregation" name="3.8 Swarm Results&#10;Aggregation (Swarm Coordinator)" camunda:type="external" camunda:topic="swarm-aggregation">
      <bpmn:incoming>Flow_Join_38</bpmn:incoming>
      <bpmn:outgoing>Flow_38_BuildGateway</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_BuildPathway" name="Build&#10;Pathway?" default="Flow_NoBuildPath">
      <bpmn:incoming>Flow_38_BuildGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_YesBuildPath</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoBuildPath</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_39_ArchitectureFeasibility" name="3.9 Architecture Feasibility&#10;Assessment (Architecture Agent)" camunda:candidateGroups="it-architecture">
      <bpmn:incoming>Flow_YesBuildPath</bpmn:incoming>
      <bpmn:outgoing>Flow_39_310</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="Timer_39_SLA" name="5 Day&#10;SLA" attachedToRef="Task_39_ArchitectureFeasibility" cancelActivity="false">
      <bpmn:outgoing>Flow_39SLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_39">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="Task_310_TPRMBuildMapping" name="3.10 TPRM-to-Build&#10;Standards Mapping (Engine)" camunda:type="external" camunda:topic="tprm-build-mapping">
      <bpmn:incoming>Flow_39_310</bpmn:incoming>
      <bpmn:outgoing>Flow_310_OversightMerge</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_PathwayMerge">
      <bpmn:incoming>Flow_NoBuildPath</bpmn:incoming>
      <bpmn:incoming>Flow_310_OversightMerge</bpmn:incoming>
      <bpmn:outgoing>Flow_PathwayMerge_Oversight</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_OversightReview" name="Oversight Review&#10;(Risk Acceptance)" camunda:candidateGroups="sla-governance-board">
      <bpmn:incoming>Flow_PathwayMerge_Oversight</bpmn:incoming>
      <bpmn:outgoing>Flow_Oversight_Contracting</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_ContractingReview" name="Contracting Review&#10;(Terms Validation)" camunda:candidateGroups="legal-compliance">
      <bpmn:incoming>Flow_Oversight_Contracting</bpmn:incoming>
      <bpmn:outgoing>Flow_Contracting_QualityGate</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_PhaseQualityGate" name="Phase 3 Quality Gate&#10;+ Approval Sign-Off" camunda:candidateGroups="sla-governance-board">
      <bpmn:incoming>Flow_Contracting_QualityGate</bpmn:incoming>
      <bpmn:outgoing>Flow_QualityGate_End</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:boundaryEvent id="Timer_QualityGateSLA" name="2 Day&#10;SLA" attachedToRef="Task_PhaseQualityGate" cancelActivity="false">
      <bpmn:outgoing>Flow_QGSLAEscalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_QualityGate">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P2D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:endEvent id="EndEvent_Phase3Complete" name="Phase 3 Complete&#10;(Due Diligence Approved)">
      <bpmn:incoming>Flow_QualityGate_End</bpmn:incoming>
      <bpmn:signalEventDefinition id="SignalDef_P3Complete" signalRef="Signal_Phase3Complete" />
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_QGSLAEscalated" name="Quality Gate&#10;SLA Escalated">
      <bpmn:incoming>Flow_QGSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_ProcessSLAEscalated" name="Process SLA&#10;Escalated (P8D)">
      <bpmn:incoming>Flow_ProcessSLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_36SLAEscalated" name="Financial Review&#10;SLA Escalated">
      <bpmn:incoming>Flow_36SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_33SLAEscalated" name="Security Assessment&#10;SLA Escalated">
      <bpmn:incoming>Flow_33SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_37SLAEscalated" name="Operational Resilience&#10;SLA Escalated">
      <bpmn:incoming>Flow_37SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_34SLAEscalated" name="Compliance Assessment&#10;SLA Escalated">
      <bpmn:incoming>Flow_34SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_35SLAEscalated" name="AI Risk Assessment&#10;SLA Escalated">
      <bpmn:incoming>Flow_35SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_39SLAEscalated" name="Architecture Feasibility&#10;SLA Escalated">
      <bpmn:incoming>Flow_39SLAEscalate</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:textAnnotation id="Annotation_OCC">
      <bpmn:text>OCC 2023-17: Third-party risk management due diligence — security assessment and evidence collection required for all vendor engagements prior to contract execution.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_OCC" sourceRef="Task_33_SecurityAssessment" targetRef="Annotation_OCC" />

    <bpmn:textAnnotation id="Annotation_SR117">
      <bpmn:text>SR 11-7: Model risk management — AI/ML systems require ethics committee review, model validation, and documented risk acceptance per Federal Reserve SR 11-7 guidance.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_SR117" sourceRef="Task_35_AIModelRiskAssessment" targetRef="Annotation_SR117" />

    <bpmn:textAnnotation id="Annotation_SOX">
      <bpmn:text>SOX: Financial stability review documents vendor financial controls, audit readiness, and going-concern viability. All financial analysis logged with provenance for audit trail compliance.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_SOX" sourceRef="Task_36_FinancialStabilityReview" targetRef="Annotation_SOX" />

    <bpmn:textAnnotation id="Annotation_GDPR">
      <bpmn:text>GDPR/CCPA: Compliance assessment validates data protection controls, cross-border transfer mechanisms (SCCs / adequacy decisions), and privacy-by-design requirements for vendor data processing activities.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_GDPR" sourceRef="Task_34_ComplianceAssessment" targetRef="Annotation_GDPR" />

    <bpmn:textAnnotation id="Annotation_EUAIAct">
      <bpmn:text>EU AI Act: AI risk classification (prohibited / high-risk / limited-risk) required per Article 9. Ethics Committee review mandatory for high-risk AI systems deployed in financial services scope.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_EUAIAct" sourceRef="Task_35_AIModelRiskAssessment" targetRef="Annotation_EUAIAct" />

    <bpmn:sequenceFlow id="Flow_Start_31" sourceRef="StartEvent_Phase3Initiated" targetRef="Task_31_EvidenceCollection" />
    <bpmn:sequenceFlow id="Flow_31_32" sourceRef="Task_31_EvidenceCollection" targetRef="Task_32_AgentSwarmDeployment" />
    <bpmn:sequenceFlow id="Flow_32_ParallelSplit" sourceRef="Task_32_AgentSwarmDeployment" targetRef="Gateway_ParallelSplit" />
    <bpmn:sequenceFlow id="Flow_Split_Security" sourceRef="Gateway_ParallelSplit" targetRef="Task_33_SecurityAssessment" />
    <bpmn:sequenceFlow id="Flow_Split_Compliance" sourceRef="Gateway_ParallelSplit" targetRef="Task_34_ComplianceAssessment" />
    <bpmn:sequenceFlow id="Flow_Split_AICheck" sourceRef="Gateway_ParallelSplit" targetRef="Gateway_AIMLCheck" />
    <bpmn:sequenceFlow id="Flow_Split_Financial" sourceRef="Gateway_ParallelSplit" targetRef="Task_36_FinancialStabilityReview" />
    <bpmn:sequenceFlow id="Flow_33_37" sourceRef="Task_33_SecurityAssessment" targetRef="Task_37_OperationalResilienceVerification" />
    <bpmn:sequenceFlow id="Flow_37_Join" sourceRef="Task_37_OperationalResilienceVerification" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_34_Join" sourceRef="Task_34_ComplianceAssessment" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_AICheck_Yes" name="Yes" sourceRef="Gateway_AIMLCheck" targetRef="Task_35_AIModelRiskAssessment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isAIMLScope == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AICheck_NoAI" name="No" sourceRef="Gateway_AIMLCheck" targetRef="Gateway_AIBranchMerge" />
    <bpmn:sequenceFlow id="Flow_35_AIBranchMerge" sourceRef="Task_35_AIModelRiskAssessment" targetRef="Gateway_AIBranchMerge" />
    <bpmn:sequenceFlow id="Flow_AIBranchMerge_Join" sourceRef="Gateway_AIBranchMerge" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_36_Join" sourceRef="Task_36_FinancialStabilityReview" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_Join_38" sourceRef="Gateway_ParallelJoin" targetRef="Task_38_SwarmResultsAggregation" />
    <bpmn:sequenceFlow id="Flow_38_BuildGateway" sourceRef="Task_38_SwarmResultsAggregation" targetRef="Gateway_BuildPathway" />
    <bpmn:sequenceFlow id="Flow_YesBuildPath" name="Yes" sourceRef="Gateway_BuildPathway" targetRef="Task_39_ArchitectureFeasibility">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${selectedPathway == 'BUILD' || selectedPathway == 'HYBRID'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NoBuildPath" name="No (Buy)" sourceRef="Gateway_BuildPathway" targetRef="Gateway_PathwayMerge" />
    <bpmn:sequenceFlow id="Flow_39_310" sourceRef="Task_39_ArchitectureFeasibility" targetRef="Task_310_TPRMBuildMapping" />
    <bpmn:sequenceFlow id="Flow_310_OversightMerge" sourceRef="Task_310_TPRMBuildMapping" targetRef="Gateway_PathwayMerge" />
    <bpmn:sequenceFlow id="Flow_PathwayMerge_Oversight" sourceRef="Gateway_PathwayMerge" targetRef="Task_OversightReview" />
    <bpmn:sequenceFlow id="Flow_Oversight_Contracting" sourceRef="Task_OversightReview" targetRef="Task_ContractingReview" />
    <bpmn:sequenceFlow id="Flow_Contracting_QualityGate" sourceRef="Task_ContractingReview" targetRef="Task_PhaseQualityGate" />
    <bpmn:sequenceFlow id="Flow_QualityGate_End" sourceRef="Task_PhaseQualityGate" targetRef="EndEvent_Phase3Complete" />
    <bpmn:sequenceFlow id="Flow_ProcessSLAEscalate" sourceRef="Timer_ProcessSLA" targetRef="EndEvent_ProcessSLAEscalated" />
    <bpmn:sequenceFlow id="Flow_36SLAEscalate" sourceRef="Timer_36_SLA" targetRef="EndEvent_36SLAEscalated" />
    <bpmn:sequenceFlow id="Flow_33SLAEscalate" sourceRef="Timer_33_SLA" targetRef="EndEvent_33SLAEscalated" />
    <bpmn:sequenceFlow id="Flow_34SLAEscalate" sourceRef="Timer_34_SLA" targetRef="EndEvent_34SLAEscalated" />
    <bpmn:sequenceFlow id="Flow_35SLAEscalate" sourceRef="Timer_35_SLA" targetRef="EndEvent_35SLAEscalated" />
    <bpmn:sequenceFlow id="Flow_37SLAEscalate" sourceRef="Timer_37_SLA" targetRef="EndEvent_37SLAEscalated" />
    <bpmn:sequenceFlow id="Flow_39SLAEscalate" sourceRef="Timer_39_SLA" targetRef="EndEvent_39SLAEscalated" />
    <bpmn:sequenceFlow id="Flow_QGSLAEscalate" sourceRef="Timer_QualityGateSLA" targetRef="EndEvent_QGSLAEscalated" />

  </bpmn:process>

  <bpmn:process id="Process_VendorResponse" name="Vendor / Third Party" isExecutable="false" camunda:historyTimeToLive="180">

    <bpmn:laneSet id="LaneSet_Vendor">
      <bpmn:lane id="Lane_VendorResponse" name="Vendor Response">
        <bpmn:flowNodeRef>StartEvent_VendorEngagement</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VendorEvidenceSubmission</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VendorSecurityQuestionnaire</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VendorComplianceAttestation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_VendorEngagementEnd</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_VendorEngagement" name="Vendor Engagement&#10;Initiated">
      <bpmn:outgoing>Flow_VendorStart_Evidence</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_VendorEvidenceSubmission" name="Evidence Package&#10;Submission (SOC2, ISO27001)" camunda:candidateGroups="vendor-management">
      <bpmn:incoming>Flow_VendorStart_Evidence</bpmn:incoming>
      <bpmn:outgoing>Flow_VendorEvidence_End</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_VendorSecurityQuestionnaire" name="Security Questionnaire&#10;Response (CAIQ / SIG)" camunda:candidateGroups="vendor-management" />

    <bpmn:userTask id="Task_VendorComplianceAttestation" name="Compliance Attestation&#10;(GDPR DPA, Data Processing)" camunda:candidateGroups="vendor-management" />

    <bpmn:endEvent id="EndEvent_VendorEngagementEnd" name="Vendor Engagement&#10;Complete">
      <bpmn:incoming>Flow_VendorEvidence_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_VendorStart_Evidence" sourceRef="StartEvent_VendorEngagement" targetRef="Task_VendorEvidenceSubmission" />
    <bpmn:sequenceFlow id="Flow_VendorEvidence_End" sourceRef="Task_VendorEvidenceSubmission" targetRef="EndEvent_VendorEngagementEnd" />

