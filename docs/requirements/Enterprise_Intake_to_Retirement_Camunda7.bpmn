    </bpmn:subProcess>

    <bpmn:subProcess id="SP_Phase5" name="Phase 5: Development &amp; Build">
      <bpmn:documentation>Sprint-based | 9 AI agent roles</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="phase" value="5" />
          <camunda:property name="sla_standard_hours" value="720" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Ph4_Ph5</bpmn:incoming>
      <bpmn:outgoing>Flow_Ph5_Ph6</bpmn:outgoing>
      <bpmn:startEvent id="SP_Phase5_Start" name="Start">
        <bpmn:outgoing>Flow_SP_Phase5_s</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:userTask id="SP_Phase5_Task" name="Phase5 Activities" camunda:candidateGroups="governance-lane">
        <bpmn:incoming>Flow_SP_Phase5_s</bpmn:incoming>
        <bpmn:outgoing>Flow_SP_Phase5_e</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:endEvent id="SP_Phase5_End" name="Complete">
        <bpmn:incoming>Flow_SP_Phase5_e</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_SP_Phase5_s" sourceRef="SP_Phase5_Start" targetRef="SP_Phase5_Task" />
      <bpmn:sequenceFlow id="Flow_SP_Phase5_e" sourceRef="SP_Phase5_Task" targetRef="SP_Phase5_End" />
    </bpmn:subProcess>

    <bpmn:subProcess id="SP_Phase6" name="Phase 6: Testing &amp; Validation">
      <bpmn:documentation>SLA: 5-15d | AI-augmented</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="phase" value="6" />
          <camunda:property name="sla_standard_hours" value="360" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Ph5_Ph6</bpmn:incoming>
      <bpmn:outgoing>Flow_Ph6_Ph7</bpmn:outgoing>
      <bpmn:startEvent id="SP_Phase6_Start" name="Start">
        <bpmn:outgoing>Flow_SP_Phase6_s</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:userTask id="SP_Phase6_Task" name="Phase6 Activities" camunda:candidateGroups="governance-lane">
        <bpmn:incoming>Flow_SP_Phase6_s</bpmn:incoming>
        <bpmn:outgoing>Flow_SP_Phase6_e</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:endEvent id="SP_Phase6_End" name="Complete">
        <bpmn:incoming>Flow_SP_Phase6_e</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_SP_Phase6_s" sourceRef="SP_Phase6_Start" targetRef="SP_Phase6_Task" />
      <bpmn:sequenceFlow id="Flow_SP_Phase6_e" sourceRef="SP_Phase6_Task" targetRef="SP_Phase6_End" />
    </bpmn:subProcess>

    <bpmn:subProcess id="SP_Phase7" name="Phase 7: Deployment &amp; Release">
      <bpmn:documentation>SLA: 2-5d | DMN-DT-009</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="phase" value="7" />
          <camunda:property name="sla_standard_hours" value="120" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Ph6_Ph7</bpmn:incoming>
      <bpmn:outgoing>Flow_Ph7_Ph8</bpmn:outgoing>
      <bpmn:startEvent id="SP_Phase7_Start" name="Start">
        <bpmn:outgoing>Flow_SP_Phase7_s</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:userTask id="SP_Phase7_Task" name="Phase7 Activities" camunda:candidateGroups="governance-lane">
        <bpmn:incoming>Flow_SP_Phase7_s</bpmn:incoming>
        <bpmn:outgoing>Flow_SP_Phase7_e</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:endEvent id="SP_Phase7_End" name="Complete">
        <bpmn:incoming>Flow_SP_Phase7_e</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_SP_Phase7_s" sourceRef="SP_Phase7_Start" targetRef="SP_Phase7_Task" />
      <bpmn:sequenceFlow id="Flow_SP_Phase7_e" sourceRef="SP_Phase7_Task" targetRef="SP_Phase7_End" />
    </bpmn:subProcess>

    <bpmn:subProcess id="SP_Phase8" name="Phase 8: Operations &amp; Retirement">
      <bpmn:documentation>Ongoing | 6-phase retirement</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="phase" value="8" />
          <camunda:property name="sla_standard_hours" value="8760" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Ph7_Ph8</bpmn:incoming>
      <bpmn:outgoing>Flow_Ph8_End</bpmn:outgoing>
      <bpmn:startEvent id="SP_Phase8_Start" name="Start">
        <bpmn:outgoing>Flow_SP_Phase8_s</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:userTask id="SP_Phase8_Task" name="Phase8 Activities" camunda:candidateGroups="governance-lane">
        <bpmn:incoming>Flow_SP_Phase8_s</bpmn:incoming>
        <bpmn:outgoing>Flow_SP_Phase8_e</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:endEvent id="SP_Phase8_End" name="Complete">
        <bpmn:incoming>Flow_SP_Phase8_e</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_SP_Phase8_s" sourceRef="SP_Phase8_Start" targetRef="SP_Phase8_Task" />
      <bpmn:sequenceFlow id="Flow_SP_Phase8_e" sourceRef="SP_Phase8_Task" targetRef="SP_Phase8_End" />
    </bpmn:subProcess>

    <bpmn:boundaryEvent id="Tmr_SP_Phase1" name="SLA Breach" cancelActivity="false" attachedToRef="SP_Phase1">
      <bpmn:outgoing>Flow_Tmr_SP_Phase1</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:executionListener delegateExpression="${slaBreachDelegate}" event="start" />
      </bpmn:extensionElements>
      <bpmn:timerEventDefinition id="TD_Tmr_SP_Phase1">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P2D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="Esc_SP_Phase1" name="SLA&#10;Escalation">
      <bpmn:incoming>Flow_Tmr_SP_Phase1</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Tmr_SP_Phase1" sourceRef="Tmr_SP_Phase1" targetRef="Esc_SP_Phase1" />
    <bpmn:boundaryEvent id="Tmr_SP_Phase2" name="SLA Breach" cancelActivity="false" attachedToRef="SP_Phase2">
      <bpmn:outgoing>Flow_Tmr_SP_Phase2</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:executionListener delegateExpression="${slaBreachDelegate}" event="start" />
      </bpmn:extensionElements>
      <bpmn:timerEventDefinition id="TD_Tmr_SP_Phase2">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P10D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="Esc_SP_Phase2" name="SLA&#10;Escalation">
      <bpmn:incoming>Flow_Tmr_SP_Phase2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Tmr_SP_Phase2" sourceRef="Tmr_SP_Phase2" targetRef="Esc_SP_Phase2" />
    <bpmn:boundaryEvent id="Tmr_SP_Phase3" name="SLA Breach" cancelActivity="false" attachedToRef="SP_Phase3">
      <bpmn:outgoing>Flow_Tmr_SP_Phase3</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:executionListener delegateExpression="${slaBreachDelegate}" event="start" />
      </bpmn:extensionElements>
      <bpmn:timerEventDefinition id="TD_Tmr_SP_Phase3">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P15D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="Esc_SP_Phase3" name="SLA&#10;Escalation">
      <bpmn:incoming>Flow_Tmr_SP_Phase3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Tmr_SP_Phase3" sourceRef="Tmr_SP_Phase3" targetRef="Esc_SP_Phase3" />
    <bpmn:boundaryEvent id="Tmr_SP_Phase4" name="SLA Breach" cancelActivity="false" attachedToRef="SP_Phase4">
      <bpmn:outgoing>Flow_Tmr_SP_Phase4</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:executionListener delegateExpression="${slaBreachDelegate}" event="start" />
      </bpmn:extensionElements>
      <bpmn:timerEventDefinition id="TD_Tmr_SP_Phase4">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P15D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="Esc_SP_Phase4" name="SLA&#10;Escalation">
      <bpmn:incoming>Flow_Tmr_SP_Phase4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Tmr_SP_Phase4" sourceRef="Tmr_SP_Phase4" targetRef="Esc_SP_Phase4" />
    <bpmn:boundaryEvent id="Tmr_SP_Phase5" name="SLA Breach" cancelActivity="false" attachedToRef="SP_Phase5">
      <bpmn:outgoing>Flow_Tmr_SP_Phase5</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:executionListener delegateExpression="${slaBreachDelegate}" event="start" />
      </bpmn:extensionElements>
      <bpmn:timerEventDefinition id="TD_Tmr_SP_Phase5">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P30D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="Esc_SP_Phase5" name="SLA&#10;Escalation">
      <bpmn:incoming>Flow_Tmr_SP_Phase5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Tmr_SP_Phase5" sourceRef="Tmr_SP_Phase5" targetRef="Esc_SP_Phase5" />
    <bpmn:boundaryEvent id="Tmr_SP_Phase6" name="SLA Breach" cancelActivity="false" attachedToRef="SP_Phase6">
      <bpmn:outgoing>Flow_Tmr_SP_Phase6</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:executionListener delegateExpression="${slaBreachDelegate}" event="start" />
      </bpmn:extensionElements>
      <bpmn:timerEventDefinition id="TD_Tmr_SP_Phase6">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P15D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="Esc_SP_Phase6" name="SLA&#10;Escalation">
      <bpmn:incoming>Flow_Tmr_SP_Phase6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Tmr_SP_Phase6" sourceRef="Tmr_SP_Phase6" targetRef="Esc_SP_Phase6" />
    <bpmn:boundaryEvent id="Tmr_SP_Phase7" name="SLA Breach" cancelActivity="false" attachedToRef="SP_Phase7">
      <bpmn:outgoing>Flow_Tmr_SP_Phase7</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:executionListener delegateExpression="${slaBreachDelegate}" event="start" />
      </bpmn:extensionElements>
      <bpmn:timerEventDefinition id="TD_Tmr_SP_Phase7">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="Esc_SP_Phase7" name="SLA&#10;Escalation">
      <bpmn:incoming>Flow_Tmr_SP_Phase7</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Tmr_SP_Phase7" sourceRef="Tmr_SP_Phase7" targetRef="Esc_SP_Phase7" />
    <bpmn:boundaryEvent id="Tmr_SP_Phase8" name="SLA Breach" cancelActivity="false" attachedToRef="SP_Phase8">
      <bpmn:outgoing>Flow_Tmr_SP_Phase8</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:executionListener delegateExpression="${slaBreachDelegate}" event="start" />
      </bpmn:extensionElements>
      <bpmn:timerEventDefinition id="TD_Tmr_SP_Phase8">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P365D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="Esc_SP_Phase8" name="SLA&#10;Escalation">
      <bpmn:incoming>Flow_Tmr_SP_Phase8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Tmr_SP_Phase8" sourceRef="Tmr_SP_Phase8" targetRef="Esc_SP_Phase8" />

    <bpmn:exclusiveGateway id="GW_P1_Exit" name="Initiation Gate" default="Flow_GW1_Ph2">
      <bpmn:incoming>Flow_Ph1_GW1</bpmn:incoming>
      <bpmn:outgoing>Flow_GW1_Ph2</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW1_Deferred</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW1_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_P2_Exit" name="Phase 2 Gate" default="Flow_GW2_Ph3">
      <bpmn:incoming>Flow_Ph2_GW2</bpmn:incoming>
      <bpmn:outgoing>Flow_GW2_Ph3</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW2_Remediate</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW2_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_P3_Exit" name="Phase 3 Gate" default="Flow_GW3_Ph4">
      <bpmn:incoming>Flow_Ph3_GW3</bpmn:incoming>
      <bpmn:outgoing>Flow_GW3_Ph4</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW3_Rework</bpmn:outgoing>
      <bpmn:outgoing>Flow_GW3_Escalate</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="End_Deferred" name="Deferred&#10;to Backlog" />
    <bpmn:endEvent id="End_Rejected" name="Rejected&#10;&amp; Archived" />
    <bpmn:endEvent id="End_Retired" name="Fully&#10;Decommissioned" />

    <bpmn:sequenceFlow id="Flow_Start_Ph1" sourceRef="StartEvent_Intake" targetRef="SP_Phase1" />
    <bpmn:sequenceFlow id="Flow_Ph1_GW1" sourceRef="SP_Phase1" targetRef="GW_P1_Exit" />
    <bpmn:sequenceFlow id="Flow_GW1_Ph2" name="Approved" sourceRef="GW_P1_Exit" targetRef="SP_Phase2" />
    <bpmn:sequenceFlow id="Flow_GW1_Deferred" name="Deferred" sourceRef="GW_P1_Exit" targetRef="End_Deferred">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{gateDecision=="Defer"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_GW1_Rejected" name="Rejected" sourceRef="GW_P1_Exit" targetRef="End_Rejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{gateDecision=="Reject"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Ph2_GW2" sourceRef="SP_Phase2" targetRef="GW_P2_Exit" />
    <bpmn:sequenceFlow id="Flow_GW2_Ph3" name="Approved" sourceRef="GW_P2_Exit" targetRef="SP_Phase3" />
    <bpmn:sequenceFlow id="Flow_GW2_Remediate" name="Remediate" sourceRef="GW_P2_Exit" targetRef="SP_Phase2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{gateDecision=="Remediate"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_GW2_Rejected" name="Rejected" sourceRef="GW_P2_Exit" targetRef="End_Rejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{gateDecision=="Reject"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Ph3_GW3" sourceRef="SP_Phase3" targetRef="GW_P3_Exit" />
    <bpmn:sequenceFlow id="Flow_GW3_Ph4" name="All Met" sourceRef="GW_P3_Exit" targetRef="SP_Phase4" />
    <bpmn:sequenceFlow id="Flow_GW3_Rework" name="Outstanding" sourceRef="GW_P3_Exit" targetRef="SP_Phase3">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{gateDecision=="Remediate"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_GW3_Escalate" name="Critical" sourceRef="GW_P3_Exit" targetRef="SP_Phase2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{gateDecision=="Escalate"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Ph4_Ph5" sourceRef="SP_Phase4" targetRef="SP_Phase5" />
    <bpmn:sequenceFlow id="Flow_Ph5_Ph6" sourceRef="SP_Phase5" targetRef="SP_Phase6" />
    <bpmn:sequenceFlow id="Flow_Ph6_Ph7" sourceRef="SP_Phase6" targetRef="SP_Phase7" />
    <bpmn:sequenceFlow id="Flow_Ph7_Ph8" sourceRef="SP_Phase7" targetRef="SP_Phase8" />
    <bpmn:sequenceFlow id="Flow_Ph8_End" sourceRef="SP_Phase8" targetRef="End_Retired" />

    <bpmn:subProcess id="EvSP_SLA" name="SLA Breach Management" triggeredByEvent="true">
      <bpmn:documentation>Progressive 50/75/90/100% escalation.</bpmn:documentation>
      <bpmn:startEvent id="Start_EvSP_SLA" name="SLA Check" isInterrupting="false">
        <bpmn:timerEventDefinition><bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/PT1H</bpmn:timeCycle></bpmn:timerEventDefinition>
      </bpmn:startEvent>
      <bpmn:exclusiveGateway id="GW_SLA" name="Breach Level?" default="fSLA_50" />
      <bpmn:sendTask id="SLA_50" name="50% Warning" camunda:delegateExpression="${slaWarningDelegate}">
        <bpmn:documentation>Dashboard yellow.</bpmn:documentation>
      </bpmn:sendTask>
      <bpmn:sendTask id="SLA_75" name="75% Alert" camunda:delegateExpression="${slaAlertDelegate}">
        <bpmn:documentation>Escalate to manager.</bpmn:documentation>
      </bpmn:sendTask>
      <bpmn:sendTask id="SLA_90" name="90% Critical" camunda:delegateExpression="${slaCriticalDelegate}">
        <bpmn:documentation>Governance lead.</bpmn:documentation>
      </bpmn:sendTask>
      <bpmn:task id="SLA_100" name="100% Breach + RCA">
        <bpmn:documentation>Formal record + RCA 24h.</bpmn:documentation>
      </bpmn:task>
      <bpmn:endEvent id="End_EvSP_SLA" name="" />
      <bpmn:sequenceFlow id="fSLA_0" sourceRef="Start_EvSP_SLA" targetRef="GW_SLA"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fSLA_50" sourceRef="GW_SLA" targetRef="SLA_50" name="50%"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fSLA_75" sourceRef="GW_SLA" targetRef="SLA_75" name="75%">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{slaPercentage&gt;=75}</bpmn:conditionExpression></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fSLA_90" sourceRef="GW_SLA" targetRef="SLA_90" name="90%">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{slaPercentage&gt;=90}</bpmn:conditionExpression></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fSLA_100" sourceRef="GW_SLA" targetRef="SLA_100" name="100%">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{slaPercentage&gt;=100}</bpmn:conditionExpression></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fSLA_50e" sourceRef="SLA_50" targetRef="End_EvSP_SLA"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fSLA_75e" sourceRef="SLA_75" targetRef="End_EvSP_SLA"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fSLA_90e" sourceRef="SLA_90" targetRef="End_EvSP_SLA"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fSLA_100e" sourceRef="SLA_100" targetRef="End_EvSP_SLA"></bpmn:sequenceFlow>
    </bpmn:subProcess>

    <bpmn:subProcess id="EvSP_Vuln" name="Vulnerability Remediation" triggeredByEvent="true">
      <bpmn:documentation>Critical 4h / High 24h.</bpmn:documentation>
      <bpmn:startEvent id="Start_EvSP_Vuln" name="Critical Vuln" isInterrupting="true">
        <bpmn:signalEventDefinition signalRef="Signal_CriticalVuln" />
      </bpmn:startEvent>
      <bpmn:task id="Vuln_Assess" name="Assess Impact">
        <bpmn:documentation>CVSS, blast radius.</bpmn:documentation>
      </bpmn:task>
      <bpmn:task id="Vuln_Contain" name="Contain">
        <bpmn:documentation>Isolate/patch.</bpmn:documentation>
      </bpmn:task>
      <bpmn:task id="Vuln_Fix" name="Remediate">
        <bpmn:documentation>Apply fix.</bpmn:documentation>
      </bpmn:task>
      <bpmn:task id="Vuln_Validate" name="Validate">
        <bpmn:documentation>Rescan.</bpmn:documentation>
      </bpmn:task>
      <bpmn:endEvent id="End_EvSP_Vuln" name="" />
      <bpmn:sequenceFlow id="fV1" sourceRef="Start_EvSP_Vuln" targetRef="Vuln_Assess"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fV2" sourceRef="Vuln_Assess" targetRef="Vuln_Contain"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fV3" sourceRef="Vuln_Contain" targetRef="Vuln_Fix"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fV4" sourceRef="Vuln_Fix" targetRef="Vuln_Validate"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fV5" sourceRef="Vuln_Validate" targetRef="End_EvSP_Vuln"></bpmn:sequenceFlow>
    </bpmn:subProcess>

    <bpmn:subProcess id="EvSP_Inc" name="Incident Response" triggeredByEvent="true">
      <bpmn:documentation>Sev1 15min, Sev2 1h, Sev3 4h.</bpmn:documentation>
      <bpmn:startEvent id="Start_EvSP_Inc" name="Incident" isInterrupting="true">
        <bpmn:signalEventDefinition signalRef="Signal_Incident" />
      </bpmn:startEvent>
      <bpmn:task id="Inc_Triage" name="Triage &amp; Classify">
        <bpmn:documentation>Sev1/2/3.</bpmn:documentation>
      </bpmn:task>
      <bpmn:task id="Inc_Contain" name="Contain">
        <bpmn:documentation>Stop damage.</bpmn:documentation>
      </bpmn:task>
      <bpmn:task id="Inc_Investigate" name="Investigate">
        <bpmn:documentation>RCA &amp; timeline.</bpmn:documentation>
      </bpmn:task>
      <bpmn:task id="Inc_Resolve" name="Resolve">
        <bpmn:documentation>Fix &amp; restore.</bpmn:documentation>
      </bpmn:task>
      <bpmn:task id="Inc_PIR" name="Post-Incident Review">
        <bpmn:documentation>Blameless PIR 5 days.</bpmn:documentation>
      </bpmn:task>
      <bpmn:endEvent id="End_EvSP_Inc" name="" />
      <bpmn:sequenceFlow id="fI1" sourceRef="Start_EvSP_Inc" targetRef="Inc_Triage"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fI2" sourceRef="Inc_Triage" targetRef="Inc_Contain"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fI3" sourceRef="Inc_Contain" targetRef="Inc_Investigate"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fI4" sourceRef="Inc_Investigate" targetRef="Inc_Resolve"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fI5" sourceRef="Inc_Resolve" targetRef="Inc_PIR"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fI6" sourceRef="Inc_PIR" targetRef="End_EvSP_Inc"></bpmn:sequenceFlow>
    </bpmn:subProcess>

    <bpmn:subProcess id="EvSP_Reg" name="Regulatory Change Management" triggeredByEvent="true">
      <bpmn:documentation>Impact assessment 5 days.</bpmn:documentation>
      <bpmn:startEvent id="Start_EvSP_Reg" name="Reg Change" isInterrupting="false">
        <bpmn:messageEventDefinition messageRef="Msg_RegulatoryChange" />
      </bpmn:startEvent>
      <bpmn:task id="Reg_Assess" name="Assess Impact">
        <bpmn:documentation>Scope affected.</bpmn:documentation>
      </bpmn:task>
      <bpmn:serviceTask id="Reg_Update" name="Update KB-003 &amp; DMN" camunda:delegateExpression="${regulatoryUpdateDelegate}">
        <bpmn:documentation>Registry + rules.</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:sendTask id="Reg_Notify" name="Notify Affected" camunda:delegateExpression="${notificationEngineDelegate}">
        <bpmn:documentation>Alert initiatives.</bpmn:documentation>
      </bpmn:sendTask>
      <bpmn:task id="Reg_Implement" name="Implement Changes">
        <bpmn:documentation>Update BPM.</bpmn:documentation>
      </bpmn:task>
      <bpmn:endEvent id="End_EvSP_Reg" name="" />
      <bpmn:sequenceFlow id="fR1" sourceRef="Start_EvSP_Reg" targetRef="Reg_Assess"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fR2" sourceRef="Reg_Assess" targetRef="Reg_Update"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fR3" sourceRef="Reg_Update" targetRef="Reg_Notify"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fR4" sourceRef="Reg_Notify" targetRef="Reg_Implement"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fR5" sourceRef="Reg_Implement" targetRef="End_EvSP_Reg"></bpmn:sequenceFlow>
    </bpmn:subProcess>

    <bpmn:subProcess id="EvSP_CI" name="Continuous Improvement" triggeredByEvent="true">
      <bpmn:documentation>Monthly cycle.</bpmn:documentation>
      <bpmn:startEvent id="Start_EvSP_CI" name="Monthly Cycle" isInterrupting="false">
        <bpmn:timerEventDefinition><bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P1M</bpmn:timeCycle></bpmn:timerEventDefinition>
      </bpmn:startEvent>
      <bpmn:serviceTask id="CI_Collect" name="Collect Metrics" camunda:delegateExpression="${metricsCollectionDelegate}">
        <bpmn:documentation>From all SLA timers.</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:task id="CI_Analyze" name="Analyze vs KPIs">
        <bpmn:documentation>Compare to baselines.</bpmn:documentation>
      </bpmn:task>
      <bpmn:task id="CI_Identify" name="Identify Improvements">
        <bpmn:documentation>Bottlenecks.</bpmn:documentation>
      </bpmn:task>
      <bpmn:task id="CI_Implement" name="Implement">
        <bpmn:documentation>Update BPM/DMN.</bpmn:documentation>
      </bpmn:task>
      <bpmn:task id="CI_Validate" name="Validate Impact">
        <bpmn:documentation>Cycle time reduction.</bpmn:documentation>
      </bpmn:task>
      <bpmn:endEvent id="End_EvSP_CI" name="" />
      <bpmn:sequenceFlow id="fCI1" sourceRef="Start_EvSP_CI" targetRef="CI_Collect"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fCI2" sourceRef="CI_Collect" targetRef="CI_Analyze"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fCI3" sourceRef="CI_Analyze" targetRef="CI_Identify"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fCI4" sourceRef="CI_Identify" targetRef="CI_Implement"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fCI5" sourceRef="CI_Implement" targetRef="CI_Validate"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fCI6" sourceRef="CI_Validate" targetRef="End_EvSP_CI"></bpmn:sequenceFlow>
    </bpmn:subProcess>

    <bpmn:subProcess id="EvSP_SC" name="Stakeholder Communication [BLIND SPOT]" triggeredByEvent="true">
      <bpmn:documentation>Weekly automated reporting.</bpmn:documentation>
      <bpmn:startEvent id="Start_EvSP_SC" name="Weekly Cycle" isInterrupting="false">
        <bpmn:timerEventDefinition><bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P1W</bpmn:timeCycle></bpmn:timerEventDefinition>
      </bpmn:startEvent>
      <bpmn:serviceTask id="SC_Gather" name="Gather Status" camunda:delegateExpression="${statusGatherDelegate}">
        <bpmn:documentation>All active instances.</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="SC_Report" name="Generate Report" camunda:delegateExpression="${statusReportDelegate}">
        <bpmn:documentation>SLA dashboard.</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:sendTask id="SC_Distribute" name="Distribute by Role" camunda:delegateExpression="${notificationEngineDelegate}">
        <bpmn:documentation>Via TP-012.</bpmn:documentation>
      </bpmn:sendTask>
      <bpmn:endEvent id="End_EvSP_SC" name="" />
      <bpmn:sequenceFlow id="fSC1" sourceRef="Start_EvSP_SC" targetRef="SC_Gather"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fSC2" sourceRef="SC_Gather" targetRef="SC_Report"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fSC3" sourceRef="SC_Report" targetRef="SC_Distribute"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fSC4" sourceRef="SC_Distribute" targetRef="End_EvSP_SC"></bpmn:sequenceFlow>
    </bpmn:subProcess>

  </bpmn:process>

