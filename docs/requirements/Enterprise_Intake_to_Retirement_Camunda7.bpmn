<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  id="Definitions_IntakeToRetirement"
  targetNamespace="http://bpmn.io/schema/bpmn"
  exporter="Camunda Modeler"
  exporterVersion="5.25.0">

  <bpmn:message id="Msg_IntakeRequest" name="Message_IntakeRequest" />
  <bpmn:message id="Msg_VendorQuestionnaire" name="Message_VendorQuestionnaireResponse" />
  <bpmn:message id="Msg_EnvironmentReady" name="Message_EnvironmentReady" />
  <bpmn:message id="Msg_GateDecision" name="Message_GateDecisionNotification" />
  <bpmn:message id="Msg_RegulatoryChange" name="Message_RegulatoryChange" />
  <bpmn:message id="Msg_ValidationReturn" name="Message_ValidationReturn" />
  <bpmn:signal id="Signal_CriticalVuln" name="Signal_CriticalVulnerabilityDiscovered" />
  <bpmn:signal id="Signal_Incident" name="Signal_SecurityOperationalIncident" />
  <bpmn:signal id="Signal_SLABreach" name="Signal_SLABreachEscalation" />

  <bpmn:collaboration id="Collaboration_IntakeToRetirement">
    <bpmn:documentation>Enterprise Software Intake to Retirement Lifecycle — Camunda 7 Platform Compatible.
123 tasks | 24 sub-processes | 13 gateways | 29 SLA timers | 9 DMN bindings | 6 event sub-processes.
3-level collapsed hierarchy: Phase → Sub-Phase → Tasks.</bpmn:documentation>
    <bpmn:participant id="Pool_Governance" name="Governance Pool (Enterprise Governance Board)" processRef="Process_Governance" />
    <bpmn:participant id="Pool_Requestor" name="Requestor Pool (Business Units)" processRef="Process_Requestor" />
    <bpmn:participant id="Pool_Technical" name="Technical Pool (Architecture / Security / Dev)" processRef="Process_Technical" />
    <bpmn:participant id="Pool_Vendor" name="Vendor Pool (Third-Party Vendors)" processRef="Process_Vendor" />
    <bpmn:participant id="Pool_Operations" name="Operations Pool (IT Ops / SRE)" processRef="Process_Operations" />
    <bpmn:participant id="Pool_AI" name="AI Platform Pool (AI Agents &amp; DMN Engine)" processRef="Process_AI" />
    <bpmn:messageFlow id="MF_001" sourceRef="SP_Phase1" targetRef="Pool_Requestor" name="Intake Notification" />
    <bpmn:messageFlow id="MF_002" sourceRef="SP_Phase1" targetRef="Pool_AI" name="AI Classification" />
    <bpmn:messageFlow id="MF_003" sourceRef="SP_Phase2" targetRef="Pool_Vendor" name="Vendor Questionnaire" />
    <bpmn:messageFlow id="MF_004" sourceRef="SP_Phase3" targetRef="Pool_Operations" name="Environment Request" />
    <bpmn:messageFlow id="MF_005" sourceRef="SP_Phase3" targetRef="Pool_Technical" name="Toolchain Setup" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Governance" name="Enterprise Software Intake to Retirement" isExecutable="true" camunda:historyTimeToLive="180" camunda:versionTag="1.0.0">

    <bpmn:dataStoreReference id="DS_KB001" name="KB-001: Data Classification Schema" />
    <bpmn:dataStoreReference id="DS_KB002" name="KB-002: Technology Radar" />
    <bpmn:dataStoreReference id="DS_KB003" name="KB-003: Regulatory Registry" />
    <bpmn:dataStoreReference id="DS_KB004" name="KB-004: Reference Architecture" />
    <bpmn:dataStoreReference id="DS_KB005" name="KB-005: Vendor Risk Intelligence" />
    <bpmn:dataStoreReference id="DS_KB006" name="KB-006: Security Controls Catalog" />
    <bpmn:dataStoreReference id="DS_KB007" name="KB-007: Historical Initiatives" />
    <bpmn:dataStoreReference id="DS_KB008" name="KB-008: AI Model Registry" />
    <bpmn:dataStoreReference id="DS_KB009" name="KB-009: SLA Baselines" />
    <bpmn:dataStoreReference id="DS_KB010" name="KB-010: Compliance-as-Code" />

    <bpmn:startEvent id="StartEvent_Intake" name="New Software&#10;Initiative Request">
      <bpmn:outgoing>Flow_Start_Ph1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgEvtDef_Intake" messageRef="Msg_IntakeRequest" />
    </bpmn:startEvent>

    <bpmn:subProcess id="SP_Phase1" name="Phase 1: Initiation &amp; Intake">
      <bpmn:documentation>SLA: 1-2 days | Request capture, risk triage, business case</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="phase" value="1" />
          <camunda:property name="sla_standard_hours" value="48" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_Ph1</bpmn:incoming>
      <bpmn:outgoing>Flow_Ph1_GW1</bpmn:outgoing>
      <bpmn:startEvent id="SP_Phase1_Start" name="Start">
        <bpmn:outgoing>Flow_SP_Phase1_s0</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:subProcess id="SP_1_1" name="SP-1.1: Request Capture &amp; Validation">
      <bpmn:documentation>SLA: 0.5-1 day | Submit, validate, register initiative</bpmn:documentation>
        <bpmn:extensionElements>
          <camunda:properties>
          <camunda:property name="phase" value="1" />
          <camunda:property name="sla_standard_hours" value="8" />
          </camunda:properties>
        </bpmn:extensionElements>
      <bpmn:startEvent id="Start_SP11" name="Request Received" />
      <bpmn:userTask id="T1111" name="T-1.1.1.1: Complete Intake Form" camunda:candidateGroups="role_requestor" camunda:formKey="embedded:app:forms/T1111.html">
        <bpmn:documentation>Requestor completes intake form.</bpmn:documentation>
          <bpmn:extensionElements>
            <camunda:properties>
            <camunda:property name="actor" value="Requestor" />
            </camunda:properties>
          </bpmn:extensionElements>
      </bpmn:userTask>
      <bpmn:userTask id="T1112" name="T-1.1.1.2: Attach Supporting Docs" camunda:candidateGroups="role_requestor" camunda:formKey="embedded:app:forms/T1112.html">
        <bpmn:documentation>Attach business case draft, requirements.</bpmn:documentation>
          <bpmn:extensionElements>
            <camunda:properties>
            <camunda:property name="actor" value="Requestor" />
            </camunda:properties>
          </bpmn:extensionElements>
      </bpmn:userTask>
      <bpmn:serviceTask id="T1113" name="T-1.1.1.3: AI Auto-Classification" camunda:delegateExpression="${aiIntakeAgentDelegate}">
        <bpmn:documentation>AI pre-populates fields from KB-007.</bpmn:documentation>
          <bpmn:extensionElements>
            <camunda:properties>
            <camunda:property name="actor" value="AI Intake Agent" />
            <camunda:property name="kb" value="KB-007" />
            </camunda:properties>
          </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="T1121" name="T-1.1.2.1: Validate Mandatory Fields" camunda:delegateExpression="${intakeValidationDelegate}">
        <bpmn:documentation>Schema validation.</bpmn:documentation>
          <bpmn:extensionElements>
            <camunda:properties>
            <camunda:property name="actor" value="System" />
            </camunda:properties>
          </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="T1122" name="T-1.1.2.2: AI Duplicate Detection" camunda:delegateExpression="${aiDuplicateDetectionDelegate}">
        <bpmn:documentation>Semantic similarity from KB-007.</bpmn:documentation>
          <bpmn:extensionElements>
            <camunda:properties>
            <camunda:property name="actor" value="AI Intake Agent" />
            <camunda:property name="kb" value="KB-007" />
            </camunda:properties>
          </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:task id="T1123" name="T-1.1.2.3: Route Incomplete/Duplicate">
        <bpmn:documentation>Return incomplete; route duplicate to merge.</bpmn:documentation>
          <bpmn:extensionElements>
            <camunda:properties>
            <camunda:property name="actor" value="System" />
            </camunda:properties>
          </bpmn:extensionElements>
      </bpmn:task>
      <bpmn:serviceTask id="T1131" name="T-1.1.3.1: Assign Initiative ID" camunda:delegateExpression="${initiativeIdGeneratorDelegate}">
        <bpmn:documentation>Format: INI-YYYY-NNNN.</bpmn:documentation>
          <bpmn:extensionElements>
            <camunda:properties>
            <camunda:property name="id_format" value="INI-YYYY-NNNN" />
            </camunda:properties>
          </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="T1132" name="T-1.1.3.2: Create GRC Record" camunda:delegateExpression="${grcRepositoryDelegate}">
        <bpmn:documentation>Create record in TP-002.</bpmn:documentation>
          <bpmn:extensionElements>
            <camunda:properties>
            <camunda:property name="platform" value="TP-002" />
            </camunda:properties>
          </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:sendTask id="T1133" name="T-1.1.3.3: Notify Coordinator" camunda:delegateExpression="${notificationEngineDelegate}">
        <bpmn:documentation>Notify via TP-012.</bpmn:documentation>
          <bpmn:extensionElements>
            <camunda:properties>
            <camunda:property name="platform" value="TP-012" />
            </camunda:properties>
          </bpmn:extensionElements>
      </bpmn:sendTask>
      <bpmn:endEvent id="End_SP11" name="Request Captured" />
      <bpmn:sequenceFlow id="f11_1" sourceRef="Start_SP11" targetRef="T1111"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f11_2" sourceRef="T1111" targetRef="T1112"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f11_3" sourceRef="T1112" targetRef="T1113"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f11_4" sourceRef="T1113" targetRef="T1121"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f11_5" sourceRef="T1121" targetRef="T1122"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f11_6" sourceRef="T1122" targetRef="T1123"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f11_7" sourceRef="T1123" targetRef="T1131"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f11_8" sourceRef="T1131" targetRef="T1132"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f11_9" sourceRef="T1132" targetRef="T1133"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f11_10" sourceRef="T1133" targetRef="End_SP11"></bpmn:sequenceFlow>
    </bpmn:subProcess>
      <bpmn:subProcess id="SP_1_2" name="SP-1.2: Initial Risk Triage">
      <bpmn:documentation>SLA: 0.5-1 day | DMN-DT-001, DMN-DT-002, DMN-DT-007</bpmn:documentation>
        <bpmn:extensionElements>
          <camunda:properties>
          <camunda:property name="phase" value="1" />
          <camunda:property name="sla_standard_hours" value="8" />
          </camunda:properties>
        </bpmn:extensionElements>
      <bpmn:startEvent id="Start_SP12" name="Validated Request" />
      <bpmn:serviceTask id="T1211" name="T-1.2.1.1: AI 6-Dimension Risk Scoring" camunda:delegateExpression="${aiRiskScoringDelegate}">
        <bpmn:documentation>Score: data sensitivity, regulatory, integration, vendor, business criticality, tech novelty.</bpmn:documentation>
          <bpmn:extensionElements>
            <camunda:properties>
            <camunda:property name="actor" value="AI Risk Agent" />
            <camunda:property name="kb" value="KB-001,KB-003" />
            </camunda:properties>
          </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:businessRuleTask id="T1212" name="T-1.2.1.2: DMN-DT-001 Risk Tier" camunda:decisionRef="DMN_DT_001_RiskTier" camunda:mapDecisionResult="singleResult" camunda:resultVariable="riskTierResult">
        <bpmn:documentation>Composite score + tier. Hit Policy: Priority.</bpmn:documentation>
          <bpmn:extensionElements>
            <camunda:properties>
            <camunda:property name="hit_policy" value="Priority" />
            </camunda:properties>
          </bpmn:extensionElements>
      </bpmn:businessRuleTask>
      <bpmn:serviceTask id="T1213" name="T-1.2.1.3: Flag Regulatory Triggers" camunda:delegateExpression="${aiComplianceFlagDelegate}">
        <bpmn:documentation>DMN-DT-007 Collect policy.</bpmn:documentation>
          <bpmn:extensionElements>
            <camunda:properties>
            <camunda:property name="dmn" value="DMN-DT-007" />
            </camunda:properties>
          </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:userTask id="T1221" name="T-1.2.2.1: Review AI Risk Scoring" camunda:candidateGroups="role_governance_analyst" camunda:formKey="embedded:app:forms/T1221.html">
        <bpmn:documentation>Analyst reviews AI rationale.</bpmn:documentation>
          <bpmn:extensionElements>
            <camunda:properties>
            <camunda:property name="actor" value="Governance Analyst" />
            </camunda:properties>
          </bpmn:extensionElements>
      </bpmn:userTask>
      <bpmn:userTask id="T1222" name="T-1.2.2.2: Validate/Override Tier" camunda:candidateGroups="role_governance_analyst" camunda:formKey="embedded:app:forms/T1222.html">
        <bpmn:documentation>Confirm or override with justification.</bpmn:documentation>
          <bpmn:extensionElements>
            <camunda:properties>
            <camunda:property name="actor" value="Governance Analyst" />
            </camunda:properties>
          </bpmn:extensionElements>
      </bpmn:userTask>
      <bpmn:exclusiveGateway id="GW_Confidence" name="AI Confidence ≥ 85%?" default="fConf_a">
        <bpmn:documentation>BLIND SPOT: Explicit confidence threshold gateway</bpmn:documentation>
      </bpmn:exclusiveGateway>
      <bpmn:userTask id="T1223" name="T-1.2.2.3: Escalate Low Confidence" camunda:candidateGroups="role_sr_governance_lead" camunda:formKey="embedded:app:forms/T1223.html">
        <bpmn:documentation>AI confidence &amp;lt; 85%: Sr. Lead review.</bpmn:documentation>
          <bpmn:extensionElements>
            <camunda:properties>
            <camunda:property name="actor" value="Sr. Governance Lead" />
            <camunda:property name="blind_spot" value="confidence_threshold" />
            </camunda:properties>
          </bpmn:extensionElements>
      </bpmn:userTask>
      <bpmn:businessRuleTask id="T1231" name="T-1.2.3.1: DMN-DT-002 Pathway" camunda:decisionRef="DMN_DT_002_Pathway" camunda:mapDecisionResult="singleResult" camunda:resultVariable="pathwayResult">
        <bpmn:documentation>Governance pathway. Hit Policy: Unique.</bpmn:documentation>
          <bpmn:extensionElements>
            <camunda:properties>
            <camunda:property name="hit_policy" value="Unique" />
            </camunda:properties>
          </bpmn:extensionElements>
      </bpmn:businessRuleTask>
      <bpmn:serviceTask id="T1232" name="T-1.2.3.2: Assign Governance Pathway" camunda:delegateExpression="${pathwayAssignmentDelegate}">
        <bpmn:documentation>Set governancePathway variable.</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="T1233" name="T-1.2.3.3: Generate Scope Matrix" camunda:delegateExpression="${scopeMatrixGeneratorDelegate}">
        <bpmn:documentation>Phase 2 assessment scope.</bpmn:documentation>
      </bpmn:serviceTask>
      <bpmn:endEvent id="End_SP12" name="Risk Tier &amp; Pathway Set" />
      <bpmn:sequenceFlow id="f12_1" sourceRef="Start_SP12" targetRef="T1211"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f12_2" sourceRef="T1211" targetRef="T1212"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f12_3" sourceRef="T1212" targetRef="T1213"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f12_4" sourceRef="T1213" targetRef="T1221"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f12_5" sourceRef="T1221" targetRef="T1222"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f12_6" sourceRef="T1222" targetRef="GW_Confidence"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fConf_a" sourceRef="GW_Confidence" targetRef="T1231" name="Confidence ≥ 85%"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="fConf_b" sourceRef="GW_Confidence" targetRef="T1223" name="Confidence &lt; 85%">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{riskTierResult.confidence &lt; 85}</bpmn:conditionExpression></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f12_7c" sourceRef="T1223" targetRef="T1231"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f12_8" sourceRef="T1231" targetRef="T1232"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f12_9" sourceRef="T1232" targetRef="T1233"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f12_10" sourceRef="T1233" targetRef="End_SP12"></bpmn:sequenceFlow>
    </bpmn:subProcess>
      <bpmn:subProcess id="SP_1_3" name="SP-1.3: Business Case Evaluation">
      <bpmn:documentation>SLA: 1-2 days | DMN-DT-003</bpmn:documentation>
        <bpmn:extensionElements>
          <camunda:properties>
          <camunda:property name="phase" value="1" />
          <camunda:property name="sla_standard_hours" value="16" />
          </camunda:properties>
        </bpmn:extensionElements>
      <bpmn:startEvent id="Start_SP13" name="Business Case Review" />
      <bpmn:userTask id="T1311" name="T-1.3.1.1: Map Strategic Objectives" camunda:candidateGroups="role_portfolio_manager" camunda:formKey="embedded:app:forms/T1311.html">
        <bpmn:documentation>Map to portfolio priorities.</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="T1312" name="T-1.3.1.2: Score Alignment (4 Dims)" camunda:candidateGroups="role_portfolio_manager" camunda:formKey="embedded:app:forms/T1312.html">
        <bpmn:documentation>Revenue, efficiency, risk, innovation.</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="T1313" name="T-1.3.1.3: Identify Dependencies" camunda:candidateGroups="role_portfolio_manager" camunda:formKey="embedded:app:forms/T1313.html">
        <bpmn:documentation>Portfolio conflicts and synergies.</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="T1321" name="T-1.3.2.1: Validate Budget" camunda:candidateGroups="role_finance_analyst" camunda:formKey="embedded:app:forms/T1321.html">
        <bpmn:documentation>Budget vs allocation.</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:userTask id="T1322" name="T-1.3.2.2: Calculate ROI" camunda:candidateGroups="role_finance_analyst" camunda:formKey="embedded:app:forms/T1322.html">
        <bpmn:documentation>NPV, IRR, payback period.</bpmn:documentation>
      </bpmn:userTask>
      <bpmn:businessRuleTask id="T1331" name="T-1.3.3.1: DMN-DT-003 Gate Decision" camunda:decisionRef="DMN_DT_003_GateDecision" camunda:mapDecisionResult="singleResult" camunda:resultVariable="gateDecisionResult">
        <bpmn:documentation>Approve/Conditional/Defer/Reject.</bpmn:documentation>
          <bpmn:extensionElements>
            <camunda:properties>
            <camunda:property name="hit_policy" value="Priority" />
            </camunda:properties>
          </bpmn:extensionElements>
      </bpmn:businessRuleTask>
      <bpmn:task id="T1332" name="T-1.3.3.2: Route Gate Decision">
        <bpmn:documentation>Execute decision outcome.</bpmn:documentation>
      </bpmn:task>
      <bpmn:endEvent id="End_SP13" name="Gate Decision Rendered" />
      <bpmn:sequenceFlow id="f13_1" sourceRef="Start_SP13" targetRef="T1311"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f13_2" sourceRef="T1311" targetRef="T1312"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f13_3" sourceRef="T1312" targetRef="T1313"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f13_4" sourceRef="T1313" targetRef="T1321"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f13_5" sourceRef="T1321" targetRef="T1322"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f13_6" sourceRef="T1322" targetRef="T1331"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f13_7" sourceRef="T1331" targetRef="T1332"></bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="f13_8" sourceRef="T1332" targetRef="End_SP13"></bpmn:sequenceFlow>
    </bpmn:subProcess>
      <bpmn:boundaryEvent id="Tmr_SP11_50" name="SLA 50% (4h)" attachedToRef="SP_1_1" cancelActivity="false">
        <bpmn:extensionElements>
          <camunda:executionListener delegateExpression="${slaWarningDelegate}" event="start" />
        </bpmn:extensionElements>
      <bpmn:timerEventDefinition id="TD_Tmr_SP11_50">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT4H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>      <bpmn:outgoing>Flow_Tmr_SP11_50_Esc</bpmn:outgoing>
    
    </bpmn:boundaryEvent>
      <bpmn:boundaryEvent id="Tmr_SP11_75" name="SLA 75% (6h)" attachedToRef="SP_1_1" cancelActivity="false">
        <bpmn:extensionElements>
          <camunda:executionListener delegateExpression="${slaAlertDelegate}" event="start" />
        </bpmn:extensionElements>
      <bpmn:timerEventDefinition id="TD_Tmr_SP11_75">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT6H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>      <bpmn:outgoing>Flow_Tmr_SP11_75_Esc</bpmn:outgoing>
    
    </bpmn:boundaryEvent>
      <bpmn:boundaryEvent id="Tmr_SP11_90" name="SLA 90% (7.2h)" attachedToRef="SP_1_1" cancelActivity="false">
        <bpmn:extensionElements>
          <camunda:executionListener delegateExpression="${slaCriticalDelegate}" event="start" />
        </bpmn:extensionElements>
      <bpmn:timerEventDefinition id="TD_Tmr_SP11_90">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT7H12M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>      <bpmn:outgoing>Flow_Tmr_SP11_90_Esc</bpmn:outgoing>
    
    </bpmn:boundaryEvent>
      <bpmn:boundaryEvent id="Tmr_SP11_100" name="SLA Breach (8h)" attachedToRef="SP_1_1" cancelActivity="false">
        <bpmn:extensionElements>
          <camunda:executionListener delegateExpression="${slaBreachDelegate}" event="start" />
        </bpmn:extensionElements>
      <bpmn:timerEventDefinition id="TD_Tmr_SP11_100">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT8H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>      <bpmn:outgoing>Flow_Tmr_SP11_100_Esc</bpmn:outgoing>
    
    </bpmn:boundaryEvent>
      <bpmn:endEvent id="Esc_SP_1_1" name="SLA&#10;Escalation">
        <bpmn:incoming>Flow_Esc_Tmr_SP11_50</bpmn:incoming>
        <bpmn:incoming>Flow_Esc_Tmr_SP11_75</bpmn:incoming>
        <bpmn:incoming>Flow_Esc_Tmr_SP11_90</bpmn:incoming>
        <bpmn:incoming>Flow_Esc_Tmr_SP11_100</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_Esc_Tmr_SP11_50" sourceRef="Tmr_SP11_50" targetRef="Esc_SP_1_1" />
      <bpmn:sequenceFlow id="Flow_Esc_Tmr_SP11_75" sourceRef="Tmr_SP11_75" targetRef="Esc_SP_1_1" />
      <bpmn:sequenceFlow id="Flow_Esc_Tmr_SP11_90" sourceRef="Tmr_SP11_90" targetRef="Esc_SP_1_1" />
      <bpmn:sequenceFlow id="Flow_Esc_Tmr_SP11_100" sourceRef="Tmr_SP11_100" targetRef="Esc_SP_1_1" />
      <bpmn:boundaryEvent id="Tmr_SP12_50" name="SLA 50% (4h)" attachedToRef="SP_1_2" cancelActivity="false">
        <bpmn:extensionElements>
          <camunda:executionListener delegateExpression="${slaWarningDelegate}" event="start" />
        </bpmn:extensionElements>
      <bpmn:timerEventDefinition id="TD_Tmr_SP12_50">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT4H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>      <bpmn:outgoing>Flow_Tmr_SP12_50_Esc</bpmn:outgoing>
    
    </bpmn:boundaryEvent>
      <bpmn:boundaryEvent id="Tmr_SP12_75" name="SLA 75% (6h)" attachedToRef="SP_1_2" cancelActivity="false">
        <bpmn:extensionElements>
          <camunda:executionListener delegateExpression="${slaAlertDelegate}" event="start" />
        </bpmn:extensionElements>
      <bpmn:timerEventDefinition id="TD_Tmr_SP12_75">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT6H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>      <bpmn:outgoing>Flow_Tmr_SP12_75_Esc</bpmn:outgoing>
    
    </bpmn:boundaryEvent>
      <bpmn:boundaryEvent id="Tmr_SP12_100" name="SLA Breach (8h)" attachedToRef="SP_1_2" cancelActivity="false">
        <bpmn:extensionElements>
          <camunda:executionListener delegateExpression="${slaBreachDelegate}" event="start" />
        </bpmn:extensionElements>
      <bpmn:timerEventDefinition id="TD_Tmr_SP12_100">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT8H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>      <bpmn:outgoing>Flow_Tmr_SP12_100_Esc</bpmn:outgoing>
    
    </bpmn:boundaryEvent>
      <bpmn:endEvent id="Esc_SP_1_2" name="SLA&#10;Escalation">
        <bpmn:incoming>Flow_Esc_Tmr_SP12_50</bpmn:incoming>
        <bpmn:incoming>Flow_Esc_Tmr_SP12_75</bpmn:incoming>
        <bpmn:incoming>Flow_Esc_Tmr_SP12_100</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_Esc_Tmr_SP12_50" sourceRef="Tmr_SP12_50" targetRef="Esc_SP_1_2" />
      <bpmn:sequenceFlow id="Flow_Esc_Tmr_SP12_75" sourceRef="Tmr_SP12_75" targetRef="Esc_SP_1_2" />
      <bpmn:sequenceFlow id="Flow_Esc_Tmr_SP12_100" sourceRef="Tmr_SP12_100" targetRef="Esc_SP_1_2" />
      <bpmn:boundaryEvent id="Tmr_SP13_50" name="SLA 50% (8h)" attachedToRef="SP_1_3" cancelActivity="false">
        <bpmn:extensionElements>
          <camunda:executionListener delegateExpression="${slaWarningDelegate}" event="start" />
        </bpmn:extensionElements>
      <bpmn:timerEventDefinition id="TD_Tmr_SP13_50">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT8H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>      <bpmn:outgoing>Flow_Tmr_SP13_50_Esc</bpmn:outgoing>
    
    </bpmn:boundaryEvent>
      <bpmn:boundaryEvent id="Tmr_SP13_100" name="SLA Breach (16h)" attachedToRef="SP_1_3" cancelActivity="false">
        <bpmn:extensionElements>
          <camunda:executionListener delegateExpression="${slaBreachDelegate}" event="start" />
        </bpmn:extensionElements>
      <bpmn:timerEventDefinition id="TD_Tmr_SP13_100">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT16H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>      <bpmn:outgoing>Flow_Tmr_SP13_100_Esc</bpmn:outgoing>
    
    </bpmn:boundaryEvent>
      <bpmn:endEvent id="Esc_SP_1_3" name="SLA&#10;Escalation">
        <bpmn:incoming>Flow_Esc_Tmr_SP13_50</bpmn:incoming>
        <bpmn:incoming>Flow_Esc_Tmr_SP13_100</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_Esc_Tmr_SP13_50" sourceRef="Tmr_SP13_50" targetRef="Esc_SP_1_3" />
      <bpmn:sequenceFlow id="Flow_Esc_Tmr_SP13_100" sourceRef="Tmr_SP13_100" targetRef="Esc_SP_1_3" />
      <bpmn:exclusiveGateway id="SP_Phase1_GW1" name="Validation?" default="Flow_SP_Phase1_g1ok">
        <bpmn:incoming>Flow_SP_Phase1_sp11</bpmn:incoming>
        <bpmn:outgoing>Flow_SP_Phase1_g1ok</bpmn:outgoing>
        <bpmn:outgoing>Flow_SP_Phase1_g1loop</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:exclusiveGateway id="SP_Phase1_GW2" name="Risk Tier?" default="Flow_SP_Phase1_g2std">
        <bpmn:incoming>Flow_SP_Phase1_sp12</bpmn:incoming>
        <bpmn:outgoing>Flow_SP_Phase1_g2std</bpmn:outgoing>
        <bpmn:outgoing>Flow_SP_Phase1_g2exp</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:exclusiveGateway id="SP_Phase1_Merge">
        <bpmn:incoming>Flow_SP_Phase1_sp13</bpmn:incoming>
        <bpmn:incoming>Flow_SP_Phase1_g2exp</bpmn:incoming>
        <bpmn:outgoing>Flow_SP_Phase1_end</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:endEvent id="SP_Phase1_End" name="Phase Complete">
        <bpmn:incoming>Flow_SP_Phase1_end</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_SP_Phase1_s0" sourceRef="SP_Phase1_Start" targetRef="SP_1_1" />
      <bpmn:sequenceFlow id="Flow_SP_Phase1_sp11" sourceRef="SP_1_1" targetRef="SP_Phase1_GW1" />
      <bpmn:sequenceFlow id="Flow_SP_Phase1_g1ok" name="Complete" sourceRef="SP_Phase1_GW1" targetRef="SP_1_2" />
      <bpmn:sequenceFlow id="Flow_SP_Phase1_g1loop" name="Incomplete" sourceRef="SP_Phase1_GW1" targetRef="SP_1_1">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{validationStatus=="incomplete"}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_SP_Phase1_sp12" sourceRef="SP_1_2" targetRef="SP_Phase1_GW2" />
      <bpmn:sequenceFlow id="Flow_SP_Phase1_g2std" name="Standard" sourceRef="SP_Phase1_GW2" targetRef="SP_1_3" />
      <bpmn:sequenceFlow id="Flow_SP_Phase1_g2exp" name="Express" sourceRef="SP_Phase1_GW2" targetRef="SP_Phase1_Merge">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{confirmedRiskTier=="Low"}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_SP_Phase1_sp13" sourceRef="SP_1_3" targetRef="SP_Phase1_Merge" />
      <bpmn:sequenceFlow id="Flow_SP_Phase1_end" sourceRef="SP_Phase1_Merge" targetRef="SP_Phase1_End" />
    </bpmn:subProcess>

    <bpmn:subProcess id="SP_Phase2" name="Phase 2: Assessment &amp; Due Diligence">
