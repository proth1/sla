<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_AIGovernance" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.42.0">
  <bpmn:process id="AIGovernanceProcess" name="AI Governance Process" isExecutable="true" camunda:historyTimeToLive="10">
    <bpmn:startEvent id="Start_AIGovernance" name="Start AI Governance Process" camunda:formHandlerClass="org.softcannery.camunda.FormioStartFormHandler" camunda:formKey="embedded:app:formio.html">
      <bpmn:extensionElements>
        <camunda:executionListener expression="${execution.setVariable(&#34;governance_initiation&#34;, true)}" event="start" />
        <camunda:properties>
          <camunda:property name="formio.variable" value="AI_Governance_Start" />
          <camunda:property name="formio.outputDataSource" value="AIGovernanceData" />
          <camunda:property name="formio.file" value="AI_Governance_Start.formio" />
          <camunda:property name="formio.form" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_to_initital_classification</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_StartEvent">
        <bpmn:targetRef>DataStore_AIGovernance</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:startEvent>
    <bpmn:dataStoreReference id="DataStore_AIGovernance" name="Use Case Data" />
    <bpmn:exclusiveGateway id="Gateway_RiskClassification" name="Risk&#10; Classification ?">
      <bpmn:incoming>Flow_0lpelg6</bpmn:incoming>
      <bpmn:outgoing>Flow_unacceptable_risk</bpmn:outgoing>
      <bpmn:outgoing>Flow_high_risk</bpmn:outgoing>
      <bpmn:outgoing>Flow_limited_risk</bpmn:outgoing>
      <bpmn:outgoing>Flow_minimal_risk</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_UnacceptableRisk" name="Rejected as&#10;Unacceptable Risk">
      <bpmn:incoming>Flow_unacceptable_risk</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_TeamDecision" name="Governance Team Decision ?">
      <bpmn:incoming>Flow_0vqb86j</bpmn:incoming>
      <bpmn:outgoing>Flow_team_approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_team_rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_RejectedProject" name="Use Case Rejected">
      <bpmn:incoming>Flow_team_rejected</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Task_ControlsImplementation" name="Controls Implementation" camunda:formKey="embedded:app:formio.html" camunda:assignee="implementation_team">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="formio.variable" value="Task_ControlsImplementation" />
          <camunda:property name="formio.inputDataSource" value="AIGovernanceData" />
          <camunda:property name="formio.outputDataSource" value="Task_ControlsImplementation" />
          <camunda:property name="formio.file" value="AI_Controls_Implementation.formio" />
          <camunda:property name="formio.form" />
        </camunda:properties>
        <camunda:inputOutput>
          <camunda:inputParameter name="Task_ControlsImplementation">${formio.AIGovernanceData.json}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_team_approved</bpmn:incoming>
      <bpmn:outgoing>Flow_1qgtyes</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_to_initital_classification" sourceRef="Start_AIGovernance" targetRef="Task_AIUseCaseAssessment" />
    <bpmn:sequenceFlow id="Flow_unacceptable_risk" name="Unacceptable Risk" sourceRef="Gateway_RiskClassification" targetRef="EndEvent_UnacceptableRisk">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${formio.Task_InitialRiskClassification.data.riskClassification == "Unacceptable"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_high_risk" name="High Risk" sourceRef="Gateway_RiskClassification" targetRef="Event_0yytcky">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${formio.Task_InitialRiskClassification.data.riskClassification == "High"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_limited_risk" name="Limited Risk" sourceRef="Gateway_RiskClassification" targetRef="Event_01ufa05">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${formio.Task_InitialRiskClassification.data.riskClassification == "Limited"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_minimal_risk" name="Minimal Risk" sourceRef="Gateway_RiskClassification" targetRef="Event_0ihinvy">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${formio.Task_InitialRiskClassification.data.riskClassification == "Minimal"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_team_approved" name="Approved" sourceRef="Gateway_TeamDecision" targetRef="Task_ControlsImplementation">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${formio.Task_GovernanceTeamReview.data.approvalDecision == "Approved"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_team_rejected" name="Rejected" sourceRef="Gateway_TeamDecision" targetRef="EndEvent_RejectedProject">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${formio.Task_GovernanceTeamReview.data.approvalDecision == "Rejected"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:subProcess id="Activity_0z3fg5j" name="Minimal Risk Review Process" triggeredByEvent="true">
      <bpmn:startEvent id="Event_1o5z2in" name="Minimal Risk Review">
        <bpmn:outgoing>Flow_0y2tegg</bpmn:outgoing>
        <bpmn:escalationEventDefinition id="EscalationEventDefinition_1mn70rc" escalationRef="Escalation_24b0tk1" />
      </bpmn:startEvent>
      <bpmn:userTask id="Task_StandardApproval" name="Standard Approval" camunda:formKey="embedded:app:formio.html" camunda:assignee="approval_manager">
        <bpmn:extensionElements>
          <camunda:properties>
            <camunda:property name="formio.variable" value="Task_StandardApproval" />
            <camunda:property name="formio.inputDataSource" value="AIGovernanceData" />
            <camunda:property name="formio.outputDataSource" value="Task_StandardApproval" />
            <camunda:property name="formio.file" value="AI_Standard_Approval.formio" />
            <camunda:property name="formio.form" />
          </camunda:properties>
          <camunda:inputOutput>
            <camunda:inputParameter name="Task_StandardApproval">${formio.AIGovernanceData.json}</camunda:inputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0y2tegg</bpmn:incoming>
        <bpmn:outgoing>Flow_to_standard_decision</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:exclusiveGateway id="Gateway_StandardDecision" name="Approved ?">
        <bpmn:incoming>Flow_to_standard_decision</bpmn:incoming>
        <bpmn:outgoing>Flow_standard_approved</bpmn:outgoing>
        <bpmn:outgoing>Flow_1cf4nld</bpmn:outgoing>
        <bpmn:outgoing>Flow_0rz2vw6</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:endEvent id="Event_1ih5s7p" name="Idea Rejected">
        <bpmn:incoming>Flow_1cf4nld</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:endEvent id="Event_00eqxxv" name="Idea Approved">
        <bpmn:incoming>Flow_standard_approved</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_to_standard_decision" sourceRef="Task_StandardApproval" targetRef="Gateway_StandardDecision" />
      <bpmn:sequenceFlow id="Flow_standard_approved" name="Approved" sourceRef="Gateway_StandardDecision" targetRef="Event_00eqxxv">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${formio.Task_StandardApproval.data.approvalDecision == "Approved"}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_1cf4nld" name="Rejected" sourceRef="Gateway_StandardDecision" targetRef="Event_1ih5s7p">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${formio.Task_StandardApproval.data.approvalDecision == "Rejected"}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_0y2tegg" sourceRef="Event_1o5z2in" targetRef="Task_StandardApproval" />
      <bpmn:sequenceFlow id="Flow_0rz2vw6" sourceRef="Gateway_StandardDecision" targetRef="Event_1y5tqfx" />
      <bpmn:endEvent id="Event_1y5tqfx" name="Idea Escalated to Limited Risk">
        <bpmn:incoming>Flow_0rz2vw6</bpmn:incoming>
        <bpmn:escalationEventDefinition id="EscalationEventDefinition_12dvh8k" escalationRef="Escalation_0k3bged" />
      </bpmn:endEvent>
    </bpmn:subProcess>
    <bpmn:subProcess id="Activity_0ogspoa" name="Limited Risk Review Process" triggeredByEvent="true">
      <bpmn:startEvent id="Event_0gj0di4" name="Limited Risk Review">
        <bpmn:outgoing>Flow_0806meb</bpmn:outgoing>
        <bpmn:escalationEventDefinition id="EscalationEventDefinition_1mqind9" escalationRef="Escalation_0k3bged" />
      </bpmn:startEvent>
      <bpmn:exclusiveGateway id="Gateway_1gmh4xc" name="Approved ?">
        <bpmn:incoming>Flow_0jiu5um</bpmn:incoming>
        <bpmn:outgoing>Flow_07cga6m</bpmn:outgoing>
        <bpmn:outgoing>Flow_18fpj0q</bpmn:outgoing>
        <bpmn:outgoing>Flow_0kwyj4p</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:endEvent id="Event_07l6m5m" name="Idea Approved">
        <bpmn:incoming>Flow_07cga6m</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:endEvent id="Event_0res79i" name="Idea Rejected">
        <bpmn:incoming>Flow_18fpj0q</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_0806meb" sourceRef="Event_0gj0di4" targetRef="Task_GovernanceTeamReview" />
      <bpmn:sequenceFlow id="Flow_07cga6m" name="Approved" sourceRef="Gateway_1gmh4xc" targetRef="Event_07l6m5m">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${formio.Task_StandardApproval.data.approvalDecision == "Approved"}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_18fpj0q" name="Rejected" sourceRef="Gateway_1gmh4xc" targetRef="Event_0res79i">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${formio.Task_StandardApproval.data.approvalDecision == "Rejected"}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_0kwyj4p" sourceRef="Gateway_1gmh4xc" targetRef="Event_0svwwlb" />
      <bpmn:userTask id="Task_GovernanceTeamReview" name="Governance Team Approval" camunda:formKey="embedded:app:formio.html" camunda:assignee="governance_team">
        <bpmn:extensionElements>
          <camunda:properties>
            <camunda:property name="formio.variable" value="Task_GovernanceTeamReview" />
            <camunda:property name="formio.inputDataSource" value="AIGovernanceData" />
            <camunda:property name="formio.outputDataSource" value="Task_GovernanceTeamReview" />
            <camunda:property name="formio.file" value="AI_Governance_Team_Review.formio" />
            <camunda:property name="formio.form" />
          </camunda:properties>
          <camunda:inputOutput>
            <camunda:inputParameter name="Task_GovernanceTeamReview">${formio.AIGovernanceData.json}</camunda:inputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0806meb</bpmn:incoming>
        <bpmn:outgoing>Flow_0jiu5um</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:sequenceFlow id="Flow_0jiu5um" sourceRef="Task_GovernanceTeamReview" targetRef="Gateway_1gmh4xc" />
      <bpmn:endEvent id="Event_0svwwlb" name="Idea Escalated to High Risk Review">
        <bpmn:incoming>Flow_0kwyj4p</bpmn:incoming>
        <bpmn:escalationEventDefinition id="EscalationEventDefinition_1g0igfk" escalationRef="Escalation_2f5ol35" />
      </bpmn:endEvent>
    </bpmn:subProcess>
    <bpmn:subProcess id="Activity_0jjccez" name="High Risk Review Process" triggeredByEvent="true">
      <bpmn:startEvent id="Event_1j4gdm3" name="High Risk&#10;Review">
        <bpmn:outgoing>Flow_0ewbwx5</bpmn:outgoing>
        <bpmn:escalationEventDefinition id="EscalationEventDefinition_0x6vlaj" escalationRef="Escalation_2f5ol35" />
      </bpmn:startEvent>
      <bpmn:userTask id="Task_GovernanceAdvisoryBoardReview" name="Governance Advisory Board Approval" camunda:formKey="embedded:app:formio.html" camunda:assignee="governance_board">
        <bpmn:extensionElements>
          <camunda:properties>
            <camunda:property name="formio.variable" value="Task_GovernanceAdvisoryBoardReview" />
            <camunda:property name="formio.inputDataSource" value="AIGovernanceData" />
            <camunda:property name="formio.outputDataSource" value="Task_GovernanceAdvisoryBoardReview" />
            <camunda:property name="formio.file" value="AI_Governance_Board_Review.formio" />
            <camunda:property name="formio.form" />
          </camunda:properties>
          <camunda:inputOutput>
            <camunda:inputParameter name="Task_GovernanceAdvisoryBoardReview">${formio.AIGovernanceData.json}</camunda:inputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0ewbwx5</bpmn:incoming>
        <bpmn:outgoing>Flow_to_board_decision</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:exclusiveGateway id="Gateway_BoardDecision" name="Aprpoved ?">
        <bpmn:incoming>Flow_to_board_decision</bpmn:incoming>
        <bpmn:outgoing>Flow_board_approved</bpmn:outgoing>
        <bpmn:outgoing>Flow_board_rejected</bpmn:outgoing>
      </bpmn:exclusiveGateway>
      <bpmn:endEvent id="Event_1set5z6" name="Idea Rejected">
        <bpmn:incoming>Flow_board_rejected</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:endEvent id="Event_0sphqiv" name="Idea Approved">
        <bpmn:incoming>Flow_board_approved</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_to_board_decision" sourceRef="Task_GovernanceAdvisoryBoardReview" targetRef="Gateway_BoardDecision" />
      <bpmn:sequenceFlow id="Flow_board_approved" name="Approved" sourceRef="Gateway_BoardDecision" targetRef="Event_0sphqiv">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${formio.Task_GovernanceAdvisoryBoardReview.data.approvalDecision == "Approved"}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_board_rejected" name="Rejected" sourceRef="Gateway_BoardDecision" targetRef="Event_1set5z6">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${formio.Task_GovernanceAdvisoryBoardReview.data.approvalDecision == "Rejected"}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_0ewbwx5" sourceRef="Event_1j4gdm3" targetRef="Task_GovernanceAdvisoryBoardReview" />
    </bpmn:subProcess>
    <bpmn:intermediateThrowEvent id="Event_0yytcky" name="Run the High Risk Review Process">
      <bpmn:incoming>Flow_high_risk</bpmn:incoming>
      <bpmn:outgoing>Flow_0wvju4w</bpmn:outgoing>
      <bpmn:escalationEventDefinition id="EscalationEventDefinition_0op2snr" />
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="Event_01ufa05" name="Run the Limited Risk Review Process">
      <bpmn:incoming>Flow_limited_risk</bpmn:incoming>
      <bpmn:outgoing>Flow_1v46see</bpmn:outgoing>
      <bpmn:escalationEventDefinition id="EscalationEventDefinition_0wiu69u" />
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateThrowEvent id="Event_0ihinvy" name="Run the Minimal Risk Review Process">
      <bpmn:incoming>Flow_minimal_risk</bpmn:incoming>
      <bpmn:outgoing>Flow_1iy7po6</bpmn:outgoing>
      <bpmn:escalationEventDefinition id="EscalationEventDefinition_0z9rs6s" />
    </bpmn:intermediateThrowEvent>
    <bpmn:exclusiveGateway id="Gateway_0q3l9kh">
      <bpmn:incoming>Flow_0wvju4w</bpmn:incoming>
      <bpmn:incoming>Flow_1v46see</bpmn:incoming>
      <bpmn:incoming>Flow_1iy7po6</bpmn:incoming>
      <bpmn:outgoing>Flow_1fgxfco</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0wvju4w" sourceRef="Event_0yytcky" targetRef="Gateway_0q3l9kh" />
    <bpmn:sequenceFlow id="Flow_1v46see" sourceRef="Event_01ufa05" targetRef="Gateway_0q3l9kh" />
    <bpmn:sequenceFlow id="Flow_1iy7po6" sourceRef="Event_0ihinvy" targetRef="Gateway_0q3l9kh" />
    <bpmn:subProcess id="Activity_021kbsm">
      <bpmn:incoming>Flow_1fgxfco</bpmn:incoming>
      <bpmn:outgoing>Flow_0vqb86j</bpmn:outgoing>
      <bpmn:startEvent id="Event_1d4253q">
        <bpmn:outgoing>Flow_03po89a</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:intermediateCatchEvent id="Event_1kwhtzo" name="Wait for Decision">
        <bpmn:incoming>Flow_03po89a</bpmn:incoming>
        <bpmn:outgoing>Flow_1ar2qlt</bpmn:outgoing>
        <bpmn:messageEventDefinition id="MessageEventDefinition_1gj2aqs" />
      </bpmn:intermediateCatchEvent>
      <bpmn:endEvent id="Event_0hosfwf">
        <bpmn:incoming>Flow_1ar2qlt</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_1ar2qlt" sourceRef="Event_1kwhtzo" targetRef="Event_0hosfwf" />
      <bpmn:sequenceFlow id="Flow_03po89a" sourceRef="Event_1d4253q" targetRef="Event_1kwhtzo" />
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_1fgxfco" sourceRef="Gateway_0q3l9kh" targetRef="Activity_021kbsm" />
    <bpmn:boundaryEvent id="Event_142k49d" name="SLA Time&#10;Interval" cancelActivity="false" attachedToRef="Activity_021kbsm">
      <bpmn:outgoing>Flow_0hhfzin</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_0q42hn1" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_0hhfzin" sourceRef="Event_142k49d" targetRef="Event_167vflm" />
    <bpmn:endEvent id="Event_167vflm" name="Send Reminder">
      <bpmn:incoming>Flow_0hhfzin</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_126xgmg" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0vqb86j" sourceRef="Activity_021kbsm" targetRef="Gateway_TeamDecision" />
    <bpmn:userTask id="Task_InitialRiskAssessment" name="Intake and Initial Risk Assessment" camunda:formKey="embedded:app:formio.html" camunda:assignee="risk_analyst">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="formio.variable" value="Task_InitialRiskAssessment" />
          <camunda:property name="formio.inputDataSource" value="AICaseData" />
          <camunda:property name="formio.outputDataSource" value="Task_InitialRiskAssessment" />
          <camunda:property name="formio.file" value="AI_Risk_Initial_Assessment.formio" />
          <camunda:property name="formio.form" />
        </camunda:properties>
        <camunda:inputOutput>
          <camunda:inputParameter name="Task_InitialRiskAssessment">${formio.AICaseData.json}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1n7zkcd</bpmn:incoming>
      <bpmn:outgoing>Flow_0lpelg6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_0lpelg6" sourceRef="Task_InitialRiskAssessment" targetRef="Gateway_RiskClassification" />
    <bpmn:userTask id="Task_DesignReview" name="Planning and Design Review" camunda:formKey="embedded:app:formio.html" camunda:assignee="design_reviewer">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="formio.variable" value="Task_DesignReview" />
          <camunda:property name="formio.inputDataSource" value="AICaseData" />
          <camunda:property name="formio.outputDataSource" value="Task_DesignReview" />
          <camunda:property name="formio.file" value="AI_Risk_Design_Review.formio" />
          <camunda:property name="formio.form" />
        </camunda:properties>
        <camunda:inputOutput>
          <camunda:inputParameter name="Task_DesignReview">${formio.AICaseData.json}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_148jog5</bpmn:incoming>
      <bpmn:outgoing>Flow_to_development_review</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_DevelopmentReview" name="Development Process Assessment" camunda:formKey="embedded:app:formio.html" camunda:assignee="dev_reviewer">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="formio.variable" value="Task_DevelopmentReview" />
          <camunda:property name="formio.inputDataSource" value="AICaseData" />
          <camunda:property name="formio.outputDataSource" value="Task_DevelopmentReview" />
          <camunda:property name="formio.file" value="AI_Risk_Development_Review.formio" />
          <camunda:property name="formio.form" />
        </camunda:properties>
        <camunda:inputOutput>
          <camunda:inputParameter name="Task_DevelopmentReview">${formio.AICaseData.json}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_development_review</bpmn:incoming>
      <bpmn:outgoing>Flow_to_testing_validation</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_TestingValidation" name="Testing and Validation" camunda:formKey="embedded:app:formio.html" camunda:assignee="test_validator">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="formio.variable" value="Task_TestingValidation" />
          <camunda:property name="formio.inputDataSource" value="AICaseData" />
          <camunda:property name="formio.outputDataSource" value="Task_TestingValidation" />
          <camunda:property name="formio.file" value="AI_Risk_Testing_Validation.formio" />
          <camunda:property name="formio.form" />
        </camunda:properties>
        <camunda:inputOutput>
          <camunda:inputParameter name="Task_TestingValidation">${formio.AICaseData.json}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
